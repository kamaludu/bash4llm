#--1<---[ SECTION: PRECORE_BOOT_SETUP_SHELL ]--->1--
# Only set strict shell options if executed directly,
# preventing pollution of the calling interactive shell when sourced.
if [ "${BASH_SOURCE[0]}" = "$0" ]; then
  set -euo pipefail
fi

# Disable writing of core dumps to prevent leaking API keys in RAM to disk in the event of a crash
ulimit -c 0 2>/dev/null || true

SCRIPT_NAME="bash4llm"
SCRIPT_VERSION="2.3.0"
SCRIPT_DATE="2026-07-10"

# =============================================================================
# ENVIRONMENT AUTO-DETECTION (Bootstrap)
# =============================================================================
BASH4LLM_PLAT_ANDROID=0
BASH4LLM_PLAT_MACOS=0
BASH4LLM_PLAT_WSL=0
BASH4LLM_PLAT_CYGWIN=0
BASH4LLM_PLAT_BSD=0
BASH4LLM_PLAT_LINUX=0

_uname_s="$(uname -s 2>/dev/null || echo "Linux")"
_uname_o="$(uname -o 2>/dev/null || echo "")"
_uname_r="$(uname -r 2>/dev/null || echo "")"

# 1. Termux / Android Detection
if [ -n "${TERMUX_VERSION:-}" ] || [ -d "/data/data/com.termux" ] || [[ "$_uname_o" == *"Android"* ]] || [[ "$(uname -a 2>/dev/null)" == *"Android"* ]] || [ -f /system/build.prop ]; then
  BASH4LLM_PLAT_ANDROID=1
# 2. macOS / Darwin
elif [ "$_uname_s" = "Darwin" ]; then
  BASH4LLM_PLAT_MACOS=1
# 3. Cygwin / MSYS2 / MinGW (Windows environments)
elif [[ "$_uname_s" == *"CYGWIN"* ]] || [[ "$_uname_s" == *"MSYS"* ]] || [[ "$_uname_s" == *"MINGW"* ]]; then
  BASH4LLM_PLAT_CYGWIN=1
# 4. BSD (FreeBSD, OpenBSD, NetBSD, DragonFly)
elif [[ "$_uname_s" == *"BSD"* ]] || [ "$_uname_s" = "DragonFly" ]; then
  BASH4LLM_PLAT_BSD=1
# 5. WSL (Windows Subsystem for Linux)
elif [[ "$_uname_r" == *"microsoft"* ]] || [[ "$_uname_r" == *"Microsoft"* ]]; then
  BASH4LLM_PLAT_WSL=1
  BASH4LLM_PLAT_LINUX=1 # WSL behaves primarily as Linux
# 6. Generic Linux
else
  BASH4LLM_PLAT_LINUX=1
fi
export BASH4LLM_PLAT_ANDROID BASH4LLM_PLAT_MACOS BASH4LLM_PLAT_WSL BASH4LLM_PLAT_CYGWIN BASH4LLM_PLAT_BSD BASH4LLM_PLAT_LINUX

# Initialize style and color variables to prevent set -u (nounset) errors if referenced early
C_LOGO="" C_BANNER="" C_RST="" C_BOLD=""
# Foreground - Normal
C_BLACK="" C_RED="" C_GREEN="" C_YELLOW="" C_BLUE="" C_MAGENTA="" C_CYAN="" C_WHITE=""
# Foreground - Bold
C_BBLACK="" C_BRED="" C_BGREEN="" C_BYELLOW="" C_BBLUE="" C_BMAGENTA="" C_BCYAN="" C_BWHITE=""
# Backgrounds
BG_BLACK="" BG_RED="" BG_GREEN="" BG_YELLOW="" BG_BLUE="" BG_MAGENTA="" BG_CYAN="" BG_WHITE=""

# ---------------------------------------------------------------------------
# Canonical error codes
# ---------------------------------------------------------------------------
BASH4LLM_ERR_NO_API_KEY=10
BASH4LLM_ERR_BAD_MODEL=11
BASH4LLM_ERR_CURL_FAILED=12
BASH4LLM_ERR_NO_PROMPT=14
BASH4LLM_ERR_TMP=15
BASH4LLM_ERR_API=16

# Legacy aliases mapped with consistent underscore notation
BASH4LLMERR_NO_API_KEY=$BASH4LLM_ERR_NO_API_KEY
BASH4LLMERR_BAD_MODEL=$BASH4LLM_ERR_BAD_MODEL
BASH4LLMERR_CURL_FAILED=$BASH4LLM_ERR_CURL_FAILED
BASH4LLMERR_NO_PROMPT=$BASH4LLM_ERR_NO_PROMPT
BASH4LLMERR_TMP=$BASH4LLM_ERR_TMP
BASH4LLMERR_API=$BASH4LLM_ERR_API
#--1<---[ /SECTION: PRECORE_BOOT_SETUP_SHELL ]--->1--
#--2<---[ SECTION: PRECORE_BOOT_SETUP_ENV_CMDS ]--->2--
# ---------------------------------------------------------------------------
# Verify mandatory commands (flock is excluded to allow macOS fallback)
# ---------------------------------------------------------------------------
for cmd in bash jq curl mktemp stat base64 find awk sed grep xargs tr sort head wc tee date mv chmod cp rm printf comm; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    printf 'bash4llm: %sERROR%s: required command not found: %s\n' "${C_RED}" "${C_RST}" "$cmd" >&2
    exit 1
  fi
done
#--2<---[ /SECTION: PRECORE_BOOT_SETUP_ENV_CMDS ]--->2--
#--3<---[ SECTION: PRECORE_BOOT_EARLY_HELPERS ]--->3--
# Early Helpers 
resolve_script_dir() {
  local src="${BASH_SOURCE[0]}" rl dir
  if command -v readlink >/dev/null 2>&1 && [ -L "$src" ]; then
    rl="$(readlink "$src" 2>/dev/null || true)"
    [ -n "$rl" ] && case "$rl" in /*) src="$rl" ;; *) src="$(dirname "$src")/$rl" ;; esac
  fi
  dir="$(cd "$(dirname "$src")" >/dev/null 2>&1 && pwd || printf '%s' "$(dirname "$src")")"
  printf '%s' "$dir"
}

# Create directory safely with strict permissions, ensuring it is not a symlink.
safe_mkdir() {
  local dir="${1:-}"
  local perm="${2:-700}"
  if [ -z "$dir" ]; then
    return 1
  fi
  if [ -L "$dir" ]; then
    printf 'bash4llm: %sERROR%s: directory is a symlink: %s\n' "${C_RED:-}" "${C_RST:-}" "$dir" >&2
    if [ "${BASH_SOURCE[0]}" = "$0" ]; then
      exit "${BASH4LLM_ERR_TMP:-15}"
    else
      return "${BASH4LLM_ERR_TMP:-15}"
    fi
  fi
  if [ ! -d "$dir" ]; then
    mkdir -p "$dir" 2>/dev/null || {
      printf 'bash4llm: %sERROR%s: cannot create directory: %s\n' "${C_RED:-}" "${C_RST:-}" "$dir" >&2
      if [ "${BASH_SOURCE[0]}" = "$0" ]; then
        exit "${BASH4LLM_ERR_TMP:-15}"
      else
        return "${BASH4LLM_ERR_TMP:-15}"
      fi
    }
    chmod "$perm" "$dir" 2>/dev/null || true
  fi
}

# Helper to validate options requiring an argument (shift boundary check)
check_required_arg() {
  local option="${1:-}"
  local count="${2:-0}"
  if [ "$count" -lt 2 ]; then
    log_error "ARGS" "Option $option requires an argument"
    exit "${BASH4LLM_ERR_TMP:-15}"
  fi
}

# Return canonical config dir (no trailing slash)
canonical_config_dir() {
  printf '%s' "${BASH4LLM_CONFIG_DIR%/}"
}

# Return canonical provider file path
canonical_provider_file() {
  printf '%s\n' "$(canonical_config_dir)/provider"
}

# Return canonical model file path for a provider argument
canonical_model_file() {
  local prov="${1:-}"
  printf '%s\n' "$(canonical_config_dir)/model.${prov}"
}

# Minimal provider-url helpers (embedded groq fallback)
# Returns canonical provider-url file path: <config_dir>/provider-url
canonical_provider_url_file() {
  local cfgdir
  # prefer canonical_config_dir() if present
  if type canonical_config_dir >/dev/null 2>&1; then
    cfgdir="$(canonical_config_dir)"
  else
    cfgdir="${BASH4LLM_CONFIG_DIR:-${BASH4LLM_DIR%/}/config}"
  fi
  printf '%s' "${cfgdir%/}/provider-url"
}

# Normalize model name by removing 'models/', the active provider prefix, and surrounding whitespace.
_normalize_model_name() {
  local prov="${PROVIDER:-groq}"
  # Dynamically strip the active provider's prefix (e.g., 'groq', 'gemini') and generic 'models/'
  printf '%s' "$1" | sed -e 's#^models/##' -e "s#^${prov}[:/ -]*##" -e 's/^[[:space:]]*//;s/[[:space:]]*$//'
}

#--3<---[ SUBSECTION: API_NET ]--->3--
# ensure_api_key_for_provider (robust, non-interactive safe)
ensure_api_key_for_provider() {
  local prov="${1:-}"
  local envvar current_key input_key custom_var custom_env
  [ -n "$prov" ] || return 1
  envvar="$(provider_api_env_var_name "$prov")"
  custom_var="PROVIDER_API_ENV_${prov}"
  custom_env="${!custom_var:-}"
  if [ -n "$custom_env" ]; then
    envvar="$custom_env"
  fi
  current_key="${!envvar:-}"

  # If key present, sync groq alias and return
  if [ -n "$current_key" ]; then
    if [ "$prov" = "groq" ] && [ "$envvar" != "GROQ_API_KEY" ]; then
      export GROQ_API_KEY="$current_key"
    fi
    return 0
  fi

  # Non-interactive: fail fast with clear error (do not prompt)
  if [ ! -t 0 ]; then
    printf 'bash4llm: %sERROR%s: missing API key for provider %s (env %s) in non-interactive mode\n' "${C_RED}" "${C_RST}" "$prov" "$envvar" >&2
    return "$BASH4LLM_ERR_NO_API_KEY"
  fi

  # Interactive prompt (preserve previous behavior)
  printf 'Enter API key for provider %s (env %s): ' "$prov" "$envvar" >&2
  if ! IFS= read -r input_key; then
    printf '\nbash4llm: %sERROR%s: no input received. Aborting.\n' "${C_RED}" "${C_RST}" >&2
    return "$BASH4LLM_ERR_NO_API_KEY"
  fi

  # Normalize input: strip CR/LF, leading "export ", and VAR=VALUE forms
  input_key="$(printf '%s' "$input_key" | tr -d '\r\n')"
  input_key="$(printf '%s' "$input_key" | sed -E 's/^[[:space:]]*export[[:space:]]+//I')"
  if printf '%s' "$input_key" | grep -qE '^[A-Za-z_][A-Za-z0-9_]*='; then
    input_key="$(printf '%s' "$input_key" | sed -E 's/^[A-Za-z_][A-Za-z0-9_]*=[\"\x27]?([^\"\x27]*).*$/\1/')"
  fi

  if [ -z "$input_key" ]; then
    printf 'bash4llm: %sERROR%s: API key required. Aborting.\n' "${C_RED}" "${C_RST}" >&2
    return "$BASH4LLM_ERR_NO_API_KEY"
  fi

  export "$envvar"="$input_key"
  if [ "$prov" = "groq" ] && [ "$envvar" != "GROQ_API_KEY" ]; then
    export GROQ_API_KEY="$input_key"
  fi

  printf '%b' "
${C_BCYAN}----------------------------------------${C_RST}

To avoid re-entering the key for subsequent invocations, run this in your shell:

  ${C_BGREEN}export ${envvar}=\"${input_key}\"${C_RST}

You can add that line to your shell profile (e.g., ${C_YELLOW}~/.bashrc${C_RST} or ${C_YELLOW}~/.profile${C_RST}) to persist it across sessions.

${C_BCYAN}----------------------------------------${C_RST}

" >&2

  return 0
}

enforce_network_policy() {
  if is_truthy "${DRY_RUN:-0}" || is_truthy "${BASH4LLM_SKIP_NETWORK:-0}"; then
    if [ "${DEBUG:-0}" -eq 1 ]; then
      log_info "NETWORK" "Network calls disabled by DRY_RUN or BASH4LLM_SKIP_NETWORK; skipping HTTP."
    fi
    return 1
  fi

  if is_truthy "${BASH4LLM_ENFORCE_NO_NETWORK_IF_QUIET:-0}" && is_truthy "${QUIET:-0}"; then
    if [ "${DEBUG:-0}" -eq 1 ]; then
      log_info "NETWORK" "Network calls disabled due to QUIET policy."
    fi
    return 1
  fi

  return 0
}
#--3<---[ /SUBSECTION: API_NET ]--->3--

DEBUG="${DEBUG:-${BASH4LLM_DEBUG:-0}}"
BASH4LLM_LOG="${BASH4LLM_LOG:-}"

log_prefix() { printf '%s: ' "$SCRIPT_NAME"; }

log_info() {
  local code="${1:-INFO}" msg="${2:-}"
  if [ "${DEBUG:-0}" -eq 1 ]; then
    printf '%s%sINFO%s: %s: %s\n' "$(log_prefix)" "${C_GREEN}" "${C_RST}" "$code" "$msg" >&2
  fi
  if [ -n "$BASH4LLM_LOG" ]; then printf '%s INFO %s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$code" "$msg" >>"$BASH4LLM_LOG" 2>/dev/null || true; fi
}

log_warn() {
  local code="${1:-WARN}" msg="${2:-}"
  printf '%s%sWARN%s: %s: %s\n' "$(log_prefix)" "${C_BYELLOW}" "${C_RST}" "$code" "$msg" >&2
  if [ -n "$BASH4LLM_LOG" ]; then printf '%s WARN %s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$code" "$msg" >>"$BASH4LLM_LOG" 2>/dev/null || true; fi
}

log_error() {
  local code="${1:-ERROR}" msg="${2:-}"
  printf '%s%sERROR%s: %s: %s\n' "$(log_prefix)" "${C_RED}" "${C_RST}" "$code" "$msg" >&2
  if [ -n "$BASH4LLM_LOG" ]; then printf '%s ERROR %s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$code" "$msg" >>"$BASH4LLM_LOG" 2>/dev/null || true; fi
}

log_info_user() {
  local code="${1:-INFO}" msg="${2:-}"
  if [ "${QUIET:-0}" -ne 1 ]; then
    printf '%s%sINFO%s: %s: %s\n' "$(log_prefix)" "${C_GREEN}" "${C_RST}" "$code" "$msg" >&2
  fi
  if [ -n "$BASH4LLM_LOG" ]; then
    printf '%s INFO_USER %s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$code" "$msg" >>"$BASH4LLM_LOG" 2>/dev/null || true
  fi
}

dbg() {
  if [ "${DEBUG:-0}" -ne 0 ]; then
    printf '%s\n' "$*" >&2
  fi
}

