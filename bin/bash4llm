#--1<---[ SECTION: PRECORE_RUN_HISTORY ]--->1--
# History rotation and compaction (portable)
# ---------------------------------------------------------------------------
BASH4LLM_ROTATE_HISTORY="${BASH4LLM_ROTATE_HISTORY:-0}"
BASH4LLM_HISTORY_MAX_FILES="${BASH4LLM_HISTORY_MAX_FILES:-100}"
BASH4LLM_HISTORY_MAX_BYTES="${BASH4LLM_HISTORY_MAX_BYTES:-104857600}" # 100MB
BASH4LLM_HISTORY_KEEP_DAYS="${BASH4LLM_HISTORY_KEEP_DAYS:-90}"

# ---------------------------------------------------------------------------
# rotate_history: all rotation logic executed atomically under HISTORY_LOCK
# - Ensures file counting, size summing and deletions happen under the same lock.
# - Uses portable metadata extraction to support macOS and Linux flawlessly.
# ---------------------------------------------------------------------------
rotate_history() {
  local timeout="${1:-$BASH4LLM_LOCK_TIMEOUT_HISTORY}"
  local dir="${BASH4LLM_HISTORY_DIR:-$PWD/bash4llm.d/history}"
  local max_files="${BASH4LLM_HISTORY_MAX_FILES:-100}"
  local max_bytes="${BASH4LLM_HISTORY_MAX_BYTES:-104857600}"
  local keep_days="${BASH4LLM_HISTORY_KEEP_DAYS:-90}"

  # ------------------------------
  # 1. Remove files that are too old (macOS & POSIX portable)
  # ------------------------------
  local now_epoch cutoff f f_mtime
  now_epoch=$(date +%s)
  cutoff=$(( now_epoch - (keep_days * 86400) ))
  
  while IFS= read -r -d '' f; do
    f_mtime=$(_file_mtime "$f")
    if [ "$f_mtime" -gt 0 ] && [ "$f_mtime" -lt "$cutoff" ]; then
      lock_exec "$HISTORY_LOCK" "$timeout" -- rm -f -- "$f" || true
    fi
  done < <(find "$dir" -type f -print0 2>/dev/null)

  # ------------------------------
  # 2. Remove based on byte threshold
  # ------------------------------
  local last_total=999999999999999
  while :; do
    local total=0
    local -a entries
    entries=()
    local temp_mtime temp_size oldest_line oldest_file
    
    # Portably compile active file entries
    while IFS= read -r f; do
      temp_mtime=$(_file_mtime "$f")
      temp_size=$(file_size "$f")
      total=$(( total + temp_size ))
      entries+=( "${temp_mtime}|${temp_size}|${f}" )
    done < <(find "$dir" -type f 2>/dev/null)

    if [ "$total" -le "$max_bytes" ]; then
      break
    fi

    # Prevent infinite loop / CPU DoS if files cannot be deleted
    if [ "$total" -ge "$last_total" ]; then
      log_warn "ROTATE" "History rotation bytes-based removal stuck (total=$total). Breaking loop."
      break
    fi
    last_total=$total

    # Find and delete the oldest file (ascending sort)
    oldest_line=$(printf '%s\n' "${entries[@]}" | sort -t'|' -k1,1n | head -n 1)
    if [ -z "$oldest_line" ]; then
      break
    fi

    oldest_file=$(printf '%s' "$oldest_line" | cut -d'|' -f3)

    if [ -n "$oldest_file" ] && [ -f "$oldest_file" ]; then
      lock_exec "$HISTORY_LOCK" "$timeout" -- rm -f -- "$oldest_file" || true
    else
      break
    fi
  done

  # ------------------------------
  # 3. Remove based on maximum file count
  # ------------------------------
  local last_count=999999
  while :; do
    local -a file_list
    file_list=()
    local temp_mtime count oldest_line oldest_file
    
    while IFS= read -r f; do
      temp_mtime=$(_file_mtime "$f")
      file_list+=( "${temp_mtime}|${f}" )
    done < <(find "$dir" -type f 2>/dev/null)

    count="${#file_list[@]}"
    if [ "$count" -le "$max_files" ]; then
      break
    fi

    # Prevent infinite loop / CPU DoS if files cannot be deleted
    if [ "$count" -ge "$last_count" ]; then
      log_warn "ROTATE" "History rotation files-based removal stuck (count=$count). Breaking loop."
      break
    fi
    last_count=$count

    oldest_line=$(printf '%s\n' "${file_list[@]}" | sort -t'|' -k1,1n | head -n 1)
    if [ -z "$oldest_line" ]; then
      break
    fi

    oldest_file=$(printf '%s' "$oldest_line" | cut -d'|' -f2-)

    if [ -n "$oldest_file" ] && [ -f "$oldest_file" ]; then
      lock_exec "$HISTORY_LOCK" "$timeout" -- rm -f -- "$oldest_file" || true
    else
      break
    fi
  done

  return 0
}

save_to_history() {
  local content="${1:-}"
  local filename tmpf dest lockfile rc
  filename="$(date +%Y%m%d-%H%M%S)-groq-output-$$.txt"

  safe_mkdir "$BASH4LLM_HISTORY_DIR" 700

  tmpf="$(_tmpf file "$BASH4LLM_HISTORY_DIR" groq-out 2>/dev/null)"
  if [ -z "$tmpf" ]; then
    log_error "HISTORYFAIL" "save_to_history: cannot allocate tmp file in $BASH4LLM_HISTORY_DIR"
    return "$BASH4LLMERR_TMP"
  fi

  if ! printf '%s\n' "$content" > "$tmpf" 2>/dev/null; then
    rm -f -- "$tmpf" 2>/dev/null || true
    log_error "HISTORYFAIL" "save_to_history: cannot write tmp file $tmpf"
    return "$BASH4LLMERR_TMP"
  fi

  dest="$BASH4LLM_HISTORY_DIR/$filename"
  lockfile="$HISTORY_LOCK"

  # --- atomic move only ---
  if ! lock_exec "$lockfile" "$BASH4LLM_LOCK_TIMEOUT_HISTORY" -- bash -c '
      set -e
      mv -f -- "$1" "$2"
      chmod 600 "$2" 2>/dev/null || true
    ' _ "$tmpf" "$dest"
  then
    rc=$?
    rm -f -- "$tmpf" 2>/dev/null || true
    return "$rc"
  fi

  # --- metadata update in main shell (functions available) ---
  if [ -f "$dest" ]; then
    local size_bytes ts base history_json
    size_bytes="$(file_size "$dest" 2>/dev/null || echo 0)"
    ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    base="$(basename "$dest")"

    history_json="$(jq -c -n \
      --arg path "$dest" \
      --arg base "$base" \
      --arg ts "$ts" \
      --argjson size "$size_bytes" \
      '{saved:true, path:$path, basename:$base, ts:$ts, size_bytes:$size}')"

    ui_state_write "last_history.json" "$history_json" \
      || log_warn "UI_STATE" "failed to write last_history.json"
  else
    local ts history_json
    ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    history_json="$(jq -c -n --arg ts "$ts" '{saved:false, ts:$ts}')"
    ui_state_write "last_history.json" "$history_json" || true
  fi

  if [ "${BASH4LLM_ROTATE_HISTORY:-0}" -eq 1 ]; then
    rotate_history "$BASH4LLM_LOCK_TIMEOUT_HISTORY" || true
  fi

  if [ "${DEBUG:-0}" -eq 1 ]; then
    log_info "HISTORY_SAVE" "$dest"
  fi

  return 0
}
#--1<---[ /SECTION: PRECORE_RUN_HISTORY ]--->1--
#--2<---[ SECTION: PRECORE_RUN_MANIFEST ]--->2--
# ---------------------------------------------------------------------------
# Manifest multimodal helpers (atomic, jq --arg usage)
# - manifest_create <manifest_path> [timeout]
# - manifest_add_part <manifest_path> <name> <file_path> <mime> [timeout]
# - manifest_read <manifest_path>
# Manifest stored as both JSON file and base64 staging file manifest.b64
# ---------------------------------------------------------------------------
manifest_create() {
  local manifest="${1:-}"
  local timeout="${2:-$BASH4LLM_LOCK_TIMEOUT_MODELS}"
  safe_mkdir "$(dirname "$manifest")" 700
  lock_exec "${manifest}.lock" "$timeout" -- bash -c '
   set -e
   manifest="$1"
   tmp="$(mktemp "$(dirname "$manifest")/manifest.tmp.XXXXXX")"
   printf "%s" "{\"parts\":[]}" > "$tmp"
   # write base64 staging using base64 binary and exported opts
   if [ -n "${B64_WRAP_OPT:-}" ]; then
     base64 ${B64_WRAP_OPT} "$tmp" > "${manifest}.b64"
   else
     base64 "$tmp" | tr -d "\n" > "${manifest}.b64"
   fi
   mv -f "$tmp" "$manifest"
   chmod 600 "$manifest" 2>/dev/null || true
 ' _ "$manifest"

  return $?
}

manifest_add_part() {
  local manifest="${1:-}" name="${2:-}" file_path="${3:-}" mime="${4:-}" timeout="${5:-$BASH4LLM_LOCK_TIMEOUT_MODELS}"
  local destdir lockfile part_b64 tmpstamp tmp_part rc
  [ -f "$file_path" ] || { log_error "MANIFESTFAIL" "manifest_add_part: file not found: $file_path"; return 1; }
  safe_mkdir "$(dirname "$manifest")" 700

  # Ensure a lockfile specific to this manifest (avoid global contention)
  lockfile="${manifest}.lock"

  # First, stage the part as a base64 file in the manifest directory (atomic in destdir)
  destdir="$(dirname "$manifest")"
  tmpstamp="$(date +%s)-$$"
  part_b64="$destdir/parts-$(basename "$file_path").${tmpstamp}.b64"
  tmp_part="$(_tmpf file "$BASH4LLM_TMPDIR" part 2>/dev/null)" || {
    log_error "TMP" "manifest_add_part: _tmpf failed for BASH4LLM_TMPDIR"
    return 1
  }

  if ! b64encode < "$file_path" > "$tmp_part"; then
    rm -f "$tmp_part" 2>/dev/null || true
    log_error "B64FAIL" "manifest_add_part: b64 encode failed"
    return 1
  fi

  mv -f "$tmp_part" "$part_b64" 2>/dev/null || { rm -f "$tmp_part" 2>/dev/null || true; log_error "MANIFESTFAIL" "cannot move staged part to $part_b64"; return 1; }
  chmod 600 "$part_b64" 2>/dev/null || true

  # Now update manifest atomically under lock using jq --arg
  lock_exec "$lockfile" "$timeout" -- bash -c '
    set -e
    manifest="$1"
    part_b64="$2"
    name="$3"
    mime="$4"
    tmp="$(mktemp "$(dirname "$manifest")/manifest.edit.XXXXXX")"
    if [ -f "${manifest}.b64" ]; then
      # decode base64 staging to tmp using exported decode opt
      base64 ${B64_DECODE_OPT} < "${manifest}.b64" > "$tmp" 2>/dev/null || printf "%s" "{\"parts\":[]}" > "$tmp"
    elif [ -f "$manifest" ]; then
      cp -f "$manifest" "$tmp"
    else
      printf "%s" "{\"parts\":[]}" > "$tmp"
    fi
    jq --arg name "$name" --arg path "$part_b64" --arg enc "b64" --arg type "$mime" \
       ".parts += [{name:\$name, path:\$path, encoding:\$enc, type:\$type}]" "$tmp" > "${tmp}.new"
    mv -f "${tmp}.new" "$tmp"
    # write back both manifest and base64 staging atomically
    if [ -n "${B64_WRAP_OPT:-}" ]; then
      base64 ${B64_WRAP_OPT} "$tmp" > "${manifest}.b64"
    else
      base64 "$tmp" | tr -d "\n" > "${manifest}.b64"
    fi
    cp -f "$tmp" "$manifest"
    chmod 600 "$manifest" 2>/dev/null || true
    rm -f "$tmp" 2>/dev/null || true
  ' _ "$manifest" "$part_b64" "$name" "$mime" || { log_error "MANIFESTFAIL" "manifest_add_part: update failed"; return 1; }

  if [ "${DEBUG:-0}" -eq 1 ]; then
    log_info "MANIFEST_ADD" "added part $name -> $part_b64"
  fi
  return 0
}

manifest_read() {
  local manifest="${1:-}"
  if [ -f "$manifest" ]; then
    cat "$manifest"
    return 0
  fi
  if [ -f "${manifest}.b64" ]; then
    b64decode < "${manifest}.b64"
    return $?
  fi
  return 1
}
#--2<---[ /SECTION: PRECORE_RUN_MANIFEST ]--->2--
#--3<---[ SECTION: PRECORE_RUN_UTIL_HELPERS ]--->3--
# Utility helpers
_get_perm_string() {
  local path="${1:-}" perm=""
  case "$(uname 2>/dev/null || echo Linux)" in
    Darwin)
      perm="$(stat -f %Sp "$path" 2>/dev/null || true)"
      ;;
    *)
      if command -v stat >/dev/null 2>&1; then
        perm="$(stat -c %A "$path" 2>/dev/null || true)"
      elif command -v ls >/dev/null 2>&1; then
        perm="$(ls -ld -- "$path" 2>/dev/null | awk '{print $1}' || true)"
      fi
      ;;
  esac
  printf '%s' "$perm"
}

_get_owner() {
  local path="${1:-}" owner=""
  case "$(uname 2>/dev/null || echo Linux)" in
    Darwin)
      owner="$(stat -f %Su "$path" 2>/dev/null || true)"
      ;;
    *)
      if command -v stat >/dev/null 2>&1; then
        owner="$(stat -c %U "$path" 2>/dev/null || true)"
      elif command -v ls >/dev/null 2>&1; then
        owner="$(ls -ld -- "$path" 2>/dev/null | awk '{print $3}' || true)"
      fi
      ;;
  esac
  printf '%s' "$owner"
}

_get_file_signature() {
  local path="${1:-}"
  local hash="" stat_out="" dev="" inode="" size="" ctime="" mtime="" uid="" gid="" mode="" use_hash
  # Return empty string if not a regular file
  [ -f "$path" ] || { printf ''; return 0; }

  # Decide whether to compute content hash (default 1)
  use_hash="${BASH4LLM_SIG_HASH:-1}"

  # Compute SHA256 if requested and available
  if [ "${use_hash}" != "0" ] && command -v sha256sum >/dev/null 2>&1; then
    hash="$(sha256sum "$path" 2>/dev/null | awk '{print $1}' || true)"
  else
    hash=""
  fi

  # Collect stat output in a portable way
  case "$(uname 2>/dev/null || echo Linux)" in
    Darwin)
      # BSD/macOS stat format: device inode size ctime mtime uid gid mode
      stat_out="$(stat -f '%d %i %z %c %m %u %g %p' "$path" 2>/dev/null || true)"
      ;;
    *)
      # GNU stat format: device inode size ctime mtime uid gid mode
      stat_out="$(stat -c '%d %i %s %Z %Y %u %g %a' "$path" 2>/dev/null || true)"
      ;;
  esac

  # If stat failed, ensure variables are empty and continue (do not abort)
  if [ -z "${stat_out:-}" ]; then
    dev=""; inode=""; size=""; ctime=""; mtime=""; uid=""; gid=""; mode=""
  else
    # Parse stat_out using a here-doc to avoid process substitution portability issues
    read -r dev inode size ctime mtime uid gid mode <<EOF
$stat_out
EOF
    # If read failed for any reason, reset to empty strings
    if [ -z "${dev:-}" ] && [ -z "${inode:-}" ] && [ -z "${size:-}" ]; then
      dev=""; inode=""; size=""; ctime=""; mtime=""; uid=""; gid=""; mode=""
    fi
  fi

  # Output a stable, linear signature: hash|dev|inode|size|ctime|mtime|uid|gid|mode
  printf '%s|%s|%s|%s|%s|%s|%s|%s|%s' \
    "${hash:-}" "${dev:-}" "${inode:-}" "${size:-}" "${ctime:-}" "${mtime:-}" "${uid:-}" "${gid:-}" "${mode:-}"
}

getfile_signature() { _get_file_signature "$1"; }

_is_world_writable() {
  local d="${1:-}" perms others_write
  [ -d "$d" ] || return "$BASH4LLMERR_TMP"
  perms="$(_get_perm_string "$d")"
  [ -z "$perms" ] && return "$BASH4LLMERR_TMP"
  others_write="$(printf '%s' "$perms" | awk '{print substr($0,9,1)}')"
  [ "$others_write" = "w" ]
}

# Tmpdir creation under TMP_LOCK to avoid races
# Now delegates entirely to _tmpf (dir), removing all predictable fallbacks.
make_tmpdir() {
  umask 077
  local tmpd lockfile rc
  lockfile="$TMP_LOCK"

  # Ensure base tmpdir exists before locking
  safe_mkdir "$BASH4LLM_TMPDIR" 700

  # Execute _tmpf directly in the current Bash process context
  # avoiding spawning 'sh -c', which does not see internal functions
  tmpd="$(lock_exec "$lockfile" "$BASH4LLM_LOCK_TIMEOUT_TMP" -- _tmpf dir "$BASH4LLM_TMPDIR" groq)"
  rc=$?
  if [ "$rc" -eq 0 ] && [ -n "$tmpd" ]; then
    printf '%s' "$tmpd"
    return 0
  else
    log_error "TMP" "make_tmpdir: failed to safely create secure temporary directory"
    return "$BASH4LLMERR_TMP"
  fi
}

# _tmpf: create a temporary file or directory inside a given base dir
# Usage:
#   _tmpf file <base_dir> <prefix>
#   _tmpf dir  <base_dir> <prefix>
# Returns path on stdout or non-zero on failure.
# Guarantees: uses BASH4LLM_TMPDIR as fallback, enforces umask/permissions, no predictable paths.
_tmpf() {
  local mode="${1:-}" base="${2:-}" prefix="${3:-groq}" tmp

  if [ -z "$mode" ]; then
    log_error "TMP" "_tmpf usage: _tmpf <file|dir> <base_dir> [prefix]"
    return "$BASH4LLMERR_TMP"
  fi

  # Validate BASH4LLM_TMPDIR as canonical tmp base
  if [ -z "${BASH4LLM_TMPDIR:-}" ]; then
    log_error "TMP" "_tmpf: BASH4LLM_TMPDIR not set"
    return "$BASH4LLMERR_TMP"
  fi
  if [ ! -d "$BASH4LLM_TMPDIR" ]; then
    log_error "TMP" "_tmpf: BASH4LLM_TMPDIR does not exist: $BASH4LLM_TMPDIR"
    return "$BASH4LLMERR_TMP"
  fi
  # Reject symlinks for BASH4LLM_TMPDIR
  if [ -L "$BASH4LLM_TMPDIR" ]; then
    log_error "TMP" "_tmpf: BASH4LLM_TMPDIR is a symlink: $BASH4LLM_TMPDIR"
    return "$BASH4LLMERR_TMP"
  fi
  # Enforce strict perms (700) on BASH4LLM_TMPDIR
  chmod 700 "$BASH4LLM_TMPDIR" 2>/dev/null || true

  # Prefer provided base if it is an existing directory; otherwise fall back to BASH4LLM_TMPDIR
  if [ -z "$base" ] || [ ! -d "$base" ]; then
    base="$BASH4LLM_TMPDIR"
  fi

  # Ensure base is inside BASH4LLM_TMPDIR perimeter
  case "$base" in
    "$BASH4LLM_TMPDIR"/*|"$BASH4LLM_TMPDIR")
      : # ok
      ;;
    *)
      base="$BASH4LLM_TMPDIR"
      ;;
  esac

  umask 077
  if [ "$mode" = "file" ]; then
    tmp="$(mktemp "$base/${prefix}.XXXXXX" 2>/dev/null || true)"
    if [ -z "$tmp" ]; then
      log_error "TMP" "_tmpf: mktemp failed for file in $base"
      return "$BASH4LLMERR_TMP"
    fi
    chmod 600 "$tmp" 2>/dev/null || true
    printf '%s' "$tmp"
    return 0
  elif [ "$mode" = "dir" ]; then
    tmp="$(mktemp -d "$base/${prefix}.XXXXXX" 2>/dev/null || true)"
    if [ -z "$tmp" ]; then
      log_error "TMP" "_tmpf: mktemp failed for dir in $base"
      return "$BASH4LLMERR_TMP"
    fi
    chmod 700 "$tmp" 2>/dev/null || true
    printf '%s' "$tmp"
    return 0
  else
    log_error "TMP" "_tmpf: unknown mode: $mode"
    return "$BASH4LLMERR_TMP"
  fi
}
#--3<---[ /SECTION: PRECORE_RUN_UTIL_HELPERS ]--->3--
#--4<---[ SECTION: PRECORE_RUN_SESSION_MVP ]--->4--
# Session helpers (MVP - Minimum Viable Product)
# - session_validate_id <id> -> 0 if valid, 1 if invalid
# - session_now_ts -> prints UTC timestamp YYYY-MM-DDTHH:MM:SSZ
# - session_messages_tmp_path <session_id> -> prints path under RUN_TMPDIR
# - session_read_window <session_id> <N> <out_file> -> reads last N NDJSON lines, normalizes roles, writes {"messages":[...]}
# - session_append <session_id> <role> <content> <meta_json> -> idempotent append under lock
# - session_sanitize_cmd <cmd> -> prints sanitized cmd (truncate, remove env-like KEY=VAL, redact tokens)
# ---------------------------------------------------------------------------

session_validate_id() {
  local id="${1:-}"
  if [ -z "$id" ]; then return 1; fi
  if printf '%s' "$id" | grep -qE '^[A-Za-z0-9._-]{1,128}$'; then return 0; else return 1; fi
}

session_now_ts() {
  # UTC timestamp, seconds resolution, format YYYY-MM-DDTHH:MM:SSZ
  date -u +%Y-%m-%dT%H:%M:%SZ
}

session_messages_tmp_path() {
  local sid="${1:-}"
  ensure_run_tmpdir || return 1
  printf '%s' "$RUN_TMPDIR/session-${sid}-messages.json"
}

session_sanitize_cmd() {
  local cmd="${1:-}"
  # Remove env-like KEY=VAL, redact tokens/keys, truncate to 256 chars
  local sanitized
  sanitized="$(printf '%s' "$cmd" | sed -E 's/[A-Za-z0-9_]+=([^[:space:]]+)//g' | sed -E 's/(token|key|secret)[^[:space:]]*/[REDACTED]/Ig' )"
  printf '%s' "$(printf '%s' "$sanitized" | cut -c1-256)"
}

session_read_window() {
  # Usage: session_read_window <session_id> <N> <out_file>
  local sid="${1:-}" n="${2:-10}" out="${3:-}"
  local history_dir="${BASH4LLM_HISTORY_DIR:-$PWD/bash4llm.d/history}"
  local session_file="$history_dir/sessions/${sid}.ndjson"
  local tmpdir="${RUN_TMPDIR:-${BASH4LLM_TMPDIR:-$PWD/bash4llm.d/tmp}}"
  local tmpf out_tmp line role content role_norm role_json content_json first msg_count last_ts last_line meta_json idx_file tmp_idx

  [ -n "$sid" ] || return 1
  [ -n "$out" ] || return 1

  safe_mkdir "${history_dir%/}/sessions" 700

  if ! printf '%s' "$n" | grep -qE '^[0-9]+$'; then n=10; fi
  if [ "$n" -le 0 ]; then n=10; fi

  # Ensure tmpdir exists and is writable (must be inside bash4llm.d/)
  safe_mkdir "${tmpdir%/}" 700
  if ! : > "${tmpdir%/}/.bash4llm_tmp_check" 2>/dev/null; then
    if [ "${DEBUG:-0}" -eq 1 ]; then
      printf 'DEBUG: session_read_window: tmpdir not writable: %s\n' "$tmpdir" >&2
    fi
    return 1
  else
    rm -f "${tmpdir%/}/.bash4llm_tmp_check" 2>/dev/null || true
  fi

  # Create a tmpf inside tmpdir (no /tmp, no /dev/null)
  tmpf="$(_tmpf file "$tmpdir" session.read 2>/dev/null)" || { if [ "${DEBUG:-0}" -eq 1 ]; then printf 'DEBUG: session_read_window: cannot create tmpf\n' >&2; fi; return 1; }

  # Extract last N records robustly (records separated by blank line)
  if [ -f "$session_file" ]; then
    # Acquire a short lock on the session file to avoid partial reads during concurrent append
    lock_exec "${session_file}.lock" 5 -- bash -c '
      set -e
      session_file="$1"
      n="$2"
      tmpf="$3"
      if grep -q "^$" "$session_file" 2>/dev/null; then
        awk -v n="$n" "BEGIN{RS=\"\"; ORS=RS} {rec[++c]=\$0} END{start=c-n+1; if(start<1) start=1; for(i=start;i<=c;i++) print rec[i]}" "$session_file" > "$tmpf" 2>/dev/null || cp -f "$session_file" "$tmpf" 2>/dev/null || true
      else
        if ! tail -n "$n" "$session_file" 2>/dev/null > "$tmpf"; then
          cp -f "$session_file" "$tmpf" 2>/dev/null || true
        fi
      fi
    ' _ "$session_file" "$n" "$tmpf"
  else
    if [ "${DEBUG:-0}" -eq 1 ]; then
      printf 'DEBUG: session_read_window: session file not found: %s\n' "$session_file" >&2
    fi
  fi

  # Prepare atomic output in same dir as out
  out_tmp="$(_tmpf file "$(dirname "$out")" out.tmp 2>/dev/null)" || { if [ "${DEBUG:-0}" -eq 1 ]; then printf 'DEBUG: session_read_window: cannot create out_tmp\n' >&2; fi; return 1; }
  safe_mkdir "$(dirname "$out")" 700
  : > "$out_tmp"
  chmod 600 "$out_tmp" 2>/dev/null || true

  printf '%s' '{"messages":[' >> "$out_tmp"
  first=1
  # Use jq -c to compact each JSON record (handles pretty-printed and single-line NDJSON)
  if jq -c . "$tmpf" >/dev/null 2>&1; then
    jq -c . "$tmpf" 2>/dev/null | while IFS= read -r line || [ -n "$line" ]; do
      role="$(printf '%s' "$line" | jq -r '.role // "user"')"
      case "$role" in user|assistant|system) role_norm="$role" ;; *) role_norm="user" ;; esac
      content="$(printf '%s' "$line" | jq -r '.content // ""')"
      role_json="$(printf '%s' "$role_norm" | jq -R -c '.')"
      content_json="$(printf '%s' "$content" | jq -R -s '.')"
      if [ "$first" -eq 0 ]; then printf ',' >> "$out_tmp"; fi
      printf '%s' "{\"role\":${role_json},\"content\":${content_json}}" >> "$out_tmp" 2>/dev/null || true
      first=0
    done
  else
    # fallback: try to treat tmpf as line-based NDJSON
    while IFS= read -r line || [ -n "$line" ]; do
      if printf '%s' "$line" | jq -e . >/dev/null 2>&1; then
        role="$(printf '%s' "$line" | jq -r '.role // "user"')"
        case "$role" in user|assistant|system) role_norm="$role" ;; *) role_norm="user" ;; esac
        content="$(printf '%s' "$line" | jq -r '.content // ""')"
        role_json="$(printf '%s' "$role_norm" | jq -R -c '.')"
        content_json="$(printf '%s' "$content" | jq -R -s '.')"
        if [ "$first" -eq 0 ]; then printf ',' >> "$out_tmp"; fi
        printf '%s' "{\"role\":${role_json},\"content\":${content_json}}" >> "$out_tmp" 2>/dev/null || true
        first=0
      fi
    done < "$tmpf"
  fi
  printf '%s' ']}' >> "$out_tmp"

  # Atomic replace
  if mv -f "$out_tmp" "$out" 2>/dev/null; then
    :
  else
    cp -f "$out_tmp" "$out" 2>/dev/null || true
    rm -f "$out_tmp" 2>/dev/null || true
  fi

  rm -f "$tmpf" 2>/dev/null || true
  chmod 600 "$out" 2>/dev/null || true

  # --- Update ui_state session metadata after read_window (best-effort) ---
  if [ -n "$sid" ]; then
    if ensure_run_tmpdir >/dev/null 2>&1; then
      msg_count=0
      last_ts=""
      if [ -f "$session_file" ]; then
        msg_count="$(wc -l < "$session_file" 2>/dev/null || echo 0)"
        last_line="$(tail -n 1 "$session_file" 2>/dev/null || true)"
        if printf '%s' "$last_line" | jq -e . >/dev/null 2>&1; then
          last_ts="$(printf '%s' "$last_line" | jq -r '.ts // empty' 2>/dev/null || true)"
        fi
      fi
      meta_json="$(jq -c -n --arg id "$sid" --argjson msg_count "$msg_count" --arg last_ts "${last_ts:-}" '{id:$id, active:(( $msg_count | tonumber) > 0), msg_count:$msg_count, last_ts:$last_ts}')"
      ui_state_write "sessions/${sid}.json" "$meta_json" || log_warn "UI_STATE" "failed to update session meta for $sid (read_window)"
    fi
  fi

  if [ "${DEBUG:-0}" -eq 1 ]; then
    printf 'DEBUG: session_read_window done: out=%s size=%s tmpf=%s\n' "$out" "$( [ -f "$out" ] && wc -c < "$out" || echo 0 )" "$tmpf" >&2
  fi

  return 0
}

session_append() {
  # Usage: session_append <session_id> <role> <content> <meta_json>
  local sid="${1:-}" role="${2:-}" content="${3:-}" meta_json="${4:-}"
  # Prefer SESSION_DIR (set during init), then BASH4LLM_HISTORY_DIR, then local fallback
  local base_sessions_dir="${SESSION_DIR:-${BASH4LLM_HISTORY_DIR:-./bash4llm.d}/sessions}"
  local session_file="${base_sessions_dir%/}/${sid}.ndjson"
  local lockfile="${session_file}.lock"
  local invocation_ts message_id marker normalized rand tmpf found=0 role_norm line timeout
  local marker_dir created_marker=0 sess_dir tmp_init msg_count last_ts last_line idx_file tmp_idx

  invocation_ts="$(session_now_ts)"
  message_id="$(printf '%s' "$meta_json" | jq -r '.id // empty' 2>/dev/null || true)"
  if [ -z "$message_id" ]; then
    normalized="$(printf '%s' "$content" | sed -e 's/\r$//' -e 's/\r\n/\n/g' | awk '{$1=$1; print}')"
    rand="$(printf '%04x' $((RANDOM & 0xFFFF)))"
    if command -v sha256sum >/dev/null 2>&1; then
      message_id="$(printf '%s|%s|%s' "$normalized" "$invocation_ts" "$rand" | sha256sum | cut -c1-16)"
    elif command -v openssl >/dev/null 2>&1; then
      message_id="$(printf '%s|%s|%s' "$normalized" "$invocation_ts" "$rand" | openssl dgst -sha256 | awk '{print $2}' | cut -c1-16)"
    else
      message_id="$rand"
    fi
  fi

  # Ensure session directory and file exist before creating marker/lock (race-safe init)
  sess_dir="$(dirname "$session_file")"
  safe_mkdir "$sess_dir" 700

  if [ ! -f "$session_file" ]; then
    tmp_init="$(_tmpf file "${RUN_TMPDIR:-$BASH4LLM_TMPDIR}" session.init 2>/dev/null)" || true
    : > "${tmp_init:-/dev/null}" 2>/dev/null || true
    if ! mv -f "$tmp_init" "$session_file" 2>/dev/null; then
      cp -f "$tmp_init" "$session_file" 2>/dev/null || true
    fi
    chmod 600 "$session_file" 2>/dev/null || true
  fi

  # Global guard: skip appending empty user messages
  case "$role" in user|assistant|system) role_norm="$role" ;; *) role_norm="user" ;; esac
  if [ "$role_norm" = "user" ] && [ -z "${content:-}" ]; then
    if [ "${DEBUG:-0}" -eq 1 ]; then
      log_info "SESSION" "skipping append of empty user message for session $sid"
    fi
    return 0
  fi

  # Marker: message_id-based folder locks (stable on macOS and Linux)
  # Cleanup is handled automatically on EXIT by cleanup_run_tmp_on_exit.
  if [ -n "${message_id:-}" ]; then
    marker_dir="${RUN_TMPDIR:-$BASH4LLM_TMPDIR}/session-msg-${message_id}.lockdir"
    if mkdir "$marker_dir" 2>/dev/null; then
      printf '%s\n' "$$" > "${marker_dir}/owner.pid" 2>/dev/null || true
      printf '%s\n' "$(date +%s)" > "${marker_dir}/owner.ts" 2>/dev/null || true
      chmod 700 "$marker_dir" 2>/dev/null || true
      created_marker=1
    else
      if [ "${DEBUG:-0}" -eq 1 ]; then
        log_info "SESSION" "append skipped: marker exists for message_id $message_id"
      fi
      return 0
    fi
  else
    marker_dir="${RUN_TMPDIR:-$BASH4LLM_TMPDIR}/run-$$-${RANDOM}.lockdir"
    mkdir -p "$marker_dir" 2>/dev/null || true
    printf '%s\n' "$$" > "${marker_dir}/owner.pid" 2>/dev/null || true
    printf '%s\n' "$(date +%s)" > "${marker_dir}/owner.ts" 2>/dev/null || true
    chmod 700 "$marker_dir" 2>/dev/null || true
    created_marker=1
  fi

  # Prepare tmp file for any transient checks
  tmpf="$(_tmpf file "${RUN_TMPDIR:-$BASH4LLM_TMPDIR}" session.append 2>/dev/null)" || true
  : > "${tmpf:-/dev/null}" 2>/dev/null || true

  timeout="${BASH4LLM_LOCK_TIMEOUT_HISTORY:-10}"

  # Acquire exclusive lock on session file
  exec 200>"$lockfile" 2>/dev/null || true
  if ! flock -x -w "$timeout" 200 2>/dev/null; then
    # Could not acquire lock: cleanup marker if we created it
    if [ "${created_marker:-0}" -eq 1 ]; then rm -rf -- "$marker_dir" 2>/dev/null || true; fi
    exec 200>&- 2>/dev/null || true
    rm -f "$tmpf" 2>/dev/null || true
    printf 'bash4llm: %sERROR%s: SESSION: could not acquire session lock for append\n' "${C_RED}" "${C_RST}" >&2
    log_error "SESSION" "could not acquire session lock for append"
    return 1
  fi

  # If message_id present, do a quick existence check under lock by searching for the id token.
  if [ -n "${message_id:-}" ] && [ -f "$session_file" ]; then
    # Only search for the id field; this is cheap and avoids content-based heuristics
    if grep -F "\"id\":\"$message_id\"" "$session_file" >/dev/null 2>/dev/null; then
      # duplicate detected: release lock and keep marker (treat as done)
      flock -u 200 2>/dev/null || true
      exec 200>&- 2>/dev/null || true
      rm -f "$tmpf" 2>/dev/null || true
      if [ "${DEBUG:-0}" -eq 1 ]; then
        log_info "SESSION" "append skipped: duplicate detected for message_id $message_id"
      fi
      return 0
    fi
  fi

  # Normalize role and meta, build line
  meta_json="$(printf '%s' "$meta_json" | jq -c '.' 2>/dev/null || printf '%s' '{}' )"

  # Build a compact single-line NDJSON record for the session
  line="$(jq -c -n \
    --arg ts "$invocation_ts" \
    --arg role "$role_norm" \
    --arg content "$content" \
    --argjson meta "$meta_json" \
    '{ts:$ts, role:$role, content:$content, meta:$meta}')"

  # Perform append (we already hold the lock)
  if ! printf "%s\n" "$line" >> "$session_file" 2>/dev/null; then
    # If append failed, try to reinitialize file safely
    : > "$session_file" 2>/dev/null || true
    if ! printf "%s\n" "$line" >> "$session_file" 2>/dev/null; then
      # Append definitively failed: cleanup marker if we created it
      if [ "${created_marker:-0}" -eq 1 ]; then
        rm -rf -- "$marker_dir" 2>/dev/null || true
      fi
      flock -u 200 2>/dev/null || true
      exec 200>&- 2>/dev/null || true
      rm -f "$tmpf" 2>/dev/null || true
      printf 'bash4llm: %sERROR%s: SESSION: failed to append message to %s\n' "${C_RED}" "${C_RST}" "$session_file" >&2
      log_error "SESSION" "failed to append message to $session_file"
      return 1
    fi
  fi

  chmod 600 "$session_file" 2>/dev/null || true

  # Release lock
  flock -u 200 2>/dev/null || true
  exec 200>&- 2>/dev/null || true

  rm -f "$tmpf" 2>/dev/null || true

  # Leave marker in place to indicate completion
  touch "${marker_dir}/done" 2>/dev/null || true

  # --- Update ui_state session metadata (canonical single source) ---
  if ensure_run_tmpdir >/dev/null 2>&1; then
    # Compute msg_count and last_ts safely (session_file exists)
    msg_count=0
    last_ts=""
    if [ -f "$session_file" ]; then
      msg_count="$(wc -l < "$session_file" 2>/dev/null || echo 0)"
      # Extract last ts from last NDJSON line if possible
      last_line="$(tail -n 1 "$session_file" 2>/dev/null || true)"
      if printf '%s' "$last_line" | jq -e . >/dev/null 2>&1; then
        last_ts="$(printf '%s' "$last_line" | jq -r '.ts // empty' 2>/dev/null || true)"
      fi
    fi

    meta_json="$(jq -c -n --arg id "$sid" --argjson msg_count "$msg_count" --arg last_ts "${last_ts:-}" \
      '{id:$id, active:true, msg_count:$msg_count, last_ts:$last_ts}')"

    # Write canonical ui_state session file
    ui_state_write "sessions/${sid}.json" "$meta_json" || log_warn "UI_STATE" "failed to write session meta for $sid"
    # Update sessions index (best-effort): read existing index, add sid if missing
    idx_file="${BASH4LLM_CONFIG_DIR%/}/ui_state/sessions/index.json"
    if [ -f "$idx_file" ]; then
      if jq -e --arg sid "$sid" '(.sessions // []) | index($sid) // empty' "$idx_file" >/dev/null 2>&1; then
        : # already present
      else
        # append sid
        tmp_idx="$(_tmpf file "${RUN_TMPDIR:-$BASH4LLM_TMPDIR}" uiidx 2>/dev/null)" || true
        if [ -n "$tmp_idx" ]; then
          jq --arg sid "$sid" '.sessions = ((.sessions // []) + [$sid])' "$idx_file" > "${tmp_idx}.new" 2>/dev/null && mv -f "${tmp_idx}.new" "$tmp_idx" && ui_state_write "sessions/index.json" "$(cat "$tmp_idx")" || true
          rm -f "$tmp_idx" 2>/dev/null || true
        fi
      fi
    else
      # create new index
      ui_state_write "sessions/index.json" "$(jq -c -n --argjson arr '[]' '{sessions:[]}' )" >/dev/null 2>&1 || true
      # then append sid
      ui_state_write "sessions/index.json" "$(jq -c -n --arg sid "$sid" '{sessions:[$sid]}' )" >/dev/null 2>&1 || true
    fi
  fi

  if [ "${DEBUG:-0}" -eq 1 ]; then
    log_info "SESSION" "appended message id ${message_id:-<no-id>} to $session_file"
  fi
  return 0
}

# Default parameters for session helpers (configurable via env)
: "${LAST_CHECK_LINES:=50}"
#--4<---[ /SECTION: PRECORE_RUN_SESSION_MVP ]--->4--

#--5<---[ SECTION: PRECORE_RUN_SESSION_CACHE ]--->5--
# =============================================================================
# Session cache helpers (Strict-safe under set -u)
# =============================================================================
SESSION_CACHE_DIR="${BASH4LLM_CONFIG_DIR%/}/session_cache"
safe_mkdir "$SESSION_CACHE_DIR" 700

# Compute a stable hash for params_string (portable)
_session_hash() {
  local s="${1:-}" h=""
  if command -v sha256sum >/dev/null 2>&1; then
    h="$(printf '%s' "$s" | sha256sum 2>/dev/null | awk '{print $1}' || true)"
  elif command -v openssl >/dev/null 2>&1; then
    h="$(printf '%s' "$s" | openssl dgst -sha256 2>/dev/null | awk '{print $2}' || true)"
  else
    # fallback: base64 of string (not cryptographic but stable)
    h="$(printf '%s' "$s" | base64 | tr -d '\n' | cut -c1-64)"
  fi
  printf '%s' "${h:-}"
}

session_cache_key() {
  local sid="${1:-}" params="${2:-}"
  [ -n "$sid" ] || return 1
  params="${params:-}"
  printf '%s|%s' "$sid" "$(_session_hash "$params")"
}

session_cache_get() {
  local sid="${1:-}" params="${2:-}" out="${3:-}"
  local key file ts now ttl
  key="$(session_cache_key "$sid" "$params")" || return 1
  file="${SESSION_CACHE_DIR%/}/${key}.cache"
  if [ ! -f "$file" ]; then return 1; fi
  # First line: expiry epoch; rest: payload
  read -r ts < "$file" 2>/dev/null || ts=0
  now="$(date +%s)"
  if [ "$now" -ge "$ts" ]; then
    # expired
    rm -f "$file" 2>/dev/null || true
    return 1
  fi
  # output payload to out
  if [ -n "$out" ]; then
    tail -n +2 "$file" > "$out" 2>/dev/null || return 1
  else
    tail -n +2 "$file" 2>/dev/null || return 0
  fi
  return 0
}

session_cache_set() {
  local sid="${1:-}" params="${2:-}" ttl="${3:-300}" infile="${4:-}"
  local key file expiry now tmp_cache
  key="$(session_cache_key "$sid" "$params")" || return 1
  file="${SESSION_CACHE_DIR%/}/${key}.cache"
  now="$(date +%s)"
  expiry=$((now + (ttl + 0)))

  # Temporary file allocation executed only once to prevent leaks and compromised atomicity
  tmp_cache="$(_tmpf file "${SESSION_CACHE_DIR%/}" session.cache 2>/dev/null)" || return 1

  # Atomic write to the previously allocated file
  if {
    printf '%s\n' "$expiry"
    if [ -n "$infile" ] && [ -f "$infile" ]; then
      cat "$infile"
    else
      cat -
    fi
  } > "$tmp_cache" 2>/dev/null; then
    chmod 600 "$tmp_cache" 2>/dev/null || true
    if mv -f "$tmp_cache" "$file" 2>/dev/null; then
      chmod 600 "$file" 2>/dev/null || true
      return 0
    else
      rm -f "$tmp_cache" 2>/dev/null || true
      return 1
    fi
  else
    rm -f "$tmp_cache" 2>/dev/null || true
    return 1
  fi
}

session_cache_invalidate() {
  local sid="${1:-}" params="${2:-}" key pattern
  if [ -z "$sid" ]; then return 1; fi
  if [ -n "$params" ]; then
    key="$(session_cache_key "$sid" "$params")" || return 1
    rm -f "${SESSION_CACHE_DIR%/}/${key}.cache" 2>/dev/null || true
  else
    # remove all entries for sid
    pattern="${SESSION_CACHE_DIR%/}/${sid}|*.cache"
    # shell globbing safe removal
    for f in ${pattern}; do
      [ -e "$f" ] && rm -f -- "$f" 2>/dev/null || true
    done
  fi
  return 0
}
#--5<---[ /SECTION: PRECORE_RUN_SESSION_CACHE ]--->5--
#--6<---[ SECTION: PRECORE_RUN_RUNTIME_GLOBALS ]--->6--
# Runtime globals and normalization (non-destructive defaults)
# ---------------------------------------------------------------------------
# NOTE: Do not assign RUN_TMPDIR/RESP/PAYLOAD/ERRF to empty strings here.
# Those variables must remain unset unless explicitly created by ensure_run_tmpdir
# in the main process. Assign only safe, non-runtime defaults.
CONTENT="${CONTENT:-}"
JSON_INPUT="${JSON_INPUT:-}"
# Session CLI flags defaults (initialized to avoid set -u failures)
SESSION_ID="${SESSION_ID:-}"
SESSION_WINDOW="${SESSION_WINDOW:-}"
# Runtime flags and other non-runtime defaults
TEMPLATE="${TEMPLATE:-}"
BATCH_FILE="${BATCH_FILE:-}"
CHAT_MODE="${CHAT_MODE:-0}"
SET_DEFAULT_MODEL="${SET_DEFAULT_MODEL:-}"
REFRESH_MODELS="${REFRESH_MODELS:-0}"
LIST_MODELS="${LIST_MODELS:-0}"
FORCE_SAVE_MODE="${FORCE_SAVE_MODE:-0}"
OUT_PATH="${OUT_PATH:-}"
SYSTEM_PROMPT="${SYSTEM_PROMPT:-}"

TEMPERATURE="${TEMPERATURE:-${TURE:-1.0}}"
TURE="$TEMPERATURE"

MAX_TOKENS="${MAX_TOKENS:-4096}"
MODEL="${MODEL:-}"
AUTO_POLICY="${AUTO_POLICY:-preferred}"
DEBUG="${DEBUG:-0}"
QUIET="${QUIET:-0}"
DRY_RUN="${DRY_RUN:-0}"
STREAM_MODE="${STREAM_MODE:-0}"
OUTPUT_MODE="${OUTPUT_MODE:-text}"
THRESHOLD="${THRESHOLD:-1000}"

# Reduced to 1 to prevent sequential retry loops (only single manual attempt)
MAX_RETRIES="${MAX_RETRIES:-1}"

SUPPORTED_PROVIDERS="${SUPPORTED_PROVIDERS:-groq gemini huggingface}"
PROVIDER="${PROVIDER:-groq}"

# Ensure config dir exists and is usable before reading persisted provider
if type ensure_config_dir >/dev/null 2>&1; then
  ensure_config_dir >/dev/null 2>&1 || true
else
  safe_mkdir "${BASH4LLM_CONFIG_DIR}" 700
fi

# NOTE: Do NOT reassign RUN_TMPDIR, RESP, PAYLOAD, ERRF to empty values anywhere
# after this point; those are runtime-managed and must be created by ensure_run_tmpdir
# in the main process.
CURL_BASE_OPTS=( --silent --show-error --no-buffer --max-time 120 )

# Ensure runtime tmpdir early so RESP/RUN_TMPDIR are available for later code
if [ "${BASH4LLM_SOURCE_ONLY:-0}" -eq 0 ]; then
  if ! ensure_run_tmpdir >/dev/null 2>&1; then
    log_error "TMP" "cannot create or access RUN_TMPDIR ($BASH4LLM_TMPDIR). Aborting."
    exit "$BASH4LLMERR_TMP"
  fi
fi

# ---------------------------------------------------------------------------
# Helpers: normalization
# ---------------------------------------------------------------------------
_normalize_bool_env() {
  local var val
  for var in ALLOW_API_CALLS DRY_RUN DEBUG; do
    val="${!var:-}"
    if [ -n "$val" ]; then
      if is_truthy "$val"; then
        export "$var"=1
      else
        export "$var"=0
      fi
    fi
  done
}
_normalize_bool_env
#--6<---[ /SECTION: PRECORE_RUN_RUNTIME_GLOBALS ]--->6--
########################################
# SECTION: PROVIDER - BEGIN
########################################
# Provider embedded: groq (full implementations)
# Functions: buildpayload_groq, call_api_groq, call_api_streaming_groq,
# refresh_models_groq, validate_model_groq, auto_select_model_groq

# Provider-specific API key (can be overridden via PROVIDER_API_ENV_groq)
GROQ_API_KEY="${GROQ_API_KEY:-}"
if [ -n "${PROVIDER_API_ENV_groq:-}" ]; then
  if [ -n "${!PROVIDER_API_ENV_groq:-}" ]; then
    GROQ_API_KEY="${!PROVIDER_API_ENV_groq}"
  fi
fi

# ---------------------------------------------------------------------------
# buildpayload_groq
# - Produces a base64-staged payload at $PAYLOAD (uses stage_b64)
# - Supports: JSON_INPUT (messages or prompt), SYSTEM_PROMPT + CONTENT,
#   or CONTENT alone.
# - Honors STREAM_MODE via stream boolean in payload.
# ---------------------------------------------------------------------------
buildpayload_groq() {
  # Build payload for Groq provider into tmp_payload
  # Assumes: MODEL, TURE, MAX_TOKENS, MESSAGES_JSON, BUILD_MESSAGES_FILE, STREAM_MODE, JSON_INPUT, CONTENT may be set
  local tmp_payload stream_json VALID_MESSAGES_JSON http_code edgecase now_ts model_from_file payload_size staged_b64 tmp_b64 content_val msgs msgs_from_file

  ensure_run_tmpdir || return "$BASH4LLMERR_TMP"

  # always allocate a random tmp file; never use deterministic fallback
  tmp_payload="$(_mktemp_in_dir "$RUN_TMPDIR" payload.XXXXXX.json 2>/dev/null || _tmpf file "$RUN_TMPDIR" payload.json)"

  # Normalize stream_json to a JSON boolean literal (true/false)
  if is_truthy "${STREAM_MODE:-0}"; then
    stream_json=true
  else
    stream_json=false
  fi
  case "${stream_json:-}" in
    true|false) ;;    # valid
    1) stream_json=true ;;
    0) stream_json=false ;;
    *) stream_json=false ;;
  esac

  # Validate numeric inputs used with tonumber in jq
  if ! printf '%s' "${TURE:-}" | grep -qE '^[0-9]+([.][0-9]+)?$'; then
    log_warn "ARGS" "invalid TURE value '${TURE:-}'; defaulting to 1.0"
    TURE="1.0"
  fi
  if ! printf '%s' "${MAX_TOKENS:-}" | grep -qE '^[0-9]+$'; then
    log_warn "ARGS" "invalid MAX_TOKENS value '${MAX_TOKENS:-}'; defaulting to 4096"
    MAX_TOKENS="4096"
  fi

  # Priority for messages:
  # 1) JSON_INPUT (if provided) -> .messages or .content/.prompt
  # 2) MESSAGES_JSON (explicit)
  # 3) BUILD_MESSAGES_FILE -> .messages
  # 4) CONTENT (positional/stdin)
  # 5) fallback single empty user message
  VALID_MESSAGES_JSON=""

  if [ -n "${JSON_INPUT:-}" ] && is_valid_json_string "${JSON_INPUT}"; then
    msgs="$(printf '%s' "$JSON_INPUT" | jq -c '.messages // empty' 2>/dev/null || true)"
    if [ -n "$msgs" ]; then
      VALID_MESSAGES_JSON="$msgs"
    else
      content_val="$(printf '%s' "$JSON_INPUT" | jq -r '.content // .prompt // empty' 2>/dev/null || true)"
      if [ -n "$content_val" ]; then
        VALID_MESSAGES_JSON="$(jq -c -n --arg content "$content_val" '[{role:"user",content:$content}]')"
      fi
    fi
  fi

  if [ -z "$VALID_MESSAGES_JSON" ] && is_valid_json_string "${MESSAGES_JSON:-}"; then
    VALID_MESSAGES_JSON="${MESSAGES_JSON}"
  fi

  if [ -z "$VALID_MESSAGES_JSON" ] && [ -n "${BUILD_MESSAGES_FILE:-}" ] && is_valid_json_file "${BUILD_MESSAGES_FILE}"; then
    msgs_from_file="$(jq -c '.messages // []' "$BUILD_MESSAGES_FILE" 2>/dev/null || true)"
    if printf '%s' "$msgs_from_file" | jq -e 'type=="array" and (length>0)' >/dev/null 2>&1; then
      # If history exists and there is current input, merge them immediately
      if [ -n "${CONTENT:-}" ]; then
        VALID_MESSAGES_JSON="$(printf '%s' "$msgs_from_file" | jq -c --arg content "$CONTENT" '. + [{role:"user", content:$content}]' 2>/dev/null || printf '%s' "$msgs_from_file")"
      else
        VALID_MESSAGES_JSON="$msgs_from_file"
      fi
    fi
  fi

  if [ -z "$VALID_MESSAGES_JSON" ] && [ -n "${CONTENT:-}" ]; then
    VALID_MESSAGES_JSON="$(jq -c -n --arg content "$CONTENT" '[{role:"user",content:$content}]')"
  fi

  if [ -z "$VALID_MESSAGES_JSON" ]; then
    VALID_MESSAGES_JSON='[{"role":"user","content":""}]'
    log_warn "PAYLOAD" "MESSAGES_JSON invalid or missing; using fallback single empty user message"
  fi

  if ! printf '%s' "$VALID_MESSAGES_JSON" | jq -e 'type=="array" and (length>0)' >/dev/null 2>&1; then
    log_warn "PAYLOAD" "VALID_MESSAGES_JSON is empty or not an array; using fallback single empty user message"
    VALID_MESSAGES_JSON='[{"role":"user","content":""}]'
  fi

  # Prepend system prompt if active
  if [ -n "${SYSTEM_PROMPT:-}" ]; then
    VALID_MESSAGES_JSON="$(jq -n --argjson messages "$VALID_MESSAGES_JSON" --arg sys "$SYSTEM_PROMPT" '[{role:"system", content:$sys}] + $messages' 2>/dev/null || jq -n --arg role "system" --arg content "${SYSTEM_PROMPT:-}" --argjson messages "$VALID_MESSAGES_JSON" '{messages:([{role:$role,content:$content}] + $messages) }')"
  fi

  if [ -z "${MODEL:-}" ] && [ -n "${BUILD_MESSAGES_FILE:-}" ] && is_valid_json_file "${BUILD_MESSAGES_FILE}"; then
    model_from_file="$(jq -r '.model // .provider?.model // empty' "$BUILD_MESSAGES_FILE" 2>/dev/null || true)"
    if [ -n "$model_from_file" ]; then
      MODEL="$model_from_file"
      if [ "${DEBUG:-0}" -eq 1 ]; then
        log_info "PAYLOAD" "MODEL set from BUILD_MESSAGES_FILE: ${MODEL}"
      fi
    fi
  fi

  if ! jq -n --arg model "${MODEL:-}" --argjson stream "$stream_json" --arg ture "$TURE" --arg max_tokens "$MAX_TOKENS" \
       --argjson messages "$(printf '%s' "$VALID_MESSAGES_JSON")" \
       '{model:$model, stream:$stream, temperature:($ture|tonumber), max_tokens:($max_tokens|tonumber), messages:$messages }' >"$tmp_payload" 2>/dev/null; then
    log_error "PAYLOAD" "jq failed to build payload; tmp_payload not created"
    rm -f "$tmp_payload" 2>/dev/null || true
    return "$BASH4LLMERR_TMP"
  fi

  if [ ! -s "$tmp_payload" ]; then
    log_error "PAYLOAD" "tmp_payload is empty after jq; aborting"
    rm -f "$tmp_payload" 2>/dev/null || true
    return "$BASH4LLMERR_TMP"
  fi

  if [ "${DEBUG:-0}" -eq 1 ]; then
    payload_size=$(wc -c < "$tmp_payload" 2>/dev/null || echo 0)
    log_info "PAYLOAD" "tmp_payload path: $tmp_payload size=${payload_size}B"
    log_info "PAYLOAD" "tmp_payload content (head 2000 chars):"
    head -c 2000 "$tmp_payload" >&2 || true
  fi

  staged_b64=""
  if type stage_b64 >/dev/null 2>&1; then
    tmp_b64="${tmp_payload}.b64"
    if stage_b64 "$tmp_b64" < "$tmp_payload" 2>/dev/null; then
      staged_b64="$tmp_b64"
      # remove original JSON payload after successful staging
      rm -f "$tmp_payload" 2>/dev/null || true
      if [ "${DEBUG:-0}" -eq 1 ]; then
        log_info "PAYLOAD" "Created base64-staged payload: $staged_b64"
      fi
    else
      if [ "${DEBUG:-0}" -eq 1 ]; then
        log_warn "PAYLOAD" "stage_b64 failed; using raw JSON payload"
      fi
      rm -f "$tmp_b64" 2>/dev/null || true
    fi
  fi

  if [ -n "$staged_b64" ]; then
    PAYLOAD="$staged_b64"
  else
    PAYLOAD="$tmp_payload"
  fi
  export PAYLOAD
  return 0
}

# ---------------------------------------------------------------------------
# call_api_groq
# - Performs HTTP POST request using curl to the resolved provider URL.
# - Leverages standard payload and response variables ($PAYLOAD, $RESP, $ERRF).
# ---------------------------------------------------------------------------
call_api_groq() {
  local provider_url="${BASH4LLM_PROVIDER_URL:-}"
  local api_key="${GROQ_API_KEY:-}"
  local http_code rc payload_dec tmp_resp tmp_err

  # Enforce central network policy
  enforce_network_policy || return $?

  if [ -z "$provider_url" ]; then
    log_error "CALL" "Provider URL not resolved"
    return "$BASH4LLMERR_API"
  fi

  ensure_run_tmpdir || return "$BASH4LLMERR_TMP"

  # Decode payload if staged in base64
  payload_dec="$PAYLOAD"
  if printf '%s' "$PAYLOAD" | grep -qE '\.b64$'; then
    payload_dec="$(_tmpf file "$RUN_TMPDIR" payload.dec 2>/dev/null)" || return "$BASH4LLMERR_TMP"
    if ! b64decode < "$PAYLOAD" > "$payload_dec" 2>/dev/null; then
      log_error "B64DECODE" "Failed to decode staging payload"
      rm -f "$payload_dec" 2>/dev/null || true
      return "$BASH4LLMERR_TMP"
    fi
  fi

  tmp_resp="$(_tmpf file "$RUN_TMPDIR" resp.tmp 2>/dev/null)" || { [ "$payload_dec" != "$PAYLOAD" ] && rm -f "$payload_dec" 2>/dev/null || true; return "$BASH4LLMERR_TMP"; }
  tmp_err="$(_tmpf file "$RUN_TMPDIR" err.tmp 2>/dev/null)" || { rm -f "$tmp_resp" 2>/dev/null || true; [ "$payload_dec" != "$PAYLOAD" ] && rm -f "$payload_dec" 2>/dev/null || true; return "$BASH4LLMERR_TMP"; }

  if [ "${DEBUG:-0}" -eq 1 ]; then
    log_info "CURL" "POST -> $provider_url"
  fi

  http_code="$(curl "${CURL_BASE_OPTS[@]}" \
    -X POST \
    -H "Authorization: Bearer $api_key" \
    -H "Content-Type: application/json" \
    --data-binary @"$payload_dec" \
    -o "$tmp_resp" \
    -w "%{http_code}" \
    "$provider_url" 2>"$tmp_err")"
  rc=$?

  # Clean decoded payload
  if [ "$payload_dec" != "$PAYLOAD" ]; then
    rm -f "$payload_dec" 2>/dev/null || true
  fi

  # Handle curl network failure
  if [ "$rc" -ne 0 ]; then
    log_error "CURL" "Network call failed with code $rc"
    cat "$tmp_err" >> "$ERRF" 2>/dev/null || true
    rm -f "$tmp_resp" "$tmp_err" 2>/dev/null || true
    return "$BASH4LLMERR_CURL_FAILED"
  fi

  # Write back response atomically
  if [ -s "$tmp_resp" ]; then
    if mv -f "$tmp_resp" "$RESP" 2>/dev/null; then
      chmod 600 "$RESP" 2>/dev/null || true
    else
      cp -f "$tmp_resp" "$RESP" 2>/dev/null || true
      chmod 600 "$RESP" 2>/dev/null || true
      rm -f "$tmp_resp" 2>/dev/null || true
    fi
  else
    rm -f "$tmp_resp" 2>/dev/null || true
  fi

  rm -f "$tmp_err" 2>/dev/null || true

  # Treat non-2xx status as API failure
  if [ "$http_code" -lt 200 ] || [ "$http_code" -ge 300 ]; then
    log_error "API" "HTTP Status code: $http_code"
    return "$BASH4LLMERR_API"
  fi

  return 0
}

# ---------------------------------------------------------------------------
# call_api_streaming_groq (streaming) - with enforcement network policy
# ---------------------------------------------------------------------------
call_api_streaming_groq() {
  # Streaming call for Groq provider with robust checks and diagnostics.
  # Expects: RUN_TMPDIR, RESP variable, and payload file (BASH4LLM_TMP_PAYLOAD or PAYLOAD).
  local tmp_payload provider_url resp_raw resp_lines resp_valid resp_chunks resp_tmp ERRF rc stderr_head now_ts decoded_payload finish_reason req_id edgecase send_payload CURL_CMD http_code json content resp_size errf_size resp_text_tmp resp_json_tmp p_dir api_json ui_last

  ensure_run_tmpdir || return "$BASH4LLMERR_TMP"

  if ! enforce_network_policy >/dev/null 2>&1; then
    if is_truthy "${DRY_RUN:-0}"; then
      if [ "${DEBUG:-0}" -eq 1 ]; then
        show_payload_head "${PAYLOAD:-}" 200 || true
        log_info "DRYRUN" "DRY-RUN: skipping streaming HTTP call"
      fi
      return 0
    fi
    log_error "NETWORK" "Network calls disabled; aborting streaming request."
    return "$BASH4LLMERR_CURL_FAILED"
  fi

  if [ -n "${PROVIDER_API_ENV_groq:-}" ] && [ -n "${!PROVIDER_API_ENV_groq:-}" ]; then
    GROQ_API_KEY="${!PROVIDER_API_ENV_groq}"
  fi
  if [ -z "${GROQ_API_KEY:-}" ] && [ -z "${BASH4LLM_API_KEY:-}" ]; then
    log_error "APIKEY" "GROQ_API_KEY (or BASH4LLM_API_KEY) is not set."
    return "$BASH4LLMERR_NO_API_KEY"
  fi

  tmp_payload="${BASH4LLM_TMP_PAYLOAD:-${PAYLOAD:-}}"
  if [ -z "${tmp_payload:-}" ]; then
    log_error "CALL_STREAM" "no payload file specified (BASH4LLM_TMP_PAYLOAD or PAYLOAD)"
    return 1
  fi
  if [ ! -s "$tmp_payload" ]; then
    log_error "CALL_STREAM" "Refusing to call curl: payload file is empty or missing: $tmp_payload"
    now_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    jq -c -n --arg ts "$now_ts" --arg note "empty_payload" '{diagnostic:true, note:$note, time:$ts}' > "${RESP:-$RUN_TMPDIR/resp.json}" 2>/dev/null || true
    return 1
  fi

  if [ -z "${BASH4LLM_PROVIDER_URL:-}" ]; then
    resolve_provider_url "${PROVIDER:-}" >/dev/null 2>&1 || true
  fi
  provider_url="${BASH4LLM_PROVIDER_URL:-}"
  if [ -z "${provider_url:-}" ]; then
    log_error "CALL_STREAM" "no provider URL set (BASH4LLM_PROVIDER_URL)"
    now_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    jq -c -n --arg ts "$now_ts" --arg note "no_provider_url" '{diagnostic:true, note:$note, time:$ts}' > "${RESP:-$RUN_TMPDIR/resp.json}" 2>/dev/null || true
    return 1
  fi

  resp_raw="$(_tmpf file "$RUN_TMPDIR" resp.raw 2>/dev/null)"
  resp_lines="$(_tmpf file "$RUN_TMPDIR" resp.lines 2>/dev/null)"
  resp_valid="$(_tmpf file "$RUN_TMPDIR" resp.valid.jsons 2>/dev/null)"
  resp_chunks="$(_tmpf file "$RUN_TMPDIR" resp.chunks.json 2>/dev/null)"
  ERRF="$(_tmpf file "$RUN_TMPDIR" curl_stream.err 2>/dev/null)"
  : > "$ERRF" 2>/dev/null || true
  rm -f "$resp_raw" "$resp_lines" "$resp_valid" "$resp_chunks" 2>/dev/null || true

  if [ "${DEBUG:-0}" -eq 1 ]; then
    log_info "CALL_STREAM" "Invoking streaming curl to $provider_url (payload: $tmp_payload)"
  fi

  decoded_payload="$(_tmpf file "$RUN_TMPDIR" payload.dec 2>/dev/null)" || true

  if printf '%s' "${tmp_payload}" | grep -qE '\.b64$'; then
    if ! b64decode < "$tmp_payload" > "$decoded_payload" 2>"$ERRF"; then
      log_error "B64DECODE" "base64 decode failed for payload; see $ERRF"
      rm -f "$decoded_payload" 2>/dev/null || true
      return "$BASH4LLMERR_TMP"
    fi
    send_payload="$decoded_payload"
  else
    send_payload="$tmp_payload"
  fi

  CURL_CMD=(curl --http1.1 -sS -N)

  if [ -n "${CURL_BASE_OPTS[*]:-}" ]; then
    CURL_CMD+=("${CURL_BASE_OPTS[@]}")
  fi

  CURL_CMD+=( -H "Content-Type: application/json" )
  if [ -n "${GROQ_API_KEY:-}" ]; then
    CURL_CMD+=( -H "Authorization: Bearer ${GROQ_API_KEY}" )
  elif [ -n "${BASH4LLM_API_KEY:-}" ]; then
    CURL_CMD+=( -H "Authorization: Bearer ${BASH4LLM_API_KEY}" )
  fi

  "${CURL_CMD[@]}" --data-binary @"$send_payload" "$provider_url" 2> "$ERRF" | \
  while IFS= read -r line || [ -n "$line" ]; do
    printf '%s\n' "$line" >> "$resp_raw"
    case "$line" in
      'data: [DONE]'|'data:[DONE]') break ;;
      data:\ * )
        json="${line#data: }"
        content="$(printf '%s' "$json" | jq -j 'try (if type=="string" then fromjson else . end | (.choices[]?.delta?.content // .choices[]?.message?.content // "")) catch ""' 2>>"$ERRF" || true; printf 'x')"
        content="${content%x}"
        if [ -n "$content" ]; then
          printf '%s' "$content"
        fi
        ;;
      *)
        if printf '%s' "$line" | jq -e . >/dev/null 2>&1; then
          content="$(printf '%s' "$line" | jq -j '(.choices[]?.delta?.content // .choices[]?.message?.content // "")' 2>>"$ERRF" || true; printf 'x')"
          content="${content%x}"
          if [ -n "$content" ]; then
            printf '%s' "$content"
          fi
        fi
        ;;
    esac
  done || true

  rc=${PIPESTATUS[0]:-0}
  # SIGPIPE (141) is normal if we terminate the read loop early
  if [ "$rc" -eq 141 ]; then
    rc=0
  fi

  rm -f "$decoded_payload" 2>/dev/null || true

  resp_size=0; [ -f "$resp_raw" ] && resp_size=$(wc -c < "$resp_raw" 2>/dev/null || echo 0)
  errf_size=0; [ -f "$ERRF" ] && errf_size=$(wc -c < "$ERRF" 2>/dev/null || echo 0)
  if [ "${DEBUG:-0}" -eq 1 ]; then
    log_info "CALL_STREAM" "curl rc=${rc} resp_raw_size=${resp_size}B ERRF_size=${errf_size}B resp_raw='${resp_raw}' ERRF='${ERRF}'"
    if [ -s "$ERRF" ]; then
      log_info "CALL_STREAM" "curl stderr (head 400 chars):"
      head -c 400 "$ERRF" 2>/dev/null | sed -n '1,20p' >&2 || true
    fi
    if [ -s "$resp_raw" ]; then
      log_info "CALL_STREAM" "resp_raw head (first 400 chars):"
      head -c 400 "$resp_raw" 2>/dev/null | sed -n '1,20p' >&2 || true
    fi
  fi

  if [ -s "$resp_raw" ]; then
    grep -E '^data:' "$resp_raw" 2>/dev/null | sed -E 's/^data:[[:space:]]*//' > "$resp_lines" 2>/dev/null || true
  fi

  : > "$resp_valid" 2>/dev/null || true
  if [ -f "$resp_lines" ] && [ -s "$resp_lines" ]; then
    while IFS= read -r _line; do
      if printf '%s' "$_line" | jq -e . >/dev/null 2>&1; then
        printf '%s\n' "$_line" >> "$resp_valid"
      fi
    done < "$resp_lines"
  fi

  if [ -s "$resp_valid" ]; then
    jq -s '.' "$resp_valid" > "$resp_chunks" 2>/dev/null || true
    resp_text_tmp="$(_tmpf file "$RUN_TMPDIR" resp.text.txt 2>/dev/null)"
    jq -r 'map(.choices[]?.delta?.content // .choices[]?.message?.content // "") | join("")' "$resp_chunks" > "$resp_text_tmp" 2>/dev/null || true
    resp_json_tmp="$(_tmpf file "$RUN_TMPDIR" resp.json 2>/dev/null)"
    if jq -e 'type=="array"' "$resp_chunks" >/dev/null 2>&1; then
      jq -c '.[-1]' "$resp_chunks" > "$resp_json_tmp" 2>/dev/null || true
    else
      cp -f "$resp_chunks" "$resp_json_tmp" 2>/dev/null || true
    fi
  else
    resp_json_tmp="$(_tmpf file "$RUN_TMPDIR" resp.json 2>/dev/null)"
    if jq -e . "$resp_raw" >/dev/null 2>&1; then
      cp -f "$resp_raw" "$resp_json_tmp" 2>/dev/null || true
    fi
  fi

  rm -f "$resp_raw" 2>/dev/null || true
  rm -f "$resp_lines" 2>/dev/null || true
  rm -f "$resp_valid" 2>/dev/null || true
  rm -f "$resp_chunks" 2>/dev/null || true
  rm -f "$resp_text_tmp" 2>/dev/null || true

  resp_tmp="$resp_json_tmp"

  if [ -z "${RESP:-}" ]; then
    RESP="${RUN_TMPDIR%/}/resp.json"
  fi
  p_dir="$(dirname "$RESP")"
  safe_mkdir "$p_dir" 700

  # Move resp_tmp -> RESP
  if [ -s "$resp_tmp" ]; then
    if [ "${resp_tmp%/}" = "${RESP%/}" ]; then
      chmod 600 "$RESP" 2>/dev/null || true
    else
      if mv -f "$resp_tmp" "${RESP}" 2>/dev/null; then
        chmod 600 "${RESP}" 2>/dev/null || true
      else
        log_error "RESP" "mv failed; writing diagnostic RESP"
        now_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
        stderr_head="$(head -c 200 "${ERRF:-/dev/null}" 2>/dev/null | sed 's/"/\\"/g' || true)"
        jq -c -n --arg http "${http_code:-0}" --arg ts "$now_ts" --arg err "$stderr_head" \
          '{diagnostic:true, last_http_status:($http|tonumber), last_time_utc:$ts, stderr_head:$err}' > "${RESP}" 2>/dev/null || true
      fi
    fi
  else
    now_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    stderr_head="$(head -c 200 "${ERRF:-/dev/null}" 2>/dev/null | sed 's/"/\\"/g' || true)"
    jq -c -n --arg http "${http_code:-0}" --arg ts "$now_ts" --arg err "$stderr_head" \
          '{diagnostic:true, last_http_status:($http|tonumber), last_time_utc:$ts, stderr_head:$err}' > "${RESP}" 2>/dev/null || printf '{"diagnostic":true,"last_http_status":%s,"last_time_utc":"%s"}\n' "${http_code:-0}" "$now_ts" > "${RESP}"
  fi

  # remove resp_tmp if still present
  rm -f "$resp_tmp" 2>/dev/null || true

  # remove ERRF after diagnostics
  rm -f "$ERRF" 2>/dev/null || true

  if ensure_run_tmpdir >/dev/null 2>&1; then
    http_code=200
    finish_reason="$(jq -r '.choices[0]?.finish_reason // empty' "${RESP}" 2>/dev/null || echo "")"
    req_id="$(jq -r '.x_groq?.id // .id // empty' "${RESP}" 2>/dev/null || echo "")"
    edgecase=0
    if [ "${BASH4LLM_EDGE_EMPTY:-0}" -eq 1 ]; then edgecase=1; fi
    now_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    api_json="$(jq -c -n --argjson http "$http_code" --arg fr "${finish_reason:-}" --argjson edge "$edgecase" --arg id "${req_id:-}" --arg ts "$now_ts" '{last_http_status:$http, last_finish_reason:$fr, last_edgecase_detected:$edge, last_req_id:$id, last_time_utc:$ts}')"
    ui_state_write "last_api.json" "$api_json" || { if [ "${DEBUG:-0}" -eq 1 ]; then log_warn "UI_STATE" "failed to write last_api.json (streaming)"; fi; }
  fi

  return "${rc:-0}"
}

# ---------------------------------------------------------------------------
# refresh_models_groq
# - Fetches /openai/v1/models and writes a newline-separated list to MODELS_FILE
# - Uses jq when possible; if response is not valid JSON, attempts a heuristic parse.
# - Writes via b64_atomic_write + lock_exec to ensure atomic update.
# ---------------------------------------------------------------------------
refresh_models_groq() {
  # Fetch Groq models and write normalized model names to MODELS_FILE.
  # Prefer .data[].name then .data[].id then top-level array .[].name/.id.
  if [ -n "${PROVIDER_API_ENV_groq:-}" ] && [ -n "${!PROVIDER_API_ENV_groq:-}" ]; then
    GROQ_API_KEY="${!PROVIDER_API_ENV_groq}"
  fi
  if [ -z "${GROQ_API_KEY:-}" ]; then
    log_error "APIKEY" "GROQ_API_KEY is required to refresh models."
    return "$BASH4LLMERR_NO_API_KEY"
  fi

  ensure_run_tmpdir || return "$BASH4LLMERR_TMP"
  local workdir tmpd out errf api_url tmp_parsed tmp_trim tmpout rc origin lockfile
  workdir="${RUN_TMPDIR:-}"
  [ -n "$workdir" ] || return "$BASH4LLMERR_TMP"
  tmpd="$(mktemp -d "$workdir/groq-models.XXXXXX")" || return "$BASH4LLMERR_TMP"
  out="$tmpd/models.json"
  errf="$tmpd/curl.err"

  resolve_provider_url "${PROVIDER:-}" >/dev/null 2>&1 || true
  if [ -n "${BASH4LLM_PROVIDER_URL:-}" ]; then
    origin="$(printf '%s' "$BASH4LLM_PROVIDER_URL" | sed -E 's#(https?://[^/]+).*#\1#')"
    api_url="${origin%/}/openai/v1/models"
  else
    log_error "MODELREFRESH" "no provider URL available to refresh models"
    rm -rf "$tmpd"
    return "$BASH4LLMERR_API"
  fi

  rm -f "$out" "$errf" 2>/dev/null || true
  if ! curl "${CURL_BASE_OPTS[@]}" -H "Authorization: Bearer ${GROQ_API_KEY}" -H "Content-Type: application/json" "${api_url}?limit=${MAX_MODELS}" -o "$out" 2>"$errf"; then
    log_error "MODELREFRESH" "Failed to fetch models from $api_url"
    if [ "${DEBUG:-0}" -eq 1 ]; then
      head -n 200 "$errf" >&2 || true
    fi
    rm -rf "$tmpd"
    return "$BASH4LLMERR_API"
  fi

  if ! jq -e . "$out" >/dev/null 2>&1; then
    log_error "MODELREFRESH" "Invalid JSON received from $api_url"
    if [ "${DEBUG:-0}" -eq 1 ]; then
      head -n 200 "$errf" >&2 || true
    fi
    rm -rf "$tmpd"
    return "$BASH4LLMERR_API"
  fi

  tmp_parsed="$tmpd/parsed_models.txt"
  : > "$tmp_parsed"

  jq -r '
    if (has("data") and (.data|type) == "array") then
      .data[]? | (.id // .name // empty)
    elif (type == "array") then
      .[]? | (.id // .name // empty)
    else
      empty
    end
  ' "$out" | awk 'NF{print}' | sed -E 's/^[[:space:]]+//;s/[[:space:]]+$//' | sort -u > "$tmp_parsed" 2>/dev/null || true

  if [ ! -s "$tmp_parsed" ]; then
    log_error "MODELREFRESH" "models refresh: parsed list empty"
    if [ "${DEBUG:-0}" -eq 1 ]; then
      head -n 200 "$errf" >&2 || true
    fi
    rm -rf "$tmpd"
    return "$BASH4LLMERR_API"
  fi

  tmp_trim="$tmpd/parsed_trimmed.txt"
  awk '{
    g=$0
    sub(/^models\//,"",g)
    sub(/^groq[:\/-]*/,"",g)
    if (g ~ /^[[:alnum:]._\/:-]+$/) print g
  }' "$tmp_parsed" | awk -v M="$MAX_MODELS" 'NR<=M{print}' > "$tmp_trim" || true

  if [ ! -s "$tmp_trim" ]; then
    log_error "MODELREFRESH" "no valid model names after normalization"
    rm -rf "$tmpd"
    return "$BASH4LLMERR_API"
  fi

  safe_mkdir "$(dirname "$MODELS_FILE")" 700
  tmpout="$(_mktemp_in_dir "$(dirname "$MODELS_FILE")" 2>/dev/null)" || true
  [ -n "$tmpout" ] || tmpout="$(_tmpf file "$(dirname "$MODELS_FILE")" models 2>/dev/null)"

  cat "$tmp_trim" > "$tmpout"

  if ! b64_atomic_write "${MODELS_FILE}.b64" 10 < "$tmpout"; then
    log_error "MODELREFRESH" "failed to stage models file"
    rm -f "$tmpout" 2>/dev/null || true
    rm -rf "$tmpd"
    return "$BASH4LLMERR_TMP"
  fi

  lockfile="$MODELS_LOCK"
  lock_exec "$lockfile" 10 -- base64 "${B64_DECODE_OPT}" < "${MODELS_FILE}.b64" > "$MODELS_FILE" \
    || { log_error "MODELREFRESH" "failed to write models file under lock"; rm -rf "$tmpd"; return "$BASH4LLMERR_TMP"; }

  chmod 600 "$MODELS_FILE" 2>/dev/null || true

  # Refreshed models are logged to the user
  log_info_user "MODELREFRESH" "Models refreshed and saved to: $MODELS_FILE (max ${MAX_MODELS})"

  rm -rf "$tmpd"
  return 0
}

# ---------------------------------------------------------------------------
# validate_model_groq
# - If MODELS_FILE exists and is non-empty, require the model to be present.
# - If MODELS_FILE does not exist or is empty, allow (backwards compatible).
# ---------------------------------------------------------------------------
validate_model_groq() {
  # Provider-specific validation for Groq models.
  # Accepts either exact matches as stored in MODELS_FILE or normalized names
  # (stripping common prefixes like "models/" or "groq:"), and enforces textual support.
  local model="${1:-}" norm_model file_match
  [ -n "$model" ] || { printf 'bash4llm: %sERROR%s: validate_model_groq: model required\n' "${C_RED}" "${C_RST}" >&2; return 1; }

  # Normalize incoming model for comparison: strip leading "models/" and "groq:" and trim
  norm_model="$(printf '%s' "$model" | sed -e 's#^models/##' -e 's#^groq[:/ -]*##' -e 's/^[[:space:]]*//;s/[[:space:]]*$//')"

  # If MODELS_FILE exists and non-empty, require presence (allow either raw or normalized forms)
  if [ -f "${MODELS_FILE:-}" ] && [ -s "${MODELS_FILE:-}" ]; then
    # Exact match first (file may contain provider-specific forms)
    if grep -x -F -q "$model" "$MODELS_FILE" 2>/dev/null; then
      file_match=1
    else
      # Compare against normalized entries (strip common prefixes in file)
      if awk '{g=$0; sub(/^models\//,"",g); sub(/^groq[:\/ -]*/,"",g); print g}' "$MODELS_FILE" \
           | grep -x -F -q "$norm_model" 2>/dev/null; then
        file_match=1
      else
        file_match=0
      fi
    fi

    if [ "$file_match" -ne 1 ]; then
      printf 'bash4llm: %sERROR%s: The model "%s" is not present in %s\n' "${C_RED}" "${C_RST}" "$model" "$MODELS_FILE" >&2
      return 1
    fi
  fi

  # Ensure the (normalized) model is text-capable
  if ! is_supported_model "$norm_model"; then
    printf 'bash4llm: %sERROR%s: The "%s" model is not supported by %s (requires non-text input).\n' "${C_RED}" "${C_RST}" "$model" "${C_GBOLD}Bash4LLM⁺${C_RST}" >&2
    return 1
  fi

  return 0
}

# ---------------------------------------------------------------------------
# auto_select_model_groq
# ---------------------------------------------------------------------------
auto_select_model_groq() {
  # Return the first supported model candidate from MODELS_FILE for Groq provider.
  # Normalizes entries by stripping common prefixes like "models/" and "groq:".
  # Prints the selected model (normalized) to stdout and returns 0 on success,
  # returns 1 if no suitable model found.
  local file="$MODELS_FILE" line norm cnt=0
  if [ -f "$file" ] && [ -s "$file" ]; then
    relative_mfile="$(canonical_model_file "groq")"
    if [ -f "$relative_mfile" ] && [ -s "$relative_mfile" ]; then
      norm="$(cat "$relative_mfile" 2>/dev/null | head -n1 | sed -e 's/^[[:space:]]*//;s/[[:space:]]*$//')"
      if [ -n "$norm" ] && is_supported_model "$norm"; then
        printf '%s' "$norm"
        return 0
      fi
    fi
    while IFS= read -r line || [ -n "$line" ]; do
      [ -z "$line" ] && continue
      cnt=$((cnt+1))
      norm="$(printf '%s' "$line" | sed -e 's#^models/##' -e 's#^groq[:/ -]*##' -e 's/^[[:space:]]*//;s/[[:space:]]*$//')"
      if is_supported_model "$norm"; then
        printf '%s' "$norm"
        return 0
      fi
      [ "$cnt" -ge "$MAX_MODELS" ] && break
    done < "$file"
  fi
  return 1
}
########################################
# SECTION: PROVIDER - END
########################################
########################################
# SECTION: CORE_SETUP - BEGIN
########################################
#--1<---[ SECTION: CORE_SETUP_DISPATCH_HELPERS ]--->1--
# Core helpers and CLI wiring (public interfaces preserved)

# Dispatch helper: call provider-specific function by name if available
call_provider() {
  local fn="${1:-}" shift_args=("${@:2}")
  if type "$fn" >/dev/null 2>&1; then
    "$fn" "${shift_args[@]}"
    return $?
  fi
  return 127
}

# Provider dispatch wrappers (call provider-specific implementations if present)
refresh_models_dispatch() {
  local destfile="${1:-${MODELS_FILE:-$BASH4LLM_MODELS_DIR/models.txt}}"
  local fn="refresh_models_${PROVIDER}"
  local rc=0

  if ! type "$fn" >/dev/null 2>&1; then
    log_error "MODELREFRESH" "Provider '$PROVIDER' does not implement $fn()."
    return 127
  fi

  # Try provider-specific refresh; prefer passing destfile but tolerate providers that ignore args
  if "$fn" "$destfile" 2>/dev/null; then
    if [ "${DEBUG:-0}" -eq 1 ]; then
      log_info "MODELREFRESH" "Models refreshed for provider $PROVIDER -> $destfile"
    fi
    return 0
  fi

  rc=$?
  if "$fn" 2>/dev/null; then
    if [ "${DEBUG:-0}" -eq 1 ]; then
      log_info "MODELREFRESH" "Models refreshed for provider $PROVIDER (no explicit dest)"
    fi
    return 0
  fi

  rc=$?
  log_error "MODELREFRESH" "refresh_models for provider $PROVIDER failed (rc $rc)."
  return "$rc"
}

validate_model_dispatch() {
  local model="${1:-}"
  local fn="validate_model_${PROVIDER}"

  if type "$fn" >/dev/null 2>&1; then
    "$fn" "$model"
    return $?
  fi

  # Explicit permissive fallback (once per run, GLOBAL guard)
  if [ -z "${VALIDATE_MODEL_DISPATCH_WARNED:-}" ]; then
    log_warn "MODEL" "provider '${PROVIDER}' does not implement ${fn}; falling back to permissive validation."
    VALIDATE_MODEL_DISPATCH_WARNED=1
  fi

  return 0
}

# auto_select_model_dispatch (call provider-specific implementations if present)
auto_select_model_dispatch() {
  local fn="auto_select_model_${PROVIDER}"
  if type "$fn" >/dev/null 2>&1; then
    "$fn"
    return $?
  fi
  return 127
}
#--1<---[ /SECTION: CORE_SETUP_DISPATCH_HELPERS ]--->1--
# resolve_model: determines the final MODEL following priority rules and validation
# Output: sets the global variable FINAL_MODEL (string) or empty if unresolved.
resolve_model() {
  local active_provider candidate norm MODEL_PROVIDER_CFG cfg_model cnt m
  ALLOWED_MODELS="${ALLOWED_MODELS:-}"

  if [ -n "${MODEL:-}" ] && [ "${MODEL_CLI_SET:-0}" -ne 1 ]; then
    MODEL_PROVIDER_CFG="$(canonical_model_file "${PROVIDER:-groq}")"
    if [ ! -s "$MODEL_PROVIDER_CFG" ]; then
      log_warn "MODEL" "MODEL is set in environment but not passed with -m/--set-default; use -m for per-run override or --set-default to persist."
    fi
  fi

  FINAL_MODEL=""

  # 1) CLI-specified model
  if [ "${MODEL_CLI_SET:-0}" -eq 1 ] && [ -n "${MODEL:-}" ]; then
    FINAL_MODEL="$MODEL"
    return 0
  fi

  # Determine active provider
  if [ -n "${PROVIDER_CLI:-}" ]; then
    active_provider="${PROVIDER_CLI}"
  elif [ -f "$(canonical_provider_file)" ] && [ -s "$(canonical_provider_file)" ]; then
    active_provider="$(sed -n '1p' "$(canonical_provider_file)" 2>/dev/null || true)"
    active_provider="$(printf '%s' "$active_provider" | awk '{$1=$1;print}')"
    [ -z "$active_provider" ] && active_provider="${PROVIDER:-groq}"
  else
    active_provider="${PROVIDER:-groq}"
  fi

  # 2) provider-specific persisted default
  MODEL_PROVIDER_CFG="$(canonical_model_file "${active_provider}")"

  if [ -z "$(canonical_config_dir)" ] || [ "$(canonical_config_dir)" = "/" ]; then
    log_error "SEC" "refusing to read provider-specific model file: invalid canonical config dir: $(canonical_config_dir)"
  else
    if [ -s "$MODEL_PROVIDER_CFG" ]; then
      candidate="$(sed -n '1p' "$MODEL_PROVIDER_CFG" 2>/dev/null || true)"
      candidate="$(printf '%s' "$candidate" | awk '{$1=$1;print}')"

      norm="$(printf '%s' "$candidate" | sed -e 's#^models/##' -e 's#^groq[:/ -]*##')"

      if [ -n "$norm" ] && is_supported_model "$norm"; then
        if validate_model_core "$norm" >/dev/null 2>&1 && validate_model_dispatch "$norm" >/dev/null 2>&1; then
          FINAL_MODEL="$norm"
          return 0
        fi
      fi
    fi
  fi

  # 3) provider auto-select
  candidate="$(auto_select_model_dispatch 2>/dev/null || true)"
  if [ -n "$candidate" ]; then
    norm="$(printf '%s' "$candidate" | sed -e 's#^models/##' -e 's#^groq[:/ -]*##')"
    if is_supported_model "$norm"; then
      if validate_model_core "$norm" >/dev/null 2>&1 && validate_model_dispatch "$norm" >/dev/null 2>&1; then
        FINAL_MODEL="$norm"
        return 0
      fi
    fi
  fi

  # 4) first supported entry in MODELS_FILE
  if [ -f "${MODELS_FILE:-}" ] && [ -s "${MODELS_FILE:-}" ]; then
    cnt=0
    while IFS= read -r m || [ -n "$m" ]; do
      [ -z "$m" ] && continue
      cnt=$((cnt+1))

      norm="$(printf '%s' "$m" | sed -e 's#^models/##' -e 's#^groq[:/ -]*##')"

      if is_supported_model "$norm"; then
        if validate_model_core "$norm" >/dev/null 2>&1 && validate_model_dispatch "$norm" >/dev/null 2>&1; then
          FINAL_MODEL="$norm"
          return 0
        fi
      fi

      [ "$cnt" -ge "$MAX_MODELS" ] && break
    done < "$MODELS_FILE"
  fi

  # 5) config MODEL= in config file (legacy)
  if [ -f "${BASH4LLM_CONFIG_DIR%/}/config" ]; then
    cfg_model="$(awk -F= '/^MODEL=/ {sub(/^MODEL=/,""); print; exit}' "${BASH4LLM_CONFIG_DIR%/}/config" 2>/dev/null || true)"
    cfg_model="$(printf '%s' "$cfg_model" | awk '{$1=$1;print}')"

    norm="$(printf '%s' "$cfg_model" | sed -e 's#^models/##' -e 's#^groq[:/ -]*##')"

    if [ -n "$norm" ] && is_supported_model "$norm"; then
      if validate_model_core "$norm" >/dev/null 2>&1 && validate_model_dispatch "$norm" >/dev/null 2>&1; then
        FINAL_MODEL="$norm"
        return 0
      fi
    fi
  fi

  # 6) ALLOWED_MODELS fallback
  if [ -n "${ALLOWED_MODELS:-}" ]; then
    cnt=0
    while IFS= read -r m || [ -n "$m" ]; do
      [ -z "$m" ] && continue
      cnt=$((cnt+1))

      norm="$(printf '%s' "$m" | sed -e 's#^models/##' -e 's#^groq[:/ -]*##')"

      if is_supported_model "$norm"; then
        if validate_model_core "$norm" >/dev/null 2>&1 && validate_model_dispatch "$norm" >/dev/null 2>&1; then
          FINAL_MODEL="$norm"
          return 0
        fi
      fi

      [ "$cnt" -ge "$MAX_MODELS" ] && break
    done <<EOF
$(printf '%s\n' "$ALLOWED_MODELS")
EOF
  fi

  FINAL_MODEL=""
  return 1
}

# ---------------------------------------------------------------------------
# Build payload from current vars (delegates to provider)
# ---------------------------------------------------------------------------
build_payload_from_vars() {
  ensure_run_tmpdir
  local fn="buildpayload_${PROVIDER}"
  local rc
  if call_provider "$fn"; then
    return 0
  else
    rc=$?
    if [ "$rc" -eq 127 ]; then
      log_error "PROVIDER" "Provider '$PROVIDER' does not provide $fn()."
      exit "$BASH4LLMERR_API"
    else
      return "$rc"
    fi
  fi
}

#--2<---[ SECTION: CORE_SETUP_API_CALL ]--->2--
# API call wrappers (non-streaming and streaming)
call_api_once() {
  local fn="call_api_${PROVIDER}"
  local rc
  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    if [ "${DEBUG:-0}" -eq 1 ]; then
      show_payload_head "$PAYLOAD" 200 || true
      log_info "DRYRUN" "DRY-RUN: skipping provider HTTP call"
    fi
    return 0
  fi
  if call_provider "$fn"; then
    return 0
  else
    rc=$?
    if [ "$rc" -eq 127 ]; then
      log_error "PROVIDER" "Provider '$PROVIDER' does not provide $fn()."
      exit "$BASH4LLMERR_API"
    else
      return "$rc"
    fi
  fi
}

call_api_streaming() {
  # Acquire the exclusive lock for the current session (if set)
  acquire_session_lock || return $?

  local fn="call_api_streaming_${PROVIDER}"
  local rc
  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    if [ "${DEBUG:-0}" -eq 1 ]; then
      show_payload_head "$PAYLOAD" 200 || true
      log_info "DRYRUN" "DRY-RUN: skipping provider streaming HTTP call"
    fi
    release_session_lock
    return 0
  fi
  if call_provider "$fn"; then
    release_session_lock
    return 0
  else
    rc=$?
    release_session_lock
    if [ "$rc" -eq 127 ]; then
      log_error "PROVIDER" "Provider '$PROVIDER' does not provide $fn()."
      exit "$BASH4LLMERR_API"
    else
      return "$rc"
    fi
  fi
}

extract_api_error() {
  [ ! -s "${RESP:-}" ] && return 0

  if jq -e . "$RESP" >/dev/null 2>&1; then
    # Prefer explicit error.message, then any non-empty choice content (first), else empty.
    jq -r '
      ( [ .error?.message // empty ] 
        + [ .choices[]? | (.message?.content // .delta?.content // empty) ] )
      | map(select(length > 0))
      | .[0] // empty
    ' "$RESP" 2>/dev/null | head -n1 || true
  else
    awk 'NF{print; exit}' "$RESP" 2>/dev/null || true
  fi
}

# detect_empty_edge_case: detects the empty completion edge case
# Does NOT print anything. If detected, sets diagnostic global variables:
#   BASH4LLM_EDGE_EMPTY=1
#   BASH4LLM_EDGE_REQ_ID, BASH4LLM_EDGE_FINISH_REASON, BASH4LLM_EDGE_COMPLETION_TOKENS
# Returns 0 if edge case is detected, 1 otherwise.
detect_empty_edge_case() {
  # Populate edge-case variables and set BASH4LLM_EDGE_EMPTY=1 when response is an "empty completion" edge.
  local resp="${RESP:-}"
  local tmp_copy content finish_reason completion_tokens req_id
  BASH4LLM_EDGE_EMPTY=0
  BASH4LLM_EDGE_REQ_ID=""
  BASH4LLM_EDGE_FINISH_REASON=""
  BASH4LLM_EDGE_COMPLETION_TOKENS=0

  # Always read from atomic copy
  tmp_copy="$(_tmpf file "${RUN_TMPDIR:-$BASH4LLM_TMPDIR}" resp_copy 2>/dev/null)" || return 1
  cp -f "$resp" "$tmp_copy" 2>/dev/null || return 1
  resp="$tmp_copy"

  if [ -z "${resp:-}" ] || [ ! -s "$resp" ]; then
    BASH4LLM_EDGE_EMPTY=1
    return 0
  fi

  if ! is_valid_json_file "$resp"; then
    BASH4LLM_EDGE_EMPTY=1
    return 0
  fi

  if jq -e 'has("diagnostic") and .diagnostic==true' "$resp" >/dev/null 2>&1; then
    BASH4LLM_EDGE_EMPTY=1
    return 0
  fi

  content="$(jq -r '.choices[0]?.message?.content // .choices[0]?.delta?.content // ""' "$resp" 2>/dev/null || echo "")"
  finish_reason="$(jq -r '.choices[0]?.finish_reason // ""' "$resp" 2>/dev/null || echo "")"
  completion_tokens="$(jq -r '.usage?.completion_tokens // 0' "$resp" 2>/dev/null || echo 0)"
  req_id="$(jq -r '.x_groq?.id // .id // empty' "$resp" 2>/dev/null || echo "")"

  BASH4LLM_EDGE_REQ_ID="${req_id:-}"
  BASH4LLM_EDGE_FINISH_REASON="${finish_reason:-}"
  BASH4LLM_EDGE_COMPLETION_TOKENS="${completion_tokens:-0}"

  if [ -z "$content" ] && [ "$finish_reason" = "stop" ] && [ "${completion_tokens:-0}" -ne 0 ] && [ "${completion_tokens:-0}" -le 1 ]; then
    BASH4LLM_EDGE_EMPTY=1
  else
    BASH4LLM_EDGE_EMPTY=0
  fi

  return 0
}
#--2<---[ /SECTION: CORE_SETUP_API_CALL ]--->2--

# ---------------------------------------------------------------------------
# Finalize and output
# ---------------------------------------------------------------------------
finalize_and_output() {
  local mode="${1:-}" text="${2:-}"
  local resp_file tmp_copy len do_save dest_dir dest_path

  # Always read from atomic copy of RESP
  resp_file="${RESP:-}"
  if [ -n "$resp_file" ]; then
    tmp_copy="$(_tmpf file "${RUN_TMPDIR:-$BASH4LLM_TMPDIR}" resp_copy 2>/dev/null)" || return "$BASH4LLMERR_TMP"
    cp -f "$resp_file" "$tmp_copy" 2>/dev/null || return "$BASH4LLMERR_TMP"
    resp_file="$tmp_copy"
  fi

  if { [ "$mode" = "json" ] || [ "$mode" = "pretty" ]; } && [ ! -s "$resp_file" ]; then
    log_error "RESP" "response file missing or empty: ${RESP:-<unset>}"
    return "$BASH4LLMERR_TMP"
  fi

  case "$mode" in
    json) cat "$resp_file" ;;
    pretty) if jq -e . "$resp_file" >/dev/null 2>&1; then jq . "$resp_file"; else cat "$resp_file"; fi ;;
    raw) printf '%s' "$text" ;;
    text) printf '%s\n' "$text" ;;
    *) printf '%s\n' "$text" ;;
  esac

  if [ "$mode" = "text" ] || [ "$mode" = "raw" ]; then
    [ "${FORCE_SAVE_MODE:-}" = "nosave" ] && return 0
    do_save=0
    len="$(printf '%s' "$text" | wc -c | tr -d ' ')"
    if [ "${FORCE_SAVE_MODE:-}" = "save" ]; then
      do_save=1
    else
      if [ "$len" -gt "$THRESHOLD" ]; then
        do_save=1
      fi
    fi
    if [ "$do_save" -eq 1 ]; then
      if [ -n "$OUT_PATH" ]; then
        if [ -d "$OUT_PATH" ]; then
          dest_dir="$OUT_PATH"
          dest_path="$dest_dir/$(date +%Y%m%d-%H%M%S)-groq-output-$$.txt"
        else
          dest_path="$OUT_PATH"
          dest_dir="$(dirname "$dest_path")"
        fi
      else
        dest_dir="$BASH4LLM_HISTORY_DIR"
        dest_path="$dest_dir/$(date +%Y%m%d-%H%M%S)-groq-output-$$.txt"
      fi
      safe_mkdir "$dest_dir" 700

      if [ -z "${RUN_TMPDIR:-}" ] || [ ! -d "$RUN_TMPDIR" ]; then
        log_error "TMP" "cannot create or access RUN_TMPDIR ($BASH4LLM_TMPDIR). Aborting."
        return "$BASH4LLMERR_TMP"
      fi

      tmp_save="$(_tmpf file "$RUN_TMPDIR" save.tmp 2>/dev/null)" || return "$BASH4LLMERR_TMP"
      printf '%s\n' "$text" > "$tmp_save" 2>/dev/null || { rm -f "$tmp_save" 2>/dev/null || true; return "$BASH4LLMERR_TMP"; }

      if type lock_exec >/dev/null 2>&1; then
        lock_exec "$HISTORY_LOCK" 10 -- mv -f "$tmp_save" "$dest_path" || { rm -f "$tmp_save" 2>/dev/null || true; return "$BASH4LLMERR_TMP"; }
      else
        mv -f "$tmp_save" "$dest_path" 2>/dev/null || { rm -f "$tmp_save" 2>/dev/null || true; return "$BASH4LLMERR_TMP"; }
      fi
      chmod 600 "$dest_path" 2>/dev/null || true
    fi
  fi
}

# ---------------------------------------------------------------------------
# Perform request with retries
# ---------------------------------------------------------------------------
perform_request_once() {
  # Acquire the exclusive lock for the current session (if set)
  acquire_session_lock || return $?

  local attempt=1 rc text api_err ui_last finish_reason req_id edgecase now_ts http_code_fallback api_json
  while [ "$attempt" -le "$MAX_RETRIES" ]; do
    if call_api_once; then
      if [ "${DRY_RUN:-0}" -eq 1 ]; then
        if [ "${DEBUG:-0}" -eq 1 ]; then
          log_info "DRYRUN" "DRY-RUN: request simulated successfully. Payload: $PAYLOAD"
        fi
        release_session_lock
        return 0
      fi

      # Reset diagnostic metrics before reading the API response
      BASH4LLM_EDGE_EMPTY=0
      BASH4LLM_EDGE_REQ_ID=""
      BASH4LLM_EDGE_FINISH_REASON=""
      BASH4LLM_EDGE_COMPLETION_TOKENS=0

      text="$(extract_text_from_resp || true)"

      # Perform edgecase detection on the response file immediately
      detect_empty_edge_case || true

      # Ensure last_api.json exists (fallback if provider didn't write it)
      ui_last="${BASH4LLM_CONFIG_DIR%/}/ui_state/last_api.json"
      if [ ! -f "$ui_last" ] || [ "$ui_last" -ot "${RESP:-/dev/null}" ]; then
        # Build fallback api_json from available globals
        finish_reason="$(jq -r '.choices[0]?.finish_reason // empty' "$RESP" 2>/dev/null || echo "")"
        req_id="$(jq -r '.x_groq?.id // .id // empty' "$RESP" 2>/dev/null || echo "")"
        edgecase=0
        if [ "${BASH4LLM_EDGE_EMPTY:-0}" -eq 1 ]; then edgecase=1; fi
        now_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
        http_code_fallback=0
        if [ -s "$RESP" ]; then http_code_fallback=200; fi
        api_json="$(jq -c -n --argjson http "$http_code_fallback" --arg fr "${finish_reason:-}" --argjson edge "$edgecase" --arg id "${req_id:-}" --arg ts "$now_ts" '{last_http_status:$http, last_finish_reason:$fr, last_edgecase_detected:$edge, last_req_id:$id, last_time_utc:$ts}')"
        ui_state_write "last_api.json" "$api_json" || { if [ "${DEBUG:-0}" -eq 1 ]; then log_warn "UI_STATE" "failed to write fallback last_api.json"; fi; }
      fi

      if [ -z "$text" ] && [ "$OUTPUT_MODE" != "json" ] && [ "$OUTPUT_MODE" != "pretty" ]; then
        api_err="$(extract_api_error || true)"
        if [ -n "$api_err" ]; then
          log_error "API" "API error: $api_err"
          release_session_lock
          return "$BASH4LLMERR_API"
        else
          # Output structured logs exactly once if empty completion edgecase is matched
          if [ "${BASH4LLM_EDGE_EMPTY:-0}" -eq 1 ]; then
            printf '%s\n' \
              "API edge case detected: empty completion" \
              "  req_id: ${BASH4LLM_EDGE_REQ_ID:-<none>}" \
              "  finish_reason: ${BASH4LLM_EDGE_FINISH_REASON:-<none>}" \
              "  completion_tokens: ${BASH4LLM_EDGE_COMPLETION_TOKENS:-0}" >&2

            log_error "API" "empty completion returned by provider (see previous diagnostic lines)."
            release_session_lock
            return "$BASH4LLMERR_API"
          fi

          # Generic fallback when response text is blank with no detailed API errors
          log_error "API" "no textual content extracted from response."
          if [ "${DEBUG:-0}" -eq 1 ]; then
            head -n 50 "${RESP:-/dev/null}" >&2 || true
          fi
          release_session_lock
          return "$BASH4LLMERR_API"
        fi
      fi
      # Ensure separation between JSON and assistant text
      if [ "$OUTPUT_MODE" = "text" ] || [ "$OUTPUT_MODE" = "raw" ]; then
        printf '\n'  # <-- newline separator
      fi

      finalize_and_output "$OUTPUT_MODE" "$text"
      release_session_lock
      return 0
    else
      rc=$?
      if [ "$rc" -eq "$BASH4LLMERR_CURL_FAILED" ]; then
        printf 'bash4llm: %sWARN%s: Network error (curl). Retrying...\n' "${C_YELLOW}" "${C_RST}" >&2
      elif [ "$rc" -eq "$BASH4LLMERR_API" ]; then
        printf 'bash4llm: %sERROR%s: HTTP/API error. Not retrying.\n' "${C_RED}" "${C_RST}" >&2
        if [ "${DEBUG:-0}" -eq 1 ]; then
          head -n 50 "${RESP:-/dev/null}" >&2 || true
        fi
        release_session_lock
        return "$BASH4LLMERR_API"
      else
        printf 'bash4llm: %sWARN%s: Unknown error (code %s). Retrying...\n' "${C_YELLOW}" "${C_RST}" "$rc" >&2
      fi
    fi

    attempt=$((attempt + 1)); sleep $((attempt * 1))
  done

  log_error "REQUEST" "request failed after $MAX_RETRIES attempts."
  release_session_lock
  return "$BASH4LLMERR_API"
}

#--3<---[ SECTION: CORE_SETUP_INPUT_HELPERS ]--->3--
# Input helpers
collect_input_from_files() {
  local out="" first=1 f
  for f in "$@"; do
    if file_readable "$f"; then
      [ "$first" -eq 0 ] && out="${out}"$'\n\n'"--- FILE: ${f} ---"$'\n\n'
      out="${out}$(cat "$f")"; first=0
    else log_error "FILE" "file not readable: $f"; exit "$BASH4LLMERR_TMP"; fi
  done
  printf '%s' "$out"
}
expand_args_to_content() {
  local out="" first=1 a
  for a in "${ARGS[@]}"; do
    if file_readable "$a"; then
      [ "$first" -eq 0 ] && out="${out}"$'\n\n'"--- FILE: ${a} ---"$'\n\n'
      out="${out}$(cat "$a")"; first=0
    else
      [ "$first" -eq 0 ] && out="${out}"$'\n\n'
      out="${out}${a}"; first=0
    fi
  done
  printf '%s' "$out"
}

file_readable() { [ -r "$1" ] && [ -f "$1" ]; }

trim() { printf '%s' "$1" | awk '{$1=$1; print}'; }

is_number() { printf '%s\n' "$1" | awk 'BEGIN{exit 0} {exit !( $0+0 == $0+0 )}'; }
#--3<---[ /SECTION: CORE_SETUP_INPUT_HELPERS ]--->3--

is_supported_model() {
  # Return 0 if model name appears to support text-only usage.
  # Reject models that clearly indicate image/audio/embedding/multimodal capabilities.
  local m="${1:-}" l
  [ -n "$m" ] || return 1
  l="$(printf '%s' "$m" | tr '[:upper:]' '[:lower:]')"

  # Patterns that indicate non-text capabilities
  case "$l" in
    *image*|*imagen*|*img*|*vision*|*vqa*|*vit*|*clip*|*render* ) return 1 ;;
    *audio*|*speech*|*tts*|*wav2vec*|*whisper* ) return 1 ;;
    *embed*|*embedding*|*vector* ) return 1 ;;
    *multimodal* ) return 1 ;;
    *) return 0 ;;
  esac
}

list_models_cli() {
  # Print MODELS_FILE entries in a provider-agnostic way.
  # Normalize entries (strip leading "models/") and mark non-text models.
  if [ ! -s "${MODELS_FILE:-}" ]; then
    printf 'No models available locally. Consider --refresh-models.\n' >&2
    return 1
  fi

  local count=0 model norm
  while IFS= read -r model || [ -n "$model" ]; do
    [ -z "$model" ] && continue
    count=$((count+1))
    norm="$(printf '%s' "$model" | sed -e 's/^models\///' -e 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    if is_supported_model "$norm"; then
      printf '%s\n' "$norm"
    else
      printf '%s\t[%sNOT SUPPORTED%s: Requires non-text input]\n' "$norm" "${C_RED}" "${C_RST}"
    fi
    if [ "$count" -ge "$MAX_MODELS" ]; then break; fi
  done < "$MODELS_FILE"
  return 0
}

validate_model_core() {
  # Validate a model name against local MODELS_FILE (if present) and textual support.
  # Accepts exact matches or matches after stripping common provider prefixes like "models/".
  local model="${1:-}" norm_model file_match
  [ -n "$model" ] || { printf 'bash4llm: %sERROR%s: validate_model_core: model required\n' "${C_RED}" "${C_RST}" >&2; return 1; }

  # Normalize incoming model for comparison
  norm_model="$(printf '%s' "$model" | sed -e 's#^models/##' -e 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  norm_model="$(printf '%s' "$norm_model" | sed -e 's#^groq[:/ -]*##')"

  # If MODELS_FILE exists and non-empty, require presence
  if [ -f "${MODELS_FILE:-}" ] && [ -s "${MODELS_FILE:-}" ]; then
    # Check exact match first
    if grep -x -F -q "$model" "$MODELS_FILE" 2>/dev/null; then
      file_match=1
    else
      # Check normalized match (strip leading models/ and groq prefixes in file entries and compare)
      if awk '{g=$0; sub(/^models\//,"",g); sub(/^groq[:\/ -]*/,"",g); print g}' "$MODELS_FILE" \
           | grep -x -F -q "$norm_model" 2>/dev/null; then
        file_match=1
      else
        file_match=0
      fi
    fi

    if [ "$file_match" -ne 1 ]; then
      printf 'bash4llm: %sERROR%s: The model "%s" is not present in %s\n' "${C_RED}" "${C_RST}" "$model" "$MODELS_FILE" >&2
      return 1
    fi
  fi

  # Check textual support
  if ! is_supported_model "$norm_model"; then
    printf 'bash4llm: %sERROR%s: The "%s" model is not supported by %s (requires non-text input).\n' "${C_RED}" "${C_RST}" "$model" "${C_GBOLD}Bash4LLM⁺${C_RST}" >&2
    return 1
  fi

  return 0
}

# ---------------------------------------------------------------------------
# Configuration and Whitelist Helpers (placed before execution logic)
# ---------------------------------------------------------------------------
load_local_config() {
  local cfg="${BASH4LLM_CONFIG_DIR%/}/config" key val line
  [ -f "$cfg" ] || return 0
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in ''|\#*) continue ;; esac
    key="${line%%=*}"
    val="${line#*=}"
    case "$key" in
      MODEL) [ -n "$val" ] && MODEL="$val" ;;
      TEMPERATURE|TURE) [ -n "$val" ] && TURE="$val" ;;
      MAX_TOKENS) [ -n "$val" ] && MAX_TOKENS="$val" ;;
      FORMAT) [ -n "$val" ] && OUTPUT_MODE="$val" ;;
      THRESHOLD) [ -n "$val" ] && THRESHOLD="$val" ;;
    esac
  done < "$cfg"
}

load_whitelist() {
  ALLOWED_MODELS=""
  if [ -f "$MODELS_FILE" ] && [ -s "$MODELS_FILE" ]; then
    ALLOWED_MODELS="$(awk '{ gsub(/^models\//,""); sub(/^[[:space:]]+/,""); sub(/[[:space:]]+$/,""); if (NF) print }' "$MODELS_FILE" 2>/dev/null || true)"
  fi
}

is_tty_out() {
  [ -t 1 ]
}

# ---------------------------------------------------------------------------
# Sourcing Guard: Stop here if sourced to load functions only.
# This prevents executing any folder creations, CLI parsing, or exit commands.
# ---------------------------------------------------------------------------
if [ "${BASH4LLM_SOURCE_ONLY:-0}" -eq 1 ]; then
  return 0 2>/dev/null || exit 0
fi

#--4<---[ SECTION: CORE_SETUP_CLI_PARSE ]--->4--
# CLI parsing (flags, normalization, immediate actions)
# ---------------------------------------------------------------------------
JSON_INPUT="${JSON_INPUT:-}" TEMPLATE="${TEMPLATE:-}" BATCH_FILE="${BATCH_FILE:-}" CHAT_MODE="${CHAT_MODE:-0}" SET_DEFAULT_MODEL="${SET_DEFAULT_MODEL:-}"
LIST_MODELS="${LIST_MODELS:-0}" LIST_PROVIDERS="${LIST_PROVIDERS:-0}" FORCE_SAVE_MODE="${FORCE_SAVE_MODE:-}" OUT_PATH="${OUT_PATH:-}"
DRY_RUN="${DRY_RUN:-0}" STREAM_MODE="${STREAM_MODE:-0}" OUTPUT_MODE="${OUTPUT_MODE:-text}" THRESHOLD="${THRESHOLD:-1000}"
INSTALL_EXTRAS="${INSTALL_EXTRAS:-0}" DEBUG="${DEBUG:-0}" QUIET="${QUIET:-0}"
PROVIDER_CLI="${PROVIDER_CLI:-}" PROVIDER_INTERACTIVE="${PROVIDER_INTERACTIVE:-0}"
SHOW_CONFIG="${SHOW_CONFIG:-0}" DIAGNOSTICS="${DIAGNOSTICS:-0}"
FILE_INPUTS=() ARGS=() OUTPUT_MODE="${OUTPUT_MODE:-text}"
MODEL_CLI_SET="${MODEL_CLI_SET:-0}"
INSTALL_EXTRAS_SRC=""
BOOTSTRAP_ONLY="${BOOTSTRAP_ONLY:-0}"

while [ $# -gt 0 ]; do
  case "$1" in
    --refresh-models|--refresh-model) REFRESH_MODELS=1; shift ;;
    --list-models) LIST_MODELS=1; shift ;;
    --list-providers) LIST_PROVIDERS=1; shift ;;
    --list-providers-raw) LIST_PROVIDERS_RAW=1; shift ;;
    --list-models-raw) LIST_MODELS_RAW=1; shift ;;
    --set-default)
      check_required_arg "--set-default" "$#"
      SET_DEFAULT_MODEL="$2"
      shift 2
      ;;
    -m|--model)
      check_required_arg "--model" "$#"
      MODEL="$2"
      MODEL_CLI_SET=1
      shift 2
      ;;
    -f)
      check_required_arg "-f" "$#"
      FILE_INPUTS+=("$2")
      shift 2
      ;;
    --json-input)
      check_required_arg "--json-input" "$#"
      JSON_INPUT="$2"
      shift 2
      ;;
    --template)
      check_required_arg "--template" "$#"
      TEMPLATE="$2"
      shift 2
      ;;
    --batch)
      check_required_arg "--batch" "$#"
      BATCH_FILE="$2"
      shift 2
      ;;
    --session)
      check_required_arg "--session" "$#"
      SESSION_ID="$2"
      if [ "${SESSION_ID:0:1}" = "-" ]; then
        log_error "ARGS" "--session requires a valid session ID argument"
        exit "$BASH4LLMERR_TMP"
      fi
      shift 2
      ;;
    --session-window)
      if [ "$#" -ge 2 ] && [ -n "${2:-}" ] && [ "${2:0:1}" != "-" ]; then
        SESSION_WINDOW="$2"
        shift 2
      else
        SESSION_WINDOW="10"
        shift
      fi
      ;;
    --system)
      check_required_arg "--system" "$#"
      SYSTEM_PROMPT="$2"
      shift 2
      ;;
    --ture|--temperature)
      check_required_arg "--temperature" "$#"
      TURE="$2"
      shift 2
      ;;
    --max)
      check_required_arg "--max" "$#"
      MAX_TOKENS="$2"
      shift 2
      ;;
    --debug) DEBUG=1; shift ;;
    --save) FORCE_SAVE_MODE="save"; shift ;;
    --nosave) FORCE_SAVE_MODE="nosave"; shift ;;
    --out)
      check_required_arg "--out" "$#"
      OUT_PATH="$2"
      shift 2
      ;;
    --threshold)
      check_required_arg "--threshold" "$#"
      THRESHOLD="$2"
      shift 2
      ;;
    --dry-run) DRY_RUN=1; shift ;;
    --quiet) QUIET=1; shift ;;
    --stream) STREAM_MODE=1; shift ;;
    --no-stream) STREAM_MODE=0; shift ;;
    --json) OUTPUT_MODE="json"; shift ;;
    --pretty) OUTPUT_MODE="pretty"; shift ;;
    --text) OUTPUT_MODE="text"; shift ;;
    --raw) OUTPUT_MODE="raw"; shift ;;
    --chat) CHAT_MODE=1; shift ;;
    --show-config) SHOW_CONFIG=1; shift ;;
    --diagnostics) DIAGNOSTICS=1; shift ;;
    --provider)
      if [ "$#" -ge 2 ] && [ -n "${2:-}" ] && [ "${2:0:1}" != "-" ]; then
        PROVIDER_CLI="$2"
        shift 2
      else
        PROVIDER_INTERACTIVE=1
        shift
      fi
      ;;
    --install-extras)
      INSTALL_EXTRAS=1
      if [ $# -gt 1 ] && [ "${2:0:1}" != "-" ]; then
        INSTALL_EXTRAS_SRC="$2"
        shift
      fi
      shift
      ;;
    --install-extras=*)
      INSTALL_EXTRAS=1
      INSTALL_EXTRAS_SRC="${1#--install-extras=}"
      shift
      ;;
    --version) printf '%s %s (%s)\n' "$SCRIPT_NAME" "$SCRIPT_VERSION" "$SCRIPT_DATE"; exit 0 ;;
    -h|--help)
      help_file="$BASH4LLM_EXTRAS_DIR/docs/help.txt"
      if [ -f "$help_file" ]; then
        # If colors are not active, show the normal file
        if [ -z "${C_TITLE:-}" ]; then
          cat "$help_file"
        else
          # Colorize on the fly in a portable way (works on both macOS and Linux)
          sed \
            -e "s/^\([A-Za-z]\{2,\}:\)/${C_TITLE}\1${C_RST}/" \
            -e "s/\(--[a-zA-Z0-9-][a-zA-Z0-9-]*\)/${C_CMD}\1${C_RST}/g" \
            -e "s/\([[:blank:],]\)\(-[a-zA-Z0-9]\)/\1${C_CMD}\2${C_RST}/g" \
            -e "s/\(<[a-zA-Z0-9_]\{1,\}>\)/${C_ARG}\1${C_RST}/g" \
            "$help_file"
        fi
      else
        printf 'Help file not found: %s\n' "$help_file" >&2
      fi
      exit 0 ;;
    --bootstrap-only)
      BOOTSTRAP_ONLY=1
      shift
      ;;
    --) shift; break ;;
    -*) printf 'bash4llm: %sERROR%s: Unknown option: %s\n' "${C_RED}" "${C_RST}" "$1" >&2; exit "$BASH4LLMERR_TMP" ;;
    *) ARGS+=("$1"); shift ;;
  esac
done
#--4<---[ /SECTION: CORE_SETUP_CLI_PARSE ]--->4--
#--5<---[ SECTION: CORE_SETUP_SESSION_ENGINE ]--->5--
# Session Engine: safe sourcing and robust fallback
# ---------------------------------------------------------------------------
# Note: Its integrated architecture will still use session_lock
# to protect the message database between concurrent instances.
SE_ENGINE_PATH="${BASH4LLM_EXTRAS_DIR}/session/session-engine.sh"
SE_AVAILABLE=0
if [ -f "$SE_ENGINE_PATH" ] && [ "${BASH4LLM_SESSION_ENGINE:-on}" != "off" ]; then
  if bash -n "$SE_ENGINE_PATH" 2>/dev/null; then
    . "$SE_ENGINE_PATH"
    if type session_engine_build_window >/dev/null 2>&1 && type session_engine_append >/dev/null 2>&1 && type session_engine_enabled >/dev/null 2>&1; then
      if session_engine_enabled 2>/dev/null; then
        SE_AVAILABLE=1
        if [ "${DEBUG:-0}" -eq 1 ]; then
          log_info "SESSION" "Session Engine loaded and available"
        fi
      else
        SE_AVAILABLE=0
        if [ "${DEBUG:-0}" -eq 1 ]; then
          log_info "SESSION" "Session Engine loaded but disabled by module"
        fi
      fi
    else
      SE_AVAILABLE=0
      log_warn "SESSION" "Session Engine module missing required functions; falling back to legacy"
    fi
  else
    SE_AVAILABLE=0
    log_warn "SESSION" "Session Engine module has syntax errors; falling back to legacy"
  fi
else
  SE_AVAILABLE=0
  if [ -n "${SESSION_ID:-}" ]; then
    if [ "${DEBUG:-0}" -eq 1 ]; then
      log_info "SESSION" "Session Engine not available; using legacy session helpers"
    fi
  fi
fi
#--5<---[ /SECTION: CORE_SETUP_SESSION_ENGINE ]--->5--

#--6<---[ SECTION: CORE_SETUP_NORM_FLAGS ]--->6--
# Guard: prevent accidental real API calls (ALLOW_API_CALLS defaults to 1)
# ---------------------------------------------------------------------------
: "${ALLOW_API_CALLS:=1}"
if [ -n "${GROQ_API_KEY:-}" ] && ! is_truthy "${ALLOW_API_CALLS:-0}" && ! is_truthy "${DRY_RUN:-0}"; then
  log_error "APIKEY" "GROQ_API_KEY is set but ALLOW_API_CALLS!=1 and DRY_RUN!=1."
  exit "$BASH4LLMERR_TMP"
fi

# Rebuild supported providers array (machine-readable source of truth)
_supported_providers_arr=()
_supported_providers_arr+=("groq")
# Resolve extras providers dir
extras_prov_dir="${PROVIDERS_DIR:-${BASH4LLM_EXTRAS_DIR}/providers}"
if [ -z "${extras_prov_dir:-}" ]; then
  extras_prov_dir="$(canonical_config_dir)/providers"
fi
if [ -d "$extras_prov_dir" ]; then
  for pf in "$extras_prov_dir"/*.sh; do
    [ -e "$pf" ] || continue
    base="$(basename "$pf" .sh)"
    [ "$base" = "groq" ] && continue
    _supported_providers_arr+=("$base")
  done
fi
SUPPORTED_PROVIDERS="$(printf '%s ' "${_supported_providers_arr[@]}" | sed 's/ $//')"

# Non-interactive machine-readable provider listing
if [ "${LIST_PROVIDERS_RAW:-0}" -eq 1 ]; then
  if [ "${#_supported_providers_arr[@]}" -eq 0 ]; then
    exit 1
  fi
  for p in "${_supported_providers_arr[@]}"; do
    printf '%s\n' "$p"
  done
  exit 0
fi

# Non-interactive machine-readable models listing
if [ "${LIST_MODELS_RAW:-0}" -eq 1 ]; then
  if [ -n "${PROVIDER_CLI:-}" ]; then
    PROVIDER="${PROVIDER_CLI}"
  fi

  if [ -f "${MODELS_FILE:-}" ] && [ -s "${MODELS_FILE:-}" ]; then
    awk '{
      g=$0
      sub(/^models\//,"",g)
      sub(/^groq[:\/ -]*/,"",g)
      sub(/^[[:space:]]+/,"",g)
      sub(/[[:space:]]+$/,"",g)
      if (g != "") print g
    }' "$MODELS_FILE"
    exit 0
  else
    exit 2
  fi
fi
#--6<---[ /SECTION: CORE_SETUP_NORM_FLAGS ]--->6--

#--7<---[ SECTION: CORE_SETUP_ACTIONS ]--->7--
# Immediate actions: list providers/models, set-default, install-extras
if [ "$LIST_PROVIDERS" -eq 1 ]; then
  printf 'Available providers:\n' >&2
  printf '  - groq (embedded)\n' >&2
  extras_prov_dir="$PROVIDERS_DIR"
  if [ -d "$extras_prov_dir" ]; then
    for f in "$extras_prov_dir"/*.sh; do
      [ -e "$f" ] || continue
      base="$(basename "$f" .sh)"
      [ "$base" = "groq" ] && continue
      printf '  - %s\n' "$base" >&2
    done
  fi
  exit 0
fi

if [ "$LIST_MODELS" -eq 1 ]; then
  if list_models_cli; then exit 0; else exit "$BASH4LLMERR_TMP"; fi
fi

if [ -n "$SET_DEFAULT_MODEL" ]; then
  safe_mkdir "$(canonical_config_dir)" 700

  # Detect correct provider before saving model preference
  if [ -n "${PROVIDER_CLI:-}" ]; then
    target_provider="${PROVIDER_CLI}"
  elif [ -f "$(canonical_provider_file)" ] && [ -s "$(canonical_provider_file)" ]; then
    target_provider="$(sed -n '1p' "$(canonical_provider_file)" 2>/dev/null || true)"
    target_provider="$(printf '%s' "$target_provider" | awk '{$1=$1;print}')"
    [ -z "$target_provider" ] && target_provider="groq"
  else
    target_provider="groq"
  fi

  target_model_file="$(canonical_model_file "${target_provider}")"
  if ! printf '%s\n' "$SET_DEFAULT_MODEL" | atomic_write "$target_model_file" 10; then
    log_error "MODEL" "cannot persist default model to $target_model_file"
    exit "$BASH4LLMERR_TMP"
  fi
  chmod 600 "$target_model_file" 2>/dev/null || true
  # Refreshed output utilizing user info logging
  log_info_user "MODEL" "default model for $target_provider set to: $SET_DEFAULT_MODEL"
  exit 0
fi

if [ "$INSTALL_EXTRAS" -eq 1 ] || [ "${INSTALL_EXTRAS:-0}" -eq 1 ]; then
  # 1. Identify the source (CLI or legacy fallback) and canonical destination
  SRC_DIR="${INSTALL_EXTRAS_SRC:-$LEGACY_EXTRAS_DIR}"
  DEST_DIR="${CANONICAL_EXTRAS_DIR}"

  SRC_BASE=""
  DEST_BASE=""

  # 2. Canonical resolution (real absolute paths to avoid bypass or self-copy)
  if [ -d "$SRC_DIR" ]; then
    SRC_BASE="$(cd "$SRC_DIR" >/dev/null 2>&1 && pwd || true)"
  fi

  safe_mkdir "$(dirname "$DEST_DIR")" 700

  if [ -d "$DEST_DIR" ]; then
    DEST_BASE="$(cd "$DEST_DIR" >/dev/null 2>&1 && pwd || true)"
  else
    PARENT_DEST="$(cd "$(dirname "$DEST_DIR")" >/dev/null 2>&1 && pwd || true)"
    if [ -n "$PARENT_DEST" ]; then
      DEST_BASE="${PARENT_DEST%/}/extras"
    fi
  fi

  # 3. Source validation
  if [ -z "$SRC_BASE" ] || [ ! -d "$SRC_BASE" ]; then
    log_error "EXTRAS" "Source directory does not exist or is invalid: ${SRC_DIR}"
    exit "$BASH4LLMERR_TMP"
  fi

  # 4. Security check against recursive overwrite
  if [ "$SRC_BASE" = "$DEST_BASE" ]; then
    log_error "EXTRAS" "Install source and destination cannot match: ${SRC_BASE}"
    exit "$BASH4LLMERR_TMP"
  fi

  # Refreshed output utilizing user info logging
  log_info_user "EXTRAS" "Sincronizzazione extras da ${SRC_BASE} a ${DEST_BASE}..."

  # 5. Safe creation of the destination with restrictive permissions (700)
  safe_mkdir "$DEST_BASE" 700

  # 6. Recursive copy preserving structure in a portable way (using /.)
  if cp -R "$SRC_BASE/." "$DEST_BASE/" 2>/dev/null; then
    # Apply restrictive permissions required by the architecture (700 folders, 600 files)
    find "$DEST_BASE" -type d -exec chmod 700 {} + 2>/dev/null || true
    find "$DEST_BASE" -type f -exec chmod 600 {} + 2>/dev/null || true
    # Refreshed output utilizing user info logging
    log_info_user "EXTRAS" "Installation successfully completed."
  else
    log_error "EXTRAS" "Error copying extras files."
    exit "$BASH4LLMERR_TMP"
  fi
  exit 0
fi

# Normalize boolean-like flags
for flag in DRY_RUN STREAM_MODE INSTALL_EXTRAS PROVIDER_INTERACTIVE LIST_MODELS LIST_PROVIDERS CHAT_MODE QUIET SHOW_CONFIG DIAGNOSTICS; do
  if is_truthy "${!flag:-0}"; then printf -v "$flag" 1; else printf -v "$flag" 0; fi
done
