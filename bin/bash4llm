#--1<---[ SECTION: PRECORE_BOOT_SETUP_SHELL ]--->1--
# Only set strict shell options if executed directly,
# preventing pollution of the calling interactive shell when sourced.
if [ "${BASH_SOURCE[0]}" = "$0" ]; then
  set -euo pipefail
fi

SCRIPT_NAME="bash4llm"
SCRIPT_VERSION="2.1.0"
SCRIPT_DATE="2026-06-24"

# Initialize color variables to prevent set -u (nounset) errors if referenced early
C_TITLE="" C_CMD="" C_ARG="" C_RST="" C_GREEN="" C_GBOLD="" C_RED="" C_YELLOW="" C_BLUE="" C_CYAN="" C_BOLD="" C_LOGO=""

# ---------------------------------------------------------------------------
# Canonical error codes
# ---------------------------------------------------------------------------
BASH4LLM_ERR_NO_API_KEY=10
BASH4LLM_ERR_BAD_MODEL=11
BASH4LLM_ERR_CURL_FAILED=12
BASH4LLM_ERR_NO_PROMPT=14
BASH4LLM_ERR_TMP=15
BASH4LLM_ERR_API=16

# Legacy aliases mapped with consistent underscore notation
BASH4LLMERR_NO_API_KEY=$BASH4LLM_ERR_NO_API_KEY
BASH4LLMERR_BAD_MODEL=$BASH4LLM_ERR_BAD_MODEL
BASH4LLMERR_CURL_FAILED=$BASH4LLM_ERR_CURL_FAILED
BASH4LLMERR_NO_PROMPT=$BASH4LLM_ERR_NO_PROMPT
BASH4LLMERR_TMP=$BASH4LLM_ERR_TMP
BASH4LLMERR_API=$BASH4LLM_ERR_API
#--1<---[ /SECTION: PRECORE_BOOT_SETUP_SHELL ]--->1--
#--2<---[ SECTION: PRECORE_BOOT_SETUP_ENV_CMDS ]--->2--
# ---------------------------------------------------------------------------
# Verify mandatory commands (flock is excluded to allow macOS fallback)
# ---------------------------------------------------------------------------
for cmd in bash jq curl mktemp stat base64 find awk sed grep xargs tr sort head wc tee date mv chmod cp rm printf comm; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    printf 'bash4llm: %sERROR%s: required command not found: %s\n' "${C_RED}" "${C_RST}" "$cmd" >&2
    exit 1
  fi
done
#--2<---[ /SECTION: PRECORE_BOOT_SETUP_ENV_CMDS ]--->2--
#--3<---[ SECTION: PRECORE_BOOT_EARLY_HELPERS ]--->3--
# Early Helpers 
resolve_script_dir() {
  local src="${BASH_SOURCE[0]}" rl dir
  if command -v readlink >/dev/null 2>&1 && [ -L "$src" ]; then
    rl="$(readlink "$src" 2>/dev/null || true)"
    [ -n "$rl" ] && case "$rl" in /*) src="$rl" ;; *) src="$(dirname "$src")/$rl" ;; esac
  fi
  dir="$(cd "$(dirname "$src")" >/dev/null 2>&1 && pwd || printf '%s' "$(dirname "$src")")"
  printf '%s' "$dir"
}

# Create directory safely with strict permissions, ensuring it is not a symlink.
safe_mkdir() {
  local dir="${1:-}"
  local perm="${2:-700}"
  if [ -z "$dir" ]; then
    return 1
  fi
  if [ -L "$dir" ]; then
    printf 'bash4llm: %sERROR%s: directory is a symlink: %s\n' "${C_RED:-}" "${C_RST:-}" "$dir" >&2
    if [ "${BASH_SOURCE[0]}" = "$0" ]; then
      exit "${BASH4LLM_ERR_TMP:-15}"
    else
      return "${BASH4LLM_ERR_TMP:-15}"
    fi
  fi
  if [ ! -d "$dir" ]; then
    mkdir -p "$dir" 2>/dev/null || {
      printf 'bash4llm: %sERROR%s: cannot create directory: %s\n' "${C_RED:-}" "${C_RST:-}" "$dir" >&2
      if [ "${BASH_SOURCE[0]}" = "$0" ]; then
        exit "${BASH4LLM_ERR_TMP:-15}"
      else
        return "${BASH4LLM_ERR_TMP:-15}"
      fi
    }
  fi
  chmod "$perm" "$dir" 2>/dev/null || true
}

# Helper to validate options requiring an argument (shift boundary check)
check_required_arg() {
  local option="${1:-}"
  local count="${2:-0}"
  if [ "$count" -lt 2 ]; then
    log_error "ARGS" "Option $option requires an argument"
    exit "${BASH4LLMERR_TMP:-15}"
  fi
}

# Return canonical config dir (no trailing slash)
canonical_config_dir() {
  printf '%s' "${BASH4LLM_CONFIG_DIR%/}"
}

# Return canonical provider file path
canonical_provider_file() {
  printf '%s\n' "$(canonical_config_dir)/provider"
}

# Return canonical model file path for a provider argument
canonical_model_file() {
  local prov="${1:-}"
  printf '%s\n' "$(canonical_config_dir)/model.${prov}"
}

# Minimal provider-url helpers (embedded groq fallback)
# Returns canonical provider-url file path: <config_dir>/provider-url
canonical_provider_url_file() {
  local cfgdir
  # prefer canonical_config_dir() if present
  if type canonical_config_dir >/dev/null 2>&1; then
    cfgdir="$(canonical_config_dir)"
  else
    cfgdir="${BASH4LLM_CONFIG_DIR:-${BASH4LLM_DIR%/}/config}"
  fi
  printf '%s' "${cfgdir%/}/provider-url"
}

#--3<---[ SUBSECTION: API_NET ]--->3--
# ensure_api_key_for_provider (robust, non-interactive safe)
# - Ensures that the API key for the provider is present.
# - In non-interactive mode (stdin is not a TTY), it does not prompt: it exits with an error code.
# - In interactive mode, it prompts as before.
# - Syncs GROQ_API_KEY for backward compatibility.
# ---------------------------------------------------------------------------
ensure_api_key_for_provider() {
  local prov="${1:-}"
  local envvar current_key input_key custom_var custom_env
  [ -n "$prov" ] || return 1
  envvar="$(provider_api_env_var_name "$prov")"
  custom_var="PROVIDER_API_ENV_${prov}"
  custom_env="${!custom_var:-}"
  if [ -n "$custom_env" ]; then
    envvar="$custom_env"
  fi
  current_key="${!envvar:-}"

  # If key present, sync groq alias and return
  if [ -n "$current_key" ]; then
    if [ "$prov" = "groq" ] && [ "$envvar" != "GROQ_API_KEY" ]; then
      export GROQ_API_KEY="$current_key"
    fi
    return 0
  fi

  # Non-interactive: fail fast with clear error (do not prompt)
  if [ ! -t 0 ]; then
    printf 'bash4llm: %sERROR%s: missing API key for provider %s (env %s) in non-interactive mode\n' "${C_RED}" "${C_RST}" "$prov" "$envvar" >&2
    return "$BASH4LLMERR_NO_API_KEY"
  fi

  # Interactive prompt (preserve previous behavior)
  printf 'Enter API key for provider %s (env %s): ' "$prov" "$envvar" >&2
  if ! IFS= read -r input_key; then
    printf '\nbash4llm: %sERROR%s: no input received. Aborting.\n' "${C_RED}" "${C_RST}" >&2
    return "$BASH4LLMERR_NO_API_KEY"
  fi

  # Normalize input: strip CR/LF, leading "export ", and VAR=VALUE forms
  input_key="$(printf '%s' "$input_key" | tr -d '\r\n')"
  input_key="$(printf '%s' "$input_key" | sed -E 's/^[[:space:]]*export[[:space:]]+//I')"
  if printf '%s' "$input_key" | grep -qE '^[A-Za-z_][A-Za-z0-9_]*='; then
    input_key="$(printf '%s' "$input_key" | sed -E 's/^[A-Za-z_][A-Za-z0-9_]*=[\"\x27]?([^\"\x27]*).*$/\1/')"
  fi

  if [ -z "$input_key" ]; then
    printf 'bash4llm: %sERROR%s: API key required. Aborting.\n' "${C_RED}" "${C_RST}" >&2
    return "$BASH4LLMERR_NO_API_KEY"
  fi

  export "$envvar"="$input_key"
  if [ "$prov" = "groq" ] && [ "$envvar" != "GROQ_API_KEY" ]; then
    export GROQ_API_KEY="$input_key"
  fi

  printf '%b' "
${C_TITLE}----------------------------------------${C_RST}

To avoid re-entering the key for subsequent invocations, run this in your shell:

  ${C_CMD}export ${envvar}=\"${input_key}\"${C_RST}

You can add that line to your shell profile (e.g., ${C_ARG}~/.bashrc${C_RST} or ${C_ARG}~/.profile${C_RST}) to persist it across sessions.

${C_TITLE}----------------------------------------${C_RST}

" >&2

  return 0
}

# ---------------------------------------------------------------------------
# enforce_network_policy
# - Central check to prevent any HTTP call when DRY_RUN or BASH4LLM_SKIP_NETWORK set.
# - Should be invoked at the start of any provider call_api_* function.
# - Returns 0 if network allowed, non-zero otherwise.
# ---------------------------------------------------------------------------
enforce_network_policy() {
  # If DRY_RUN or BASH4LLM_SKIP_NETWORK are truthy, disallow network.
  if is_truthy "${DRY_RUN:-0}" || is_truthy "${BASH4LLM_SKIP_NETWORK:-0}"; then
    if [ "${DEBUG:-0}" -eq 1 ]; then
      log_info "NETWORK" "Network calls disabled by DRY_RUN or BASH4LLM_SKIP_NETWORK; skipping HTTP."
    fi
    return 1
  fi

  # QUIET does not disable network by itself, but if QUIET is used with a policy variable we enforce it.
  if is_truthy "${BASH4LLM_ENFORCE_NO_NETWORK_IF_QUIET:-0}" && is_truthy "${QUIET:-0}"; then
    if [ "${DEBUG:-0}" -eq 1 ]; then
      log_info "NETWORK" "Network calls disabled due to QUIET policy."
    fi
    return 1
  fi

  return 0
}

# ---------------------------------------------------------------------------
# acquire_session_lock & release_session_lock
# - Centralized mechanism to prevent parallel/concurrent requests on the same session.
# - Safe on macOS/Linux. Supports automatic stale lock protection.
# ---------------------------------------------------------------------------
acquire_session_lock() {
  local sid="${SESSION_ID:-}"
  # If no active session, instances are isolated and secure by default
  [ -n "$sid" ] || return 0

  local session_file="${SESSION_DIR:-${BASH4LLM_HISTORY_DIR:-.}/sessions}/${sid}.ndjson"
  local lockfile="${session_file}.concurrency.lock"
  local lockdir="${lockfile}dir"

  if [ "${DRY_RUN:-0}" -eq 1 ] || [ "${BASH4LLM_SKIP_NETWORK:-0}" -eq 1 ]; then
    return 0
  fi

  if command -v flock >/dev/null 2>&1 && [ -z "${TERMUX_VERSION:-}" ]; then
    # Opens File Descriptor 8 on the session-specific lock file
    exec 8>"$lockfile"
    if ! flock -x -n 8; then
      log_error "SESSION" "Session '$sid' is already active in another instance of Bash4LLM."
      return 15
    fi
  else
    # POSIX fallback for systems without flock
    if ! mkdir "$lockdir" 2>/dev/null; then
      if [ -f "$lockdir/pid" ]; then
        local lp
        lp="$(cat "$lockdir/pid" 2>/dev/null || true)"
        if [ -n "$lp" ] && ! kill -0 "$lp" 2>/dev/null; then
          # The original process is dead; safely remove obsolete lock
          rm -rf "$lockdir" 2>/dev/null || true
          mkdir "$lockdir" 2>/dev/null || {
            log_error "SESSION" "Session '$sid' is already active in another instance of Bash4LLM."
            return 15
          }
        else
          log_error "SESSION" "Session '$sid' is already active in another instance of Bash4LLM."
          return 15
        fi
      else
        log_error "SESSION" "Session '$sid' is already active in another instance of Bash4LLM."
        return 15
      fi
    fi
    # Write current PID to lock directory to allow stale lock verification
    printf '%s\n' "$$" > "$lockdir/pid" 2>/dev/null || true
  fi
  return 0
}

release_session_lock() {
  local sid="${SESSION_ID:-}"
  [ -n "$sid" ] || return 0

  local session_file="${SESSION_DIR:-${BASH4LLM_HISTORY_DIR:-.}/sessions}/${sid}.ndjson"
  local lockfile="${session_file}.concurrency.lock"
  local lockdir="${lockfile}dir"

  if command -v flock >/dev/null 2>&1 && [ -z "${TERMUX_VERSION:-}" ]; then
    exec 8>&- 2>/dev/null || true
  else
    rm -rf "$lockdir" 2>/dev/null || true
  fi
}
#--3<---[ /SUBSECTION: API_NET ]--->3--
# Structured logging (activatable via DEBUG or BASH4LLM_LOG)
DEBUG="${DEBUG:-0}"
BASH4LLM_LOG="${BASH4LLM_LOG:-}" # optional path to append structured logs

log_prefix() { printf '%s: ' "$SCRIPT_NAME"; }

log_info() {
  local code="${1:-INFO}" msg="${2:-}"
  if [ "${DEBUG:-0}" -eq 1 ]; then
    printf '%s%sINFO%s: %s: %s\n' "$(log_prefix)" "${C_GREEN}" "${C_RST}" "$code" "$msg" >&2
  fi
  if [ -n "$BASH4LLM_LOG" ]; then printf '%s INFO %s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$code" "$msg" >>"$BASH4LLM_LOG" 2>/dev/null || true; fi
}

log_warn() {
  local code="${1:-WARN}" msg="${2:-}"
  printf '%s%sWARN%s: %s: %s\n' "$(log_prefix)" "${C_YELLOW}" "${C_RST}" "$code" "$msg" >&2
  if [ -n "$BASH4LLM_LOG" ]; then printf '%s WARN %s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$code" "$msg" >>"$BASH4LLM_LOG" 2>/dev/null || true; fi
}

log_error() {
  local code="${1:-ERROR}" msg="${2:-}"
  printf '%s%sERROR%s: %s: %s\n' "$(log_prefix)" "${C_RED}" "${C_RST}" "$code" "$msg" >&2
  if [ -n "$BASH4LLM_LOG" ]; then printf '%s ERROR %s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$code" "$msg" >>"$BASH4LLM_LOG" 2>/dev/null || true; fi
}

log_info_user() {
  local code="${1:-INFO}" msg="${2:-}"
  # Print to stderr only if quiet mode is not active
  if [ "${QUIET:-0}" -ne 1 ]; then
    printf '%s%sINFO%s: %s: %s\n' "$(log_prefix)" "${C_GREEN}" "${C_RST}" "$code" "$msg" >&2
  fi
  # Mirror to log file if configured
  if [ -n "$BASH4LLM_LOG" ]; then
    printf '%s INFO_USER %s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$code" "$msg" >>"$BASH4LLM_LOG" 2>/dev/null || true
  fi
}

# debug helper: if DEBUG is (1)
dbg() {
  if [ "${DEBUG:-0}" -ne 0 ]; then
    printf '%s\n' "$*" >&2
  fi
}

# ---------------------------------------------------------------------------
# Terminal Color Theme Initialization (conforms to NO_COLOR standard)
# ---------------------------------------------------------------------------
C_TITLE="" C_CMD="" C_ARG="" C_RST="" C_GREEN="" C_GBOLD="" C_RED="" C_YELLOW="" C_BLUE="" C_CYAN="" C_BOLD="" C_LOGO=""

# Enable colors if standard output or standard error are real terminals (TTY)
# and the user has not expressed a preference NO_COLOR
if { [ -t 1 ] || [ -t 2 ]; } && [ -z "${NO_COLOR:-}" ]; then
  C_TITLE=$'\e[1;36m'   # Cyan Bold (Titles, Prompts)
  C_CMD=$'\e[1;32m'     # Green (REPL Commands, Username/provider)
  C_ARG=$'\e[0;33m'     # Yellow/Orange (Command arguments, variables)
  C_RST=$'\e[0m'        # Reset to standard color
  C_GREEN=$'\e[0;32m'   # Standard green
  C_GBOLD=$'\e[1;32m'   # Bold green 
  C_RED=$'\e[0;31m'     # Standard red (Errors)
  C_YELLOW=$'\e[0;33m'  # Standard yellow
  C_BLUE=$'\e[0;34m'    # Standard blue
  C_CYAN=$'\e[0;36m'    # Standard cyan (Info)
  C_BOLD=$'\e[1m'       # Bold
  C_LOGO=$'\e[1;97;42m' # Bold white on green background
fi
#--3<---[ /SECTION: PRECORE_BOOT_EARLY_HELPERS ]--->3--
#--4<---[ SECTION: PRECORE_BOOT_DIR_PATH ]--->4--
SCRIPTDIR="$(resolve_script_dir)"
# Allow external override of repository root via BASH4LLM_ROOT.
# Priority: explicit BASH4LLM_DIR env > BASH4LLM_ROOT env > SCRIPTDIR-derived default.
if [ -n "${BASH4LLM_DIR:-}" ]; then
  : # keep explicit BASH4LLM_DIR from environment
elif [ -n "${BASH4LLM_ROOT:-}" ]; then
  BASH4LLM_DIR="${BASH4LLM_ROOT%/}/bash4llm.d"
else
  BASH4LLM_DIR="$SCRIPTDIR/bash4llm.d"
fi

# Standard subdirectories derived from BASH4LLM_DIR (internally managed, non-overridable)
BASH4LLM_CONFIG_DIR="${BASH4LLM_DIR}/config"
BASH4LLM_MODELS_DIR="${BASH4LLM_DIR}/models"
BASH4LLM_TEMPLATES_DIR="${BASH4LLM_DIR}/templates"
BASH4LLM_HISTORY_DIR="${BASH4LLM_DIR}/history"
BASH4LLM_TMPDIR="${BASH4LLM_DIR}/tmp"
MODELS_FILE="${BASH4LLM_MODELS_DIR}/models.txt"
MAX_MODELS="${MAX_MODELS:-200}"

# Canonical configurations derived from validated variables
CANONICAL_EXTRAS_DIR="${BASH4LLM_DIR}/extras"
LEGACY_EXTRAS_DIR="${SCRIPTDIR%/}/extras"
BASH4LLM_EXTRAS_DIR="${CANONICAL_EXTRAS_DIR}"
PROVIDERS_DIR="${BASH4LLM_EXTRAS_DIR}/providers"
export BASH4LLM_EXTRAS_DIR PROVIDERS_DIR

# Validate BASH4LLM_DIR invariants
if [ -z "${BASH4LLM_DIR:-}" ]; then
  printf 'bash4llm: ERROR: BASH4LLM_DIR is empty; cannot derive directories\n' >&2
  exit "${BASH4LLMERR_TMP:-15}"
fi

# Forbid using /tmp or subpaths of /tmp as BASH4LLM_DIR
case "${BASH4LLM_DIR:-}" in
  /tmp|/tmp/*)
    printf 'bash4llm: ERROR: BASH4LLM_DIR must not be /tmp or under /tmp: %s\n' "${BASH4LLM_DIR}" >&2
    exit "${BASH4LLMERR_TMP:-15}"
    ;;
esac

# Ensure all directories exist safely with strict permissions (only when executed directly)
if [ "${BASH4LLM_SOURCE_ONLY:-0}" -ne 1 ] && [ "${BASH_SOURCE[0]}" = "$0" ]; then
  safe_mkdir "$BASH4LLM_DIR" 700
  safe_mkdir "$BASH4LLM_CONFIG_DIR" 700
  safe_mkdir "$BASH4LLM_MODELS_DIR" 700
  safe_mkdir "$BASH4LLM_TEMPLATES_DIR" 700
  safe_mkdir "$BASH4LLM_HISTORY_DIR" 700
  safe_mkdir "$BASH4LLM_TMPDIR" 700
  safe_mkdir "$BASH4LLM_EXTRAS_DIR" 700
  safe_mkdir "$BASH4LLM_CONFIG_DIR/providers" 700
  safe_mkdir "$BASH4LLM_HISTORY_DIR/sessions" 700
fi

# Set restricted session directory destination
SESSION_DIR="${BASH4LLM_HISTORY_DIR}/sessions"
#--4<---[ /SECTION: PRECORE_BOOT_DIR_PATH ]--->4--

# Helper: ensure config dir exists and is usable before any writes
ensure_config_dir() {
  safe_mkdir "${BASH4LLM_CONFIG_DIR}" 700

  # Quick writability check: try to create a temp file inside
  if ! : > "${BASH4LLM_CONFIG_DIR}/.bash4llm_tmp_check" 2>/dev/null; then
    log_error "CONFIG" "config dir not writable: ${BASH4LLM_CONFIG_DIR}"
    return 1
  else
    rm -f "${BASH4LLM_CONFIG_DIR}/.bash4llm_tmp_check" 2>/dev/null || true
  fi

  return 0
}

# Ensure config dir exists now (fail early if not)
ensure_config_dir || { log_error "CONFIG" "config dir unavailable; aborting."; exit "$BASH4LLMERR_TMP"; }

# Write provider-url file (single-line, non-secret). Best-effort; do not write API keys.
# Usage: write_provider_url_if_missing <provider> <url>
write_provider_url_if_missing() {
  local prov="${1:-}" url="${2:-}" file dir tmp
  [ -z "$prov" ] && return 1
  [ -z "$url" ] && return 1
  file="$(canonical_provider_url_file)"
  dir="$(dirname "$file")"
  safe_mkdir "$dir" 700
  # If file already exists and non-empty, do nothing
  if [ -f "$file" ] && [ -s "$file" ]; then
    return 0
  fi
  # Write atomically into RUN_TMPDIR if available, else directly (best-effort)
  if [ -n "${RUN_TMPDIR:-}" ] && [ -d "${RUN_TMPDIR:-}" ]; then
    tmp="$(mktemp "${RUN_TMPDIR%/}/provider-url.XXXXXX" 2>/dev/null || true)"
  else
    tmp="$(mktemp 2>/dev/null || true)"
  fi
  if [ -n "$tmp" ]; then
    printf '%s\n' "$url" > "$tmp"
    mv -f "$tmp" "$file" 2>/dev/null || cp -f "$tmp" "$file" 2>/dev/null || { rm -f "$tmp" 2>/dev/null || true; return 1; }
    chmod 600 "$file" 2>/dev/null || true
    return 0
  else
    # fallback: write directly
    printf '%s\n' "$url" > "$file" 2>/dev/null || return 1
    chmod 600 "$file" 2>/dev/null || true
    return 0
  fi
}

# Resolve provider URL with priority: ENV (BASH4LLM_API_URL / BASH4LLM_PROVIDER_URL) > provider-url file > embedded default (groq)
# Usage: resolve_provider_url <provider>
resolve_provider_url() {
  local prov="${1:-$PROVIDER}" prov_file prov_val cfgdir
  # 1) ENV
  if [ -n "${BASH4LLM_API_URL:-}" ]; then
    BASH4LLM_PROVIDER_URL="${BASH4LLM_API_URL}"
    export BASH4LLM_PROVIDER_URL
    return 0
  fi
  if [ -n "${BASH4LLM_PROVIDER_URL:-}" ]; then
    return 0
  fi
  # 2) provider-url file
  prov_file="$(canonical_provider_url_file)"
  if [ -f "$prov_file" ] && [ -s "$prov_file" ]; then
    prov_val="$(sed -n '1p' "$prov_file" 2>/dev/null | awk '{$1=$1;print}')"
    if [ -n "$prov_val" ]; then
      BASH4LLM_PROVIDER_URL="$prov_val"
      export BASH4LLM_PROVIDER_URL
      return 0
    fi
  fi
  # 3) embedded default for groq only (minimal)
  if [ "${prov:-}" = "groq" ]; then
    BASH4LLM_PROVIDER_URL="https://api.groq.com/openai/v1/chat/completions"
    export BASH4LLM_PROVIDER_URL
    return 0
  fi
  return 1
}

# Fail-fast if canonical_config_dir is empty for any reason
if [ -z "$(canonical_config_dir)" ]; then
  printf 'bash4llm: %sERROR%s: CONFIG: canonical config dir is empty; aborting.\n' "${C_RED}" "${C_RST}" >&2
  exit 1
fi

# Canonical PROVIDER_FILE path built only from BASH4LLM_CONFIG_DIR
PROVIDER_FILE="$(canonical_provider_file)"

#--5<---[ SECTION: PRECORE_BOOT_HELPERS ]--->5--
# Provider API key helpers (available early)
# - provider_api_env_var_name <prov> -> prints canonical env var name (e.g., GROQ_API_KEY)
# - ensure_api_key_for_provider <prov> -> ensures API key is set (may prompt interactively)
provider_api_env_var_name() {
  local prov="${1:-}"
  local prov_upper
  prov_upper="$(printf '%s' "$prov" | tr '[:lower:]' '[:upper:]' | tr -c 'A-Z0-9_' '_')"
  printf '%s' "${prov_upper}_API_KEY"
}

# Check if a string is valid JSON (non-empty, parsable by jq)
is_valid_json_string() {
  local s="${1:-}"
  [ -n "${s:-}" ] || return 1
  printf '%s' "$s" | jq -e . >/dev/null 2>&1
}

# Portable base64 wrappers (Linux, macOS, BusyBox)
# - b64encode: reads stdin, writes base64 without newlines
# - b64decode: reads base64 stdin, writes decoded bytes
# These functions replace all direct base64 calls.
b64encode() {
  # Portable base64 encode: do not rely on multi-token options.
  # Always produce single-line output by stripping newlines.
  if base64 2>/dev/null | tr -d '\n'; then
    :
  else
    return 1
  fi
}

b64decode() {
  # Use base64 with decode option if set; fall back to -d explicitly
  if [ -n "${B64_DECODE_OPT:-}" ]; then
    base64 ${B64_DECODE_OPT}
  else
    base64 -d
  fi
}

is_truthy() {
  case "${1:-}" in
    1|true|TRUE|True|yes|YES|Yes) return 0 ;;
    *) return 1 ;;
  esac
}

# - file_size returns bytes (portable)
file_size() {
  local f="${1:-}"
  if [ -z "$f" ] || [ ! -f "$f" ]; then
    printf '0'
    return 0
  fi
  case "$(uname 2>/dev/null || echo Linux)" in
    Darwin) stat -f %z "$f" 2>/dev/null || printf '0' ;;
    *) stat -c %s "$f" 2>/dev/null || printf '0' ;;
  esac
}

# Check if a file contains valid JSON (non-empty, parsable by jq)
is_valid_json_file() {
  local f="${1:-}"
  [ -f "$f" ] || return 1
  [ -s "$f" ] || return 1
  # Trim leading BOM/whitespace by letting jq parse; jq -e returns 0 on valid JSON
  jq -e . "$f" >/dev/null 2>&1
}

# Normalize debug variable: prefer DEBUG, but respect BASH4LLM_DEBUG if DEBUG unset
# Place this after CLI parsing and before any logging or DEBUG checks
if [ -n "${BASH4LLM_DEBUG:-}" ] && [ -z "${DEBUG:-}" ]; then
  DEBUG="${BASH4LLM_DEBUG}"
fi
DEBUG="${DEBUG:-0}"

# stage_b64: read stdin, write atomic base64 staging file under RUN_TMPDIR or destdir
# Usage: stage_b64 <dest_b64_path> <max_bytes>
stage_b64() {
  local src dst max_bytes tmp_local tmp_b64 workdir size tmp_local_is_temp=0 lockfile

  if [ "$#" -eq 2 ]; then
    src="$1"; dst="$2"
  elif [ "$#" -eq 1 ]; then
    dst="$1"; src=""
  else
    log_error "STAGE" "stage_b64 usage: stage_b64 [src] dst"
    return 1
  fi

  max_bytes="${MAX_STAGE_BYTES:-10485760}"
  [ -n "$dst" ] || return 1

  workdir="$(dirname "$dst")"
  safe_mkdir "$workdir" 700

  # Acquire tmp_local
  if [ -n "$src" ]; then
    if [ ! -f "$src" ] || [ ! -s "$src" ]; then
      log_error "STAGE" "stage_b64: source payload missing or empty: $src"
      return 1
    fi
    tmp_local="$src"
  else
    tmp_local="$(_tmpf file "${RUN_TMPDIR:-$BASH4LLM_TMPDIR}" payload.tmp 2>/dev/null)" || {
      log_error "STAGE" "failed to allocate tmp_local"
      return 1
    }
    if ! cat - > "$tmp_local" 2>/dev/null; then
      rm -f -- "$tmp_local" 2>/dev/null || true
      log_error "STAGE" "failed to write staging payload from stdin"
      return 1
    fi
    tmp_local_is_temp=1
  fi

  # Size check
  size="$(file_size "$tmp_local" 2>/dev/null || echo 0)"
  if [ "$size" -gt "$max_bytes" ]; then
    log_error "STAGE" "staged payload exceeds max allowed size ($size > $max_bytes)"
    [ "$tmp_local_is_temp" -eq 1 ] && rm -f -- "$tmp_local" 2>/dev/null || true
    return 1
  fi

  # Create tmp_b64 inside BASH4LLM_TMPDIR (safe), then move into workdir atomically
  tmp_b64="$(_tmpf file "$BASH4LLM_TMPDIR" .groq-b64 2>/dev/null)" || {
    [ "$tmp_local_is_temp" -eq 1 ] && rm -f -- "$tmp_local" 2>/dev/null || true
    log_error "STAGE" "failed to allocate tmp_b64"
    return 1
  }

  # Encode to base64 in a portable way, then remove newlines to produce a single-line payload.
  if base64 "$tmp_local" 2>/dev/null | tr -d '\n' > "$tmp_b64"; then
    :
  else
    rm -f -- "$tmp_b64" 2>/dev/null || true
    if [ "$tmp_local_is_temp" -eq 1 ]; then
      rm -f -- "$tmp_local" 2>/dev/null || true
    fi
    return 1
  fi

  chmod 600 "$tmp_b64" 2>/dev/null || true

  # Atomic move into final dst
  lockfile="${workdir%/}/.bash4llm.lock"
  if type lock_exec >/dev/null 2>&1; then
    lock_exec "$lockfile" 10 -- mv -f -- "$tmp_b64" "$dst" || {
      rm -f -- "$tmp_local" "$tmp_b64" 2>/dev/null || true
      return 1
    }
  else
    mv -f "$tmp_b64" "$dst" 2>/dev/null || {
      rm -f -- "$tmp_local" "$tmp_b64" 2>/dev/null || true
      return 1
    }
  fi
  chmod 600 "$dst" 2>/dev/null || true

  [ "$tmp_local_is_temp" -eq 1 ] && rm -f -- "$tmp_local" 2>/dev/null || true

  if [ "${DEBUG:-0}" -eq 1 ]; then
    log_info "STAGE" "staged base64 payload: $dst (size $(wc -c < "$dst" 2>/dev/null)B)"
  fi
  return 0
}

# lock_exec: acquire exclusive flock or folder-based lock on a lockfile with timeout (improved fallback for macOS compatibility)
# Usage: lock_exec <lockfile> <timeout> -- <command> [args...]
# Guarantees: acquires lock, runs command in subshell, always releases lock.
lock_exec() {
  local lockfile="${1:-}"
  local timeout="${2:-10}"
  local rc
  shift 2
  if [ "$1" != "--" ]; then
    log_error "USAGE" "lock_exec <lockfile> <timeout> -- <cmd> [args...]"
    return 2
  fi
  shift

  local lockdir="${lockfile}.lockdir"
  safe_mkdir "$(dirname "$lockfile")" 700

  if command -v flock >/dev/null 2>&1 && [ -z "${TERMUX_VERSION:-}" ]; then
    # Use flock if available (Linux and macOS with homebrew/util-linux)
    (
      # Open FD 9 for the lockfile inside subshell to avoid leaking FDs to caller
      exec 9>"$lockfile"
      if ! flock -x -w "$timeout" 9; then
        printf '%s%sERROR%s: LOCKTIMEOUT: could not acquire lock on %s within %s seconds\n' "$(log_prefix)" "${C_RED}" "${C_RST}" "$lockfile" "$timeout" >&2
        exit 124
      fi
      # Execute the requested command in this subshell under lock
      set -e
      "$@"
    )
    rc=$?
    return "$rc"
  else
    # Fallback to mkdir lock (POSIX atomicity compliant, works natively on standard macOS/Darwin)
    local start_time elapsed
    start_time=$(date +%s)
    while ! mkdir "$lockdir" 2>/dev/null; do
      elapsed=$(( $(date +%s) - start_time ))
      if [ "$elapsed" -ge "$timeout" ]; then
        printf '%s%sERROR%s: LOCKTIMEOUT: could not acquire directory lock %s within %s seconds\n' "$(log_prefix)" "${C_RED}" "${C_RST}" "$lockdir" "$timeout" >&2
        return 124
      fi
      sleep 0.1
    done

    # Run inside fallback block
    (
      set +e
      "$@"
    )
    rc=$?
    rmdir "$lockdir" 2>/dev/null || true
    return "$rc"
  fi
}

# Compatibility wrapper: _mktemp_in_dir -> uses _tmpf to create a secure temp file
# Usage: _mktemp_in_dir <dir> [prefix]
# Returns path on stdout or non-zero on failure.
_mktemp_in_dir() {
  local base="${1:-}" prefix="${2:-groq}" tmp
  if [ -z "$base" ]; then
    log_error "TMP" "_mktemp_in_dir: base dir required"
    return "$BASH4LLMERR_TMP"
  fi
  # Delegate to _tmpf which already enforces umask/perms and returns a path
  tmp="$(_tmpf file "$base" "$prefix" 2>/dev/null)"
  if [ -z "$tmp" ]; then
    log_error "TMP" "_mktemp_in_dir: failed to create temp in $base"
    return "$BASH4LLMERR_TMP"
  fi
  printf '%s' "$tmp"
  return 0
}

# Debug-safe payload preview (decodes b64 payloads)
show_payload_head() {
  local path="${1:-$PAYLOAD}" lines="${2:-200}"
  if [ -z "${path:-}" ]; then
    printf 'bash4llm: %sERROR%s: payload file missing: %s\n' "${C_RED}" "${C_RST}" "<unset>" >&2
    exit "$BASH4LLMERR_TMP"
  fi
  if [ ! -e "$path" ]; then
    printf 'bash4llm: %sERROR%s: payload file missing: %s\n' "${C_RED}" "${C_RST}" "$path" >&2
    exit "$BASH4LLMERR_TMP"
  fi
  if [ ! -s "$path" ]; then
    printf 'bash4llm: %sINFO%s: payload exists but is empty: %s\n' "${C_GREEN}" "${C_RST}" "$path" >&2
    return 0
  fi

  # Diagnostic output only when DEBUG=1
  if [ "${DEBUG:-0}" -eq 1 ]; then
    printf 'bash4llm: %sINFO%s: payload path: %s\n' "${C_GREEN}" "${C_RST}" "$path" >&2
    printf 'bash4llm: %sINFO%s: payload (head %d lines):\n' "${C_GREEN}" "${C_RST}" "$lines" >&2
    if printf '%s' "$path" | grep -qE '\.b64$'; then
      b64decode < "$path" 2>/dev/null | head -n "$lines" >&2 || true
    else
      head -n "$lines" "$path" 2>/dev/null >&2 || true
    fi
  fi

  return 0
}

# Atomic raw write helper
# - atomic_write <dest> <timeout> -- (reads stdin)
atomic_write() {
  # Atomic write with optional lock support.
  # Usage: atomic_write /path/to/target [timeout_seconds]
  local dest="$1"
  local timeout="${2:-10}"
  [ -n "$dest" ] || return "$BASH4LLMERR_TMP"
  local destdir tmp lockfile rc

  destdir="$(dirname -- "$dest")"
  safe_mkdir "$destdir" 700
  lockfile="${destdir}/.bash4llm.lock"

  tmp="$(mktemp "$destdir/.groq-atomic.XXXXXX" 2>/dev/null || true)"
  [ -n "$tmp" ] || tmp="$destdir/.groq-atomic.$$.$RANDOM"

  if ! cat - > "$tmp"; then
    rm -f -- "$tmp" 2>/dev/null || true
    log_error "ATOMICFAIL" "writing to temp failed"
    return "$BASH4LLMERR_TMP"
  fi
  chmod 600 "$tmp" 2>/dev/null || true

  # If lock_exec available, use it to perform the mv under lock; otherwise mv directly
  if type lock_exec >/dev/null 2>&1; then
    lock_exec "$lockfile" "$timeout" -- mv -f -- "$tmp" "$dest" \
      || { rc=$?; rm -f -- "$tmp" 2>/dev/null || true; return "$rc"; }
    chmod 600 "$dest" 2>/dev/null || true
  else
    if mv -f -- "$tmp" "$dest" 2>/dev/null; then
      chmod 600 "$dest" 2>/dev/null || true
    else
      rc=$?
      rm -f -- "$tmp" 2>/dev/null || true
      log_error "ATOMICFAIL" "mv failed with rc $rc"
      return "$rc"
    fi
  fi

  return 0
}

# Response extraction helpers
extract_text_from_resp() {
  # Extract textual content from RESP and print to stdout.
  # Return codes:
  # 0 = success (text printed)
  # 2 = RESP is diagnostic (no real content)
  # 1 = no textual content found or error
  local resp_file="${RESP:-}"
  local tmp_copy
  if [ -z "${resp_file:-}" ]; then
    log_error "EXTRACT" "RESP path not set"
    return 1
  fi

  # Always read from atomic copy
  tmp_copy="$(_tmpf file "${RUN_TMPDIR:-$BASH4LLM_TMPDIR}" resp_copy 2>/dev/null)" || return 1
  cp -f "$resp_file" "$tmp_copy" 2>/dev/null || return 1
  resp_file="$tmp_copy"

  if ! is_valid_json_file "$resp_file"; then
    log_warn "EXTRACT" "RESP missing or not valid JSON: $resp_file"
    if [ -f "$resp_file" ]; then
      cat "$resp_file" 2>/dev/null || true
      return 0
    fi
    return 1
  fi

  if jq -e 'has("diagnostic") and .diagnostic==true' "$resp_file" >/dev/null 2>&1; then
    log_warn "EXTRACT" "RESP is diagnostic JSON; skipping text extraction"
    return 2
  fi

  if jq -e '.choices and (.choices|length>0) and ( [ .choices[]? | (.message?.content // .delta?.content // "") ] | map(select(.!="")) | length > 0 )' "$resp_file" >/dev/null 2>&1; then
    jq -r '[.choices[]? | (.message?.content // .delta?.content // "")] | map(select(.!="")) | join("\n\n")' "$resp_file" 2>/dev/null || return 1
    return 0
  fi

  if jq -e '.choices and (.choices|length>0) and ( [ .choices[]? | (.text? // "") ] | map(select(.!="")) | length > 0 )' "$resp_file" >/dev/null 2>&1; then
    jq -r '[.choices[]?.text? // empty] | map(select(.!="")) | join("\n\n")' "$resp_file" 2>/dev/null || return 1
    return 0
  fi

  if jq -e '(.output_text? // empty) != "" or (.data and (.data|length>0) and ( [ .data[]? | (.text? // "") ] | map(select(.!="")) | length > 0 ))' "$resp_file" >/dev/null 2>&1; then
    if [ "$(jq -r '.output_text // empty' "$resp_file" 2>/dev/null)" != "" ]; then
      jq -r '.output_text' "$resp_file" 2>/dev/null || return 1
      return 0
    else
      jq -r '[.data[]?.text? // empty] | map(select(.!="")) | join("\n\n")' "$resp_file" 2>/dev/null || return 1
      return 0
    fi
  fi

  if jq -e 'paths(scalars) as $p | getpath($p) | type=="string"' "$resp_file" >/dev/null 2>&1; then
    jq -r '[.. | scalars | select(type=="string")] | join("\n\n")' "$resp_file" 2>/dev/null || return 1
    return 0
  fi

  log_warn "EXTRACT" "No textual content found in RESP"
  return 1
}

# Ensure and create a run-specific tmpdir under BASH4LLM_TMPDIR and set neutral payload path.
# Now uses _tmpf (dir) as the single source of truth. No predictable fallbacks, no /tmp.
DEBUG_PRESERVE="${DEBUG_PRESERVE:-0}"

ensure_run_tmpdir() {
  local print_only=0 subshell=0 tmpdir
  if [ "${1:-}" = "--print" ]; then print_only=1; fi

  # Detect subshell
  if [ -n "${BASHPID:-}" ] && [ "${BASHPID:-}" != "$$" ]; then
    subshell=1
  fi

  # Reuse existing RUN_TMPDIR if valid and inside BASH4LLM_TMPDIR
  if [ -n "${RUN_TMPDIR:-}" ] && [ -d "${RUN_TMPDIR:-}" ]; then
    case "$RUN_TMPDIR" in
      "$BASH4LLM_TMPDIR"/*|"$BASH4LLM_TMPDIR")
        chmod 700 "$RUN_TMPDIR" 2>/dev/null || true
        : "${PAYLOAD:=$RUN_TMPDIR/payload}"
        : "${RESP:=$RUN_TMPDIR/resp.json}"
        : "${ERRF:=$RUN_TMPDIR/err.log}"
        if [ "$print_only" -eq 0 ] && [ "$subshell" -eq 0 ]; then
          : > "$RESP" 2>/dev/null || true
          chmod 600 "$RESP" 2>/dev/null || true
          : > "$ERRF" 2>/dev/null || true
          chmod 600 "$ERRF" 2>/dev/null || true
          export RUN_TMPDIR PAYLOAD RESP ERRF
        fi
        [ "$print_only" -eq 1 ] && printf '%s' "$RUN_TMPDIR"
        return 0
        ;;
      *)
        log_warn "TMP" "existing RUN_TMPDIR outside BASH4LLM_TMPDIR; discarding: $RUN_TMPDIR"
        RUN_TMPDIR=""
        ;;
    esac
  fi

  # Validate BASH4LLM_TMPDIR
  if [ -z "${BASH4LLM_TMPDIR:-}" ]; then
    log_error "TMP" "BASH4LLM_TMPDIR not set"
    return "$BASH4LLMERR_TMP"
  fi
  safe_mkdir "$BASH4LLM_TMPDIR" 700

  # Create RUN_TMPDIR exclusively via _tmpf (dir)
  tmpdir="$(_tmpf dir "$BASH4LLM_TMPDIR" run 2>/dev/null)" || {
    log_error "TMP" "ensure_run_tmpdir: _tmpf failed to create run tmpdir"
    return "$BASH4LLMERR_TMP"
  }

  RUN_TMPDIR="$tmpdir"

  # Provider-agnostic payload paths
  : "${PAYLOAD:=$RUN_TMPDIR/payload}"
  : "${RESP:=$RUN_TMPDIR/resp.json}"
  : "${ERRF:=$RUN_TMPDIR/err.log}"

  # Create RESP/ERRF only in main process
  if [ "$print_only" -eq 0 ] && [ "$subshell" -eq 0 ]; then
    : > "$RESP" 2>/dev/null || true
    chmod 600 "$RESP" 2>/dev/null || true
    : > "$ERRF" 2>/dev/null || true
    chmod 600 "$ERRF" 2>/dev/null || true
  fi

  # Cleanup function
  cleanup_run_tmp_on_exit() {
    local rc_in=$?   # preserves original exit code

    # Release exclusive session lock if active
    if type release_session_lock >/dev/null 2>&1; then
      release_session_lock 2>/dev/null || true
    fi

    # Safely clear active session markers if they were registered globally
    if [ -n "${RUN_TMPDIR:-}" ]; then
      rm -rf "${RUN_TMPDIR:-}"/session-msg-*.lockdir 2>/dev/null || true
    fi

    if [ "${DEBUG_PRESERVE:-0}" -eq 1 ]; then
      [ "${DEBUG:-0}" -eq 1 ] && log_info "TMP" "DEBUG_PRESERVE set; preserving RUN_TMPDIR=$RUN_TMPDIR"
      return "$rc_in"
    fi

    if [ -n "${RUN_TMPDIR:-}" ]; then
      case "$RUN_TMPDIR" in
        "$BASH4LLM_TMPDIR"/*|"$BASH4LLM_TMPDIR")
          rm -rf -- "$RUN_TMPDIR" 2>/dev/null || true
          [ "${DEBUG:-0}" -eq 1 ] && log_info "TMP" "Cleaned RUN_TMPDIR: $RUN_TMPDIR"
          ;;
        *)
          [ "${DEBUG:-0}" -eq 1 ] && log_info "TMP" "RUN_TMPDIR outside BASH4LLM_TMPDIR; not removed: $RUN_TMPDIR"
          ;;
      esac
    fi

    return "$rc_in"   # always returns the original exit code
  }

  # Install trap only in main process
  if [ "$subshell" -eq 0 ] && [ "$print_only" -eq 0 ]; then
    trap cleanup_run_tmp_on_exit EXIT INT TERM
  fi

  # Export variables
  if [ "$print_only" -eq 0 ]; then
    export RUN_TMPDIR PAYLOAD RESP ERRF
    [ "${DEBUG:-0}" -eq 1 ] && log_info "TMP" "Created RUN_TMPDIR: $RUN_TMPDIR"
  else
    printf '%s' "$print_only"
  fi

  return 0
}

cleanup_tmp() {
  if [ -n "${RUN_TMPDIR:-}" ]; then
    case "$RUN_TMPDIR" in
      "$BASH4LLM_TMPDIR"/*|"$BASH4LLM_TMPDIR")
        rm -rf -- "$RUN_TMPDIR" 2>/dev/null || true
        ;;
      *)
        ;;
    esac
  fi
}

# Atomic base64 write/read helpers (use for payloads, manifests, staging)
# - b64_atomic_write <dest.b64> <timeout> -- (reads stdin)
# - b64_atomic_read <src.b64> (writes decoded to stdout)
b64_atomic_write() {
  local dest="$1"
  local timeout="${2:-10}"
  local destdir tmp lockfile rc
  shift 2 || true

  [ -n "$dest" ] || {
    log_error "B64FAIL" "b64_atomic_write: dest required"
    return "$BASH4LLMERR_TMP"
  }

  destdir="$(dirname -- "$dest")"
  safe_mkdir "$destdir" 700

  lockfile="${destdir%/}/.bash4llm.lock"

  # Allocate tmp inside BASH4LLM_TMPDIR (safe), not inside destdir
  tmp="$(_tmpf file "$BASH4LLM_TMPDIR" .groq-b64 2>/dev/null)" || {
    log_error "B64FAIL" "failed to allocate tmp for b64_atomic_write"
    return "$BASH4LLMERR_TMP"
  }

  if ! b64encode > "$tmp"; then
    rm -f -- "$tmp" 2>/dev/null || true
    log_error "B64FAIL" "base64 encoding failed"
    return "$BASH4LLMERR_TMP"
  fi
  chmod 600 "$tmp" 2>/dev/null || true

  # Atomic move into final destination
  lock_exec "$lockfile" "$timeout" -- mv -f -- "$tmp" "$dest" || {
    rc=$?
    rm -f -- "$tmp" 2>/dev/null || true
    return "$rc"
  }

  chmod 600 "$dest" 2>/dev/null || true
  return 0
}

b64_atomic_read() {
  local src="$1"
  [ -f "$src" ] || return 1
  b64decode < "$src"
  return $?
}

# ui_state_write: centralized helper to write JSON files for the GUI (atomic)
# Usage: ui_state_write <relpath> <json-string>
# Writes to: $BASH4LLM_CONFIG_DIR/ui_state/<relpath>
# Guarantees: atomic write, strict perms, non-fatal on error (logs warning).
ui_state_write() {
  # Write UI state JSON atomically.
  # Usage: ui_state_write filename content_string
  local name="${1:-}" content="${2:-}"
  local dir target

  if [ -n "${BASH4LLM_CONFIG_DIR:-}" ]; then
    dir="${BASH4LLM_CONFIG_DIR%/}/ui_state"
  else
    dir="${RUN_TMPDIR%/}/ui_state"
  fi

  if [ -z "${name:-}" ]; then
    log_error "UI_STATE" "ui_state_write requires a filename"
    return 1
  fi

  safe_mkdir "$dir" 700
  target="$dir/$name"

  # Use atomic_write helper (timeout optional) to write content
  printf '%s' "$content" | atomic_write "$target" 10 || { log_warn "UI_STATE" "atomic write failed for $target"; return 1; }
  chmod 600 "$target" 2>/dev/null || true
  if [ "${DEBUG:-0}" -eq 1 ]; then
    log_info "UI_STATE" "wrote $target (size $(wc -c < "$target" 2>/dev/null)B)"
  fi
  return 0
}
#--5<---[ /SECTION: PRECORE_BOOT_HELPERS ]--->5--
#--6<---[ SECTION: PRECORE_BOOT_CLI_HELPERS ]--->6--
# Internal CLI helpers: print canonical config paths (safe, single-file)
# These flags are handled early and exit immediately after printing.
# Supported forms:
#   ./bash4llm --print-config-dir
#   ./bash4llm --print-provider-file
#   ./bash4llm --print-model-file <provider>
#   ./bash4llm --print-model-file=<provider>
# ---------------------------------------------------------------------------
if [ "$#" -gt 0 ]; then
  # Iterate through args to support flags anywhere on the command line
  i=1
  while [ "$i" -le "$#" ]; do
    arg="${!i}"
    case "$arg" in
      --print-config-dir)
        printf '%s\n' "$(canonical_config_dir)"
        exit 0
        ;;
      --print-provider-file)
        printf '%s\n' "$(canonical_provider_file)"
        exit 0
        ;;
      --print-model-file)
        next_index=$((i+1))
        if [ "$next_index" -le "$#" ]; then
          prov="${!next_index}"
          printf '%s\n' "$(canonical_model_file "$prov")"
          exit 0
        else
          printf 'bash4llm: %sERROR%s: usage: --print-model-file <provider>\n' "${C_RED}" "${C_RST}" >&2
          exit 2
        fi
        ;;        
      --print-model-file=*)
        prov="${arg#--print-model-file=}"
        printf '%s\n' "$(canonical_model_file "$prov")"
        exit 0
        ;;
      # allow short-circuit if user passed combined flags like --help etc.
      --help|-h)
        # fall through to normal help handling later
        break
        ;;
      *)
        # not one of our print flags; continue scanning
        ;;
    esac
    i=$((i+1))
  done
fi

umask 077

# ---------------------------------------------------------------------------
# Centralized lock names (co-located with resources)
# ---------------------------------------------------------------------------
MODELS_LOCK="${MODELS_LOCK:-$BASH4LLM_MODELS_DIR/models.lock}"
HISTORY_LOCK="${HISTORY_LOCK:-$BASH4LLM_HISTORY_DIR/history.lock}"
TMP_LOCK="${TMP_LOCK:-$BASH4LLM_TMPDIR/tmp.lock}"

# Lock timeouts (configurable via env)
BASH4LLM_LOCK_TIMEOUT_TMP="${BASH4LLM_LOCK_TIMEOUT_TMP:-10}"
BASH4LLM_LOCK_TIMEOUT_MODELS="${BASH4LLM_LOCK_TIMEOUT_MODELS:-10}"
BASH4LLM_LOCK_TIMEOUT_HISTORY="${BASH4LLM_LOCK_TIMEOUT_HISTORY:-10}"
# Load and validate provider module for given provider name
load_provider_module() {
  local provider="${1:-}"
  local current_user owner file_owner perms group_write others_write beforesig aftersig dump_file rc _nounset_was_on supports_streaming supports_refresh_models loaded_from prov_json req1 req2

  # Skip if already loaded for the same provider
  if [ "${LOADED_PROVIDER_NAME:-}" = "$provider" ] && [ "${PROVIDER_MODULE_LOADED:-0}" -eq 1 ]; then
    return 0
  fi

  LOADED_PROVIDER_NAME="$provider"
  PROVIDER_MODULE_LOADED=0
  PROVIDER_MODULE_PATH="$PROVIDERS_DIR/${provider}.sh"
  PROVIDER_DIR="$PROVIDERS_DIR"

  safe_mkdir "$PROVIDER_DIR" 700

  if _is_world_writable "$PROVIDER_DIR"; then
    log_error "SEC" "provider directory is world-writable."
    return 1
  fi

  current_user="$(id -un 2>/dev/null || printf '')"
  owner="$(_get_owner "$PROVIDER_DIR")"
  [ -n "$owner" ] && [ "$owner" != "$current_user" ] && log_warn "SEC" "provider directory owned by $owner"

  if [ ! -f "$PROVIDER_MODULE_PATH" ]; then
    if [ "$provider" != "groq" ]; then
      printf 'Provider %s is not installed.\n' "$provider" >&2
      PROVIDER_MODULE_LOADED=0
      return 0
    else
      PROVIDER_MODULE_LOADED=1
      return 0
    fi
  fi

  if [ -L "$PROVIDER_MODULE_PATH" ]; then
    log_error "SEC" "provider file is symlink."
    return 1
  fi

  file_owner="$(_get_owner "$PROVIDER_MODULE_PATH")"
  [ -n "$file_owner" ] && [ "$file_owner" != "$current_user" ] && { log_error "SEC" "wrong owner for provider file."; return 1; }

  perms="$(_get_perm_string "$PROVIDER_MODULE_PATH")"
  group_write="$(printf '%s' "$perms" | awk '{print substr($0,6,1)}')"
  others_write="$(printf '%s' "$perms" | awk '{print substr($0,9,1)}')"
  if [ "$group_write" = "w" ] || [ "$others_write" = "w" ]; then
    log_error "SEC" "provider file writable by group/world."
    return 1
  fi

  beforesig="$(getfile_signature "$PROVIDER_MODULE_PATH" 2>/dev/null || true)"

  # --- SAFE LOAD: isolate provider in subshell, export only functions defined by provider ---
  if bash -n "$PROVIDER_MODULE_PATH" 2>/dev/null; then
    dump_file="$(_mktemp_in_dir "$BASH4LLM_TMPDIR" "provdump.${provider}.XXXXXX" 2>/dev/null)"
    [ -z "$dump_file" ] && { log_error "SEC" "cannot create provider dump file"; return 1; }

    # Subshell: capture functions added by sourcing the provider
    (
      set -e

      # Safe cleanup within subshell in case sourcing or dumping crashes prematurely
      trap 'rm -f "$dump_file.before.$$" "$dump_file.after.$$" "$dump_file.funcs.$$" 2>/dev/null' EXIT

      # capture function list before
      declare -F | awk '{print $3}' | sort > "$dump_file.before.$$" 2>/dev/null || true

      # source provider inside subshell (isolated)
      . "$PROVIDER_MODULE_PATH"

      # capture function list after
      declare -F | awk '{print $3}' | sort > "$dump_file.after.$$" 2>/dev/null || true

      # compute functions added by provider (lines in after but not in before)
      comm -13 "$dump_file.before.$$" "$dump_file.after.$$" > "$dump_file.funcs.$$" 2>/dev/null || true

      # ensure required functions exist; if missing, fail early
      req1="buildpayload_${provider}"
      req2="call_api_${provider}"
      for f in "$req1" "$req2"; do
        if ! grep -xq "$f" "$dump_file.funcs.$$" 2>/dev/null; then
          if ! type "$f" >/dev/null 2>&1; then
            printf 'ERROR: provider %s missing required function: %s\n' "$provider" "$f" >&2
            exit 99
          fi
        fi
      done

      # Write definitions of the functions added by the provider into the dump file
      : > "$dump_file"
      while IFS= read -r fn; do
        [ -z "$fn" ] && continue
        if type "$fn" >/dev/null 2>&1; then
          declare -f "$fn" >> "$dump_file"
        fi
      done < "$dump_file.funcs.$$"
    )
    rc=$?

    if [ "$rc" -ne 0 ]; then
      log_error "PROVIDER" "provider module failed isolation load (rc=$rc)"
      rm -f "$dump_file" 2>/dev/null || true
      return 1
    fi

    # --- Minimal and safe nounset handling around sourcing the dump ---
    # Detect if nounset (set -u) is active; if so, disable it temporarily.
    _nounset_was_on=0
    if (set -o | awk '/^nounset/ {print $2}' 2>/dev/null | grep -q on); then
      _nounset_was_on=1
      set +u
    fi

    # Import the dumped functions into main shell (dump contains all functions provider defined)
    . "$dump_file"

    # Restore nounset if it was on
    if [ "$_nounset_was_on" -eq 1 ]; then
      set -u
    fi

    PROVIDER_MODULE_LOADED=1
    rm -f "$dump_file" 2>/dev/null || true

    # Verify signature unchanged
    aftersig="$(getfile_signature "$PROVIDER_MODULE_PATH" 2>/dev/null || true)"
    [ "$beforesig" != "$aftersig" ] && { log_error "SEC" "provider file changed."; return 1; }

  else
    log_warn "PROVIDER" "provider module invalid; falling back to embedded provider."
    PROVIDER_MODULE_LOADED=0
  fi

  # --- Write provider capabilities to ui_state (canonical) ---
  if [ -n "${provider:-}" ]; then
    supports_streaming=0
    supports_refresh_models=0
    if type "call_api_streaming_groq" >/dev/null 2>&1 || type "call_api_streaming_${provider}" >/dev/null 2>&1; then supports_streaming=1; fi
    if type "refresh_models_${provider}" >/dev/null 2>&1; then supports_refresh_models=1; fi
    loaded_from="${PROVIDER_MODULE_PATH:-embedded}"
    prov_json="$(jq -c -n --arg p "$provider" --arg loaded "$loaded_from" --argjson sstream "$supports_streaming" --argjson srefresh "$supports_refresh_models" '{provider:$p, supports_streaming:$sstream, supports_refresh_models:$srefresh, loaded_from:$loaded}')"
    ui_state_write "provider_capabilities.json" "$prov_json" || log_warn "UI_STATE" "failed to write provider_capabilities for $provider"
  fi

  return 0
}

# ---------------------------------------------------------------------------
# Detect portable base64 encode/decode commands (avoid parsing --help)
# Sets B64_ENCODE_CMD and B64_DECODE_CMD arrays used by wrappers
# ---------------------------------------------------------------------------
_detect_base64_opts() {
  # Default conservative options
  B64_WRAP_OPT=""
  B64_DECODE_OPT="-d"

  # Detect encode option that prevents line wrapping (GNU coreutils)
  if printf '' | base64 -w0 >/dev/null 2>&1; then
    B64_WRAP_OPT="-w0"
  else
    B64_WRAP_OPT=""
  fi

  # Detect decode option -d vs -D
  if printf 'dGVzdA==' | base64 -d 2>/dev/null | grep -q 'test'; then
    B64_DECODE_OPT="-d"
  elif printf 'dGVzdA==' | base64 -D 2>/dev/null | grep -q 'test'; then
    B64_DECODE_OPT="-D"
  else
    B64_DECODE_OPT="-d"
  fi

  export B64_WRAP_OPT B64_DECODE_OPT
}
_detect_base64_opts

# ---------------------------------------------------------------------------
# Portable file size and listing helpers for rotate_history
# - list_files_sorted_by_mtime lists files with mtime and path (portable)
# ---------------------------------------------------------------------------
# list_files_sorted_by_mtime <dir> -> prints "mtime_seconds|path" lines sorted ascending
list_files_sorted_by_mtime() {
  local dir="${1:-}"
  find "$dir" -type f -print0 2>/dev/null | while IFS= read -r -d '' f; do
    local mtime
    case "$(uname 2>/dev/null || echo Linux)" in
      Darwin) mtime="$(stat -f %m "$f" 2>/dev/null || echo 0)" ;;
      *) mtime="$(stat -c %Y "$f" 2>/dev/null || echo 0)" ;;
    esac
    printf '%s|%s\n' "$mtime" "$f"
  done | sort -n
}

# ---------------------------------------------------------------------------
# tac_fallback: portable reverse file lines (fallback to awk)
# Usage: tac_fallback <file>
# ---------------------------------------------------------------------------
tac_fallback() {
  local f="${1:-}"
  if command -v tac >/dev/null 2>&1; then
    tac "$f"
    return $?
  fi
  # awk-based fallback: print file in reverse
  awk ' { lines[NR] = $0 } END { for (i=NR; i>0; i--) print lines[i] } ' "$f"
  return 0
}

# ---------------------------------------------------------------------------
# _file_mtime: portable mtime in seconds for a file
# Usage: _file_mtime <file> -> prints epoch seconds or 0
# ---------------------------------------------------------------------------
_file_mtime() {
  local f="${1:-}"
  if [ ! -e "$f" ]; then printf '0'; return 0; fi
  case "$(uname 2>/dev/null || echo Linux)" in
    Darwin) stat -f %m "$f" 2>/dev/null || printf '0' ;;
    *) stat -c %Y "$f" 2>/dev/null || printf '0' ;;
  esac
}

# ---------------------------------------------------------------------------
# jq_safe: run jq with error handling; returns 0 if JSON valid and jq succeeded
# Usage: jq_safe <filter> <file>
# ---------------------------------------------------------------------------
jq_safe() {
  # wrapper to run jq and capture errors to ERRF if set
  local filter="${1:-}" file="${2:-}" rc
  if [ -z "$file" ] || [ ! -s "$file" ]; then
    return 1
  fi
  if ! jq -e "$filter" "$file" >/dev/null 2>&1; then
    rc=$?
    # If ERRF is defined, append jq stderr for diagnostics
    if [ -n "${ERRF:-}" ]; then
      jq "$filter" "$file" 2>>"$ERRF" >/dev/null 2>&1 || true
    fi
    return "$rc"
  fi
  return 0
}
