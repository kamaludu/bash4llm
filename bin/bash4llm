  custom_key_var="${PROVIDER_API_ENV_groq}"
  GROQ_API_KEY="${!custom_key_var:-}"
fi

buildpayload_groq() {
  local tmp_payload="" stream_json="" VALID_MESSAGES_JSON="" http_code="" edgecase=0 now_ts="" model_from_file="" payload_size=0 staged_b64="" tmp_b64="" content_val="" msgs="" msgs_from_file=""

  tmp_payload="$(_mktemp_in_dir "$RUN_TMPDIR" payload.XXXXXX.json 2>/dev/null || _tmpf file "$RUN_TMPDIR" payload.json)"

  if is_truthy "${STREAM_MODE:-0}"; then
    stream_json=true
  else
    stream_json=false
  fi
  case "${stream_json:-}" in
    true|false) ;;
    1) stream_json=true ;;
    0) stream_json=false ;;
    *) stream_json=false ;;
  esac

  if ! printf '%s' "${TEMPERATURE:-}" | grep -qE '^[0-9]+([.][0-9]+)?$'; then
    log_warn "ARGS" "invalid TURE value '${TEMPERATURE:-}'; defaulting to 1.0"
    TURE="1.0"
  fi
  if ! printf '%s' "${MAX_TOKENS:-}" | grep -qE '^[0-9]+$'; then
    log_warn "ARGS" "invalid MAX_TOKENS value '${MAX_TOKENS:-}'; defaulting to 4096"
    MAX_TOKENS="4096"
  fi

  VALID_MESSAGES_JSON=""

  if [ -n "${JSON_INPUT:-}" ] && is_valid_json_string "${JSON_INPUT}"; then
    msgs="$(printf '%s' "$JSON_INPUT" | jq -c '.messages // empty' 2>/dev/null || true)"
    if [ -n "$msgs" ]; then
      VALID_MESSAGES_JSON="$msgs"
    else
      content_val="$(printf '%s' "$JSON_INPUT" | jq -r '.content // .prompt // empty' 2>/dev/null || true)"
      if [ -n "$content_val" ]; then
        VALID_MESSAGES_JSON="$(jq -c -n --arg content "$content_val" '[{role:"user",content:$content}]')"
      fi
    fi
  fi

  if [ -z "$VALID_MESSAGES_JSON" ] && [ -n "${MESSAGES_JSON:-}" ] && is_valid_json_string "${MESSAGES_JSON:-}"; then
    VALID_MESSAGES_JSON="${MESSAGES_JSON}"
  fi

  if [ -z "$VALID_MESSAGES_JSON" ] && [ -n "${BUILD_MESSAGES_FILE:-}" ] && is_valid_json_file "${BUILD_MESSAGES_FILE}"; then
    msgs_from_file="$(jq -c '.messages // []' "$BUILD_MESSAGES_FILE" 2>/dev/null || true)"
    if printf '%s' "$msgs_from_file" | jq -e 'type=="array" and (length>0)' >/dev/null 2>&1; then
      if [ -n "${CONTENT:-}" ]; then
        VALID_MESSAGES_JSON="$(printf '%s' "$msgs_from_file" | jq -c --arg content "$CONTENT" '. + [{role:"user", content:$content}]' 2>/dev/null || printf '%s' "$msgs_from_file")"
      else
        VALID_MESSAGES_JSON="$msgs_from_file"
      fi
    fi
  fi

  if [ -z "$VALID_MESSAGES_JSON" ] && [ -n "${CONTENT:-}" ]; then
    VALID_MESSAGES_JSON="$(jq -c -n --arg content "$CONTENT" '[{role:"user",content:$content}]')"
  fi

  if [ -z "$VALID_MESSAGES_JSON" ]; then
    VALID_MESSAGES_JSON='[{"role":"user","content":""}]'
    log_warn "PAYLOAD" "MESSAGES_JSON invalid or missing; using fallback single empty user message"
  fi

  if ! printf '%s' "$VALID_MESSAGES_JSON" | jq -e 'type=="array" and (length>0)' >/dev/null 2>&1; then
    log_warn "PAYLOAD" "VALID_MESSAGES_JSON is empty or not an array; using fallback single empty user message"
    VALID_MESSAGES_JSON='[{"role":"user","content":""}]'
  fi

  if [ -n "${SYSTEM_PROMPT:-}" ]; then
    VALID_MESSAGES_JSON="$(jq -n --argjson messages "$VALID_MESSAGES_JSON" --arg sys "$SYSTEM_PROMPT" '[{role:"system", content:$sys}] + $messages' 2>/dev/null || jq -n --arg role "system" --arg content "${SYSTEM_PROMPT:-}" --argjson messages "$VALID_MESSAGES_JSON" '{messages:([{role:$role,content:$content}] + $messages) }')"
  fi

  if [ -z "${MODEL:-}" ] && [ -n "${BUILD_MESSAGES_FILE:-}" ] && is_valid_json_file "${BUILD_MESSAGES_FILE}"; then
    model_from_file="$(jq -r '.model // .provider?.model // empty' "$BUILD_MESSAGES_FILE" 2>/dev/null || true)"
    if [ -n "$model_from_file" ]; then
      MODEL="$model_from_file"
      if [ "${DEBUG:-0}" -eq 1 ]; then
        log_info "PAYLOAD" "MODEL set from BUILD_MESSAGES_FILE: ${MODEL}"
      fi
    fi
  fi

  if ! jq -n --arg model "${MODEL:-}" --argjson stream "$stream_json" --arg ture "$TEMPERATURE" --arg max_tokens "$MAX_TOKENS" \
       --argjson messages "$(printf '%s' "$VALID_MESSAGES_JSON")" \
       '{model:$model, stream:$stream, temperature:($ture|tonumber), max_tokens:($max_tokens|tonumber), messages:$messages }' >"$tmp_payload" 2>/dev/null; then
    log_error "PAYLOAD" "jq failed to build payload; tmp_payload not created"
    rm -f "$tmp_payload" 2>/dev/null || true
    return "$BASH4LLM_ERR_TMP"
  fi

  if [ ! -s "$tmp_payload" ]; then
    log_error "PAYLOAD" "tmp_payload is empty after jq; aborting"
    rm -f "$tmp_payload" 2>/dev/null || true
    return "$BASH4LLM_ERR_TMP"
  fi

  if [ "${DEBUG:-0}" -eq 1 ]; then
    payload_size=$(wc -c < "$tmp_payload" 2>/dev/null || echo 0)
    log_info "PAYLOAD" "tmp_payload path: $tmp_payload size=${payload_size}B"
    log_info "PAYLOAD" "tmp_payload content (head 2000 chars):"
    head -c 2000 "$tmp_payload" >&2 || true
  fi

  staged_b64=""
  if type stage_b64 >/dev/null 2>&1; then
    tmp_b64="${tmp_payload}.b64"
    if stage_b64 "$tmp_b64" < "$tmp_payload" 2>/dev/null; then
      staged_b64="$tmp_b64"
      rm -f "$tmp_payload" 2>/dev/null || true
      if [ "${DEBUG:-0}" -eq 1 ]; then
        log_info "PAYLOAD" "Created base64-staged payload: $staged_b64"
      fi
    else
      if [ "${DEBUG:-0}" -eq 1 ]; then
        log_warn "PAYLOAD" "stage_b64 failed; using raw JSON payload"
      fi
      rm -f "$tmp_b64" 2>/dev/null || true
    fi
  fi

  if [ -n "$staged_b64" ]; then
    PAYLOAD="$staged_b64"
  else
    PAYLOAD="$tmp_payload"
  fi
  export PAYLOAD
  return 0
}

call_api_groq() {
  local provider_url="${BASH4LLM_PROVIDER_URL:-}"
  local api_key="${GROQ_API_KEY:-}"
  local http_code="" rc=0 payload_dec="" tmp_resp="" tmp_err=""

  enforce_network_policy || return $?

  if [ -z "$provider_url" ]; then
    log_error "CALL" "Provider URL not resolved"
    return "$BASH4LLM_ERR_API"
  fi

  payload_dec="$PAYLOAD"
  # Native suffix match replacing grep sub-process
  if [[ "$PAYLOAD" == *.b64 ]]; then
    payload_dec="$(_tmpf file "$RUN_TMPDIR" payload.dec 2>/dev/null)" || return "$BASH4LLM_ERR_TMP"
    if ! b64decode < "$PAYLOAD" > "$payload_dec" 2>/dev/null; then
      log_error "B64DECODE" "Failed to decode staging payload"
      rm -f "$payload_dec" 2>/dev/null || true
      return "$BASH4LLM_ERR_TMP"
    fi
  fi

  tmp_resp="$(_tmpf file "$RUN_TMPDIR" resp.tmp 2>/dev/null)" || { [ "$payload_dec" != "$PAYLOAD" ] && rm -f "$payload_dec" 2>/dev/null || true; return "$BASH4LLM_ERR_TMP"; }
  tmp_err="$(_tmpf file "$RUN_TMPDIR" err.tmp 2>/dev/null)" || { rm -f "$tmp_resp" 2>/dev/null || true; [ "$payload_dec" != "$PAYLOAD" ] && rm -f "$payload_dec" 2>/dev/null || true; return "$BASH4LLM_ERR_TMP"; }

  if [ "${DEBUG:-0}" -eq 1 ]; then
    log_info "CURL" "POST -> $provider_url"
  fi

  http_code="$(curl "${CURL_BASE_OPTS[@]}" \
    -X POST \
    -H "Authorization: Bearer $api_key" \
    -H "Content-Type: application/json" \
    --data-binary @"$payload_dec" \
    -o "$tmp_resp" \
    -w "%{http_code}" \
    "$provider_url" < /dev/null 2>"$tmp_err")"
  rc=$?

  if [ "$payload_dec" != "$PAYLOAD" ]; then
    rm -f "$payload_dec" 2>/dev/null || true
  fi

  if [ "$rc" -ne 0 ]; then
    log_error "CURL" "Network call failed with code $rc"
    cat "$tmp_err" >> "$ERRF" 2>/dev/null || true
    rm -f "$tmp_resp" "$tmp_err" 2>/dev/null || true
    return "$BASH4LLM_ERR_CURL_FAILED"
  fi

  if [ -s "$tmp_resp" ]; then
    if mv -f "$tmp_resp" "$RESP" 2>/dev/null; then
      chmod 600 "$RESP" 2>/dev/null || true
    else
      cp -f "$tmp_resp" "$RESP" 2>/dev/null || true
      chmod 600 "$RESP" 2>/dev/null || true
      rm -f "$tmp_resp" 2>/dev/null || true
    fi
  else
    rm -f "$tmp_resp" 2>/dev/null || true
  fi

  rm -f "$tmp_err" 2>/dev/null || true

  if [ "$http_code" -lt 200 ] || [ "$http_code" -ge 300 ]; then
    log_error "API" "HTTP Status code: $http_code"
    return "$BASH4LLM_ERR_API"
  fi

  return 0
}

# Single jq SSE streaming parser featuring instant HTTP and JSON API errors formatting
call_api_streaming_groq() {
  local tmp_payload="" provider_url="" resp_raw="" resp_lines="" resp_valid="" resp_chunks="" resp_tmp="" rc=0 stderr_head="" now_ts="" decoded_payload="" finish_reason="" req_id="" edgecase=0 send_payload="" CURL_CMD=() http_code="" json="" content="" resp_size=0 errf_size=0 resp_json_tmp="" p_dir="" api_json="" ui_last=""
  local curl_err_log=""

  if ! enforce_network_policy >/dev/null 2>&1; then
    if is_truthy "${DRY_RUN:-0}"; then
      if [ "${DEBUG:-0}" -eq 1 ]; then
        show_payload_head "${PAYLOAD:-}" 200 || true
        log_info "DRYRUN" "DRY-RUN: skipping streaming HTTP call"
      fi
      return 0
    fi
    log_error "NETWORK" "Network calls disabled; aborting streaming request."
    return "$BASH4LLM_ERR_CURL_FAILED"
  fi

  if [ -n "${PROVIDER_API_ENV_groq:-}" ] && declare -p "${PROVIDER_API_ENV_groq}" >/dev/null 2>&1; then
    custom_key_var="${PROVIDER_API_ENV_groq}"
    GROQ_API_KEY="${!custom_key_var:-}"
  fi
  if [ -z "${GROQ_API_KEY:-}" ] && [ -z "${BASH4LLM_API_KEY:-}" ]; then
    log_error "APIKEY" "GROQ_API_KEY (or BASH4LLM_API_KEY) is not set."
    return "$BASH4LLM_ERR_NO_API_KEY"
  fi

  tmp_payload="${BASH4LLM_TMP_PAYLOAD:-${PAYLOAD:-}}"
  if [ -z "${tmp_payload:-}" ]; then
    log_error "CALL_STREAM" "no payload file specified (BASH4LLM_TMP_PAYLOAD or PAYLOAD)"
    return 1
  fi
  if [ ! -s "$tmp_payload" ]; then
    log_error "CALL_STREAM" "Refusing to call curl: payload file is empty or missing: $tmp_payload"
    now_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    jq -c -n --arg ts "$now_ts" --arg note "empty_payload" '{diagnostic:true, note:$note, time:$ts}' > "${RESP:-$RUN_TMPDIR/resp.json}" 2>/dev/null || true
    return 1
  fi

  if [ -z "${BASH4LLM_PROVIDER_URL:-}" ]; then
    resolve_provider_url "${PROVIDER:-}" >/dev/null 2>&1 || true
  fi
  provider_url="${BASH4LLM_PROVIDER_URL:-}"
  if [ -z "${provider_url:-}" ]; then
    log_error "CALL_STREAM" "no provider URL set (BASH4LLM_PROVIDER_URL)"
    now_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    jq -c -n --arg ts "$now_ts" --arg note "no_provider_url" '{diagnostic:true, note:$note, time:$ts}' > "${RESP:-$RUN_TMPDIR/resp.json}" 2>/dev/null || true
    return 1
  fi

  resp_raw="$(_tmpf file "$RUN_TMPDIR" resp.raw 2>/dev/null)"
  resp_lines="$(_tmpf file "$RUN_TMPDIR" resp.lines 2>/dev/null)"
  resp_valid="$(_tmpf file "$RUN_TMPDIR" resp.valid.jsons 2>/dev/null)"
  resp_chunks="$(_tmpf file "$RUN_TMPDIR" resp.chunks.json 2>/dev/null)"
  
  curl_err_log="$(_tmpf file "$RUN_TMPDIR" curl_stream.err 2>/dev/null)"
  : > "$curl_err_log" 2>/dev/null || true
  rm -f "$resp_raw" "$resp_lines" "$resp_valid" "$resp_chunks" 2>/dev/null || true

  if [ "${DEBUG:-0}" -eq 1 ]; then
    log_info "CALL_STREAM" "Invoking streaming curl to $provider_url (payload: $tmp_payload)"
  fi

  decoded_payload="$(_tmpf file "$RUN_TMPDIR" payload.dec 2>/dev/null)" || true

  # Native suffix match replacing grep sub-process
  if [[ "$tmp_payload" == *.b64 ]]; then
    if ! b64decode < "$tmp_payload" > "$decoded_payload" 2>"$curl_err_log"; then
      log_error "B64DECODE" "base64 decode failed for payload; see $curl_err_log"
      rm -f "$decoded_payload" "$curl_err_log" 2>/dev/null || true
      return "$BASH4LLM_ERR_TMP"
    fi
    send_payload="$decoded_payload"
  else
    send_payload="$tmp_payload"
  fi

  CURL_CMD=(curl --http1.1 -sS -N)

  if [ -n "${CURL_BASE_OPTS[*]:-}" ]; then
    CURL_CMD+=("${CURL_BASE_OPTS[@]}")
  fi

  CURL_CMD+=( -H "Content-Type: application/json" )
  if [ -n "${GROQ_API_KEY:-}" ]; then
    CURL_CMD+=( -H "Authorization: Bearer ${GROQ_API_KEY}" )
  elif [ -n "${BASH4LLM_API_KEY:-}" ]; then
    CURL_CMD+=( -H "Authorization: Bearer ${BASH4LLM_API_KEY}" )
  fi

  # Print a safe terminal-only separation newline to stderr to prevent visual clutter before streaming
  if [ "${QUIET:-0}" -ne 1 ] && [ -t 2 ]; then
    printf '\n' >&2
  fi

  # Single-pass unbuffered jq pipeline preserving stream raw telemetry
  "${CURL_CMD[@]}" --data-binary @"$send_payload" "$provider_url" 2> "$curl_err_log" | \
  tee "$resp_raw" | \
  jq --unbuffered -R -r '
    if startswith("data: ") then
      sub("^data:[[:space:]]*"; "") |
      select(. != "[DONE]") |
      try (fromjson | .choices[0] | (.delta.content // .message.content // "")) catch ""
    else
      try (
        fromjson | 
        if .error.message then ("\nAPI Error: " + .error.message) 
        elif .message then ("\nAPI Error: " + .message) 
        else empty end
      ) catch empty
    fi
  '

  rc=${PIPESTATUS[0]:-0}
  if [ "$rc" -eq 141 ]; then
    rc=0
  fi

  rm -f "$decoded_payload" 2>/dev/null || true

  resp_size=0; [ -f "$resp_raw" ] && resp_size=$(wc -c < "$resp_raw" 2>/dev/null || echo 0)
  errf_size=0; [ -f "$curl_err_log" ] && errf_size=$(wc -c < "$curl_err_log" 2>/dev/null || echo 0)
  if [ "${DEBUG:-0}" -eq 1 ]; then
    log_info "CALL_STREAM" "curl rc=${rc} resp_raw_size=${resp_size}B ERRF_size=${errf_size}B"
    if [ -s "$curl_err_log" ]; then
      log_info "CALL_STREAM" "curl stderr (head 400 chars):"
      head -c 400 "$curl_err_log" 2>/dev/null | sed -n '1,20p' >&2 || true
    fi
  fi

  if [ -s "$resp_raw" ]; then
    grep -E '^data:' "$resp_raw" 2>/dev/null | sed -E 's/^data:[[:space:]]*//' > "$resp_lines" 2>/dev/null || true
  fi

  : > "$resp_valid" 2>/dev/null || true
  if [ -f "$resp_lines" ] && [ -s "$resp_lines" ]; then
    while IFS= read -r _line; do
      if printf '%s' "$_line" | jq -e . >/dev/null 2>&1; then
        printf '%s\n' "$_line" >> "$resp_valid"
      fi
    done < "$resp_lines"
  fi

  if [ -s "$resp_valid" ]; then
    jq -s '.' "$resp_valid" > "$resp_chunks" 2>/dev/null || true
    resp_json_tmp="$(_tmpf file "$RUN_TMPDIR" resp.json 2>/dev/null)"
    
    # Builds a standard synthetic JSON by unifying all deltas into a single text,
    # ensuring that thread history and metrics are properly preserved.
    jq -c '
      if (length > 0) then
        .[0] as $first |
        .[-1] as $last |
        {
          id: ($last.id // $first.id // "synthetic"),
          object: "chat.completion",
          created: ($last.created // $first.created // 0),
          model: ($last.model // $first.model // "unknown"),
          choices: [{
            index: 0,
            message: {
              role: "assistant",
              content: (map(.choices[]?.delta?.content // .choices[]?.message?.content // "") | join(""))
            },
            finish_reason: ($last.choices[0]?.finish_reason // "stop")
          }],
          usage: ($last.usage // empty)
        }
      else
        {}
      fi
    ' "$resp_chunks" > "$resp_json_tmp" 2>/dev/null || true
  else
    resp_json_tmp="$(_tmpf file "$RUN_TMPDIR" resp.json 2>/dev/null)"
    if jq -e . "$resp_raw" >/dev/null 2>&1; then
      cp -f "$resp_raw" "$resp_json_tmp" 2>/dev/null || true
    fi
  fi

  rm -f "$resp_raw" 2>/dev/null || true
  rm -f "$resp_lines" 2>/dev/null || true
  rm -f "$resp_valid" 2>/dev/null || true
  rm -f "$resp_chunks" 2>/dev/null || true

  resp_tmp="$resp_json_tmp"

  if [ -z "${RESP:-}" ]; then
    RESP="${RUN_TMPDIR%/}/resp.json"
  fi
  p_dir="$(dirname "$RESP")"
  safe_mkdir "$p_dir" 700

  if [ -s "$resp_tmp" ]; then
    if [ "${resp_tmp%/}" = "${RESP%/}" ]; then
      chmod 600 "$RESP" 2>/dev/null || true
    else
      if mv -f "$resp_tmp" "${RESP}" 2>/dev/null; then
        chmod 600 "${RESP}" 2>/dev/null || true
      else
        log_error "RESP" "mv failed; writing diagnostic RESP"
        now_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
        stderr_head="$(head -c 200 "${curl_err_log:-/dev/null}" 2>/dev/null | sed 's/"/\\"/g' || true)"
        jq -c -n --arg http "${http_code:-0}" --arg ts "$now_ts" --arg err "$stderr_head" \
          '{diagnostic:true, last_http_status:($http|tonumber), last_time_utc:$ts, stderr_head:$err}' > "${RESP}" 2>/dev/null || true
      fi
    fi
  else
    now_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    stderr_head="$(head -c 200 "${curl_err_log:-/dev/null}" 2>/dev/null | sed 's/"/\\"/g' || true)"
    jq -c -n --arg http "${http_code:-0}" --arg ts "$now_ts" --arg err "$stderr_head" \
          '{diagnostic:true, last_http_status:($http|tonumber), last_time_utc:$ts, stderr_head:$err}' > "${RESP}" 2>/dev/null || printf '{"diagnostic":true,"last_http_status":%s,"last_time_utc":"%s"}\n' "${http_code:-0}" "$now_ts" > "${RESP}"
  fi

  rm -f "$resp_tmp" 2>/dev/null || true
  rm -f "$curl_err_log" 2>/dev/null || true

  if ensure_run_tmpdir >/dev/null 2>&1; then
    http_code=200
    finish_reason="$(jq -r '.choices[0]?.finish_reason // empty' "${RESP}" 2>/dev/null || echo "")"
    req_id="$(jq -r '.x_groq?.id // .id // empty' "${RESP}" 2>/dev/null || echo "")"
    edgecase=0
    if [ "${BASH4LLM_EDGE_EMPTY:-0}" -eq 1 ]; then edgecase=1; fi
    now_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    api_json="$(jq -c -n --argjson http "$http_code" --arg fr "${finish_reason:-}" --argjson edge "$edgecase" --arg id "${req_id:-}" --arg ts "$now_ts" '{last_http_status:$http, last_finish_reason:$fr, last_edgecase_detected:$edge, last_req_id:$id, last_time_utc:$ts}')"
    ui_state_write "last_api.json" "$api_json" || { if [ "${DEBUG:-0}" -eq 1 ]; then log_warn "UI_STATE" "failed to write last_api.json (streaming)"; fi; }
  fi

  return "${rc:-0}"
}

refresh_models_groq() {
  if [ -n "${PROVIDER_API_ENV_groq:-}" ] && declare -p "${PROVIDER_API_ENV_groq}" >/dev/null 2>&1; then
    custom_key_var="${PROVIDER_API_ENV_groq}"
    GROQ_API_KEY="${!custom_key_var:-}"
  fi
  if [ -z "${GROQ_API_KEY:-}" ]; then
    log_error "APIKEY" "GROQ_API_KEY is required to refresh models."
    return "$BASH4LLM_ERR_NO_API_KEY"
  fi

  ensure_run_tmpdir || return "$BASH4LLM_ERR_TMP"
  local workdir="" tmpd="" out="" errf="" api_url="" tmp_parsed="" tmp_trim="" tmpout="" rc=0 origin="" lockfile=""
  workdir="${RUN_TMPDIR:-}"
  [ -n "$workdir" ] || return "$BASH4LLM_ERR_TMP"
  tmpd="$(mktemp -d "$workdir/groq-models.XXXXXX")" || return "$BASH4LLM_ERR_TMP"
  out="$tmpd/models.json"
  errf="$tmpd/curl.err"

  resolve_provider_url "${PROVIDER:-}" >/dev/null 2>&1 || true
  if [ -n "${BASH4LLM_PROVIDER_URL:-}" ]; then
    origin="$(printf '%s' "$BASH4LLM_PROVIDER_URL" | sed -E 's#(https?://[^/]+).*#\1#')"
    api_url="${origin%/}/openai/v1/models"
  else
    log_error "MODELREFRESH" "no provider URL available to refresh models"
    rm -rf "$tmpd"
    return "$BASH4LLM_ERR_API"
  fi

  rm -f "$out" "$errf" 2>/dev/null || true
  if ! curl "${CURL_BASE_OPTS[@]}" -H "Authorization: Bearer ${GROQ_API_KEY}" -H "Content-Type: application/json" "${api_url}?limit=${MAX_MODELS}" -o "$out" 2>"$errf"; then
    log_error "MODELREFRESH" "Failed to fetch models from $api_url"
    if [ "${DEBUG:-0}" -eq 1 ]; then
      head -n 200 "$errf" >&2 || true
    fi
    rm -rf "$tmpd"
    return "$BASH4LLM_ERR_API"
  fi

  if ! jq -e . "$out" >/dev/null 2>&1; then
    log_error "MODELREFRESH" "Invalid JSON received from $api_url"
    if [ "${DEBUG:-0}" -eq 1 ]; then
      head -n 200 "$errf" >&2 || true
    fi
    rm -rf "$tmpd"
    return "$BASH4LLM_ERR_API"
  fi

  tmp_parsed="$tmpd/parsed_models.txt"
  : > "$tmp_parsed"

  jq -r '
    if (has("data") and (.data|type) == "array") then
      .data[]? | (.id // .name // empty)
    elif (type == "array") then
      .[]? | (.id // .name // empty)
    else
      empty
    end
  ' "$out" | awk 'NF{print}' | sed -E 's/^[[:space:]]+//;s/[[:space:]]+$//' | sort -u > "$tmp_parsed" 2>/dev/null || true

  if [ ! -s "$tmp_parsed" ]; then
    log_error "MODELREFRESH" "models refresh: parsed list empty"
    if [ "${DEBUG:-0}" -eq 1 ]; then
      head -n 200 "$errf" >&2 || true
    fi
    rm -rf "$tmpd"
    return "$BASH4LLM_ERR_API"
  fi

  tmp_trim="$tmpd/parsed_trimmed.txt"
  awk '{
    g=$0
    sub(/^models\//,"",g)
    sub(/^groq[:\/-]*/,"",g)
    if (g ~ /^[[:alnum:]._\/:-]+$/) print g
  }' "$tmp_parsed" | awk -v M="$MAX_MODELS" 'NR<=M{print}' > "$tmp_trim" || true

  if [ ! -s "$tmp_trim" ]; then
    log_error "MODELREFRESH" "no valid model names after normalization"
    rm -rf "$tmpd"
    return "$BASH4LLM_ERR_API"
  fi

  safe_mkdir "$(dirname "$MODELS_FILE")" 700
  tmpout="$(_mktemp_in_dir "$(dirname "$MODELS_FILE")" 2>/dev/null)" || true
  [ -n "$tmpout" ] || tmpout="$(_tmpf file "$(dirname "$MODELS_FILE")" models 2>/dev/null)"

  cat "$tmp_trim" > "$tmpout"

  if ! b64_atomic_write "${MODELS_FILE}.b64" 10 < "$tmpout"; then
    log_error "MODELREFRESH" "failed to stage models file"
    rm -f "$tmpout" 2>/dev/null || true
    rm -rf "$tmpd"
    return "$BASH4LLM_ERR_TMP"
  fi

  lockfile="$MODELS_LOCK"
  lock_exec "$lockfile" 10 -- base64 "${B64_DECODE_OPT}" < "${MODELS_FILE}.b64" > "$MODELS_FILE" \
    || { log_error "MODELREFRESH" "failed to write models file under lock"; rm -rf "$tmpd"; return "$BASH4LLM_ERR_TMP"; }

  chmod 600 "$MODELS_FILE" 2>/dev/null || true

  log_info_user "MODELREFRESH" "Models refreshed and saved to: $MODELS_FILE (max ${MAX_MODELS})"

  # Safe cleanup of the staged tmpout file to eliminate resource leak
  [ -n "${tmpout:-}" ] && [ -f "$tmpout" ] && rm -f "$tmpout" 2>/dev/null || true
  rm -rf "$tmpd"
  return 0
}

validate_model_groq() {
  local model="${1:-}"
  validate_model_core "$model"
  return $?
}

validate_key_groq() {
  local key="${1:-}"
  local url="${BASH4LLM_PROVIDER_URL:-https://api.groq.com/openai/v1/chat/completions}"
  local base_url="${url%/chat/completions}"
  local api_url="${base_url%/v1}/v1/models"
  local http_code="" curl_rc=0
  local tmpout="" errf=""

  if [ -z "$key" ]; then
    return 1
  fi

  if type _mktemp_in_dir >/dev/null 2>&1; then
    tmpout="$(_mktemp_in_dir "$BASH4LLM_TMPDIR" 2>/dev/null || true)"
  fi
  [ -n "$tmpout" ] || tmpout="$(_tmpf file "$BASH4LLM_TMPDIR" groq-key-diag 2>/dev/null || mktemp "${BASH4LLM_TMPDIR}/groq-key-diag.XXXXXX")"
  errf="${tmpout}.err"

  http_code="$(curl "${CURL_BASE_OPTS[@]}" --max-time 10 \
    -H "Authorization: Bearer $key" \
    -o "$tmpout" \
    -w "%{http_code}" \
    "$api_url" 2>"$errf" || echo "CURL_ERR")"
  curl_rc=$?

  rm -f "$tmpout" "$errf" 2>/dev/null || true

  if [ "$http_code" = "CURL_ERR" ] || [ "$curl_rc" -eq 28 ]; then
    return 28
  fi

  if [ "$http_code" = "200" ]; then
    return 0
  else
    return 1
  fi
}

auto_select_model_groq() {
  local file="$MODELS_FILE" line="" norm="" cnt=0
  if [ -f "$file" ] && [ -s "$file" ]; then
    relative_mfile="$(canonical_model_file "groq")"
    if [ -f "$relative_mfile" ] && [ -s "$relative_mfile" ]; then
      norm="$(_normalize_model_name "$(head -n1 "$relative_mfile" 2>/dev/null)")"
      if [ -n "$norm" ] && is_supported_model "$norm"; then
        printf '%s' "$norm"
        return 0
      fi
    fi
    while IFS= read -r line || [ -n "$line" ]; do
      [ -z "$line" ] && continue
      cnt=$((cnt+1))
      norm="$(_normalize_model_name "$line")"
      if is_supported_model "$norm"; then
        printf '%s' "$norm"
        return 0
      fi
      [ "$cnt" -ge "$MAX_MODELS" ] && break
    done < "$file"
  fi
  return 1
}
########################################
# SECTION: PROVIDER - END
########################################
########################################
# SECTION: CORE_SETUP - BEGIN
########################################
#--1<---[ SECTION: CORE_SETUP_DISPATCH_HELPERS ]--->1--
validate_provider_interface() {
  local p="${1:-}"
  local missing=0
  local -a required=( "buildpayload_${p}" "call_api_${p}" )
  local -a optional=( "call_api_streaming_${p}" "refresh_models_${p}" "validate_model_${p}" "auto_select_model_${p}" )
  local f=""

  for f in "${required[@]}"; do
    if ! type "$f" >/dev/null 2>&1; then
      log_error "PROVIDER" "Provider '$p' module does not define required function $f()."
      missing=1
    fi
  done

  for f in "${optional[@]}"; do
    if ! type "$f" >/dev/null 2>&1; then
      if [ "${DEBUG:-0}" -eq 1 ]; then
        log_info "PROVIDER" "Provider '$p' missing optional function $f()"
      fi
    fi
  done

  return $missing
}

call_provider() {
  local fn="${1:-}"
  local -a shift_args=("${@:2}")
  if type "$fn" >/dev/null 2>&1; then
    "$fn" ${shift_args[@]+"${shift_args[@]}"}
    return $?
  fi
  return 127
}

validate_provider_key_dispatch() {
  local key="${1:-}"
  local fn="validate_key_${PROVIDER}"

  if type "$fn" >/dev/null 2>&1; then
    "$fn" "$key"
    return $?
  fi

  return 127
}

refresh_models_dispatch() {
  local destfile="${1:-${MODELS_FILE:-$BASH4LLM_MODELS_DIR/models.txt}}"
  local fn="refresh_models_${PROVIDER}"
  local rc=0

  if ! type "$fn" >/dev/null 2>&1; then
    log_error "MODELREFRESH" "Provider '$PROVIDER' does not implement $fn()."
    return 127
  fi

  if "$fn" "$destfile" 2>/dev/null; then
    if [ "${DEBUG:-0}" -eq 1 ]; then
      log_info "MODELREFRESH" "Models refreshed for provider $PROVIDER -> $destfile"
    fi
    print_persistence_reminder
    return 0
  fi

  rc=$?
  if "$fn" 2>/dev/null; then
    if [ "${DEBUG:-0}" -eq 1 ]; then
      log_info "MODELREFRESH" "Models refreshed for provider $PROVIDER (no explicit dest)"
    fi
    print_persistence_reminder
    return 0
  fi

  rc=$?
  log_error "MODELREFRESH" "refresh_models for provider $PROVIDER failed (rc $rc)."
  return "$rc"
}

validate_model_dispatch() {
  local model="${1:-}"
  local fn="validate_model_${PROVIDER}"

  if type "$fn" >/dev/null 2>&1; then
    "$fn" "$model"
    return $?
  fi

  if [ -z "${VALIDATE_MODEL_DISPATCH_WARNED:-}" ]; then
    log_warn "MODEL" "provider '${PROVIDER}' does not implement ${fn}; falling back to permissive validation."
    VALIDATE_MODEL_DISPATCH_WARNED=1
  fi

  return 0
}

auto_select_model_dispatch() {
  local fn="auto_select_model_${PROVIDER}"
  if type "$fn" >/dev/null 2>&1; then
    "$fn"
    return $?
  fi
  return 127
}
#--1<---[ /SECTION: CORE_SETUP_DISPATCH_HELPERS ]--->1--
#--2<---[ SECTION: CORE_SETUP_API_CALL ]--->2--
resolve_model() {
  local active_provider="" candidate="" norm="" MODEL_PROVIDER_CFG="" cfg_model="" cnt=0 m=""
  ALLOWED_MODELS="${ALLOWED_MODELS:-}"

  if [ -n "${MODEL:-}" ] && [ "${MODEL_CLI_SET:-0}" -ne 1 ] && [ "${CHAT_MODE:-0}" -ne 1 ]; then
    MODEL_PROVIDER_CFG="$(canonical_model_file "${PROVIDER:-groq}")"
    if [ ! -s "$MODEL_PROVIDER_CFG" ]; then
      log_warn "MODEL" "MODEL is set in environment but not passed with -m/--set-default; use -m for per-run override or --set-default to persist."
    fi
  fi

  FINAL_MODEL=""

  if [ "${MODEL_CLI_SET:-0}" -eq 1 ] && [ -n "${MODEL:-}" ]; then
    FINAL_MODEL="$MODEL"
    return 0
  fi

  if [ -n "${PROVIDER_CLI:-}" ] && [ "$PROVIDER_CLI" != "list" ]; then
    active_provider="${PROVIDER_CLI}"
  elif [ -f "$(canonical_provider_file)" ] && [ -s "$(canonical_provider_file)" ]; then
    active_provider="$(sed -n '1p' "$(canonical_provider_file)" 2>/dev/null || true)"
    active_provider="$(printf '%s' "$active_provider" | awk '{$1=$1;print}')"
    [ -z "$active_provider" ] && active_provider="${PROVIDER:-groq}"
  else
    active_provider="${PROVIDER:-groq}"
  fi

  MODEL_PROVIDER_CFG="$(canonical_model_file "${active_provider}")"

  if [ -z "$(canonical_config_dir)" ] || [ "$(canonical_config_dir)" = "/" ]; then
    log_error "SEC" "refusing to read provider-specific model file: invalid canonical config dir: $(canonical_config_dir)"
  else
    if [ -s "$MODEL_PROVIDER_CFG" ]; then
      candidate="$(sed -n '1p' "$MODEL_PROVIDER_CFG" 2>/dev/null || true)"
      candidate="$(printf '%s' "$candidate" | awk '{$1=$1;print}')"
      norm="$(_normalize_model_name "$candidate")"
      if [ -n "$norm" ] && is_supported_model "$norm"; then
        if validate_model_core "$norm" >/dev/null 2>&1 && validate_model_dispatch "$norm" >/dev/null 2>&1; then
          FINAL_MODEL="$norm"
          return 0
        fi
      fi
    fi
  fi

  candidate="$(auto_select_model_dispatch 2>/dev/null || true)"
  if [ -n "$candidate" ]; then
    norm="$(_normalize_model_name "$candidate")"
    if is_supported_model "$norm"; then
      if validate_model_core "$norm" >/dev/null 2>&1 && validate_model_dispatch "$norm" >/dev/null 2>&1; then
        FINAL_MODEL="$norm"
        return 0
      fi
    fi
  fi

  if [ -f "${MODELS_FILE:-}" ] && [ -s "${MODELS_FILE:-}" ]; then
    cnt=0
    while IFS= read -r m || [ -n "$m" ]; do
      [ -z "$m" ] && continue
      cnt=$((cnt+1))
      norm="$(_normalize_model_name "$m")"
      if is_supported_model "$norm"; then
        if validate_model_core "$norm" >/dev/null 2>&1 && validate_model_dispatch "$norm" >/dev/null 2>&1; then
          FINAL_MODEL="$norm"
          return 0
        fi
      fi
      [ "$cnt" -ge "$MAX_MODELS" ] && break
    done < "$MODELS_FILE"
  fi

  if [ -f "${BASH4LLM_CONFIG_DIR%/}/config" ]; then
    cfg_model="$(awk -F= '/^MODEL=/ {sub(/^MODEL=/,""); print; exit}' "${BASH4LLM_CONFIG_DIR%/}/config" 2>/dev/null || true)"
    cfg_model="$(printf '%s' "$cfg_model" | awk '{$1=$1;print}')"
    norm="$(_normalize_model_name "$cfg_model")"
    if [ -n "$norm" ] && is_supported_model "$norm"; then
      if validate_model_core "$norm" >/dev/null 2>&1 && validate_model_dispatch "$norm" >/dev/null 2>&1; then
        FINAL_MODEL="$norm"
        return 0
      fi
    fi
  fi

  if [ -n "${ALLOWED_MODELS:-}" ]; then
    cnt=0
    while IFS= read -r m || [ -n "$m" ]; do
      [ -z "$m" ] && continue
      cnt=$((cnt+1))
      norm="$(_normalize_model_name "$m")"
      if is_supported_model "$norm"; then
        if validate_model_core "$norm" >/dev/null 2>&1 && validate_model_dispatch "$norm" >/dev/null 2>&1; then
          FINAL_MODEL="$norm"
          return 0
        fi
      fi
      [ "$cnt" -ge "$MAX_MODELS" ] && break
    done <<EOF
$(printf '%s\n' "$ALLOWED_MODELS")
EOF
  fi

  FINAL_MODEL=""
  return 1
}

build_payload_from_vars() {
  ensure_run_tmpdir
  local fn="buildpayload_${PROVIDER}"
  local rc=""
  if call_provider "$fn"; then
    return 0
  else
    rc=$?
    if [ "$rc" -eq 127 ]; then
      log_error "PROVIDER" "Provider '$PROVIDER' does not provide $fn()."
      exit "$BASH4LLM_ERR_API"
    else
      return "$rc"
    fi
  fi
}

call_api_once() {
  local fn="call_api_${PROVIDER}"
  local rc=""
  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    if [ "${DEBUG:-0}" -eq 1 ]; then
      show_payload_head "$PAYLOAD" 200 || true
      log_info "DRYRUN" "DRY-RUN: skipping provider HTTP call"
    fi
    return 0
  fi
  if call_provider "$fn"; then
    return 0
  else
    rc=$?
    if [ "$rc" -eq 127 ]; then
      log_error "PROVIDER" "Provider '$PROVIDER' does not provide $fn()."
      exit "$BASH4LLM_ERR_API"
    else
      return "$rc"
    fi
  fi
}

call_api_streaming() {
  acquire_thread_lock || return $?

  local fn="call_api_streaming_${PROVIDER}"
  local rc=""
  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    if [ "${DEBUG:-0}" -eq 1 ]; then
      show_payload_head "$PAYLOAD" 200 || true
      log_info "DRYRUN" "DRY-RUN: skipping provider streaming HTTP call"
    fi
    release_thread_lock
    return 0
  fi

  # Clean interrupt handling without eval (security policy compliant)
  trap 'printf "\n[Streaming request interrupted by user]\n" >&2; exit 130' INT

  call_provider "$fn"
  rc=$?

  # Restore default behavior
  trap - INT

  release_thread_lock
  return "$rc"
}

extract_api_error() {
  if [ ! -s "${RESP:-}" ]; then return 0; fi
  if jq -e . "$RESP" >/dev/null 2>&1; then
    jq -r '
      ( [ .error?.message // empty ] 
        + [ .choices[]? | (.message?.content // .delta?.content // empty) ] )
      | map(select(length > 0))
      | .[0] // empty
    ' "$RESP" 2>/dev/null | head -n1 || true
  else
    awk 'NF{print; exit}' "$RESP" 2>/dev/null || true
  fi
}

detect_empty_edge_case() {
  local resp="${RESP:-}"
  local tmp_copy="" content="" finish_reason="" completion_tokens=0 req_id=""
  BASH4LLM_EDGE_EMPTY=0
  BASH4LLM_EDGE_REQ_ID=""
  BASH4LLM_EDGE_FINISH_REASON=""
  BASH4LLM_EDGE_COMPLETION_TOKENS=0

  tmp_copy="$(_tmpf file "${RUN_TMPDIR:-$BASH4LLM_TMPDIR}" resp_copy 2>/dev/null)" || return 1
  cp -f "$resp" "$tmp_copy" 2>/dev/null || return 1
  resp="$tmp_copy"

  if [ -z "${resp:-}" ] || [ ! -s "$resp" ]; then
    BASH4LLM_EDGE_EMPTY=1
    return 0
  fi

  if ! is_valid_json_file "$resp"; then
    BASH4LLM_EDGE_EMPTY=1
    return 0
  fi

  if jq -e 'has("diagnostic") and .diagnostic==true' "$resp" >/dev/null 2>&1; then
    BASH4LLM_EDGE_EMPTY=1
    return 0
  fi

  content="$(jq -r '.choices[0]?.message?.content // .choices[0]?.delta?.content // ""' "$resp" 2>/dev/null || echo "")"
  finish_reason="$(jq -r '.choices[0]?.finish_reason // ""' "$resp" 2>/dev/null || echo "")"
  completion_tokens="$(jq -r '.usage?.completion_tokens // 0' "$resp" 2>/dev/null || echo 0)"
  req_id="$(jq -r '.x_groq?.id // .id // empty' "$resp" 2>/dev/null || echo "")"

  BASH4LLM_EDGE_REQ_ID="${req_id:-}"
  BASH4LLM_EDGE_FINISH_REASON="${finish_reason:-}"
  BASH4LLM_EDGE_COMPLETION_TOKENS="${completion_tokens:-0}"

  if [ -z "$content" ] && [ "$finish_reason" = "stop" ] && [ "${completion_tokens:-0}" -ne 0 ] && [ "${completion_tokens:-0}" -le 1 ]; then
    BASH4LLM_EDGE_EMPTY=1
  else
    BASH4LLM_EDGE_EMPTY=0
  fi

  return 0
}

finalize_and_output() {
  local mode="${1:-}" text="${2:-}"
  local resp_file="" tmp_copy="" len=0 do_save=0 dest_dir="" dest_path="" tmp_save=""

  resp_file="${RESP:-}"
  if [ -n "$resp_file" ]; then
    tmp_copy="$(_tmpf file "${RUN_TMPDIR:-$BASH4LLM_TMPDIR}" resp_copy 2>/dev/null)" || return "$BASH4LLM_ERR_TMP"
    cp -f "$resp_file" "$tmp_copy" 2>/dev/null || return "$BASH4LLM_ERR_TMP"
    resp_file="$tmp_copy"
  fi

  if { [ "$mode" = "json" ] || [ "$mode" = "pretty" ]; } && [ ! -s "$resp_file" ]; then
    log_error "RESP" "response file missing or empty: ${RESP:-<unset>}"
    return "$BASH4LLM_ERR_TMP"
  fi

  # Print a safe terminal-only separation newline to stderr to prevent visual clutter
  if [ "${QUIET:-0}" -ne 1 ] && [ -t 2 ]; then
    printf '\n' >&2
  fi

  case "$mode" in
    json) cat "$resp_file" ;;
    pretty) if jq -e . "$resp_file" >/dev/null 2>&1; then jq . "$resp_file"; else cat "$resp_file"; fi ;;
    raw) printf '%s' "$text" ;;
    text) printf '%s\n' "$text" ;;
    *) printf '%s\n' "$text" ;;
  esac

  if [ "$mode" = "text" ] || [ "$mode" = "raw" ]; then
    if [ "${FORCE_SAVE_MODE:-}" = "nosave" ]; then return 0; fi
    do_save=0
    len="$(printf '%s' "$text" | wc -c | tr -d ' ')"
    if [ "${FORCE_SAVE_MODE:-}" = "save" ]; then
      do_save=1
    else
      if [ "$len" -gt "$THRESHOLD" ]; then
        do_save=1
      fi
    fi
    if [ "$do_save" -eq 1 ]; then
      if [ -n "$OUT_PATH" ]; then
        if [ -d "$OUT_PATH" ]; then
          dest_dir="$OUT_PATH"
          dest_path="$dest_dir/$(date +%Y%m%d-%H%M%S)-groq-output-$$.txt"
        else
          dest_path="$OUT_PATH"
          dest_dir="$(dirname "$dest_path")"
        fi
      else
        dest_dir="$BASH4LLM_HISTORY_DIR"
        dest_path="$dest_dir/$(date +%Y%m%d-%H%M%S)-groq-output-$$.txt"
      fi
      safe_mkdir "$dest_dir" 700

      if [ -z "${RUN_TMPDIR:-}" ] || [ ! -d "$RUN_TMPDIR" ]; then
        log_error "TMP" "cannot create or access RUN_TMPDIR ($BASH4LLM_TMPDIR). Aborting."
        return "$BASH4LLM_ERR_TMP"
      fi

      tmp_save="$(_tmpf file "$RUN_TMPDIR" save.tmp 2>/dev/null)" || return "$BASH4LLM_ERR_TMP"
      printf '%s\n' "$text" > "$tmp_save" 2>/dev/null || { rm -f "$tmp_save" 2>/dev/null || true; return "$BASH4LLM_ERR_TMP"; }

      lock_exec "$HISTORY_LOCK" 10 -- mv -f "$tmp_save" "$dest_path" || { rm -f "$tmp_save" 2>/dev/null || true; return "$BASH4LLM_ERR_TMP"; }
      chmod 600 "$dest_path" 2>/dev/null || true
    fi
  fi
}

perform_request_once() {
  acquire_thread_lock || return $?

  local attempt=1 rc="" text="" api_err="" ui_last="" finish_reason="" req_id="" edgecase=0 now_ts="" http_code_fallback="" api_json=""
  local prev_trap=""

  while [ "$attempt" -le "$MAX_RETRIES" ]; do
    # Clean interrupt handling without eval (security policy compliant)
    trap 'printf "\n[Request interrupted by user]\n" >&2; exit 130' INT

    call_api_once
    rc=$?

    # Restore default behavior
    trap - INT

    if [ "$rc" -eq 130 ]; then
      release_thread_lock
      return 130
    fi

    if [ "$rc" -eq 0 ]; then
      if [ "${DRY_RUN:-0}" -eq 1 ]; then
        if [ "${DEBUG:-0}" -eq 1 ]; then
          log_info "DRYRUN" "DRY-RUN: request simulated successfully. Payload: $PAYLOAD"
        fi
        release_thread_lock
        return 0
      fi

      BASH4LLM_EDGE_EMPTY=0
      BASH4LLM_EDGE_REQ_ID=""
      BASH4LLM_EDGE_FINISH_REASON=""
      BASH4LLM_EDGE_COMPLETION_TOKENS=0

      text="$(extract_text_from_resp || true)"
      detect_empty_edge_case || true

      ui_last="${BASH4LLM_CONFIG_DIR%/}/ui_state/last_api.json"
      if [ ! -f "$ui_last" ] || [ "$ui_last" -ot "${RESP:-/dev/null}" ]; then
        finish_reason="$(jq -r '.choices[0]?.finish_reason // empty' "$RESP" 2>/dev/null || echo "")"
        req_id="$(jq -r '.x_groq?.id // .id // empty' "$RESP" 2>/dev/null || echo "")"
        edgecase=0
        if [ "${BASH4LLM_EDGE_EMPTY:-0}" -eq 1 ]; then edgecase=1; fi
        now_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
        http_code_fallback=0
        if [ -s "$RESP" ]; then http_code_fallback=200; fi
        api_json="$(jq -c -n --argjson http "$http_code_fallback" --arg fr "${finish_reason:-}" --argjson edge "$edgecase" --arg id "${req_id:-}" --arg ts "$now_ts" '{last_http_status:$http, last_finish_reason:$fr, last_edgecase_detected:$edge, last_req_id:$id, last_time_utc:$ts}')"
        ui_state_write "last_api.json" "$api_json" || { if [ "${DEBUG:-0}" -eq 1 ]; then log_warn "UI_STATE" "failed to write fallback last_api.json"; fi; }
      fi

      if [ -z "$text" ] && [ "$OUTPUT_MODE" != "json" ] && [ "$OUTPUT_MODE" != "pretty" ]; then
        api_err="$(extract_api_error || true)"
        if [ -n "$api_err" ]; then
          log_error "API" "API error: $api_err"
          release_thread_lock
          return "$BASH4LLM_ERR_API"
        else
          if [ "${BASH4LLM_EDGE_EMPTY:-0}" -eq 1 ]; then
            printf '%s\n' \
              "API edge case detected: empty completion" \
              "  req_id: ${BASH4LLM_EDGE_REQ_ID:-<none>}" \
              "  finish_reason: ${BASH4LLM_EDGE_FINISH_REASON:-<none>}" \
              "  completion_tokens: ${BASH4LLM_EDGE_COMPLETION_TOKENS:-0}" >&2

            log_error "API" "empty completion returned by provider (see previous diagnostic lines)."
            release_thread_lock
            return "$BASH4LLM_ERR_API"
          fi

          log_error "API" "no textual content extracted from response."
          if [ "${DEBUG:-0}" -eq 1 ]; then
            head -n 50 "${RESP:-/dev/null}" >&2 || true
          fi
          release_thread_lock
          return "$BASH4LLM_ERR_API"
        fi
      fi

      finalize_and_output "$OUTPUT_MODE" "$text"
      print_persistence_reminder
      release_thread_lock
      return 0
    else
      if [ "$rc" -eq "$BASH4LLM_ERR_CURL_FAILED" ]; then
        printf 'bash4llm: %sWARN%s: Network error (curl). Retrying...\n' "${C_BYELLOW}" "${C_RST}" >&2
      elif [ "$rc" -eq "$BASH4LLM_ERR_API" ]; then
        printf 'bash4llm: %sERROR%s: HTTP/API error. Not retrying.\n' "${C_RED}" "${C_RST}" >&2
        if [ "${DEBUG:-0}" -eq 1 ]; then
          head -n 50 "${RESP:-/dev/null}" >&2 || true
        fi
        release_thread_lock
        return "$BASH4LLM_ERR_API"
      else
        printf 'bash4llm: %sWARN%s: Unknown error (code %s). Retrying...\n' "${C_BYELLOW}" "${C_RST}" "$rc" >&2
      fi
    fi

    attempt=$((attempt + 1)); sleep $((attempt * 1))
  done

  log_error "REQUEST" "request failed after $MAX_RETRIES attempts."
  release_thread_lock
  return "$BASH4LLM_ERR_API"
}
#--2<---[ /SECTION: CORE_SETUP_API_CALL ]--->2--
#--3<---[ SECTION: CORE_SETUP_INPUT_HELPERS ]--->3--
collect_input_from_files() {
  local out="" first=1 f
  for f in "$@"; do
    if file_readable "$f"; then
      [ "$first" -eq 0 ] && out="${out}"$'\n\n'"--- FILE: ${a} ---"$'\n\n'
      out="${out}$(cat "$f")"; first=0
    else log_error "FILE" "file not readable: $f"; exit "$BASH4LLM_ERR_TMP"; fi
  done
  printf '%s' "$out"
}

expand_args_to_content() {
  local out="" first=1 a
  # Guard against empty array expansion under strict set -u shell mode
  for a in ${ARGS[@]+"${ARGS[@]}"}; do
    if file_readable "$a"; then
      [ "$first" -eq 0 ] && out="${out}"$'\n\n'"--- FILE: ${a} ---"$'\n\n'
      out="${out}$(cat "$a")"; first=0
    else
      [ "$first" -eq 0 ] && out="${out}"$'\n\n'
      out="${out}${a}"; first=0
    fi
  done
  printf '%s' "$out"
}

file_readable() { [ -r "$1" ] && [ -f "$1" ]; }
    
trim() { printf '%s' "$1" | awk '{$1=$1; print}'; }

is_number() { printf '%s\n' "$1" | awk 'BEGIN{exit 0} {exit !( $0+0 == $0+0 )}'; }

is_supported_model() {
  local m="${1:-}" l=""
  [ -n "$m" ] || return 1
  l="$(printf '%s' "$m" | tr '[:upper:]' '[:lower:]')"

  case "$l" in
    *image*|*imagen*|*img*|*vision*|*vqa*|*vit*|*clip*|*render* ) return 1 ;;
    *audio*|*speech*|*tts*|*wav2vec*|*whisper* ) return 1 ;;
    *embed*|*embedding*|*vector* ) return 1 ;;
    *multimodal* ) return 1 ;;
    *) return 0 ;;
  esac
}

list_models_cli() {
  if [ ! -s "${MODELS_FILE:-}" ]; then
    printf 'No models available locally. Consider --refresh-models.\n' >&2
    return 1
  fi

  local count=0 model="" norm=""
  while IFS= read -r model || [ -n "$model" ]; do
    [ -z "$model" ] && continue
    count=$((count+1))
    norm="$(_normalize_model_name "$model")"
    if is_supported_model "$norm"; then
      printf '%s\n' "$norm"
    else
      printf '%s\t[%sNOT SUPPORTED%s: Requires non-text input]\n' "$norm" "${C_RED}" "${C_RST}"
    fi
    if [ "$count" -ge "$MAX_MODELS" ]; then break; fi
  done < "$MODELS_FILE"
  return 0
}

validate_model_core() {
  local model="${1:-}" norm_model="" file_match=0
  [ -n "$model" ] || { printf 'bash4llm: %sERROR%s: validate_model_core: model required\n' "${C_RED}" "${C_RST}" >&2; return 1; }

  norm_model="$(_normalize_model_name "$model")"

  if [ -f "${MODELS_FILE:-}" ] && [ -s "${MODELS_FILE:-}" ]; then
    if grep -x -F -q "$model" "$MODELS_FILE" 2>/dev/null; then
      file_match=1
    else
      file_match=0
      while IFS= read -r m || [ -n "$m" ]; do
        [ -z "$m" ] && continue
        if [ "$(_normalize_model_name "$m")" = "$norm_model" ]; then
          file_match=1
          break
        fi
      done < "$MODELS_FILE"
    fi

    if [ "$file_match" -ne 1 ]; then
      printf 'bash4llm: %sERROR%s: The model "%s" is not present in %s\n' "${C_RED}" "${C_RST}" "$model" "$MODELS_FILE" >&2
      return 1
    fi
  fi

  if ! is_supported_model "$norm_model"; then
    printf 'bash4llm: %sERROR%s: The "%s" model is not supported by %s (requires non-text input).\n' "${C_RED}" "${C_RST}" "$model" "${C_BGREEN}Bash4LLM⁺${C_RST}" >&2
    return 1
  fi

  return 0
}

load_local_config() {
  local cfg="${BASH4LLM_CONFIG_DIR%/}/config" key="" val="" line=""
  [ -f "$cfg" ] || return 0
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in ''|\#*) continue ;; esac
    key="${line%%=*}"
    val="${line#*=}"
    case "$key" in
      MODEL) [ -n "$val" ] && MODEL="$val" ;;
      TEMPERATURE|TURE) [ -n "$val" ] && TURE="$val" ;;
      MAX_TOKENS) [ -n "$val" ] && MAX_TOKENS="$val" ;;
      FORMAT) [ -n "$val" ] && OUTPUT_MODE="$val" ;;
      THRESHOLD) [ -n "$val" ] && THRESHOLD="$val" ;;
    esac
  done < "$cfg"
}

load_whitelist() {
  local m="" norm=""
  ALLOWED_MODELS=""
  if [ -f "$MODELS_FILE" ] && [ -s "$MODELS_FILE" ]; then
    while IFS= read -r m || [ -n "$m" ]; do
      [ -z "$m" ] && continue
      norm="$(_normalize_model_name "$m")"
      [ -n "$norm" ] && ALLOWED_MODELS="${ALLOWED_MODELS}${norm}"$'\n'
    done < "$MODELS_FILE"
  fi
}

is_tty_out() {
  [ -t 1 ]
}

# ---------------------------------------------------------------------------
# Sourcing Guard & Interactive Parent-Shell Sourcing Handler (Session Unlock)
# ---------------------------------------------------------------------------
if [ "${BASH_SOURCE[0]}" != "$0" ]; then
  # Skip execution if only loading functions (BASH4LLM_SOURCE_ONLY=1)
  if [ "${BASH4LLM_SOURCE_ONLY:-0}" -ne 1 ]; then
    if [ "${BASH4LLM_OPENSSL_ACTIVE:-0}" -eq 1 ] && vault_exists; then
      if [ -z "${_B4L_RT_CTX:-}" ]; then
        # Display session unlock prompt with inline hidden input warning
        printf "%bUnlock Vault Session: %b[input is hidden]%b " "${C_BCYAN:-}" "${C_MAGENTA:-}" "${C_RST:-}" >&2
        if [ -r /dev/tty ] && [ -c /dev/tty ]; then
          stty -echo 2>/dev/null || true
          IFS= read -r _B4L_RT_CTX < /dev/tty
          stty echo 2>/dev/null || true
        else
          # Fallback for headless or non-interactive environments
          IFS= read -r _B4L_RT_CTX
        fi
        printf '\n' >&2
        
        if [ -n "$_B4L_RT_CTX" ]; then
          # Attempt to decrypt the master vault key to validate the password
          _test_key="$(_vault_decrypt_file "$_VAULT_FILE" "$_B4L_RT_CTX" 2>/dev/null)"
          
          # Validate key format: must be successful and output a 64-character hex string
          if [ -n "$_test_key" ] && [[ "$_test_key" =~ ^[0-9a-fA-F]{64}$ ]]; then
            export _B4L_RT_CTX
            printf "%bSession unlocked successfully.%b\n" "${C_BGREEN:-}" "${C_RST:-}" >&2
          else
            unset _B4L_RT_CTX
            printf "%bUnlock failed: incorrect Master Password.%b\n" "${C_BRED:-}" "${C_RST:-}" >&2
          fi
          unset _test_key
        else
          printf "%bUnlock aborted: empty passcode.%b\n" "${C_BRED:-}" "${C_RST:-}" >&2
        fi
      else
        printf "%bSession is already unlocked.%b\n" "${C_BGREEN:-}" "${C_RST:-}" >&2
      fi
    fi
  fi

  # === AUTOMATIC NAMESPACE CLEANUP ===
  # Run cleanup only if the user has not explicitly requested feature import
  if [ "${BASH4LLM_SOURCE_ONLY:-0}" -ne 1 ]; then
    unset -f resolve_script_dir safe_mkdir check_required_arg canonical_config_dir \
             canonical_provider_file canonical_model_file canonical_provider_url_file \
             trim_space sync_models_file_path validate_file_input _normalize_model_name \
             ensure_api_key_for_provider enforce_network_policy _extract_notes_section \
             log_prefix log_info log_warn log_error log_info_user dbg ensure_config_dir \
             write_provider_url_if_missing resolve_provider_url provider_api_env_var_name \
             is_valid_json_string b64encode b64decode is_truthy file_size is_valid_json_file \
             stage_b64 lock_exec _mktemp_in_dir show_payload_head atomic_write \
             extract_text_from_resp cleanup_run_tmp_on_exit ensure_run_tmpdir b64_atomic_write \
             b64_atomic_read ui_state_write run_static_config_check explain_error_code \
             load_provider_module _detect_base64_opts list_files_sorted_by_mtime tac_fallback \
             _file_mtime jq_safe rotate_history save_to_history manifest_create \
             manifest_add_part manifest_read _get_perm_string _get_owner _get_file_signature \
             getfile_signature _is_world_writable make_tmpdir _tmpf thread_validate_id \
             thread_now_ts thread_messages_tmp_path thread_sanitize_cmd _update_thread_index \
             _thread_delete_locked thread_delete_core _thread_rename_locked thread_rename_core \
             acquire_thread_lock release_thread_lock _thread_read_window_locked thread_read_window \
             thread_append _thread_hash thread_cache_key thread_cache_get thread_cache_set \
             thread_cache_invalidate _normalize_bool_env \
                 _vault_read_password _vault_set_opts _vault_encrypt_to_file _vault_decrypt_file \
                 vault_exists vault_init vault_load_keys vault_change_password vault_destroy \
                 vault_recover vault_manage_keys vault_get_provider_key vault_console \
                 _secure_hash_sha256 diagnose_tls_connection 2>/dev/null || true

    unset BASH4LLM_PLAT_ANDROID BASH4LLM_PLAT_MACOS BASH4LLM_PLAT_WSL BASH4LLM_PLAT_CYGWIN \
          BASH4LLM_PLAT_BSD BASH4LLM_PLAT_LINUX SCRIPT_NAME SCRIPT_VERSION SCRIPT_DATE \
          C_LOGO C_BANNER C_RST C_BOLD C_NOBOLD C_UNDERLINE C_NOUNDERLINE C_BLACK C_RED C_GREEN C_YELLOW C_BLUE \
          C_MAGENTA C_CYAN C_WHITE C_BBLACK C_BRED C_BGREEN C_BYELLOW C_BBLUE C_BMAGENTA \
          C_BCYAN C_BWHITE BG_BLACK BG_RED BG_GREEN BG_YELLOW BG_BLUE BG_MAGENTA BG_CYAN \
          BG_WHITE BASH4LLM_ERR_NO_API_KEY BASH4LLM_ERR_BAD_MODEL BASH4LLM_ERR_CURL_FAILED \
          BASH4LLM_ERR_NO_PROMPT BASH4LLM_ERR_TMP BASH4LLM_ERR_API BASH4LLM_ERR_SEC \
          BASH4LLMERR_NO_API_KEY BASH4LLMERR_BAD_MODEL BASH4LLMERR_CURL_FAILED BASH4LLMERR_NO_PROMPT \
          BASH4LLMERR_TMP BASH4LLMERR_API BASH4LLMERR_SEC SCRIPTDIR BASH4LLM_DIR \
          BASH4LLM_CONFIG_DIR BASH4LLM_MODELS_DIR BASH4LLM_TEMPLATES_DIR BASH4LLM_HISTORY_DIR \
          BASH4LLM_TMPDIR MAX_MODELS CANONICAL_EXTRAS_DIR LEGACY_EXTRAS_DIR BASH4LLM_EXTRAS_DIR \
          PROVIDERS_DIR THREAD_DIR MODELS_LOCK HISTORY_LOCK TMP_LOCK BASH4LLM_LOCK_TIMEOUT_TMP \
          BASH4LLM_LOCK_TIMEOUT_MODELS BASH4LLM_LOCK_TIMEOUT_HISTORY BASH4LLM_OPENSSL_ACTIVE \
          _BASH4LLM_OPENSSL_HELPER BASH4LLM_VAULT_ENABLED B64_WRAP_OPT B64_DECODE_OPT \
          BASH4LLM_ROTATE_HISTORY BASH4LLM_HISTORY_MAX_FILES BASH4LLM_HISTORY_MAX_BYTES \
          BASH4LLM_HISTORY_KEEP_DAYS MODELS_FILE LAST_CHECK_LINES THREAD_CACHE_DIR \
          _VAULT_FILE _VAULT_REC_FILE _VAULT_DAT_FILE _BASH4LLM_VAULT_PBKDF2 _B4L_CFG_DIR 2>/dev/null || true
  fi

  # Interrupt parent-shell execution to prevent CLI action processing
  return 0 2>/dev/null || exit 0
fi
#--3<---[ /SECTION: CORE_SETUP_INPUT_HELPERS ]--->3--
#--4<---[ SECTION: CORE_SETUP_CLI_PARSE ]--->4--
JSON_INPUT="${JSON_INPUT:-}" TEMPLATE="${TEMPLATE:-}" BATCH_FILE="${BATCH_FILE:-}" CHAT_MODE="${CHAT_MODE:-0}" SET_DEFAULT_MODEL="${SET_DEFAULT_MODEL:-}"
LIST_MODELS="${LIST_MODELS:-0}" LIST_PROVIDERS="${LIST_PROVIDERS:-0}" FORCE_SAVE_MODE="${FORCE_SAVE_MODE:-}" OUT_PATH="${OUT_PATH:-}"
DRY_RUN="${DRY_RUN:-0}" STREAM_MODE="${STREAM_MODE:-0}" OUTPUT_MODE="${OUTPUT_MODE:-text}" THRESHOLD="${THRESHOLD:-1000}"
INSTALL_EXTRAS="${INSTALL_EXTRAS:-0}" DEBUG="${DEBUG:-0}" QUIET="${QUIET:-0}"
PROVIDER_CLI="${PROVIDER_CLI:-}" PROVIDER_INTERACTIVE="${PROVIDER_INTERACTIVE:-0}"
SHOW_CONFIG="${SHOW_CONFIG:-0}" DIAGNOSTICS="${DIAGNOSTICS:-0}"
FILE_INPUTS=() ARGS=() OUTPUT_MODE="${OUTPUT_MODE:-text}"
MODEL_CLI_SET="${MODEL_CLI_SET:-0}"
INSTALL_EXTRAS_SRC=""
BOOTSTRAP_ONLY="${BOOTSTRAP_ONLY:-0}"
INIT_THREAD="${INIT_THREAD:-0}"

DELETE_THREAD=0
DELETE_THREAD_ID=""
RENAME_THREAD=0
RENAME_THREAD_ID=""
RENAME_TITLE=""

# Parsed options with robust alias resolutions (--providers, --tui, --diagnostic, --install-extra)
while [ $# -gt 0 ]; do
  case "$1" in
    --no-color)
      shift
      ;;
    --init-thread) INIT_THREAD=1; shift ;;
    --delete-thread)
      check_required_arg "--delete-thread" "$#"
      DELETE_THREAD_ID="$2"
      DELETE_THREAD=1
      shift 2
      ;;
    --rename-thread)
      check_required_arg "--rename-thread" "$#"
      RENAME_THREAD_ID="$2"
      RENAME_THREAD=1
      shift 2
      ;;
    --title)
      check_required_arg "--title" "$#"
      RENAME_TITLE="$2"
      shift 2
      ;;
    --refresh-models|--refresh-model) REFRESH_MODELS=1; shift ;;
    --list-models|--list-model) LIST_MODELS=1; shift ;;
    --list-providers|--list-provider) LIST_PROVIDERS=1; shift ;;
    --list-providers-raw|--list-provider-raw) LIST_PROVIDERS_RAW=1; shift ;;
    --list-models-raw|--list-model-raw) LIST_MODELS_RAW=1; shift ;;
    --set-default)
      check_required_arg "--set-default" "$#"
      SET_DEFAULT_MODEL="$2"
      shift 2
      ;;
    -m|--model)
      check_required_arg "--model" "$#"
      MODEL="$2"
      MODEL_CLI_SET=1
      shift 2
      ;;
    -f)
      check_required_arg "-f" "$#"
      FILE_INPUTS+=("$2")
      shift 2
      ;;
    --json-input)
      check_required_arg "--json-input" "$#"
      JSON_INPUT="$2"
      shift 2
      ;;
    --template)
      check_required_arg "--template" "$#"
      TEMPLATE="$2"
      shift 2
      ;;
    --batch)
      check_required_arg "--batch" "$#"
      BATCH_FILE="$2"
      shift 2
      ;;
    --thread)
      check_required_arg "--thread" "$#"
      THREAD_ID="$2"
      if [ "${THREAD_ID:0:1}" = "-" ]; then
        log_error "ARGS" "--thread requires a valid thread ID argument"
        exit "$BASH4LLM_ERR_TMP"
      fi
      shift 2
      ;;
    --thread-window)
      if [ "$#" -ge 2 ] && [ -n "${2:-}" ] && [ "${2:0:1}" != "-" ]; then
        THREAD_WINDOW="$2"
        shift 2
      else
        THREAD_WINDOW="10"
        shift
      fi
      ;;
    --system)
      check_required_arg "--system" "$#"
      SYSTEM_PROMPT="$2"
      shift 2
      ;;
    --ture|--temperature)
      check_required_arg "--temperature" "$#"
      TEMPERATURE="$2"
      TURE="$2"
      shift 2
      ;;
    --max)
      check_required_arg "--max" "$#"
      MAX_TOKENS="$2"
      shift 2
      ;;
    --debug) DEBUG=1; shift ;;
    --save) FORCE_SAVE_MODE="save"; shift ;;
    --nosave) FORCE_SAVE_MODE="nosave"; shift ;;
    --out)
      check_required_arg "--out" "$#"
      OUT_PATH="$2"
      shift 2
      ;;
    --threshold)
      check_required_arg "--threshold" "$#"
      THRESHOLD="$2"
      shift 2
      ;;
    --dry-run) DRY_RUN=1; shift ;;
    --quiet) QUIET=1; shift ;;
    --stream) STREAM_MODE=1; shift ;;
    --no-stream) STREAM_MODE=0; shift ;;
    --json) OUTPUT_MODE="json"; shift ;;
    --pretty) OUTPUT_MODE="pretty"; shift ;;
    --text) OUTPUT_MODE="text"; shift ;;
    --raw) OUTPUT_MODE="raw"; shift ;;
    --chat|--tui) CHAT_MODE=1; shift ;;
    --show-config) SHOW_CONFIG=1; shift ;;
    --diagnostics|--diagnostic) DIAGNOSTICS=1; shift ;;
    --provider|--providers)
      if [ "$#" -ge 2 ] && [ -n "${2:-}" ] && [ "${2:0:1}" != "-" ]; then
        PROVIDER_CLI="$2"
        shift 2
      else
        PROVIDER_INTERACTIVE=1
        shift
      fi
      ;;
    --install-extras|--install-extra)
      INSTALL_EXTRAS=1
      if [ $# -gt 1 ] && [ "${2:0:1}" != "-" ]; then
        INSTALL_EXTRAS_SRC="$2"
        shift
      fi
      shift
      ;;
    --install-extras=*|--install-extra=*)
      INSTALL_EXTRAS=1
      if [[ "$1" == --install-extras=* ]]; then
        INSTALL_EXTRAS_SRC="${1#--install-extras=}"
      else
        INSTALL_EXTRAS_SRC="${1#--install-extra=}"
      fi
      shift
      ;;
    # -------------------------------------------------------------------------
    # Cryptographic Vault CLI Entrypoint Option
    # -------------------------------------------------------------------------
    --vault)
      if [ "${BASH4LLM_OPENSSL_ACTIVE:-0}" -eq 1 ]; then
        # Ensure temporary runtime environment is ready
        ensure_run_tmpdir || exit "$BASH4LLM_ERR_TMP"
        vault_console
        exit 0
      else
        log_error "SECURITY" "The OpenSSL helper module is not active or openssl is missing on this platform. Vault command unavailable."
        exit 1
      fi
      ;;
    --version) printf '%s %s (%s)\n' "$SCRIPT_NAME" "$SCRIPT_VERSION" "$SCRIPT_DATE"; exit 0 ;;
    -h|--help)
      help_file="$BASH4LLM_EXTRAS_DIR/docs/help.txt"
      if [ -f "$help_file" ]; then
        if [ -z "${C_BCYAN:-}" ]; then
          cat "$help_file"
        else
          sed \
            -e "s/^\([A-Za-z][A-Za-z[:blank:]&]*:\)/${C_BCYAN}\1${C_RST}/" \
            -e "s/\(--[a-zA-Z0-9-][a-zA-Z0-9-]*\)/${C_BGREEN}\1${C_RST}/g" \
            -e "s/\([[:blank:],]\)\(-[a-zA-Z0-9]\)/\1${C_BGREEN}\2${C_RST}/g" \
            -e "s/\(<[a-zA-Z0-9_]\{1,\}>\)/${C_YELLOW}\1${C_RST}/g" \
            -e "s/\`\([^\`]*\)\`/${C_BYELLOW}\1${C_RST}/g" \
            "$help_file"
        fi
      else
        printf 'Help file not found: %s\n' "$help_file" >&2
      fi
      exit 0 ;;
    --bootstrap-only)
      BOOTSTRAP_ONLY=1
      shift
      ;;
    --) shift; break ;;
    -*) printf 'bash4llm: %sERROR%s: Unknown option: %s\n' "${C_RED}" "${C_RST}" "$1" >&2; exit "$BASH4LLM_ERR_TMP" ;;
    *) ARGS+=("$1"); shift ;;
  esac
done

# 1. Resolve active provider based on CLI overrides or persisted state
if [ -n "${PROVIDER_CLI:-}" ] && [ "$PROVIDER_CLI" != "list" ]; then
  PROVIDER="$PROVIDER_CLI"
elif [ -f "$(canonical_provider_file)" ] && [ -s "$(canonical_provider_file)" ]; then
  PROVIDER="$(sed -n '1p' "$(canonical_provider_file)" 2>/dev/null || true)"
  PROVIDER="$(printf '%s' "$PROVIDER" | awk '{$1=$1;print}')"
  [ -n "$PROVIDER" ] || PROVIDER="groq"
else
  PROVIDER="groq"
fi

# 2. Persist provider if set via CLI (excluding list commands)
if [ -n "${PROVIDER_CLI:-}" ] && [ "$PROVIDER_CLI" != "list" ] && [ "${PROVIDER_INTERACTIVE:-0}" -eq 0 ]; then
  if ! ensure_config_dir; then
    log_error "PROVIDER" "cannot persist provider selection: config dir unavailable."
    exit "$BASH4LLM_ERR_TMP"
  fi
  target_provider_file="$(canonical_provider_file)"
  printf '%s\n' "$PROVIDER" | atomic_write "$target_provider_file" 10 || {
    log_error "PROVIDER" "cannot persist provider selection to ${target_provider_file}."
    exit "$BASH4LLM_ERR_TMP"
  }
  chmod 600 "$target_provider_file" 2>/dev/null || true
  rm -f "$(canonical_provider_url_file)" 2>/dev/null || true
fi

# 3. Immediately load the corresponding provider module
if [ "${PROVIDER_INTERACTIVE:-0}" -eq 0 ]; then
  if ! load_provider_module "$PROVIDER"; then
    log_error "PROVIDER" "failed to load provider module: $PROVIDER"
    exit "$BASH4LLM_ERR_TMP"
  fi
fi

# 4. Early synchronization of the models file path
sync_models_file_path "$PROVIDER"

#--4<---[ /SECTION: CORE_SETUP_CLI_PARSE ]--->4--
#--5<---[ SECTION: CORE_SETUP_SESSION_ENGINE ]--->5--
_engine_path="${BASH4LLM_EXTRAS_DIR}/session/session-engine.sh"
_engine_available=0
if [ -f "$_engine_path" ] && [ "${BASH4LLM_SESSION_ENGINE:-on}" != "off" ]; then
  if bash -n "$_engine_path" 2>/dev/null; then
    . "$_engine_path"
    if type session_engine_build_window >/dev/null 2>&1 && type session_engine_append >/dev/null 2>&1 && type session_engine_enabled >/dev/null 2>&1; then
      if session_engine_enabled 2>/dev/null; then
        _engine_available=1
        if [ "${DEBUG:-0}" -eq 1 ]; then
          log_info "SESSION" "Session Engine loaded and available"
        fi
      else
        _engine_available=0
        if [ "${DEBUG:-0}" -eq 1 ]; then
          log_info "SESSION" "Session Engine loaded but disabled by module"
        fi
      fi
    else
      _engine_available=0
      log_warn "SESSION" "Session Engine module missing required functions; falling back to legacy"
    fi
  else
    _engine_available=0
    log_warn "SESSION" "Session Engine module has syntax errors; falling back to legacy"
  fi
else
  _engine_available=0
fi
#--5<---[ /SECTION: CORE_SETUP_SESSION_ENGINE ]--->5--
#--6<---[ SECTION: CORE_SETUP_NORM_FLAGS ]--->6--
: "${ALLOW_API_CALLS:=1}"
if [ -n "${GROQ_API_KEY:-}" ] && ! is_truthy "${ALLOW_API_CALLS:-0}" && ! is_truthy "${DRY_RUN:-0}"; then
  log_error "APIKEY" "GROQ_API_KEY is set but ALLOW_API_CALLS!=1 and DRY_RUN!=1."
  exit "$BASH4LLM_ERR_TMP"
fi

_supported_providers_arr=()
_supported_providers_arr+=("groq")
extras_prov_dir="${PROVIDERS_DIR:-${BASH4LLM_EXTRAS_DIR}/providers}"
if [ -z "${extras_prov_dir:-}" ]; then
  extras_prov_dir="$(canonical_config_dir)/providers"
fi
if [ -d "$extras_prov_dir" ]; then
  for pf in "$extras_prov_dir"/*.sh; do
    [ -e "$pf" ] || continue
    base="$(basename "$pf" .sh)"
    [ "$base" = "groq" ] && continue
    _supported_providers_arr+=("$base")
  done
fi
SUPPORTED_PROVIDERS="$(printf '%s ' "${_supported_providers_arr[@]}" | sed 's/ $//')"
export SUPPORTED_PROVIDERS

if [ "${LIST_PROVIDERS_RAW:-0}" -eq 1 ]; then
  if [ "${#_supported_providers_arr[@]}" -eq 0 ]; then
    exit 1
  fi
  for p in ${_supported_providers_arr[@]+"${_supported_providers_arr[@]}"}; do
    printf '%s\n' "$p"
  done
  exit 0
fi

if [ "${LIST_MODELS_RAW:-0}" -eq 1 ]; then
  if [ -n "${PROVIDER_CLI:-}" ]; then
    PROVIDER="${PROVIDER_CLI}"
  fi

  if [ -f "${MODELS_FILE:-}" ] && [ -s "${MODELS_FILE:-}" ]; then
    while IFS= read -r m || [ -n "$m" ]; do
      [ -z "$m" ] && continue
      norm="$(_normalize_model_name "$m")"
      [ -n "$norm" ] && printf '%s\n' "$norm"
    done < "$MODELS_FILE"
    exit 0
  else
    exit 2
  fi
fi
#--6<---[ /SECTION: CORE_SETUP_NORM_FLAGS ]--->6--
#--7<---[ SECTION: CORE_SETUP_ACTIONS ]--->7--
if [ "${DELETE_THREAD:-0}" -eq 1 ]; then
  if [ -z "${DELETE_THREAD_ID:-}" ]; then
    log_error "THREAD" "--delete-thread requires a valid thread ID"
    exit "$BASH4LLM_ERR_TMP"
  fi
  thread_delete_core "$DELETE_THREAD_ID"
  exit 0
fi

if [ "${RENAME_THREAD:-0}" -eq 1 ]; then
  if [ -z "${RENAME_THREAD_ID:-}" ]; then
    log_error "THREAD" "--rename-thread requires a valid thread ID"
    exit "$BASH4LLM_ERR_TMP"
  fi
  thread_rename_core "$RENAME_THREAD_ID" "${RENAME_TITLE:-}"
  exit 0
fi

if [ "$LIST_PROVIDERS" -eq 1 ]; then
  printf 'Available providers:\n' >&2
  printf '  - groq (embedded)\n' >&2
  extras_prov_dir="$PROVIDERS_DIR"
  if [ -d "$extras_prov_dir" ]; then
    for f in "$extras_prov_dir"/*.sh; do
      [ -e "$f" ] || continue
      base="$(basename "$f" .sh)"
      [ "$base" = "groq" ] && continue
      printf '  - %s\n' "$base" >&2
    done
  fi
  exit 0
fi

if [ "$LIST_MODELS" -eq 1 ]; then
    if list_models_cli; then exit 0; else exit "$BASH4LLM_ERR_TMP"; fi
fi

if [ -n "$SET_DEFAULT_MODEL" ]; then
  safe_mkdir "$(canonical_config_dir)" 700

  # Directly use the active provider which is guaranteed to be initialized
  target_provider="${PROVIDER:-groq}"

  target_model_file="$(canonical_model_file "${target_provider}")"
  if ! printf '%s\n' "$SET_DEFAULT_MODEL" | atomic_write "$target_model_file" 10; then
    log_error "MODEL" "cannot persist default model to $target_model_file"
    exit "$BASH4LLM_ERR_TMP"
  fi
  chmod 600 "$target_model_file" 2>/dev/null || true
  log_info_user "MODEL" "default model for $target_provider set to: $SET_DEFAULT_MODEL"
  exit 0
fi

if [ "$INSTALL_EXTRAS" -eq 1 ] || [ "${INSTALL_EXTRAS:-0}" -eq 1 ]; then
  SRC_DIR="${INSTALL_EXTRAS_SRC:-$LEGACY_EXTRAS_DIR}"
  DEST_DIR="${CANONICAL_EXTRAS_DIR}"

  SRC_BASE=""
  DEST_BASE=""

  if [ -d "$SRC_DIR" ]; then
    SRC_BASE="$(cd "$SRC_DIR" >/dev/null 2>&1 && pwd || true)"
  fi

  safe_mkdir "$(dirname "$DEST_DIR")" 700

  if [ -d "$DEST_DIR" ]; then
    DEST_BASE="$(cd "$DEST_DIR" >/dev/null 2>&1 && pwd || true)"
  else
    PARENT_DEST="$(cd "$(dirname "$DEST_DIR")" >/dev/null 2>&1 && pwd || true)"
    if [ -n "$PARENT_DEST" ]; then
      DEST_BASE="${PARENT_DEST%/}/extras"
    fi
  fi

  if [ -z "$SRC_BASE" ] || [ ! -d "$SRC_BASE" ]; then
    log_error "EXTRAS" "Source directory does not exist or is invalid: ${SRC_DIR}"
    exit "$BASH4LLM_ERR_TMP"
  fi

  if [ "$SRC_BASE" = "$DEST_BASE" ]; then
    log_error "EXTRAS" "Install source and destination cannot match: ${SRC_BASE}"
    exit "$BASH4LLM_ERR_TMP"
  fi

  log_info_user "EXTRAS" "Synchronizing extras from ${SRC_BASE} to ${DEST_BASE}..."

  safe_mkdir "$DEST_BASE" 700

  if cp -R "$SRC_BASE/." "$DEST_BASE/" 2>/dev/null; then
    find "$DEST_BASE" -type d -exec chmod 700 {} + 2>/dev/null || true
    find "$DEST_BASE" -type f -exec chmod 600 {} + 2>/dev/null || true
    log_info_user "EXTRAS" "Installation successfully completed."
  else
    log_error "EXTRAS" "Error copying extras files."
    exit "$BASH4LLM_ERR_TMP"
  fi
  exit 0
fi

if [ "${INIT_THREAD:-0}" -eq 1 ]; then
  if [ -z "${THREAD_ID:-}" ]; then
    log_error "THREAD" "--init-thread requires a valid thread ID via --thread"
    exit "$BASH4LLM_ERR_TMP"
  fi
  if ! thread_validate_id "$THREAD_ID"; then
    log_error "THREAD" "invalid thread id: $THREAD_ID"
    exit "$BASH4LLM_ERR_TMP"
  fi

  safe_mkdir "$BASH4LLM_HISTORY_DIR/threads" 700
  thread_file="${BASH4LLM_HISTORY_DIR}/threads/${THREAD_ID}.ndjson"
  if [ ! -f "$thread_file" ]; then
    : > "$thread_file"
    chmod 600 "$thread_file"
  fi

  meta_file="${BASH4LLM_CONFIG_DIR%/}/ui_state/threads/${THREAD_ID}.json"
  meta_json="$(jq -c -n --arg id "$THREAD_ID" --arg title "Thread ${THREAD_ID:0:8}" \
    '{id:$id, active:true, msg_count:0, last_ts:"", title:$title}')"
  ui_state_write "threads/${THREAD_ID}.json" "$meta_json"

  lock_exec "$HISTORY_LOCK" 10 -- _update_thread_index "$THREAD_ID"

  log_info_user "THREAD" "Thread initialized: $THREAD_ID"
  exit 0
fi
#--7<---[ /SECTION: CORE_SETUP_ACTIONS ]--->7--
########################################
# SECTION: CORE_SETUP - END
########################################
########################################
# SECTION: CORE_PROVIDER - BEGIN
########################################
#--1<---[ SECTION: CORE_PROVIDER_PRO_LOAD ]--->1--
# This section remains exclusively for handling interactive provider requests and 
# validating provider interface boundaries. Early loading occurred in Pass 3.
if [ "$PROVIDER_INTERACTIVE" -eq 1 ] || [ "${PROVIDER_CLI:-}" = "list" ]; then
  IFS=' ' read -r -a _prov_arr <<EOF
$SUPPORTED_PROVIDERS
EOF

  current_default="$PROVIDER"
  if [ -f "$(canonical_provider_file)" ]; then
    pf="$(sed -n '1p' "$(canonical_provider_file)" 2>/dev/null || true)"
    pf="$(printf '%s' "$pf" | awk '{$1=$1;print}')"
    [ -n "$pf" ] && current_default="$pf"
  fi

  printf 'Select provider:\n' >&2
  i=1
  for p in ${_prov_arr[@]+"${_prov_arr[@]}"}; do
    if [ "$p" = "$current_default" ]; then
      printf '%d) %s (default)\n' "$i" "$p" >&2
    else
      printf '%d) %s\n' "$i" "$p" >&2
    fi
    i=$((i+1))
  done

  printf '> ' >&2
  if ! IFS= read -r sel; then
    printf 'No selection made.\n' >&2
    exit "$BASH4LLM_ERR_TMP"
  fi
  sel="$(trim "$sel")"

  if [ -z "$sel" ]; then
    chosen="$current_default"
  else
    if printf '%s\n' "$sel" | grep -qE '^[0-9]+$'; then
      idx="$sel"
      chosen="${_prov_arr[$((idx-1))]}"
    else
      chosen=""
      for p in ${_prov_arr[@]+"${_prov_arr[@]}"}; do
        if [ "$p" = "$sel" ]; then
          chosen="$p"
          break
        fi
      done
    fi
  fi

  [ -n "$chosen" ] || { log_error "PROVIDER" "Selection out of range or unknown provider."; exit "$BASH4LLM_ERR_TMP"; }

  prev_provider="$PROVIDER"

  if ! ensure_config_dir; then
    log_error "PROVIDER" "cannot persist provider selection: config dir unavailable."
    exit "$BASH4LLM_ERR_TMP"
  fi

  target_provider_file="$(canonical_provider_file)"
  if ! printf '%s\n' "$chosen" | atomic_write "$target_provider_file" 10; then
    log_error "PROVIDER" "cannot persist provider selection to $target_provider_file."
    exit "$BASH4LLM_ERR_TMP"
  fi
  chmod 600 "$target_provider_file" 2>/dev/null || true
  rm -f "$(canonical_provider_url_file)" 2>/dev/null || true

  PROVIDER="$chosen"
  resolve_provider_url "${PROVIDER:-}" >/dev/null 2>&1 || true
  PROVIDER_INTERACTIVE_SELECTED=1

  if ! load_provider_module "$PROVIDER"; then
    log_error "PROVIDER" "failed to load provider module: $PROVIDER"
    exit "$BASH4LLM_ERR_TMP"
  fi

  if [ -n "${PROVIDER_INTERACTIVE_SELECTED:-}" ] && [ "$#" -eq 0 ]; then
    log_info_user "PROVIDER" "Provider set to: ${PROVIDER:-}"
    exit 0
  fi
fi

if [ "${PROVIDER:-}" = "groq" ]; then
  prov_file="$(canonical_provider_url_file)"
  if [ ! -f "$prov_file" ] || [ ! -s "$prov_file" ]; then
    embedded_url="https://api.groq.com/openai/v1/chat/completions"
    write_provider_url_if_missing "groq" "$embedded_url" >/dev/null 2>&1 || true
  fi
fi

# Ensure provider is fully loaded and validated
if [ "${PROVIDER_MODULE_LOADED:-0}" -eq 1 ]; then
  if ! validate_provider_interface "$PROVIDER"; then
    exit "$BASH4LLM_ERR_API"
  fi
else
  if ! load_provider_module "$PROVIDER"; then
    log_error "PROVIDER" "failed to load provider module: $PROVIDER"
    exit "$BASH4LLM_ERR_TMP"
  fi
  if ! validate_provider_interface "$PROVIDER"; then
    exit "$BASH4LLM_ERR_API"
  fi
fi

if [ "${REFRESH_MODELS:-0}" -eq 1 ]; then
  resolve_provider_url "${PROVIDER:-}" >/dev/null 2>&1 || true

  if ! ensure_api_key_for_provider "$PROVIDER"; then
    log_error "APIKEY" "API key required to refresh models for provider $PROVIDER."
    exit "$BASH4LLM_ERR_NO_API_KEY"
  fi
  refresh_models_dispatch "$MODELS_FILE" || exit "$BASH4LLM_ERR_API"
  exit 0
fi

if [ ! -s "${MODELS_FILE:-}" ]; then
  if ! ensure_api_key_for_provider "$PROVIDER"; then
    log_error "APIKEY" "API key required to refresh models for provider $PROVIDER."
  else
    refresh_models_dispatch "$MODELS_FILE" || true
  fi
fi
#--1<---[ /SECTION: CORE_PROVIDER_PRO_LOAD ]--->1--
#--2<---[ SECTION: CORE_PROVIDER_SHOW ]--->2--
if [ "${PRINT_CONFIG_DIR:-0}" -eq 1 ]; then
  printf '%s\n' "$(canonical_config_dir)"
