    exit "$BASH4LLM_ERR_TMP"
  fi
fi

_normalize_bool_env() {
  local var val
  for var in ALLOW_API_CALLS DRY_RUN DEBUG; do
    val="${!var:-}"
    if [ -n "$val" ]; then
      if is_truthy "$val"; then
        export "$var"=1
      else
        export "$var"=0
      fi
    fi
  done
}
