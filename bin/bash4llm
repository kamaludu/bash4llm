# Centralized lock names (co-located with resources)
# ---------------------------------------------------------------------------
MODELS_LOCK="${MODELS_LOCK:-$BASH4LLM_MODELS_DIR/models.lock}"
HISTORY_LOCK="${HISTORY_LOCK:-$BASH4LLM_HISTORY_DIR/history.lock}"
TMP_LOCK="${TMP_LOCK:-$BASH4LLM_TMPDIR/tmp.lock}"

# Lock timeouts (configurable via env)
BASH4LLM_LOCK_TIMEOUT_TMP="${BASH4LLM_LOCK_TIMEOUT_TMP:-10}"
BASH4LLM_LOCK_TIMEOUT_MODELS="${BASH4LLM_LOCK_TIMEOUT_MODELS:-10}"
