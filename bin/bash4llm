MODEL="$FINAL_MODEL"

STDIN_CONTENT=""
if [ -z "${JSON_INPUT:-}" ] && [ ! -t 0 ]; then
  STDIN_CONTENT="$(cat - 2>/dev/null || true)"
fi

assemble_content() {
  CONTENT="${CONTENT:-}"
  local tmpl tmp_tmpl tmp_final extra file_content

  if [ -n "$JSON_INPUT" ]; then CONTENT=""; return 0; fi

  if [ "${#FILE_INPUTS[@]}" -gt 0 ]; then
    CONTENT="$(collect_input_from_files "${FILE_INPUTS[@]}")"
    if [ "${#ARGS[@]}" -gt 0 ]; then
      extra="$(expand_args_to_content)"
      [ -n "$extra" ] && CONTENT="${CONTENT}"$'\n\n'"$extra"
    fi
    return 0
  fi

  if [ -n "$TEMPLATE" ]; then
    if [ "${#FILE_INPUTS[@]}" -gt 0 ]; then
      CONTENT="$(collect_input_from_files "${FILE_INPUTS[@]}")"
    elif [ -n "$STDIN_CONTENT" ]; then
      CONTENT="$STDIN_CONTENT"
    else
      if [ "${#ARGS[@]}" -gt 0 ]; then CONTENT="$(expand_args_to_content)"; else CONTENT=""; fi
    fi

    tmpl="$(cat "$BASH4LLM_TEMPLATES_DIR/$TEMPLATE" 2>/dev/null || true)"
    ensure_run_tmpdir
    tmp_tmpl="$(_mktemp_in_dir "$RUN_TMPDIR" 2>/dev/null || true)"

    if [ -n "$tmp_tmpl" ]; then
      printf '%s' "$tmpl" | awk -v repl="$CONTENT" '{ gsub(/\{\{CONTENT\}\}/, repl); print }' > "$tmp_tmpl"
      tmp_final="${tmp_tmpl}.final"
      mv "$tmp_tmpl" "$tmp_final" 2>/dev/null || true
      file_content="$(cat "$tmp_final" 2>/dev/null || printf '%s' "$tmpl")"
      CONTENT="$file_content"
      rm -f "$tmp_final" 2>/dev/null || true
    else
      CONTENT="$(printf '%s' "$tmpl" | awk -v repl="$CONTENT" '{ gsub(/\{\{CONTENT\}\}/, repl); print }')"
    fi
    return 0
  fi

  if [ -n "$STDIN_CONTENT" ]; then
    CONTENT="$STDIN_CONTENT"
    if [ "${#ARGS[@]}" -gt 0 ]; then
      extra="$(expand_args_to_content)"
      [ -n "$extra" ] && CONTENT="${CONTENT}"$'\n\n'"$extra"
    fi
    return 0
  fi

  if [ "${#ARGS[@]}" -gt 0 ]; then CONTENT="$(expand_args_to_content)"; else CONTENT=""; fi
  return 0
}

assemble_content

if [ -n "${PROVIDER_INTERACTIVE_SELECTED:-}" ] && [ "$#" -eq 0 ] && [ -z "${CONTENT:-}" ]; then
  # Refreshed output utilizing user info logging
  log_info_user "PROVIDER" "Provider set to: ${PROVIDER:-}"
  exit 0
fi

if [ -n "${JSON_INPUT:-}" ] || [ "${CHAT_MODE:-0}" -eq 1 ] || [ -n "${BATCH_FILE:-}" ]; then
  : 
elif [ -n "${CONTENT:-}" ]; then
  : 
elif [ "$#" -gt 0 ]; then
  CONTENT="$(printf '%s ' "$@")"
  CONTENT="${CONTENT%" "}" 
else
  log_error "INPUT" "no prompt provided."
  exit "$BASH4LLMERR_NO_PROMPT"
fi

if [ -z "$CONTENT" ] && [ -z "$JSON_INPUT" ] && [ "$CHAT_MODE" -eq 0 ] && [ -z "$BATCH_FILE" ]; then
  log_error "INPUT" "no prompt provided."
  exit "$BASH4LLMERR_NO_PROMPT"
fi

is_number "$TURE" || { log_error "ARGS" "--ture must be numeric"; exit "$BASH4LLMERR_TMP"; }
is_number "$MAX_TOKENS" || { log_error "ARGS" "--max must be numeric"; exit "$BASH4LLMERR_TMP"; }

if [ -n "$ALLOWED_MODELS" ] && [ -n "$MODEL" ]; then
  norm_model="$(printf '%s' "$MODEL" | sed -e 's#^models/##' -e 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  if ! printf '%s\n' "$ALLOWED_MODELS" | grep -x -F -q "$norm_model"; then
    log_error "MODEL" "model '$MODEL' not supported or deprecated."
    printf '%s\n' "$ALLOWED_MODELS" >&2
    exit "$BASH4LLMERR_BAD_MODEL"
  fi
fi

ensure_run_tmpdir

# Batch processing
if [ -n "$BATCH_FILE" ]; then
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in ''|\#*) continue ;; esac
    CONTENT="$line"

    if [ -n "${SESSION_ID:-}" ]; then
      if ! session_validate_id "$SESSION_ID"; then
        log_error "SESSION" "invalid session id: $SESSION_ID"
        exit "$BASH4LLMERR_TMP"
      fi
      safe_mkdir "$BASH4LLM_HISTORY_DIR/sessions" 700

      if [ -n "${SESSION_WINDOW:-}" ]; then
        if ! printf '%s' "$SESSION_WINDOW" | grep -qE '^[0-9]+$'; then
          SESSION_WINDOW=10
        fi
      else
        SESSION_WINDOW=10
      fi
      if [ "$SESSION_WINDOW" -gt 20 ]; then
        log_warn "SESSION" "session-window > 20 requested ($SESSION_WINDOW); recommended <= 20"
      fi

      ensure_run_tmpdir || { log_error "SESSION" "cannot create run tmpdir"; exit "$BASH4LLMERR_TMP"; }
      BUILD_MESSAGES_FILE="${RUN_TMPDIR%/}/session-${SESSION_ID}-messages.json"
      export BUILD_MESSAGES_FILE

      if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
        if ! session_engine_build_window "$SESSION_ID" "$SESSION_WINDOW" "${BASH4LLM_SESSION_TARGET_BYTES:-}" "$BUILD_MESSAGES_FILE" 2>/dev/null; then
          log_warn "SESSION" "session_engine_build_window failed; falling back to legacy session_read_window"
          session_read_window "$SESSION_ID" "$SESSION_WINDOW" "$BUILD_MESSAGES_FILE" 2>/dev/null || log_warn "SESSION" "legacy session_read_window also failed"
        fi
      else
        session_read_window "$SESSION_ID" "$SESSION_WINDOW" "$BUILD_MESSAGES_FILE" 2>/dev/null || log_warn "SESSION" "legacy session_read_window failed"
      fi

      if [ ! -f "${BUILD_MESSAGES_FILE:-}" ] || [ "$(jq -r '.messages | length' "$BUILD_MESSAGES_FILE" 2>/dev/null || echo 0)" -eq 0 ]; then
        jq -n --arg role "user" --arg content "${CONTENT:-}" '{messages:[{role:$role,content:$content}] }' > "${BUILD_MESSAGES_FILE}"
      fi
    fi

    build_payload_from_vars

    if ! ensure_api_key_for_provider "$PROVIDER"; then
      log_error "APIKEY" "missing API key; aborting batch item."
      continue
    fi

    if [ "$STREAM_MODE" -eq 1 ]; then
      call_api_streaming || log_error "CALL" "Error during streaming call."
    else
      perform_request_once || true
    fi

    printf '\n----\n'
  done < "$BATCH_FILE"
  exit 0
fi

# =============================================================================
# chat mode: REPL / INTERACTIVE SHELL MODE
# =============================================================================
if [ "$CHAT_MODE" -eq 1 ]; then
  if [ ! -t 0 ]; then
    log_error "CHAT" "interactive chat requires a valid TTY."
    exit "$BASH4LLMERR_TMP"
  fi

  set -o history 2>/dev/null || true
  export HISTSIZE=1000
  HISTFILE="${BASH4LLM_HISTORY_DIR}/repl_history"
  
  touch "$HISTFILE" 2>/dev/null && chmod 600 "$HISTFILE" 2>/dev/null || true
  history -r "$HISTFILE" 2>/dev/null || true

  if [ "$QUIET" -ne 1 ]; then
    printf '%s\n' '-----------------------------------------' >&2
    printf 'Starting %s Interactive Shell\n' "${C_LOGO} Bash4LLM⁺ ${C_RST}" >&2
    printf 'Press Ctrl+D to quit, type /? for Help\n' >&2
    printf '%s\n\n' '-----------------------------------------' >&2
  fi

  trap 'printf "\n[Interrupted. Type /exit or press Ctrl+D to exit]\n" >&2' INT

  if [ -z "${SESSION_ID:-}" ]; then
    SESSION_ID="repl-$(date +%Y%m%d)-$$"
  fi

  while true; do
    PROMPT="You (model: ${MODEL:-default}) > "
    if [ -n "$C_CMD" ] && [ -t 1 ] && [ "$QUIET" -ne 1 ]; then
      # Wrap color escape sequences in \001 and \002 so readline calculates prompt width correctly
      PROMPT=$'\001'"$C_CMD"$'\002'"You (model: ${MODEL:-default}) > "$'\001'"$C_RST"$'\002'
    fi

    userline=""
    if ! IFS= read -r -e -p "$PROMPT" userline; then
      read_rc=$?
      # If the read was interrupted by a signal (e.g. SIGINT / Ctrl+C), stay in the REPL
      if [ "$read_rc" -eq 130 ]; then
        printf '\n' >&2
        continue
      fi
      printf '\nExited.\n' >&2
      break
    fi

    userline="$(printf '%s' "$userline" | awk '{$1=$1;print}')"
    [ -z "$userline" ] && continue

    history -s "$userline" 2>/dev/null || true
    history -w "$HISTFILE" 2>/dev/null || true

    case "$userline" in
      /exit|/quit)
        cleanup_run_tmp_on_exit
        exit 0
        ;;
      /help|/\?)
        printf '%b' "
${C_TITLE}------------------------------------------${C_RST}
${C_TITLE}Interactive Shell Commands:${C_RST}
  ${C_CMD}/help${C_RST}, ${C_CMD}/?${C_RST}            - Show this help menu
  ${C_CMD}/exit${C_RST}, ${C_CMD}/quit${C_RST}         - Exit the interactive shell
  ${C_CMD}/clear${C_RST}               - Clear terminal screen and reset conversation history
  ${C_CMD}/undo${C_RST}                - Remove the last prompt and response from history
  ${C_CMD}/status${C_RST}              - Show active configurations and session statistics
  ${C_CMD}/system${C_RST} [${C_ARG}<prompt>${C_RST}]   - View or update the current system prompt instructions
  ${C_CMD}/model${C_RST} ${C_ARG}<name>${C_RST}        - Switch the active LLM model
  ${C_CMD}/file${C_RST} ${C_ARG}<path>${C_RST} [${C_ARG}prompt${C_RST}]- Read a file, append an optional prompt, and send to model
${C_TITLE}------------------------------------------${C_RST}

" >&2
        continue
        ;;
      /clear)
        if [ -n "${SESSION_ID:-}" ]; then
          session_file="${SESSION_DIR:-${BASH4LLM_HISTORY_DIR:-.}/sessions}/${SESSION_ID}.ndjson"
          if [ -f "$session_file" ]; then
            : > "$session_file" 2>/dev/null || true
          fi
          if command -v session_cache_invalidate >/dev/null 2>&1; then
            session_cache_invalidate "$SESSION_ID" >/dev/null 2>/dev/null || true
          fi
        fi
        if [ -t 1 ]; then
          clear 2>/dev/null || printf '\033[H\033[2J' >&2
        fi
        printf '\n\033[1;33mInteractive session context and screen cleared.\033[0m\n\n' >&2
        continue
        ;;
      /undo)
        if [ -n "${SESSION_ID:-}" ]; then
          session_file="${SESSION_DIR:-${BASH4LLM_HISTORY_DIR:-.}/sessions}/${SESSION_ID}.ndjson"
          if [ -f "$session_file" ] && [ -s "$session_file" ]; then
            total_lines="$(wc -l < "$session_file" 2>/dev/null | tr -d ' ' || echo 0)"
            if [ "$total_lines" -ge 2 ]; then
              tmp_undo="$(_tmpf file "${RUN_TMPDIR:-$BASH4LLM_TMPDIR}" undo 2>/dev/null)"
              if [ -n "$tmp_undo" ]; then
                head -n "$((total_lines - 2))" "$session_file" > "$tmp_undo" 2>/dev/null \
                  && mv -f "$tmp_undo" "$session_file" 2>/dev/null || true
                rm -f "$tmp_undo" 2>/dev/null || true
                if command -v session_cache_invalidate >/dev/null 2>&1; then
                  session_cache_invalidate "$SESSION_ID" >/dev/null 2>/dev/null || true
                fi
                printf '\n\033[1;33mUndone last turn (removed last query & response from history).\033[0m\n\n' >&2
              else
                printf 'bash4llm: %sERROR%s: Failed to prepare temporary file for undo.\n' "${C_RED}" "${C_RST}" >&2
              fi
            elif [ "$total_lines" -eq 1 ]; then
              : > "$session_file" 2>/dev/null || true
              printf '\n\033[1;33mConversation history truncated.\033[0m\n\n' >&2
            else
              printf '\nConversation history is already empty.\n\n' >&2
            fi
          else
            printf '\nNo conversation history to undo.\n\n' >&2
          fi
        fi
        continue
        ;;
      /status)
        printf '\n%sCurrent REPL Status:%s\n' "${C_CYAN}" "${C_RST}" >&2
        printf '  Provider:      %s\n' "${PROVIDER:-groq}" >&2
        printf '  Model:         %s\n' "${MODEL:-default}" >&2
        printf '  Temperature:   %s\n' "${TURE:-1.0}" >&2
        printf '  Max Tokens:    %s\n' "${MAX_TOKENS:-4096}" >&2
        printf '  Session ID:    %s\n' "${SESSION_ID:-none}" >&2
        if [ -n "${SESSION_ID:-}" ]; then
          session_file="${SESSION_DIR:-${BASH4LLM_HISTORY_DIR:-.}/sessions}/${SESSION_ID}.ndjson"
          if [ -f "$session_file" ]; then
            msg_count="$(wc -l < "$session_file" 2>/dev/null | tr -d ' ' || echo 0)"
            size_bytes="$(file_size "$session_file" 2>/dev/null || echo 0)"
            printf '  Session File:  %s (%s bytes, %s messages)\n' "$session_file" "$size_bytes" "$msg_count" >&2
          else
            printf '  Session File:  empty/not created yet\n' >&2
          fi
        fi
        if [ -n "${SYSTEM_PROMPT:-}" ]; then
          printf '  System Prompt: %s\n' "${SYSTEM_PROMPT}" >&2
        else
          printf '  System Prompt: <none>\n' >&2
        fi
        printf '\n' >&2
        continue
        ;;
      /system|/system\ *)
        if [ "$userline" = "/system" ]; then
          if [ -n "${SYSTEM_PROMPT:-}" ]; then
            printf '\nCurrent System Prompt:\n%s\n\n' "${SYSTEM_PROMPT}" >&2
          else
            printf '\nNo system prompt is currently set.\n\n' >&2
          fi
        else
          new_sys="${userline#/system }"
          SYSTEM_PROMPT="$(printf '%s' "$new_sys" | awk '{$1=$1;print}')"
          printf '\n\033[1;32mSystem prompt updated for this session.\033[0m\n\n' >&2
        fi
        continue
        ;;
      /model\ *)
        new_model="${userline#/model }"
        new_model="$(printf '%s' "$new_model" | tr -d -c 'A-Za-z0-9._/:-' | awk '{$1=$1;print}')"
        if [ -z "$new_model" ]; then
          printf 'bash4llm: %sERROR%s: Empty or invalid model name.\n' "${C_RED}" "${C_RST}" >&2
        else
          if validate_model_dispatch "$new_model" >/dev/null 2>&1; then
            MODEL="$new_model"
            printf '\n%sModel successfully set to: %s%s\n' "${C_GREEN}" "$MODEL" "${C_RST}" >&2
          else
            printf 'bash4llm: %sERROR%s: Model "%s" is not supported or registered.\n' "${C_RED}" "${C_RST}" "$new_model" >&2
          fi
        fi
        continue
        ;;
      /file\ *)
        # Clear any leftover variable from global scope
        unset file_cmd_args file_path file_prompt file_content file_size combined_prompt
        
        file_cmd_args="${userline#/file }"
        file_cmd_args="$(printf '%s' "$file_cmd_args" | awk '{$1=$1;print}')"
        
        if [ -z "$file_cmd_args" ]; then
          printf 'bash4llm: %sERROR%s: Usage: /file <path> [optional prompt...]\n' "${C_RED}" "${C_RST}" >&2
          continue
        fi
        
        # Safely extract first word as path and the rest as prompt
        file_path="$(printf '%s' "$file_cmd_args" | awk '{print $1}')"
        file_prompt="$(printf '%s' "$file_cmd_args" | cut -d' ' -f2-)"
        if [ "$file_path" = "$file_cmd_args" ]; then
          file_prompt=""
        fi
        
        # Reusing existing helper to validate file safely in interactive mode
        if ! file_readable "$file_path"; then
          printf 'bash4llm: %sERROR%s: File does not exist or is not readable: %s\n' "${C_RED}" "${C_RST}" "$file_path" >&2
          continue
        fi
        
        # Enforce size limit (100 KB) to protect memory and context window
        file_size="$(file_size "$file_path" 2>/dev/null || echo 0)"
        if [ "$file_size" -gt 102400 ] 2>/dev/null; then
          printf 'bash4llm: %sERROR%s: File exceeds max attach limit of 100 KB: %s (%s KB)\n' \
            "${C_RED}" "${C_RST}" "$file_path" "$((file_size / 1024))" >&2
          continue
        fi
        
        # Read content safely (cat is safe here since path is validated)
        file_content="$(cat "$file_path" 2>/dev/null || true)"
        
        # Build the combined prompt
        if [ -n "$file_prompt" ]; then
          combined_prompt="$(printf 'Prompt: %s\n\n[File Attached: %s]\n---\n%s\n---\n' \
            "$file_prompt" "$(basename "$file_path")" "$file_content")"
        else
          combined_prompt="$(printf '[File Attached: %s]\n---\n%s\n---\n' \
            "$(basename "$file_path")" "$file_content")"
        fi
        
        # Set CONTENT (this will bypass the global assignment next)
        CONTENT="$combined_prompt"
        
        # Cleanup temporary global variables
        unset file_cmd_args file_path file_prompt file_content file_size combined_prompt
        ;;
      /*)
        printf 'bash4llm: %sERROR%s: Unknown command. Type /help or /? to list available commands.\n' "${C_RED}" "${C_RST}" >&2
        continue
        ;;
    esac

    # Only assign userline to CONTENT if it has not been pre-populated by /file
    if [ -z "${CONTENT:-}" ]; then
      CONTENT="$userline"
    fi

    if [ -n "${SESSION_ID:-}" ]; then
      if ! session_validate_id "$SESSION_ID" >/dev/null 2>&1; then
        log_error "SESSION" "invalid session id: $SESSION_ID"
        continue
      fi

      ensure_run_tmpdir || { log_error "SESSION" "cannot access run tmpdir"; continue; }
      BUILD_MESSAGES_FILE="$RUN_TMPDIR/session-${SESSION_ID}-messages.json"
      export BUILD_MESSAGES_FILE

      if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
        session_engine_build_window "$SESSION_ID" "${SESSION_WINDOW:-10}" "${BASH4LLM_SESSION_TARGET_BYTES:-}" "$BUILD_MESSAGES_FILE" >/dev/null 2>&1 \
          || session_read_window "$SESSION_ID" "${SESSION_WINDOW:-10}" "$BUILD_MESSAGES_FILE" >/dev/null 2>&1 || true
      else
        session_read_window "$SESSION_ID" "${SESSION_WINDOW:-10}" "$BUILD_MESSAGES_FILE" >/dev/null 2>&1 || true
      fi
    fi

    if build_payload_from_vars >/dev/null 2>&1; then
      if ! ensure_api_key_for_provider "$PROVIDER" >/dev/null 2>&1; then
        log_error "APIKEY" "Missing API key for provider $PROVIDER."
        continue
      fi

      if [ "$STREAM_MODE" -eq 1 ]; then
        if ! call_api_streaming; then
          log_error "CALL" "Streaming request failed."
          continue
        fi
      else
        if [ -t 1 ] && [ "$QUIET" -ne 1 ] && { [ "$OUTPUT_MODE" = "text" ] || [ "$OUTPUT_MODE" = "raw" ]; }; then
          printf '\n%s\n' "${C_CMD}Assistant:${C_RST}" >&2
        fi
        if ! perform_request_once; then
          log_error "CALL" "API request failed."
          continue
        fi
      fi

      if [ -n "${SESSION_ID:-}" ] && [ "${DRY_RUN:-0}" -ne 1 ]; then
        meta_source="cli"
        meta_cmd="$(session_sanitize_cmd "$0 ${ARGS[*]:-}")"
        meta_json="$(jq -c -n --arg source "$meta_source" --arg cmd "$meta_cmd" --arg id "" '{source:$source, cmd:$cmd, id:$id}')"

        if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
          session_engine_append "$SESSION_ID" "user" "$CONTENT" "$meta_json" >/dev/null 2>&1 \
            || session_append "$SESSION_ID" "user" "$CONTENT" "$meta_json" >/dev/null 2>&1 || true
        else
          session_append "$SESSION_ID" "user" "$CONTENT" "$meta_json" >/dev/null 2>&1 || true
        fi

        if [ -s "${RESP:-}" ]; then
          assistant_text="$(extract_text_from_resp 2>/dev/null || true)"
          assistant_text="$(printf '%s' "$assistant_text" | sed -e 's/\r$//' -e '/^[[:space:]]*$/d' || true)"
          if [ -n "${assistant_text:-}" ]; then
            meta_source="provider"
            meta_json="$(jq -c -n --arg source "$meta_source" --arg model "$MODEL" --arg id "" '{source:$source, model:$model, id:$id}')"

            if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
              session_engine_append "$SESSION_ID" "assistant" "$assistant_text" "$meta_json" >/dev/null 2>&1 \
                || session_append "$SESSION_ID" "assistant" "$assistant_text" "$meta_json" >/dev/null 2>&1 || true
            else
              session_append "$SESSION_ID" "assistant" "$assistant_text" "$meta_json" >/dev/null 2>&1 || true
            fi
          fi
        fi
      fi

    else
      log_error "PAYLOAD" "Failed to compile net request payload."
    fi

    # Reset CONTENT for the next turn
    unset CONTENT

    printf '\n' >&2
  done

  trap - INT
  exit 0
fi

# Single request (streaming or non-streaming)
if [ "$STREAM_MODE" -eq 1 ]; then
  if [ -n "${SESSION_ID:-}" ]; then
    if ! session_validate_id "$SESSION_ID"; then
      log_error "SESSION" "invalid session id: $SESSION_ID"
      exit "$BASH4LLMERR_TMP"
    fi
    safe_mkdir "$BASH4LLM_HISTORY_DIR/sessions" 700

    if [ -n "${SESSION_WINDOW:-}" ]; then
      if ! printf '%s' "$SESSION_WINDOW" | grep -qE '^[0-9]+$'; then
        SESSION_WINDOW=10
      fi
    else
      SESSION_WINDOW=10
    fi
    if [ "$SESSION_WINDOW" -gt 20 ]; then
      log_warn "SESSION" "session-window > 20 requested ($SESSION_WINDOW); recommended <= 20"
    fi

    ensure_run_tmpdir || { log_error "SESSION" "cannot create run tmpdir"; exit "$BASH4LLMERR_TMP"; }
    BUILD_MESSAGES_FILE="$RUN_TMPDIR/session-${SESSION_ID}-messages.json"

    if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
      if ! session_engine_build_window "$SESSION_ID" "$SESSION_WINDOW" "${BASH4LLM_SESSION_TARGET_BYTES:-}" "$BUILD_MESSAGES_FILE" 2>/dev/null; then
        log_warn "SESSION" "session_engine_build_window failed; falling back to legacy session_read_window"
        session_read_window "$SESSION_ID" "$SESSION_WINDOW" "$BUILD_MESSAGES_FILE" || { log_warn "SESSION" "failed to read session window for $SESSION_ID"; rm -f "$BUILD_MESSAGES_FILE" 2>/dev/null || true; }
      fi
    else
      session_read_window "$SESSION_ID" "$SESSION_WINDOW" "$BUILD_MESSAGES_FILE" || { log_warn "SESSION" "failed to read session window for $SESSION_ID"; rm -f "$BUILD_MESSAGES_FILE" 2>/dev/null || true; }
    fi

    export BUILD_MESSAGES_FILE
  fi

  build_payload_from_vars

  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    if [ "${DEBUG:-0}" -eq 1 ]; then
      log_info "DRY" "dry-run: skipping API key check for provider $PROVIDER"
    fi
  else
    if ! ensure_api_key_for_provider "$PROVIDER"; then
      log_error "APIKEY" "missing API key; aborting."
      exit "$BASH4LLMERR_NO_API_KEY"
    fi
  fi

  if call_api_streaming; then
     if [ "${DEBUG:-0}" -eq 1 ]; then
       log_info "STREAM" "Streaming completed; captured response in $RESP"
     fi

     if [ -n "${SESSION_ID:-}" ]; then
      if [ -n "${CONTENT:-}" ]; then
        meta_source="cli"
        meta_cmd="$(session_sanitize_cmd "$0 ${ARGS[*]:-}")"
        meta_json="$(jq -c -n --arg source "$meta_source" --arg cmd "$meta_cmd" --arg id "" '{source:$source, cmd:$cmd, id:$id}')"

        if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
          if ! session_engine_append "$SESSION_ID" "user" "$CONTENT" "$meta_json"; then
            log_warn "SESSION" "session_engine_append (user) failed; falling back to legacy session_append"
            session_append "$SESSION_ID" "user" "$CONTENT" "$meta_json" || log_warn "SESSION" "failed to append message to session $SESSION_ID (streaming)"
          fi
        else
          session_append "$SESSION_ID" "user" "$CONTENT" "$meta_json" || log_warn "SESSION" "failed to append message to session $SESSION_ID (streaming)"
        fi
      fi

      if [ "${DRY_RUN:-0}" -ne 1 ] && [ -s "${RESP:-}" ]; then
        assistant_text="$(extract_text_from_resp || true)"
        assistant_text="$(printf '%s' "$assistant_text" | sed -e 's/\r$//' -e '/^[[:space:]]*$/d' || true)"
        if [ -n "${assistant_text:-}" ]; then
          meta_source="provider"
          meta_json="$(jq -c -n --arg source "$meta_source" --arg model "$MODEL" --arg id "" '{source:$source, model:$model, id:$id}')"

          if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
            if ! session_engine_append "$SESSION_ID" "assistant" "$assistant_text" "$meta_json"; then
              log_warn "SESSION" "session_engine_append (assistant) failed; falling back to legacy session_append"
              session_append "$SESSION_ID" "assistant" "$assistant_text" "$meta_json" || log_warn "SESSION" "failed to append assistant response to session $SESSION_ID (streaming)"
            fi
          else
            session_append "$SESSION_ID" "assistant" "$assistant_text" "$meta_json" || log_warn "SESSION" "failed to append assistant response to session $SESSION_ID (streaming)"
          fi
        fi
      fi
    fi

    printf '\n'
    exit 0
  else
    log_error "STREAM" "streaming request failed."
    exit "$BASH4LLMERR_CURL_FAILED"
  fi

else
  # Non-streaming single request path
  if is_tty_out && [ "$QUIET" -ne 1 ] && { [ "$OUTPUT_MODE" = "text" ] || [ "$OUTPUT_MODE" = "raw" ]; }; then
    printf '%s\n' "${C_TITLE}You:${C_RST}" >&2
    if [ "${#ARGS[@]}" -gt 0 ]; then
      anyfile=0
      for a in "${ARGS[@]}"; do [ -r "$a" ] && [ -f "$a" ] && { anyfile=1; break; }; done
      [ "$anyfile" -eq 1 ] && printf '%s\n' "(using file contents)" >&2 || printf '%s\n' "$CONTENT" >&2
    else
      printf '%s\n' "$CONTENT" >&2
    fi
    printf '%s\n' "${C_CMD}Provider ($PROVIDER, model: $MODEL):${C_RST}" >&2
  fi

  if [ -n "${SESSION_ID:-}" ]; then
    if ! session_validate_id "$SESSION_ID"; then
      log_error "SESSION" "invalid session id: $SESSION_ID"
      exit "$BASH4LLMERR_TMP"
    fi
    safe_mkdir "$BASH4LLM_HISTORY_DIR/sessions" 700

    if [ -n "${SESSION_WINDOW:-}" ]; then
      if ! printf '%s' "$SESSION_WINDOW" | grep -qE '^[0-9]+$'; then
        SESSION_WINDOW=10
      fi
    else
      SESSION_WINDOW=10
    fi
    if [ "$SESSION_WINDOW" -gt 20 ]; then
      log_warn "SESSION" "session-window > 20 requested ($SESSION_WINDOW); recommended <= 20"
    fi

    ensure_run_tmpdir || { log_error "SESSION" "cannot create run tmpdir"; exit "$BASH4LLMERR_TMP"; }
    BUILD_MESSAGES_FILE="$RUN_TMPDIR/session-${SESSION_ID}-messages.json"

    if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
      if ! session_engine_build_window "$SESSION_ID" "$SESSION_WINDOW" "${BASH4LLM_SESSION_TARGET_BYTES:-}" "$BUILD_MESSAGES_FILE" 2>/dev/null; then
        log_warn "SESSION" "session_engine_build_window failed; falling back to legacy session_read_window"
        session_read_window "$SESSION_ID" "$SESSION_WINDOW" "$BUILD_MESSAGES_FILE" || { log_warn "SESSION" "failed to read session window for $SESSION_ID"; rm -f "$BUILD_MESSAGES_FILE" 2>/dev/null || true; }
      fi
    else
      session_read_window "$SESSION_ID" "$SESSION_WINDOW" "$BUILD_MESSAGES_FILE" || { log_warn "SESSION" "failed to read session window for $SESSION_ID"; rm -f "$BUILD_MESSAGES_FILE" 2>/dev/null || true; }
    fi

    export BUILD_MESSAGES_FILE
  fi

  build_payload_from_vars

  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    if [ "${DEBUG:-0}" -eq 1 ]; then
      log_info "DRY" "dry-run: skipping API key check for provider $PROVIDER"
    fi
  else
    if ! ensure_api_key_for_provider "$PROVIDER"; then
      log_error "APIKEY" "missing API key; aborting."
      exit "$BASH4LLMERR_NO_API_KEY"
    fi
  fi

  if perform_request_once; then
    if [ -n "${SESSION_ID:-}" ]; then
      if [ -n "${CONTENT:-}" ]; then
        meta_source="cli"
        meta_cmd="$(session_sanitize_cmd "$0 ${ARGS[*]:-}")"
        meta_json="$(jq -c -n --arg source "$meta_source" --arg cmd "$meta_cmd" --arg id "" '{source:$source, cmd:$cmd, id:$id}')"

        if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
          if ! session_engine_append "$SESSION_ID" "user" "$CONTENT" "$meta_json"; then
            log_warn "SESSION" "session_engine_append (user) failed; falling back to legacy session_append"
            session_append "$SESSION_ID" "user" "$CONTENT" "$meta_json" || log_warn "SESSION" "failed to append message to session $SESSION_ID"
          fi
        else
          session_append "$SESSION_ID" "user" "$CONTENT" "$meta_json" || log_warn "SESSION" "failed to append message to session $SESSION_ID"
        fi
      fi

      if [ "${DRY_RUN:-0}" -ne 1 ] && [ -s "${RESP:-}" ]; then
        assistant_text="$(extract_text_from_resp || true)"
        assistant_text="$(printf '%s' "$assistant_text" | sed -e 's/\r$//' -e '/^[[:space:]]*$/d' || true)"
        if [ -n "${assistant_text:-}" ]; then
          meta_source="provider"
          meta_json="$(jq -c -n --arg source "$meta_source" --arg model "$MODEL" --arg id "" '{source:$source, model:$model, id:$id}')"

          if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
            if ! session_engine_append "$SESSION_ID" "assistant" "$assistant_text" "$meta_json"; then
              log_warn "SESSION" "session_engine_append (assistant) failed; falling back to legacy session_append"
              session_append "$SESSION_ID" "assistant" "$assistant_text" "$meta_json" || log_warn "SESSION" "failed to append assistant response to session $SESSION_ID"
            fi
          else
            session_append "$SESSION_ID" "assistant" "$assistant_text" "$meta_json" || log_warn "SESSION" "failed to append assistant response to session $SESSION_ID"
          fi
        fi
      fi
    fi
    exit 0
  else
    if [ -n "${SESSION_ID:-}" ]; then
      if [ -n "${CONTENT:-}" ]; then
        meta_source="cli"
        meta_cmd="$(session_sanitize_cmd "$0 ${ARGS[*]:-}")"
        meta_json="$(jq -c -n --arg source "$meta_source" --arg cmd "$meta_cmd" --arg id "" '{source:$source, cmd:$cmd, id:$id}')"

        if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
          if ! session_engine_append "$SESSION_ID" "user" "$CONTENT" "$meta_json"; then
            log_warn "SESSION" "session_engine_append (user) failed after failed request; falling back to legacy session_append"
            session_append "$SESSION_ID" "user" "$CONTENT" "$meta_json" || log_warn "SESSION" "failed to append message to session $SESSION_ID after failed request"
          fi
        else
          session_append "$SESSION_ID" "user" "$CONTENT" "$meta_json" || log_warn "SESSION" "failed to append message to session $SESSION_ID after failed request"
        fi
      fi
    fi
    exit "$BASH4LLMERR_API"
  fi
fi
#--3<---[ /SECTION: CORE_PROVIDER_MAIN ]--->3--
########################################
# SECTION: CORE_PROVIDER - END
########################################
