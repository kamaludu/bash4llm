#--1<---[ SECTION: PRECORE_RUN_HISTORY ]--->1--
BASH4LLM_ROTATE_HISTORY="${BASH4LLM_ROTATE_HISTORY:-0}"
BASH4LLM_HISTORY_MAX_FILES="${BASH4LLM_HISTORY_MAX_FILES:-100}"
BASH4LLM_HISTORY_MAX_BYTES="${BASH4LLM_HISTORY_MAX_BYTES:-104857600}"
BASH4LLM_HISTORY_KEEP_DAYS="${BASH4LLM_HISTORY_KEEP_DAYS:-90}"

rotate_history() {
  local timeout="${1:-$BASH4LLM_LOCK_TIMEOUT_HISTORY}"
  local dir="${BASH4LLM_HISTORY_DIR:-$PWD/bash4llm.d/history}"
  local max_files="${BASH4LLM_HISTORY_MAX_FILES:-100}"
  local max_bytes="${BASH4LLM_HISTORY_MAX_BYTES:-104857600}"
  local keep_days="${BASH4LLM_HISTORY_KEEP_DAYS:-90}"

  local now_epoch cutoff f f_mtime
  now_epoch=$(date +%s)
  cutoff=$(( now_epoch - (keep_days * 86400) ))
  
  while IFS= read -r -d '' f; do
    f_mtime=$(_file_mtime "$f")
    if [ "$f_mtime" -gt 0 ] && [ "$f_mtime" -lt "$cutoff" ]; then
      lock_exec "$HISTORY_LOCK" "$timeout" -- rm -f -- "$f" || true
    fi
  done < <(find "$dir" -type f -print0 2>/dev/null)

  local last_total=999999999999999
  while :; do
    local total=0
    local -a entries
    entries=()
    local temp_mtime temp_size oldest_line oldest_file
    
    while IFS= read -r f; do
      temp_mtime=$(_file_mtime "$f")
      temp_size=$(file_size "$f")
      total=$(( total + temp_size ))
      entries+=( "${temp_mtime}|${temp_size}|${f}" )
    done < <(find "$dir" -type f 2>/dev/null)

    if [ "$total" -le "$max_bytes" ]; then
      break
    fi

    if [ "$total" -ge "$last_total" ]; then
      log_warn "ROTATE" "History rotation bytes-based removal stuck (total=$total). Breaking loop."
      break
    fi
    last_total=$total

    oldest_line=$(printf '%s\n' "${entries[@]}" | sort -t'|' -k1,1n | head -n 1)
    if [ -z "$oldest_line" ]; then
      break
    fi

    oldest_file=$(printf '%s' "$oldest_line" | cut -d'|' -f3)

    if [ -n "$oldest_file" ] && [ -f "$oldest_file" ]; then
      lock_exec "$HISTORY_LOCK" "$timeout" -- rm -f -- "$oldest_file" || true
    else
      break
    fi
  done

  local last_count=999999
  while :; do
    local -a file_list
    file_list=()
    local temp_mtime count oldest_line oldest_file
    
    while IFS= read -r f; do
      temp_mtime=$(_file_mtime "$f")
      file_list+=( "${temp_mtime}|${f}" )
    done < <(find "$dir" -type f 2>/dev/null)

    count="${#file_list[@]}"
    if [ "$count" -le "$max_files" ]; then
      break
    fi

    if [ "$count" -ge "$last_count" ]; then
      log_warn "ROTATE" "History rotation files-based removal stuck (count=$count). Breaking loop."
      break
    fi
    last_count=$count

    oldest_line=$(printf '%s\n' "${file_list[@]}" | sort -t'|' -k1,1n | head -n 1)
    if [ -z "$oldest_line" ]; then
      break
    fi

    oldest_file=$(printf '%s' "$oldest_line" | cut -d'|' -f2-)

    if [ -n "$oldest_file" ] && [ -f "$oldest_file" ]; then
      lock_exec "$HISTORY_LOCK" "$timeout" -- rm -f -- "$oldest_file" || true
    else
      break
    fi
  done

  return 0
}

save_to_history() {
  local content="${1:-}"
  local filename tmpf dest lockfile rc
  filename="$(date +%Y%m%d-%H%M%S)-groq-output-$$.txt"

  safe_mkdir "$BASH4LLM_HISTORY_DIR" 700

  tmpf="$(_tmpf file "$BASH4LLM_HISTORY_DIR" groq-out 2>/dev/null)"
  if [ -z "$tmpf" ]; then
    log_error "HISTORYFAIL" "save_to_history: cannot allocate tmp file in $BASH4LLM_HISTORY_DIR"
    return "$BASH4LLM_ERR_TMP"
  fi

  if ! printf '%s\n' "$content" > "$tmpf" 2>/dev/null; then
    rm -f -- "$tmpf" 2>/dev/null || true
    log_error "HISTORYFAIL" "save_to_history: cannot write tmp file $tmpf"
    return "$BASH4LLM_ERR_TMP"
  fi

  dest="$BASH4LLM_HISTORY_DIR/$filename"
  lockfile="$HISTORY_LOCK"

  if ! lock_exec "$lockfile" "$BASH4LLM_LOCK_TIMEOUT_HISTORY" -- bash -c '
      set -e
      mv -f -- "$1" "$2"
      chmod 600 "$2" 2>/dev/null || true
    ' _ "$tmpf" "$dest"
  then
    rc=$?
    rm -f -- "$tmpf" 2>/dev/null || true
    return "$rc"
  fi

  if [ -f "$dest" ]; then
    local size_bytes ts base history_json
    size_bytes="$(file_size "$dest" 2>/dev/null || echo 0)"
    ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    base="$(basename "$dest")"

    history_json="$(jq -c -n \
      --arg path "$dest" \
      --arg base "$base" \
      --arg ts "$ts" \
      --argjson size "$size_bytes" \
      '{saved:true, path:$path, basename:$base, ts:$ts, size_bytes:$size}')"

    ui_state_write "last_history.json" "$history_json" \
      || log_warn "UI_STATE" "failed to write last_history.json"
  else
    local ts history_json
    ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    history_json="$(jq -c -n --arg ts "$ts" '{saved:false, ts:$ts}')"
    ui_state_write "last_history.json" "$history_json" || true
  fi

  if [ "${BASH4LLM_ROTATE_HISTORY:-0}" -eq 1 ]; then
    rotate_history "$BASH4LLM_LOCK_TIMEOUT_HISTORY" || true
  fi

  if [ "${DEBUG:-0}" -eq 1 ]; then
    log_info "HISTORY_SAVE" "$dest"
  fi

  return 0
}
#--1<---[ /SECTION: PRECORE_RUN_HISTORY ]--->1--
#--2<---[ SECTION: PRECORE_RUN_MANIFEST ]--->2--
manifest_create() {
  local manifest="${1:-}"
  local timeout="${2:-$BASH4LLM_LOCK_TIMEOUT_MODELS}"
  safe_mkdir "$(dirname "$manifest")" 700
  lock_exec "${manifest}.lock" "$timeout" -- bash -c '
   set -e
   manifest="$1"
   tmp="$(mktemp "$(dirname "$manifest")/manifest.tmp.XXXXXX")"
   printf "%s" "{\"parts\":[]}" > "$tmp"
   if [ -n "${B64_WRAP_OPT:-}" ]; then
     base64 ${B64_WRAP_OPT} "$tmp" > "${manifest}.b64"
   else
     base64 "$tmp" | tr -d "\n" > "${manifest}.b64"
   fi
   mv -f "$tmp" "$manifest"
   chmod 600 "$manifest" 2>/dev/null || true
 ' _ "$manifest"

  return $?
}

manifest_add_part() {
  local manifest="${1:-}" name="${2:-}" file_path="${3:-}" mime="${4:-}" timeout="${5:-$BASH4LLM_LOCK_TIMEOUT_MODELS}"
  local destdir lockfile part_b64 tmpstamp tmp_part rc
  [ -f "$file_path" ] || { log_error "MANIFESTFAIL" "manifest_add_part: file not found: $file_path"; return 1; }
  safe_mkdir "$(dirname "$manifest")" 700

  lockfile="${manifest}.lock"

  destdir="$(dirname "$manifest")"
  tmpstamp="$(date +%s)-$$"
  part_b64="$destdir/parts-$(basename "$file_path").${tmpstamp}.b64"
  tmp_part="$(_tmpf file "$BASH4LLM_TMPDIR" part 2>/dev/null)" || {
    log_error "TMP" "manifest_add_part: _tmpf failed for BASH4LLM_TMPDIR"
    return 1
  }

  if ! b64encode < "$file_path" > "$tmp_part"; then
    rm -f "$tmp_part" 2>/dev/null || true
    log_error "B64FAIL" "manifest_add_part: b64 encode failed"
    return 1
  fi

  mv -f "$tmp_part" "$part_b64" 2>/dev/null || { rm -f "$tmp_part" 2>/dev/null || true; log_error "MANIFESTFAIL" "cannot move staged part to $part_b64"; return 1; }
  chmod 600 "$part_b64" 2>/dev/null || true

  lock_exec "$lockfile" "$timeout" -- bash -c '
    set -e
    manifest="$1"
    part_b64="$2"
    name="$3"
    mime="$4"
    tmp="$(mktemp "$(dirname "$manifest")/manifest.edit.XXXXXX")"
    if [ -f "${manifest}.b64" ]; then
      base64 ${B64_DECODE_OPT} < "${manifest}.b64" > "$tmp" 2>/dev/null || printf "%s" "{\"parts\":[]}" > "$tmp"
    elif [ -f "$manifest" ]; then
      cp -f "$manifest" "$tmp"
    else
      printf "%s" "{\"parts\":[]}" > "$tmp"
    fi
    jq --arg name "$name" --arg path "$part_b64" --arg enc "b64" --arg type "$mime" \
       ".parts += [{name:\$name, path:\$path, encoding:\$enc, type:\$type}]" "$tmp" > "${tmp}.new"
    mv -f "${tmp}.new" "$tmp"
    if [ -n "${B64_WRAP_OPT:-}" ]; then
      base64 ${B64_WRAP_OPT} "$tmp" > "${manifest}.b64"
    else
      base64 "$tmp" | tr -d "\n" > "${manifest}.b64"
    fi
    cp -f "$tmp" "$manifest"
    chmod 600 "$manifest" 2>/dev/null || true
    rm -f "$tmp" 2>/dev/null || true
  ' _ "$manifest" "$part_b64" "$name" "$mime" || { log_error "MANIFESTFAIL" "manifest_add_part: update failed"; return 1; }

  if [ "${DEBUG:-0}" -eq 1 ]; then
    log_info "MANIFEST_ADD" "added part $name -> $part_b64"
  fi
  return 0
}

manifest_read() {
  local manifest="${1:-}"
  if [ -f "$manifest" ]; then
    cat "$manifest"
    return 0
  fi
  if [ -f "${manifest}.b64" ]; then
    b64decode < "${manifest}.b64"
    return $?
  fi
  return 1
}
#--2<---[ /SECTION: PRECORE_RUN_MANIFEST ]--->2--
#--3<---[ SECTION: PRECORE_RUN_UTIL_HELPERS ]--->3--
_get_perm_string() {
  local path="${1:-}" perm=""
  if [ "$BASH4LLM_PLAT_MACOS" -eq 1 ]; then
    perm="$(stat -f %Sp "$path" 2>/dev/null || true)"
  else
    if command -v stat >/dev/null 2>&1; then
      perm="$(stat -c %A "$path" 2>/dev/null || true)"
    elif command -v ls >/dev/null 2>&1; then
      perm="$(ls -ld -- "$path" 2>/dev/null | awk '{print $1}' || true)"
    fi
  fi
  printf '%s' "$perm"
}

_get_owner() {
  local path="${1:-}" owner=""
  if [ "$BASH4LLM_PLAT_MACOS" -eq 1 ]; then
    owner="$(stat -f %Su "$path" 2>/dev/null || true)"
  else
    if command -v stat >/dev/null 2>&1; then
      owner="$(stat -c %U "$path" 2>/dev/null || true)"
    elif command -v ls >/dev/null 2>&1; then
      owner="$(ls -ld -- "$path" 2>/dev/null | awk '{print $3}' || true)"
    fi
  fi
  printf '%s' "$owner"
}

_get_file_signature() {
  local path="${1:-}"
  local hash="" stat_out="" dev="" inode="" size="" ctime="" mtime="" uid="" gid="" mode="" use_hash
  [ -f "$path" ] || { printf ''; return 0; }

  use_hash="${BASH4LLM_SIG_HASH:-1}"

  if [ "${use_hash}" != "0" ] && command -v sha256sum >/dev/null 2>&1; then
    hash="$(sha256sum "$path" 2>/dev/null | awk '{print $1}' || true)"
  else
    hash=""
  fi

  if [ "$BASH4LLM_PLAT_MACOS" -eq 1 ]; then
    stat_out="$(stat -f '%d %i %z %c %m %u %g %p' "$path" 2>/dev/null || true)"
  else
    stat_out="$(stat -c '%d %i %s %Z %Y %u %g %a' "$path" 2>/dev/null || true)"
  fi

  if [ -z "${stat_out:-}" ]; then
    dev=""; inode=""; size=""; ctime=""; mtime=""; uid=""; gid=""; mode=""
  else
    read -r dev inode size ctime mtime uid gid mode <<EOF
$stat_out
EOF
    if [ -z "${dev:-}" ] && [ -z "${inode:-}" ] && [ -z "${size:-}" ]; then
      dev=""; inode=""; size=""; ctime=""; mtime=""; uid=""; gid=""; mode=""
    fi
  fi

  printf '%s|%s|%s|%s|%s|%s|%s|%s|%s' \
    "${hash:-}" "${dev:-}" "${inode:-}" "${size:-}" "${ctime:-}" "${mtime:-}" "${uid:-}" "${gid:-}" "${mode:-}"
}

getfile_signature() { _get_file_signature "$1"; }

_is_world_writable() {
  local d="${1:-}" perms others_write
  [ -d "$d" ] || return "$BASH4LLM_ERR_TMP"
  perms="$(_get_perm_string "$d")"
  [ -z "$perms" ] && return "$BASH4LLM_ERR_TMP"
  others_write="$(printf '%s' "$perms" | awk '{print substr($0,9,1)}')"
  [ "$others_write" = "w" ]
}

make_tmpdir() {
  umask 077
  local tmpd lockfile rc
  lockfile="$TMP_LOCK"

  safe_mkdir "$BASH4LLM_TMPDIR" 700

  tmpd="$(lock_exec "$lockfile" "$BASH4LLM_LOCK_TIMEOUT_TMP" -- _tmpf dir "$BASH4LLM_TMPDIR" groq)"
  rc=$?
  if [ "$rc" -eq 0 ] && [ -n "$tmpd" ]; then
    printf '%s' "$tmpd"
    return 0
  else
    log_error "TMP" "make_tmpdir: failed to safely create secure temporary directory"
    return "$BASH4LLM_ERR_TMP"
  fi
}

_tmpf() {
  local mode="${1:-}" base="${2:-}" prefix="${3:-groq}" tmp

  if [ -z "$mode" ]; then
    log_error "TMP" "_tmpf usage: _tmpf <file|dir> <base_dir> [prefix]"
    return "$BASH4LLM_ERR_TMP"
  fi

  if [ -z "${BASH4LLM_TMPDIR:-}" ]; then
    log_error "TMP" "_tmpf: BASH4LLM_TMPDIR not set"
    return "$BASH4LLM_ERR_TMP"
  fi
  if [ ! -d "$BASH4LLM_TMPDIR" ]; then
    log_error "TMP" "_tmpf: BASH4LLM_TMPDIR does not exist: $BASH4LLM_TMPDIR"
    return "$BASH4LLM_ERR_TMP"
  fi
  if [ -L "$BASH4LLM_TMPDIR" ]; then
    log_error "TMP" "_tmpf: BASH4LLM_TMPDIR is a symlink: $BASH4LLM_TMPDIR"
    return "$BASH4LLM_ERR_TMP"
  fi
  chmod 700 "$BASH4LLM_TMPDIR" 2>/dev/null || true

  case "$base" in
    "$BASH4LLM_TMPDIR"/*|"$BASH4LLM_TMPDIR")
      :
      ;;
    *)
      base="$BASH4LLM_TMPDIR"
      ;;
  esac

  umask 077
  if [ "$mode" = "file" ]; then
    tmp="$(mktemp "$base/${prefix}.XXXXXX" 2>/dev/null || true)"
    if [ -z "$tmp" ]; then
      log_error "TMP" "_tmpf: mktemp failed for file in $base"
      return "$BASH4LLM_ERR_TMP"
    fi
    chmod 600 "$tmp" 2>/dev/null || true
    printf '%s' "$tmp"
    return 0
  elif [ "$mode" = "dir" ]; then
    tmp="$(mktemp -d "$base/${prefix}.XXXXXX" 2>/dev/null || true)"
    if [ -z "$tmp" ]; then
      log_error "TMP" "_tmpf: mktemp failed for dir in $base"
      return "$BASH4LLM_ERR_TMP"
    fi
    chmod 700 "$tmp" 2>/dev/null || true
    printf '%s' "$tmp"
    return 0
  else
    log_error "TMP" "_tmpf: unknown mode: $mode"
    return "$BASH4LLM_ERR_TMP"
  fi
}
#--3<---[ /SECTION: PRECORE_RUN_UTIL_HELPERS ]--->3--
#--4<---[ SECTION: PRECORE_RUN_SESSION_MVP ]--->4--
session_validate_id() {
  local id="${1:-}"
  if [ -z "$id" ]; then return 1; fi
  if printf '%s' "$id" | grep -qE '^[A-Za-z0-9._-]{1,128}$'; then return 0; else return 1; fi
}

session_now_ts() {
  date -u +%Y-%m-%dT%H:%M:%SZ
}

session_messages_tmp_path() {
  local sid="${1:-}"
  ensure_run_tmpdir || return 1
  printf '%s' "$RUN_TMPDIR/session-${sid}-messages.json"
}

session_sanitize_cmd() {
  local cmd="${1:-}"
  local sanitized
  sanitized="$(printf '%s' "$cmd" | sed -E 's/[A-Za-z0-9_]+=([^[:space:]]+)//g' | sed -E 's/(token|key|secret)[^[:space:]]*/[REDACTED]/Ig' )"
  printf '%s' "$(printf '%s' "$sanitized" | cut -c1-256)"
}

_update_session_index() {
  local sid="${1:-}"
  [ -n "$sid" ] || return 0
  local idx_file="${BASH4LLM_CONFIG_DIR%/}/ui_state/sessions/index.json"
  if [ -f "$idx_file" ]; then
    if jq -e --arg sid "$sid" '(.sessions // []) | index($sid) // empty' "$idx_file" >/dev/null 2>&1; then
      :
    else
      local tmp_idx
      tmp_idx="$(_tmpf file "${RUN_TMPDIR:-$BASH4LLM_TMPDIR}" uiidx 2>/dev/null)" || true
      if [ -n "$tmp_idx" ]; then
        if jq --arg sid "$sid" '.sessions = ((.sessions // []) + [$sid])' "$idx_file" > "${tmp_idx}.new" 2>/dev/null; then
          mv -f "${tmp_idx}.new" "$tmp_idx"
          ui_state_write "sessions/index.json" "$(cat "$tmp_idx")" || true
        fi
        rm -f "$tmp_idx" 2>/dev/null || true
      fi
    fi
  else
    ui_state_write "sessions/index.json" "{\"sessions\":[]}" >/dev/null 2>&1 || true
    ui_state_write "sessions/index.json" "$(jq -c -n --arg sid "$sid" '{sessions:[$sid]}')" >/dev/null 2>&1 || true
  fi
}

_session_delete_locked() {
  local sid="$1" sfile="$2" mfile="$3" ifile="$4" t_idx="$5"
  rm -f -- "$sfile" 2>/dev/null || true
  rm -f -- "${sfile}.concurrency.lock" 2>/dev/null || true
  rm -rf -- "${sfile}.concurrency.lockdir" 2>/dev/null || true
  rm -f -- "$mfile" 2>/dev/null || true

  if [ -f "$ifile" ]; then
    if jq --arg sid "$sid" ".sessions = (.sessions - [\$sid])" "$ifile" > "$t_idx" 2>/dev/null; then
      mv -f "$t_idx" "$ifile" 2>/dev/null
      chmod 600 "$ifile" 2>/dev/null || true
    else
      rm -f "$t_idx" 2>/dev/null || true
    fi
  fi
}

session_delete_core() {
  local sid="${1:-}"
  [ -n "$sid" ] || return 1
  if ! session_validate_id "$sid"; then
    log_error "SESSION" "invalid session id for deletion: $sid"
    return "$BASH4LLM_ERR_TMP"
  fi

  local session_file="${SESSION_DIR:-${BASH4LLM_HISTORY_DIR:-.}/sessions}/${sid}.ndjson"
  local meta_file="${BASH4LLM_CONFIG_DIR%/}/ui_state/sessions/${sid}.json"
  local idx_file="${BASH4LLM_CONFIG_DIR%/}/ui_state/sessions/index.json"
  local tmp_idx

  tmp_idx="${BASH4LLM_TMPDIR%/}/idx_del.$$.tmp"

  lock_exec "$HISTORY_LOCK" 10 -- _session_delete_locked "$sid" "$session_file" "$meta_file" "$idx_file" "$tmp_idx"
  rm -f "$tmp_idx" 2>/dev/null || true

  if type session_cache_invalidate >/dev/null 2>&1; then
    session_cache_invalidate "$sid" >/dev/null 2>&1 || true
  fi

  log_info "SESSION" "deleted session $sid"
  return 0
}

_session_rename_locked() {
  local mfile="$1" t_meta="$2" sid="$3" title="$4" m_count="$5" l_ts="$6"
  if [ -f "$mfile" ] && jq -e . "$mfile" >/dev/null 2>&1; then
    jq --arg title "$title" \
       --argjson msg_count "$m_count" \
       --arg last_ts "$l_ts" \
       ".title = \$title | .msg_count = \$msg_count | .last_ts = \$last_ts" "$mfile" > "$t_meta"
  else
    jq -n --arg id "$sid" --arg title "$title" \
          --argjson msg_count "$m_count" --arg last_ts "$l_ts" \
          "{id:\$id, title:\$title, active:true, msg_count:\$msg_count, last_ts:\$last_ts}" > "$t_meta"
  fi
  mv -f "$t_meta" "$mfile"
  chmod 600 "$mfile"
}

session_rename_core() {
  local sid="${1:-}" title="${2:-}"
  [ -n "$sid" ] || return 1
  if ! session_validate_id "$sid"; then
    log_error "SESSION" "invalid session id for rename: $sid"
    return "$BASH4LLM_ERR_TMP"
  fi

  title="$(printf '%s' "$title" | tr -d '\r\n' | awk '{$1=$1;print}')"
  [ -n "$title" ] || title="Session ${sid:0:8}"

  local meta_file="${BASH4LLM_CONFIG_DIR%/}/ui_state/sessions/${sid}.json"
  local tmp_meta msg_count last_ts
  local session_file="${SESSION_DIR:-${BASH4LLM_HISTORY_DIR:-.}/sessions}/${sid}.ndjson"

  tmp_meta="$(_tmpf file "${RUN_TMPDIR:-$BASH4LLM_TMPDIR}" meta_ren 2>/dev/null)" || return "$BASH4LLM_ERR_TMP"

  msg_count=0
  last_ts=""
  if [ -f "$session_file" ]; then
    msg_count="$(wc -l < "$session_file" 2>/dev/null || echo 0)"
    local last_line
    last_line="$(tail -n 1 "$session_file" 2>/dev/null || true)"
    if printf '%s' "$last_line" | jq -e . >/dev/null 2>&1; then
      last_ts="$(printf '%s' "$last_line" | jq -r '.ts // empty' 2>/dev/null || true)"
    fi
  fi

  lock_exec "$HISTORY_LOCK" 10 -- _session_rename_locked "$meta_file" "$tmp_meta" "$sid" "$title" "$msg_count" "$last_ts"
  rm -f "$tmp_meta" 2>/dev/null || true

  log_info "SESSION" "renamed session $sid to '$title'"
  return 0
}

acquire_session_lock() {
  local sid="${SESSION_ID:-}"
  [ -n "$sid" ] || return 0

  if ! session_validate_id "$sid"; then
    log_error "SESSION" "invalid session id: $sid"
    return 15
  fi

  local session_file="${SESSION_DIR:-${BASH4LLM_HISTORY_DIR:-.}/sessions}/${sid}.ndjson"
  local lockfile="${session_file}.concurrency.lock"

  if [ "${DRY_RUN:-0}" -eq 1 ] || [ "${BASH4LLM_SKIP_NETWORK:-0}" -eq 1 ]; then
    return 0
  fi

  if [ -L "$lockfile" ]; then
    log_error "SEC" "session lockfile is a symlink: $lockfile. Aborting."
    return 15
  fi

  safe_mkdir "$(dirname "$lockfile")" 700

  local use_flock=0
  if command -v flock >/dev/null 2>&1 && [ "$BASH4LLM_PLAT_ANDROID" -eq 0 ] && [ "$BASH4LLM_PLAT_MACOS" -eq 0 ] && [ "$BASH4LLM_PLAT_BSD" -eq 0 ]; then
    use_flock=1
  fi

  if [ "$use_flock" -eq 1 ]; then
    exec 8>"$lockfile" 2>/dev/null || return 0
    if ! flock -x -n 8 2>/dev/null; then
      log_error "SESSION" "Session '$sid' is already active in another instance of Bash4LLM."
      exec 8>&- 2>/dev/null || true
      return 15
    fi
  fi
  return 0
}

release_session_lock() {
  local sid="${SESSION_ID:-}"
  [ -n "$sid" ] || return 0

  if ! session_validate_id "$sid"; then
    log_error "SESSION" "invalid session id: $sid"
    return 15
  fi

  local session_file="${SESSION_DIR:-${BASH4LLM_HISTORY_DIR:-.}/sessions}/${sid}.ndjson"
  local lockfile="${session_file}.concurrency.lock"

  if [ -L "$lockfile" ]; then
    log_error "SEC" "session lockfile is a symlink during release: $lockfile. Aborting."
    return 15
  fi

  local use_flock=0
  if command -v flock >/dev/null 2>&1 && [ "$BASH4LLM_PLAT_ANDROID" -eq 0 ] && [ "$BASH4LLM_PLAT_MACOS" -eq 0 ] && [ "$BASH4LLM_PLAT_BSD" -eq 0 ]; then
    use_flock=1
  fi

  if [ "$use_flock" -eq 1 ] && { true 2>/dev/null <&8; }; then
    exec 8>&- 2>/dev/null || true
  fi
}

_session_read_window_locked() {
  local session_file="${1:-}"
  local n="${2:-10}"
  local tmpf="${3:-}"
  [ -n "$session_file" ] || return 1
  [ -n "$tmpf" ] || return 1

  if grep -q "^$" "$session_file" 2>/dev/null; then
    awk -v n="$n" 'BEGIN{RS=""; ORS=RS} {rec[++c]=$0} END{start=c-n+1; if(start<1) start=1; for(i=start;i<=c;i++) print rec[i]}' "$session_file" > "$tmpf" 2>/dev/null || cp -f "$session_file" "$tmpf" 2>/dev/null || true
  else
    if ! tail -n "$n" "$session_file" 2>/dev/null > "$tmpf"; then
      cp -f "$session_file" "$tmpf" 2>/dev/null || true
    fi
  fi
}

session_read_window() {
  local sid="${1:-}" n="${2:-10}" out="${3:-}"
  local history_dir="${BASH4LLM_HISTORY_DIR:-$PWD/bash4llm.d/history}"
  local session_file="$history_dir/sessions/${sid}.ndjson"
  local tmpdir="${RUN_TMPDIR:-${BASH4LLM_TMPDIR:-$PWD/bash4llm.d/tmp}}"
  local tmpf   out_tmp line role content role_norm role_json content_json first msg_count last_ts last_line meta_json idx_file tmp_idx

  [ -n "$sid" ] || return 1
  [ -n "$out" ] || return 1

  if ! session_validate_id "$sid"; then
    log_error "SESSION" "invalid session id: $sid"
    return 1
  fi

  safe_mkdir "${history_dir%/}/sessions" 700

  if ! printf '%s' "$n" | grep -qE '^[0-9]+$'; then n=10; fi
  if [ "$n" -le 0 ]; then n=10; fi

  safe_mkdir "${tmpdir%/}" 700
  if ! : > "${tmpdir%/}/.bash4llm_tmp_check" 2>/dev/null; then
    if [ "${DEBUG:-0}" -eq 1 ]; then
      printf 'DEBUG: session_read_window: tmpdir not writable: %s\n' "$tmpdir" >&2
    fi
    return 1
  else
    rm -f "${tmpdir%/}/.bash4llm_tmp_check" 2>/dev/null || true
  fi

  tmpf="$(_tmpf file "$tmpdir" session.read 2>/dev/null)" || { if [ "${DEBUG:-0}" -eq 1 ]; then printf 'DEBUG: session_read_window: cannot create tmpf\n' >&2; fi; return 1; }

  if [ -f "$session_file" ]; then
    lock_exec "${session_file}.lock" 5 -- _session_read_window_locked "$session_file" "$n" "$tmpf"
  else
    if [ "${DEBUG:-0}" -eq 1 ]; then
      printf 'DEBUG: session_read_window: session file not found: %s\n' "$session_file" >&2
    fi
  fi

  out_tmp="$(_tmpf file "$(dirname "$out")" out.tmp 2>/dev/null)" || { if [ "${DEBUG:-0}" -eq 1 ]; then printf 'DEBUG: session_read_window: cannot create out_tmp\n' >&2; fi; return 1; }
  safe_mkdir "$(dirname "$out")" 700
  : > "$out_tmp"
  chmod 600 "$out_tmp" 2>/dev/null || true

  printf '%s' '{"messages":[' >> "$out_tmp"
  first=1
  if jq -c . "$tmpf" >/dev/null 2>&1; then
    jq -c . "$tmpf" 2>/dev/null | while IFS= read -r line || [ -n "$line" ]; do
      role="$(printf '%s' "$line" | jq -r '.role // "user"')"
      case "$role" in user|assistant|system) role_norm="$role" ;; *) role_norm="user" ;; esac
      content="$(printf '%s' "$line" | jq -r '.content // ""')"
      role_json="$(printf '%s' "$role_norm" | jq -R -c '.')"
      content_json="$(printf '%s' "$content" | jq -R -s '.')"
      if [ "$first" -eq 0 ]; then printf ',' >> "$out_tmp"; fi
      printf '%s' "{\"role\":${role_json},\"content\":${content_json}}" >> "$out_tmp" 2>/dev/null || true
      first=0
    done
  else
    while IFS= read -r line || [ -n "$line" ]; do
      if printf '%s' "$line" | jq -e . >/dev/null 2>&1; then
        role="$(printf '%s' "$line" | jq -r '.role // "user"')"
        case "$role" in user|assistant|system) role_norm="$role" ;; *) role_norm="user" ;; esac
        content="$(printf '%s' "$line" | jq -r '.content // ""')"
        role_json="$(printf '%s' "$role_norm" | jq -R -c '.')"
        content_json="$(printf '%s' "$content" | jq -R -s '.')"
        if [ "$first" -eq 0 ]; then printf ',' >> "$out_tmp"; fi
        printf '%s' "{\"role\":${role_json},\"content\":${content_json}}" >> "$out_tmp" 2>/dev/null || true
        first=0
      fi
    done < "$tmpf"
  fi
  printf '%s' ']}' >> "$out_tmp"

  if mv -f "$out_tmp" "$out" 2>/dev/null; then
    :
  else
    cp -f "$out_tmp" "$out" 2>/dev/null || true
    rm -f "$out_tmp" 2>/dev/null || true
  fi

  rm -f "$tmpf" 2>/dev/null || true
  chmod 600 "$out" 2>/dev/null || true

  if [ -n "$sid" ]; then
    if ensure_run_tmpdir >/dev/null 2>&1; then
      msg_count=0
      last_ts=""
      if [ -f "$session_file" ]; then
        msg_count="$(wc -l < "$session_file" 2>/dev/null || echo 0)"
        last_line="$(tail -n 1 "$session_file" 2>/dev/null || true)"
        if printf '%s' "$last_line" | jq -e . >/dev/null 2>&1; then
          last_ts="$(printf '%s' "$last_line" | jq -r '.ts // empty' 2>/dev/null || true)"
        fi
      fi
      meta_json="$(jq -c -n --arg id "$sid" --argjson msg_count "$msg_count" --arg last_ts "${last_ts:-}" '{id:$id, active:(( $msg_count | tonumber) > 0), msg_count:$msg_count, last_ts:$last_ts}')"
      ui_state_write "sessions/${sid}.json" "$meta_json" || log_warn "UI_STATE" "failed to update session meta for $sid (read_window)"
    fi
  fi

  if [ "${DEBUG:-0}" -eq 1 ]; then
    printf 'DEBUG: session_read_window done: out=%s size=%s tmpf=%s\n' "$out" "$( [ -f "$out" ] && wc -c < "$out" || echo 0 )" "$tmpf" >&2
  fi

  return 0
}

session_append() {
  local sid="${1:-}" role="${2:-}" content="${3:-}" meta_json="${4:-}"
  local base_sessions_dir="${SESSION_DIR:-${BASH4LLM_HISTORY_DIR:-./bash4llm.d}/sessions}"
  local session_file="${base_sessions_dir%/}/${sid}.ndjson"
  local lockfile="${session_file}.lock"
  local invocation_ts message_id marker normalized rand tmpf found=0 role_norm line timeout
  local marker_dir created_marker=0 sess_dir tmp_init msg_count last_ts last_line idx_file tmp_idx
  local meta_file current_title first_content

  [ -n "$sid" ] || return 1

  if ! session_validate_id "$sid"; then
    log_error "SESSION" "invalid session id: $sid"
    return 1
  fi

  invocation_ts="$(session_now_ts)"
  message_id="$(printf '%s' "$meta_json" | jq -r '.id // empty' 2>/dev/null || true)"
  if [ -z "$message_id" ]; then
    normalized="$(printf '%s' "$content" | sed -e 's/\r$//' -e 's/\r\n/\n/g' | awk '{$1=$1; print}')"
    rand="$(printf '%04x' $((RANDOM & 0xFFFF)))"
    if command -v sha256sum >/dev/null 2>&1; then
      message_id="$(printf '%s|%s|%s' "$normalized" "$invocation_ts" "$rand" | sha256sum | cut -c1-16)"
    elif command -v openssl >/dev/null 2>&1; then
      message_id="$(printf '%s|%s|%s' "$normalized" "$invocation_ts" "$rand" | openssl dgst -sha256 | awk '{print $2}' | cut -c1-16)"
    else
      message_id="$rand"
    fi
  fi

  sess_dir="$(dirname "$session_file")"
  safe_mkdir "$sess_dir" 700

  if [ ! -f "$session_file" ]; then
    tmp_init="$(_tmpf file "${RUN_TMPDIR:-$BASH4LLM_TMPDIR}" session.init 2>/dev/null)" || true
    : > "${tmp_init:-/dev/null}" 2>/dev/null || true
    if ! mv -f "$tmp_init" "$session_file" 2>/dev/null; then
      cp -f "$tmp_init" "$session_file" 2>/dev/null || true
    fi
    chmod 600 "$session_file" 2>/dev/null || true
  fi

  case "$role" in user|assistant|system) role_norm="$role" ;; *) role_norm="user" ;; esac
  if [ "$role_norm" = "user" ] && [ -z "${content:-}" ]; then
    if [ "${DEBUG:-0}" -eq 1 ]; then
      log_info "SESSION" "skipping append of empty user message for session $sid"
    fi
    return 0
  fi

  if [ -n "${message_id:-}" ]; then
    marker_dir="${RUN_TMPDIR:-$BASH4LLM_TMPDIR}/session-msg-${message_id}.lockdir"
    if mkdir "$marker_dir" 2>/dev/null; then
      printf '%s\n' "$$" > "${marker_dir}/owner.pid" 2>/dev/null || true
      printf '%s\n' "$(date +%s)" > "${marker_dir}/owner.ts" 2>/dev/null || true
      chmod 700 "$marker_dir" 2>/dev/null || true
      created_marker=1
    else
      if [ "${DEBUG:-0}" -eq 1 ]; then
        log_info "SESSION" "append skipped: marker exists for message_id $message_id"
      fi
      return 0
    fi
  else
    marker_dir="${RUN_TMPDIR:-$BASH4LLM_TMPDIR}/run-$$-${RANDOM}.lockdir"
    mkdir -p "$marker_dir" 2>/dev/null || true
    printf '%s\n' "$$" > "${marker_dir}/owner.pid" 2>/dev/null || true
    printf '%s\n' "$(date +%s)" > "${marker_dir}/owner.ts" 2>/dev/null || true
    chmod 700 "$marker_dir" 2>/dev/null || true
    created_marker=1
  fi

  line="$(jq -c -n \
    --arg ts "$invocation_ts" \
    --arg role "$role_norm" \
    --arg content "$content" \
    --argjson meta "$(printf '%s' "$meta_json" | jq -c '.' 2>/dev/null || printf '%s' '{}')" \
    '{ts:$ts, role:$role, content:$content, meta:$meta}')"

  timeout="${BASH4LLM_LOCK_TIMEOUT_HISTORY:-10}"

  local use_flock=0
  if command -v flock >/dev/null 2>&1 && [ "$BASH4LLM_PLAT_ANDROID" -eq 0 ] && [ "$BASH4LLM_PLAT_MACOS" -eq 0 ] && [ "$BASH4LLM_PLAT_BSD" -eq 0 ]; then
    use_flock=1
  fi

  local write_success=0

  if [ "$use_flock" -eq 1 ]; then
    (
      exec 200>"$lockfile"
      if flock -x -w "$timeout" 200 2>/dev/null; then
        if [ -n "${message_id:-}" ] && grep -F -q "\"id\":\"$message_id\"" "$session_file" 2>/dev/null; then
          exit 0
        fi
        printf "%s\n" "$line" >> "$session_file"
      else
        exit 124
      fi
    )
    local append_rc=$?
    if [ "$append_rc" -eq 0 ]; then
      write_success=1
    else
      if [ "${created_marker:-0}" -eq 1 ]; then rm -rf -- "$marker_dir" 2>/dev/null || true; fi
      log_error "SESSION" "lock-append execution failed (code $append_rc)"
      return 1
    fi
  else
    local fallback_lockdir="${session_file}.fallback.lockdir"
    local start_time now acquired=0
    start_time=$(date +%s 2>/dev/null || echo 0)
    while :; do
      if mkdir "$fallback_lockdir" 2>/dev/null; then acquired=1; break; fi
      now=$(date +%s 2>/dev/null || echo 0)
      if [ $((now - start_time)) -ge "$timeout" ]; then break; fi
      sleep 0.1 2>/dev/null || sleep 1
    done

    if [ "$acquired" -eq 1 ]; then
      if [ -n "${message_id:-}" ] && grep -F -q "\"id\":\"$message_id\"" "$session_file" 2>/dev/null; then
        rmdir "$fallback_lockdir" 2>/dev/null || true
        return 0
      fi
      printf "%s\n" "$line" >> "$session_file"
      write_success=1
      rmdir "$fallback_lockdir" 2>/dev/null || true
    else
      if [ "${created_marker:-0}" -eq 1 ]; then rm -rf -- "$marker_dir" 2>/dev/null || true; fi
      log_error "SESSION" "fallback directory lock acquisition timed out"
      return 1
    fi
  fi

  if [ "$write_success" -eq 1 ]; then
    chmod 600 "$session_file" 2>/dev/null || true
    touch "${marker_dir}/done" 2>/dev/null || true

    if ensure_run_tmpdir >/dev/null 2>&1; then
      msg_count=0
      last_ts=""
      if [ -f "$session_file" ]; then
        msg_count="$(wc -l < "$session_file" 2>/dev/null || echo 0)"
        last_line="$(tail -n 1 "$session_file" 2>/dev/null || true)"
        if printf '%s' "$last_line" | jq -e . >/dev/null 2>&1; then
          last_ts="$(printf '%s' "$last_line" | jq -r '.ts // empty' 2>/dev/null || true)"
        fi
      fi

      meta_file="${BASH4LLM_CONFIG_DIR%/}/ui_state/sessions/${sid}.json"
      current_title=""
      if [ -f "$meta_file" ]; then
        current_title="$(jq -r '.title // empty' "$meta_file" 2>/dev/null || true)"
      fi

      if [ -z "$current_title" ] && [ "$msg_count" -ge 1 ]; then
        first_content=""
        if [ -f "$session_file" ]; then
          first_content="$(jq -r 'select(.role=="user") | .content' "$session_file" | head -n 1 | tr -d '\n\r' | cut -c 1-35)"
        fi
        [ -z "$first_content" ] && first_content="Session ${sid:0:8}"
        current_title="$first_content"
      fi

      meta_json="$(jq -c -n --arg id "$sid" --argjson msg_count "$msg_count" --arg last_ts "${last_ts:-}" --arg title "${current_title:-}" \
        '{id:$id, active:true, msg_count:$msg_count, last_ts:$last_ts, title:$title}')"

      ui_state_write "sessions/${sid}.json" "$meta_json" || log_warn "UI_STATE" "failed to write session meta for $sid"

      lock_exec "$HISTORY_LOCK" 10 -- _update_session_index "$sid"
    fi
  fi

  if [ "${DEBUG:-0}" -eq 1 ]; then
    log_info "SESSION" "appended message id ${message_id:-<no-id>} to $session_file"
  fi
  return 0
}

: "${LAST_CHECK_LINES:=50}"
#--4<---[ /SECTION: PRECORE_RUN_SESSION_MVP ]--->4--
#--5<---[ SECTION: PRECORE_RUN_SESSION_CACHE ]--->5--
# =============================================================================
# Session cache helpers (Strict-safe under set -u)
# =============================================================================
SESSION_CACHE_DIR="${BASH4LLM_CONFIG_DIR%/}/session_cache"
safe_mkdir "$SESSION_CACHE_DIR" 700

_session_hash() {
  local s="${1:-}" h=""
  if command -v sha256sum >/dev/null 2>&1; then
    h="$(printf '%s' "$s" | sha256sum 2>/dev/null | awk '{print $1}' || true)"
  elif command -v openssl >/dev/null 2>&1; then
    h="$(printf '%s' "$s" | openssl dgst -sha256 2>/dev/null | awk '{print $2}' || true)"
  else
    h="$(printf '%s' "$s" | base64 | tr -d '\n' | cut -c1-64)"
  fi
  printf '%s' "${h:-}"
}

session_cache_key() {
  local sid="${1:-}" params="${2:-}"
  [ -n "$sid" ] || return 1
  params="${params:-}"
  printf '%s|%s' "$sid" "$(_session_hash "$params")"
}

session_cache_get() {
  local sid="${1:-}" params="${2:-}" out="${3:-}"
  local key file ts now ttl
  key="$(session_cache_key "$sid" "$params")" || return 1
  file="${SESSION_CACHE_DIR%/}/${key}.cache"
  if [ ! -f "$file" ]; then return 1; fi
  read -r ts < "$file" 2>/dev/null || ts=0
  now="$(date +%s)"
  if [ "$now" -ge "$ts" ]; then
    rm -f "$file" 2>/dev/null || true
    return 1
  fi
  if [ -n "$out" ]; then
    tail -n +2 "$file" > "$out" 2>/dev/null || return 1
  else
    tail -n +2 "$file" 2>/dev/null || return 0
  fi
  return 0
}

session_cache_set() {
  local sid="${1:-}" params="${2:-}" ttl="${3:-300}" infile="${4:-}"
  local key file expiry now tmp_cache
  key="$(session_cache_key "$sid" "$params")" || return 1
  file="${SESSION_CACHE_DIR%/}/${key}.cache"
  now="$(date +%s)"
  expiry=$((now + (ttl + 0)))

  tmp_cache="$(_tmpf file "${SESSION_CACHE_DIR%/}" session.cache 2>/dev/null)" || return 1

  if {
    printf '%s\n' "$expiry"
    if [ -n "$infile" ] && [ -f "$infile" ]; then
      cat "$infile"
    else
      cat -
    fi
  } > "$tmp_cache" 2>/dev/null; then
    chmod 600 "$tmp_cache" 2>/dev/null || true
    if mv -f "$tmp_cache" "$file" 2>/dev/null; then
      chmod 600 "$file" 2>/dev/null || true
      return 0
    else
      rm -f "$tmp_cache" 2>/dev/null || true
      return 1
    fi
  else
    rm -f "$tmp_cache" 2>/dev/null || true
    return 1
  fi
}

session_cache_invalidate() {
  local sid="${1:-}" params="${2:-}" key f
  if [ -z "$sid" ]; then return 1; fi
  if [ -n "$params" ]; then
    key="$(session_cache_key "$sid" "$params")" || return 1
    rm -f "${SESSION_CACHE_DIR%/}/${key}.cache" 2>/dev/null || true
  else
    for f in "${SESSION_CACHE_DIR%/}/${sid}|"*.cache; do
      [ -e "$f" ] && rm -f -- "$f" 2>/dev/null || true
    done
  fi
  return 0
}
