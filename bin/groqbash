# ---------------------------------------------------------------------------
# Provider embedded: groq (full implementations)
# Functions: buildpayload_groq, call_api_groq, call_api_streaming_groq,
# refresh_models_groq, validate_model_groq, auto_select_model_groq
# ---------------------------------------------------------------------------

# Provider-specific API key (can be overridden via PROVIDER_API_ENV_groq)
GROQ_API_KEY="${GROQ_API_KEY:-}"
if [ -n "${PROVIDER_API_ENV_groq:-}" ]; then
  if [ -n "${!PROVIDER_API_ENV_groq:-}" ]; then
    GROQ_API_KEY="${!PROVIDER_API_ENV_groq}"
  fi
fi

# Small helper: create a temp file inside a directory (returns path)
_mktemp_in_dir() {
  local dir="$1" tmpf
  [ -n "$dir" ] || return "$GROQBASHERRTMP"
  [ -d "$dir" ] || return "$GROQBASHERRTMP"
  tmpf="$(mktemp -p "$dir" groq-XXXX 2>/dev/null || true)"
  [ -n "$tmpf" ] || return "$GROQBASHERRTMP"
  printf '%s' "$tmpf"
  return 0
}

# ---------------------------------------------------------------------------
# buildpayload_groq
# - Produces a base64-staged payload at $PAYLOAD (uses b64_atomic_write)
# - Supports: JSON_INPUT (messages or prompt), SYSTEM_PROMPT + CONTENT,
#   or CONTENT alone.
# - Honors STREAM_MODE via stream boolean in payload.
# ---------------------------------------------------------------------------
buildpayload_groq() {
  local workdir tmp_payload model_in_file model_to_use user_prompt stream_json
  workdir="${RUN_TMPDIR:-}"
  if [ -z "$workdir" ] || [ ! -d "$workdir" ]; then
    workdir="$(make_tmpdir 2>/dev/null || true)"
  fi
  [ -n "$workdir" ] || return "$GROQBASHERRTMP"
  tmp_payload="$(_mktemp_in_dir "$workdir")" || return "$GROQBASHERRTMP"
  umask 077

  if is_truthy "${STREAM_MODE:-0}"; then stream_json=true; else stream_json=false; fi

  # If JSON_INPUT provided, prefer it (supports both messages and prompt shapes)
  if [ -n "${JSON_INPUT:-}" ]; then
    if jq -e 'has("messages")' "$JSON_INPUT" >/dev/null 2>&1; then
      # stage the provided JSON as base64
      b64_atomic_write "$tmp_payload.b64" 10 < "$JSON_INPUT" || { rm -f "$tmp_payload.b64" 2>/dev/null || true; return "$GROQBASHERRTMP"; }
      mv -f "$tmp_payload.b64" "$PAYLOAD" 2>/dev/null || { rm -f "$tmp_payload.b64" 2>/dev/null || true; return "$GROQBASHERRTMP"; }
      return 0
    fi
    if jq -e 'has("prompt")' "$JSON_INPUT" >/dev/null 2>&1; then
      user_prompt="$(jq -r '.prompt' "$JSON_INPUT" 2>/dev/null || true)"
      model_in_file="$(jq -r '.model // empty' "$JSON_INPUT" 2>/dev/null || true)"
      model_to_use="${model_in_file:-$MODEL}"
      jq -n --arg model "$model_to_use" \
            --argjson stream "$stream_json" \
            --arg ture "$TURE" \
            --arg max_tokens "$MAX_TOKENS" \
            --arg user "$user_prompt" \
            '{model:$model, stream:$stream, temperature:($ture|tonumber), max_tokens:($max_tokens|tonumber), messages:[{role:"user",content:$user}] }' >"$tmp_payload"
      b64_atomic_write "$tmp_payload.b64" 10 < "$tmp_payload" || { rm -f "$tmp_payload.b64" 2>/dev/null || true; return "$GROQBASHERRTMP"; }
      mv -f "$tmp_payload.b64" "$PAYLOAD" 2>/dev/null || { rm -f "$tmp_payload.b64" 2>/dev/null || true; return "$GROQBASHERRTMP"; }
      return 0
    fi
    # Otherwise stage the raw JSON_INPUT
    b64_atomic_write "$tmp_payload.b64" 10 < "$JSON_INPUT" || { rm -f "$tmp_payload.b64" 2>/dev/null || true; return "$GROQBASHERRTMP"; }
    mv -f "$tmp_payload.b64" "$PAYLOAD" 2>/dev/null || { rm -f "$tmp_payload.b64" 2>/dev/null || true; return "$GROQBASHERRTMP"; }
    return 0
  fi

  # Build payload from CONTENT / SYSTEM_PROMPT
  if [ -n "${SYSTEM_PROMPT:-}" ]; then
    jq -n --arg model "$MODEL" \
          --argjson stream "$stream_json" \
          --arg ture "$TURE" \
          --arg max_tokens "$MAX_TOKENS" \
          --arg system "$SYSTEM_PROMPT" \
          --arg user "$CONTENT" \
          '{model:$model, stream:$stream, temperature:($ture|tonumber), max_tokens:($max_tokens|tonumber), messages:[{role:"system",content:$system},{role:"user",content:$user}] }' >"$tmp_payload"
  else
    jq -n --arg model "$MODEL" \
          --argjson stream "$stream_json" \
          --arg ture "$TURE" \
          --arg max_tokens "$MAX_TOKENS" \
          --arg user "$CONTENT" \
          '{model:$model, stream:$stream, temperature:($ture|tonumber), max_tokens:($max_tokens|tonumber), messages:[{role:"user",content:$user}] }' >"$tmp_payload"
  fi

  b64_atomic_write "$tmp_payload.b64" 10 < "$tmp_payload" || { rm -f "$tmp_payload.b64" 2>/dev/null || true; return "$GROQBASHERRTMP"; }
  mv -f "$tmp_payload.b64" "$PAYLOAD" 2>/dev/null || { rm -f "$tmp_payload.b64" 2>/dev/null || true; return "$GROQBASHERRTMP"; }
  return 0
}

buildpayloadgroq() { buildpayload_groq "$@"; }

# ---------------------------------------------------------------------------
# call_api_groq (non-streaming)
# - Expects $PAYLOAD to be a base64-staged file or raw JSON file.
# - Writes response to $RESP and returns 0 on HTTP 2xx.
# ---------------------------------------------------------------------------
call_api_groq() {
  if [ -z "${GROQ_API_KEY:-}" ]; then log_error "APIKEY" "GROQ_API_KEY is not set."; return "$GROQBASHERRNOAPIKEY"; fi
  if [ -z "${PAYLOAD:-}" ] || [ ! -s "${PAYLOAD:-}" ]; then log_error "PAYLOAD" "payload file missing or empty: ${PAYLOAD:-<unset>}"; return "$GROQBASHERRTMP"; fi
  if is_truthy "${DRY_RUN:-0}"; then log_info "DRYRUN" "DRY-RUN: skipping HTTP call"; return 0; fi

  ensure_run_tmpdir || return "$GROQBASHERRTMP"
  ERRF="${ERRF:-$RUN_TMPDIR/curl.err}"
  RESP="${RESP:-$RUN_TMPDIR/resp.json}"

  local workdir tmpout http_code _time_total api_url rc decoded_payload
  workdir="${RUN_TMPDIR:-}"
  [ -n "$workdir" ] || return "$GROQBASHERRTMP"
  tmpout="$(_mktemp_in_dir "$workdir")" || return "$GROQBASHERRTMP"
  api_url="https://api.groq.com/openai/v1/chat/completions"

  decoded_payload="$workdir/payload.dec.$$"
  if printf '%s' "$PAYLOAD" | grep -qE '\.b64$'; then
    b64decode < "$PAYLOAD" > "$decoded_payload" || { rm -f "$decoded_payload" 2>/dev/null || true; return "$GROQBASHERRTMP"; }
  else
    cp -f "$PAYLOAD" "$decoded_payload" 2>/dev/null || true
  fi

  if ! curl "${CURL_BASE_OPTS[@]}" -H "Authorization: Bearer ${GROQ_API_KEY}" -H "Content-Type: application/json" --data-binary @"$decoded_payload" -o "$RESP" -w '%{http_code} %{time_total}' "$api_url" 2>"$ERRF" >"$tmpout"; then
    rc=$?
  else
    rc=0
  fi

  rm -f "$decoded_payload" 2>/dev/null || true
  read -r http_code _time_total < "$tmpout" 2>/dev/null || http_code="$(cat "$tmpout" 2>/dev/null || echo "000")"
  rm -f "$tmpout" 2>/dev/null || true

  case "$http_code" in
    2*) return 0 ;;
    *) log_error "HTTP" "HTTP error code: $http_code"; log_info "RESPHEAD" "Response (head):"; head -n 200 "$RESP" >&2 || true; log_info "CURLERR" "Curl stderr (head):"; head -n 200 "$ERRF" >&2 || true; return "$GROQBASHERRAPI" ;;
  esac
}

call_api_groq_legacy() { call_api_groq "$@"; }

# ---------------------------------------------------------------------------
# call_api_streaming_groq
# - Performs an HTTP/1.1 request and parses SSE lines of the form "data: <json>"
# - Writes raw stream to RESP_RAW and, if valid JSON chunks exist, builds RESP (array)
# - Emits content fragments to stdout as they arrive.
# ---------------------------------------------------------------------------
call_api_streaming_groq() {
  if [ -z "${GROQ_API_KEY:-}" ]; then log_error "APIKEY" "GROQ_API_KEY is not set."; return "$GROQBASHERRNOAPIKEY"; fi
  if is_truthy "${DRY_RUN:-0}"; then log_info "DRYRUN" "DRY-RUN: skipping streaming HTTP call"; return 0; fi

  ensure_run_tmpdir || return "$GROQBASHERRTMP"
  ERRF="${ERRF:-$RUN_TMPDIR/curl.err}"
  RESP="${RESP:-$RUN_TMPDIR/resp.json}"
  RESP_RAW="$RUN_TMPDIR/resp.raw"
  : > "$RESP_RAW" 2>/dev/null || true
  chmod 600 "$RESP_RAW" 2>/dev/null || true

  local api_url rc decoded_payload
  api_url="https://api.groq.com/openai/v1/chat/completions"

  decoded_payload="$RUN_TMPDIR/payload.dec.$$"
  if printf '%s' "$PAYLOAD" | grep -qE '\.b64$'; then
    b64decode < "$PAYLOAD" > "$decoded_payload" || { rm -f "$decoded_payload" 2>/dev/null || true; return "$GROQBASHERRTMP"; }
  else
    cp -f "$PAYLOAD" "$decoded_payload" 2>/dev/null || true
  fi

  local CURL_CMD
  if command -v stdbuf >/dev/null 2>&1; then
    CURL_CMD=(stdbuf -oL curl --http1.1 "${CURL_BASE_OPTS[@]}")
  else
    CURL_CMD=(curl --http1.1 "${CURL_BASE_OPTS[@]}")
  fi

  # Inform the user that streaming is starting and where chunks will be saved
  log_info "STREAM" "Streaming active; chunks will be saved under $RUN_TMPDIR"

  "${CURL_CMD[@]}" -H "Authorization: Bearer ${GROQ_API_KEY}" -H "Content-Type: application/json" --data-binary @"$decoded_payload" "$api_url" 2>"$ERRF" | tee -a "$RESP_RAW" | \
  while IFS= read -r line; do
    case "$line" in
      'data: [DONE]'|'data:[DONE]') break ;;
      data:\ * )
        json="${line#data: }"
        content="$(printf '%s' "$json" | jq -r 'try (fromjson | (.choices[]?.delta?.content // .choices[]?.message?.content // "")) catch ""' 2>>"$ERRF" || true)"
        if [ -n "$content" ]; then
          printf '%s' "$content"
        fi
        ;;
      *) ;;
    esac
  done

  rc=${PIPESTATUS[0]:-0}
  rm -f "$decoded_payload" 2>/dev/null || true
  if [ "$rc" -ne 0 ]; then
    log_error "CURLSTREAM" "curl streaming failed (rc $rc)"; head -n 50 "$ERRF" >&2 || true
    return "$GROQBASHERRCURL_FAILED"
  fi

  # Inform the user that streaming completed and where the reconstructed output will be written
  log_info "STREAM" "Streaming completed; building outputs in $RUN_TMPDIR (final JSON: $RESP)"

  # Robust save of streaming response:
  # 1) extract lines starting with "data:" and strip the prefix
  # 2) keep only JSON-valid lines
  # 3) build resp.chunks.json (array) and resp.text.txt (concatenated content)
  # 4) write RESP atomically if chunks exist
  #
  : > "$RUN_TMPDIR/resp.lines" 2>/dev/null || true
  grep -E '^data:' "$RESP_RAW" 2>/dev/null | sed -E 's/^data:[[:space:]]*//' > "$RUN_TMPDIR/resp.lines" 2>/dev/null || true

  : > "$RUN_TMPDIR/resp.valid.jsons" 2>/dev/null || true
  while IFS= read -r _line; do
    if printf '%s' "$_line" | jq -e . >/dev/null 2>&1; then
      printf '%s\n' "$_line" >> "$RUN_TMPDIR/resp.valid.jsons"
    fi
  done < "$RUN_TMPDIR/resp.lines"

  if [ -s "$RUN_TMPDIR/resp.valid.jsons" ]; then
    jq -s '.' "$RUN_TMPDIR/resp.valid.jsons" > "$RUN_TMPDIR/resp.chunks.json" 2>/dev/null || true
    jq -r 'map(.choices[]?.delta?.content // .choices[]?.message?.content // "") | join("")' "$RUN_TMPDIR/resp.chunks.json" > "$RUN_TMPDIR/resp.text.txt" 2>/dev/null || true
    if type atomic_write >/dev/null 2>&1; then
      cat "$RUN_TMPDIR/resp.chunks.json" | atomic_write "$RESP" "$GROQBASH_LOCK_TIMEOUT_TMP" || cp -f "$RUN_TMPDIR/resp.chunks.json" "$RESP" 2>/dev/null || true
    else
      cp -f "$RUN_TMPDIR/resp.chunks.json" "$RESP" 2>/dev/null || true
    fi

    # Remove intermediate files to keep run dir clean (safe removal only under GROQBASH_TMPDIR)
    if [ -n "${RUN_TMPDIR:-}" ] && case "$RUN_TMPDIR" in "$GROQBASH_TMPDIR"/*) true;; "$GROQBASH_TMPDIR") true;; *) false;; esac; then
      rm -f "$RUN_TMPDIR/resp.lines" "$RUN_TMPDIR/resp.valid.jsons" 2>/dev/null || true
      log_info "STREAM" "Removed intermediate files resp.lines and resp.valid.jsons from $RUN_TMPDIR"
    fi
  else
    if jq -e . "$RESP_RAW" >/dev/null 2>&1; then
      cp -f "$RESP_RAW" "$RESP" 2>/dev/null || true
    fi
  fi

  return 0
}

call_api_streaming_groq_legacy() { call_api_streaming_groq "$@"; }

# ---------------------------------------------------------------------------
# refresh_models_groq
# - Fetches /openai/v1/models and writes a newline-separated list to MODELS_FILE
# - Uses jq when possible; if response is not valid JSON, attempts a heuristic parse.
# - Writes via b64_atomic_write + lock_exec to ensure atomic update.
# ---------------------------------------------------------------------------
refresh_models_groq() {
  if [ -n "${PROVIDER_API_ENV_groq:-}" ] && [ -n "${!PROVIDER_API_ENV_groq:-}" ]; then
    GROQ_API_KEY="${!PROVIDER_API_ENV_groq}"
  fi
  if [ -z "${GROQ_API_KEY:-}" ]; then
    log_error "APIKEY" "GROQ_API_KEY is required to refresh models."
    return "$GROQBASHERRNOAPIKEY"
  fi

  ensure_run_tmpdir || return "$GROQBASHERRTMP"
  local workdir tmpd out errf parsed tmpout api_url jq_ok
  workdir="${RUN_TMPDIR:-}"
  [ -n "$workdir" ] || return "$GROQBASHERRTMP"
  tmpd="$(mktemp -d -p "$workdir" groq-models.XXXX 2>/dev/null || true)"
  [ -n "$tmpd" ] || return "$GROQBASHERRTMP"
  out="$tmpd/models.json"; errf="$tmpd/curl.err"
  api_url="https://api.groq.com/openai/v1/models"

  if ! curl "${CURL_BASE_OPTS[@]}" -H "Authorization: Bearer ${GROQ_API_KEY}" -H "Content-Type: application/json" "$api_url" -o "$out" 2>"$errf"; then
    log_error "CURL" "curl failed while refreshing models"; head -n 50 "$errf" >&2 || true
    rm -rf "$tmpd"
    return "$GROQBASHERRCURL_FAILED"
  fi

  parsed="$tmpd/parsed_models.txt"
  if jq -e . "$out" >/dev/null 2>&1; then
    jq_ok=1
    jq -r '.data[]?.id // empty' "$out" 2>/dev/null | sort -u > "$parsed" || true
  else
    jq_ok=0
    log_warn "MODELREFRESH" "models response not valid JSON; using heuristic parse"
    # Heuristic: extract "id":"..." occurrences
    grep -oE '"id"[[:space:]]*:[[:space:]]*"[^"]+"' "$out" 2>/dev/null | sed -E 's/.*"([^"]+)".*/\1/' | sort -u > "$parsed" || true
  fi

  if [ -s "$parsed" ]; then
    if [ "$jq_ok" -eq 0 ]; then
      # Validate heuristic output contains plausible ids (alnum, ., _, :, -)
      if ! awk '/^[[:alnum:]._:-]+$/{print; ok=1} END{exit !ok}' "$parsed"; then
        log_error "MODELREFRESH" "Heuristic parse produced invalid model ids; aborting refresh"
        rm -rf "$tmpd"
        return "$GROQBASHERRAPI"
      fi
    fi

    mkdir -p "$(dirname "$MODELS_FILE")" 2>/dev/null || true
    tmpout="$(_mktemp_in_dir "$(dirname "$MODELS_FILE")" )" || tmpout="$MODELS_FILE.tmp"
    cat "$parsed" > "$tmpout"
    # write base64 staging and then atomically decode under models lock
    b64_atomic_write "${MODELS_FILE}.b64" 10 < "$tmpout" || { rm -f "$tmpout" 2>/dev/null || true; rm -rf "$tmpd"; return "$GROQBASHERRTMP"; }
    lockfile="$MODELS_LOCK"
    lock_exec "$lockfile" 10 -- sh -c '
      set -e
      manifest_b64="$1"
      dest="$2"
      # decode staging using exported decode opt
      base64 ${B64_DECODE_OPT} < "$manifest_b64" > "$dest"
      chmod 600 "$dest" 2>/dev/null || true
    ' _ "${MODELS_FILE}.b64" "$MODELS_FILE"
    chmod 600 "$MODELS_FILE" 2>/dev/null || true
    log_info "MODELREFRESH" "Models refreshed and saved to: $MODELS_FILE"
    rm -rf "$tmpd"
    return 0
  else
    log_error "MODELREFRESH" "models refresh: parsed list empty"
    rm -rf "$tmpd"
    return "$GROQBASHERRAPI"
  fi
}

refreshmodelsgroq() { refresh_models_groq "$@"; }

# ---------------------------------------------------------------------------
# validate_model_groq
# - If MODELS_FILE exists and is non-empty, require the model to be present.
# - If MODELS_FILE does not exist or is empty, allow (backwards compatible).
# ---------------------------------------------------------------------------
validate_model_groq() {
  local model="$1"
  if [ -f "$MODELS_FILE" ] && [ -s "$MODELS_FILE" ]; then
    if grep -x -F -q "$model" "$MODELS_FILE" 2>/dev/null; then
      return 0
    else
      return 1
    fi
  fi
  # No local whitelist available: accept (compat)
  return 0
}

validatemodelgroq() { validate_model_groq "$@"; }

# ---------------------------------------------------------------------------
# auto_select_model_groq
# - Returns the first non-empty model from MODELS_FILE if present.
# ---------------------------------------------------------------------------
auto_select_model_groq() {
  local file="$MODELS_FILE" result=""
  if [ -f "$file" ] && [ -s "$file" ]; then
    result="$(awk 'NF{print; exit}' "$file" 2>/dev/null || true)"
  fi
  result="$(printf '%s' "$result" | awk '{$1=$1;print}')"
  printf '%s' "$result"
  return 0
}

autoselectmodelgroq() { auto_select_model_groq "$@"; }
# ==== PROVIDER END ====
# ==== CORE BEGIN ====
# ---------------------------------------------------------------------------
# Core helpers and CLI wiring (public interfaces preserved)
# ---------------------------------------------------------------------------

# Dispatch helper: call provider-specific function by name if available
call_provider() {
  local fn="$1" shift_args=("${@:2}")
  if type "$fn" >/dev/null 2>&1; then
    "$fn" "${shift_args[@]}"
    return $?
  fi
  return 127
}

# Provider dispatch wrappers (call provider-specific implementations if present)
refresh_models_dispatch() {
  local destfile="${1:-$MODELS_FILE}"
  local fn="refresh_models_${PROVIDER}"
  if call_provider "$fn"; then
    return 0
  else
    return $?
  fi
}

validate_model_dispatch() {
  local model="$1"
  local fn="validate_model_${PROVIDER}"
  if type "$fn" >/dev/null 2>&1; then
    "$fn" "$model"
    return $?
  fi
  # Default permissive behavior if provider does not implement validation
  return 0
}

auto_select_model_dispatch() {
  local fn="auto_select_model_${PROVIDER}"
  if call_provider "$fn"; then
    return 0
  fi
  return 1
}

# ---------------------------------------------------------------------------
# Build payload from current vars (delegates to provider)
# ---------------------------------------------------------------------------
build_payload_from_vars() {
  ensure_run_tmpdir
  local fn="buildpayload_${PROVIDER}"
  if call_provider "$fn"; then
    return 0
  else
    rc=$?
    if [ "$rc" -eq 127 ]; then
      log_error "PROVIDER" "Provider '$PROVIDER' does not provide $fn()."
      exit "$GROQBASHERRAPI"
    else
      return "$rc"
    fi
  fi
}

# ---------------------------------------------------------------------------
# API call wrappers (non-streaming and streaming)
# ---------------------------------------------------------------------------
call_api_once() {
  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    show_payload_head "$PAYLOAD" 200 || true
    log_info "DRYRUN" "DRY-RUN: skipping provider HTTP call"
    return 0
  fi
  local fn="call_api_${PROVIDER}"
  if call_provider "$fn"; then
    return 0
  else
    rc=$?
    if [ "$rc" -eq 127 ]; then
      log_error "PROVIDER" "Provider '$PROVIDER' does not provide $fn()."
      exit "$GROQBASHERRAPI"
    else
      return "$rc"
    fi
  fi
}

call_api_streaming() {
  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    show_payload_head "$PAYLOAD" 200 || true
    log_info "DRYRUN" "DRY-RUN: skipping provider streaming HTTP call"
    return 0
  fi
  local fn="call_api_streaming_${PROVIDER}"
  if call_provider "$fn"; then
    return 0
  else
    rc=$?
    if [ "$rc" -eq 127 ]; then
      log_error "PROVIDER" "Provider '$PROVIDER' does not provide $fn()."
      exit "$GROQBASHERRAPI"
    else
      return "$rc"
    fi
  fi
}

# ---------------------------------------------------------------------------
# Response extraction helpers
# ---------------------------------------------------------------------------
extract_text_from_resp() {
  [ ! -s "${RESP:-}" ] && return 0
  if jq -e . "$RESP" >/dev/null 2>&1; then
    jq -r '
      [ .choices[]? | (.message?.content // .delta?.content // "") ] | join("\n")
    ' "$RESP" 2>/dev/null | sed 's/\\"/"/g' || true
  else
    cat "$RESP" 2>/dev/null || true
  fi
  return 0
}

extract_api_error() {
  [ ! -s "${RESP:-}" ] && return 0
  if jq -e . "$RESP" >/dev/null 2>&1; then
    jq -r '.error?.message // .choices[]?.message?.content // empty' "$RESP" 2>/dev/null | head -n1 || true
  else
    awk 'NF{print; exit}' "$RESP" 2>/dev/null || true
  fi
}

# ---------------------------------------------------------------------------
# Finalize and output (fixed tmp usage and save logic)
# ---------------------------------------------------------------------------
finalize_and_output() {
  local mode="$1" text="$2"
  if { [ "$mode" = "json" ] || [ "$mode" = "pretty" ]; } && [ ! -s "${RESP:-}" ]; then
    log_error "RESP" "response file missing or empty: ${RESP:-<unset>}"
    return "$GROQBASHERRTMP"
  fi

  case "$mode" in
    json) cat "$RESP" ;;
    pretty) if jq -e . "$RESP" >/dev/null 2>&1; then jq . "$RESP"; else cat "$RESP"; fi ;;
    raw) printf '%s' "$text" ;;
    text) printf '%s\n' "$text" ;;
    *) printf '%s\n' "$text" ;;
  esac

  if [ "$mode" = "text" ] || [ "$mode" = "raw" ]; then
    [ "${FORCE_SAVE_MODE:-}" = "nosave" ] && return 0
    local len do_save=0 dest_dir dest_path
    len="$(printf '%s' "$text" | wc -c | tr -d ' ')"
    if [ "${FORCE_SAVE_MODE:-}" = "save" ]; then
      do_save=1
    else
      if [ "$len" -gt "$THRESHOLD" ]; then
        do_save=1
      fi
    fi
    if [ "$do_save" -eq 1 ]; then
      if [ -n "$OUT_PATH" ]; then
        if [ -d "$OUT_PATH" ]; then dest_dir="$OUT_PATH"; dest_path="$dest_dir/$(date +%Y%m%d-%H%M%S)-groq-output-$$.txt"; else dest_path="$OUT_PATH"; dest_dir="$(dirname "$dest_path")"; fi
      else dest_dir="$GROQBASH_HISTORY_DIR"; dest_path="$dest_dir/$(date +%Y%m%d-%H%M%S)-groq-output-$$.txt"; fi
      mkdir -p "$dest_dir" 2>/dev/null || true

      if [ -z "${RUN_TMPDIR:-}" ] || [ ! -d "$RUN_TMPDIR" ]; then
        log_error "TMPFAIL" "RUN_TMPDIR not available for saving output."
        return "$GROQBASHERRTMP"
      fi

      # Save via save_to_history which handles atomic tmp creation and rotation
      save_to_history "$text" || log_warn "HISTORY" "Failed to save output to history."
    fi
  fi
}

# ---------------------------------------------------------------------------
# Perform request with retries
# ---------------------------------------------------------------------------
perform_request_once() {
  local attempt=1 rc
  while [ "$attempt" -le "$MAX_RETRIES" ]; do
    if call_api_once; then
      if [ "${DRY_RUN:-0}" -eq 1 ]; then
        log_info "DRYRUN" "DRY-RUN: request simulated successfully. Payload: $PAYLOAD"
        return 0
      fi
      local text api_err
      text="$(extract_text_from_resp || true)"
      if [ -z "$text" ] && [ "$OUTPUT_MODE" != "json" ] && [ "$OUTPUT_MODE" != "pretty" ]; then
        api_err="$(extract_api_error || true)"
        if [ -n "$api_err" ]; then
          log_error "API" "API error: $api_err"
          return "$GROQBASHERRAPI"
        else
          log_error "API" "no textual content extracted from response."
          head -n 50 "${RESP:-/dev/null}" >&2 || true
          return "$GROQBASHERRAPI"
        fi
      fi
      finalize_and_output "$OUTPUT_MODE" "$text"
      return 0
    else
      rc=$?
      if [ "$rc" -eq "$GROQBASHERRCURL_FAILED" ]; then printf 'groqbash: WARN: Network error (curl). Retrying...\n' >&2
      elif [ "$rc" -eq "$GROQBASHERRAPI" ]; then printf 'groqbash: ERROR: HTTP/API error. Not retrying.\n' >&2; head -n 50 "${RESP:-/dev/null}" >&2 || true; return "$GROQBASHERRAPI"
      else printf 'groqbash: WARN: Unknown error (code %s). Retrying...\n' "$rc" >&2
      fi
    fi
    attempt=$((attempt + 1)); sleep $((attempt * 1))
  done
  log_error "REQUEST" "request failed after $MAX_RETRIES attempts."
  return "$GROQBASHERRAPI"
}

# ---------------------------------------------------------------------------
# Input helpers
# ---------------------------------------------------------------------------
collect_input_from_files() {
  local out="" first=1 f
  for f in "$@"; do
    if file_readable "$f"; then
      [ "$first" -eq 0 ] && out="${out}"$'\n\n'"--- FILE: ${f} ---"$'\n\n'
      out="${out}$(cat "$f")"; first=0
    else log_error "FILE" "file not readable: $f"; exit "$GROQBASHERRTMP"; fi
  done
  printf '%s' "$out"
}
expand_args_to_content() {
  local out="" first=1 a
  for a in "${ARGS[@]}"; do
    if file_readable "$a"; then
      [ "$first" -eq 0 ] && out="${out}"$'\n\n'"--- FILE: ${a} ---"$'\n\n'
      out="${out}$(cat "$a")"; first=0
    else
      [ "$first" -eq 0 ] && out="${out}"$'\n\n'
      out="${out}${a}"; first=0
    fi
  done
  printf '%s' "$out"
}
file_readable() { [ -r "$1" ] && [ -f "$1" ]; }
trim() { printf '%s' "$1" | awk '{$1=$1; print}'; }
is_number() { printf '%s\n' "$1" | awk 'BEGIN{exit 0} {exit !( $0+0 == $0+0 )}'; }

# ---------------------------------------------------------------------------
# CLI parsing (flags, normalization, immediate actions)
# ---------------------------------------------------------------------------
JSON_INPUT="${JSON_INPUT:-}" TEMPLATE="${TEMPLATE:-}" BATCH_FILE="${BATCH_FILE:-}" CHAT_MODE="${CHAT_MODE:-0}" SET_DEFAULT_MODEL="${SET_DEFAULT_MODEL:-}"
REFRESH_MODELS="${REFRESH_MODELS:-0}" LIST_MODELS="${LIST_MODELS:-0}" LIST_PROVIDERS="${LIST_PROVIDERS:-0}" FORCE_SAVE_MODE="${FORCE_SAVE_MODE:-}" OUT_PATH="${OUT_PATH:-}"
DRY_RUN="${DRY_RUN:-0}" STREAM_MODE="${STREAM_MODE:-0}" QUIET="${QUIET:-0}" INSTALL_EXTRAS="${INSTALL_EXTRAS:-0}" DEBUG="${DEBUG:-0}"
PROVIDER_CLI="${PROVIDER_CLI:-}" PROVIDER_INTERACTIVE="${PROVIDER_INTERACTIVE:-0}"
SHOW_CONFIG="${SHOW_CONFIG:-0}" DIAGNOSTICS="${DIAGNOSTICS:-0}"
FILE_INPUTS=() ARGS=() OUTPUT_MODE="${OUTPUT_MODE:-text}"

while [ $# -gt 0 ]; do
  case "$1" in
    --refresh-models|--refresh-model) REFRESH_MODELS=1; shift ;;
    --list-models) LIST_MODELS=1; shift ;;
    --list-providers) LIST_PROVIDERS=1; shift ;;
    --set-default) SET_DEFAULT_MODEL="${2:-}"; shift 2 ;;
    -m|--model) MODEL="${2:-}"; shift 2 ;;
    -f) FILE_INPUTS+=("${2:-}"); shift 2 ;;
    --json-input) JSON_INPUT="${2:-}"; shift 2 ;;
    --template) TEMPLATE="${2:-}"; shift 2 ;;
    --batch) BATCH_FILE="${2:-}"; shift 2 ;;
    --system) SYSTEM_PROMPT="${2:-}"; shift 2 ;;
    --ture) TURE="${2:-}"; shift 2 ;;
    --temperature) TURE="${2:-}"; shift 2 ;;
    --max) MAX_TOKENS="${2:-}"; shift 2 ;;
    --debug) DEBUG=1; shift ;;
    --save) FORCE_SAVE_MODE="save"; shift ;;
    --nosave) FORCE_SAVE_MODE="nosave"; shift ;;
    --out) OUT_PATH="${2:-}"; shift 2 ;;
    --threshold) THRESHOLD="${2:-}"; shift 2 ;;
    --dry-run) DRY_RUN=1; shift ;;
    --quiet) QUIET=1; shift ;;
    --stream) STREAM_MODE=1; shift ;;
    --no-stream) STREAM_MODE=0; shift ;;
    --json) OUTPUT_MODE="json"; shift ;;
    --pretty) OUTPUT_MODE="pretty"; shift ;;
    --text) OUTPUT_MODE="text"; shift ;;
    --raw) OUTPUT_MODE="raw"; shift ;;
    --chat) CHAT_MODE=1; shift ;;
    --show-config) SHOW_CONFIG=1; shift ;;
    --diagnostics) DIAGNOSTICS=1; shift ;;
    --provider)
      if [ "${2:-}" ] && [ "${2:0:1}" != "-" ]; then PROVIDER_CLI="${2:-}"; shift 2; else PROVIDER_INTERACTIVE=1; shift; fi
      ;;
    --install-extras) INSTALL_EXTRAS=1; shift ;;
    --version) printf '%s %s (%s)\n' "$SCRIPT_NAME" "$SCRIPT_VERSION" "$SCRIPT_DATE"; exit 0 ;;
    -h|--help)
      help_file="$GROQBASH_EXTRAS_DIR/docs/help.txt"
      if [ -f "$help_file" ]; then cat "$help_file"; else printf 'Help file not found: %s\n' "$help_file" >&2; fi
      exit 0 ;;
    --) shift; break ;;
    -*) printf 'Unknown option: %s\n' "$1" >&2; exit "$GROQBASHERRTMP" ;;
    *) ARGS+=("$1"); shift ;;
  esac
done

# ---------------------------------------------------------------------------
# Normalize boolean-like flags
# ---------------------------------------------------------------------------
for flag in DRY_RUN STREAM_MODE INSTALL_EXTRAS PROVIDER_INTERACTIVE REFRESH_MODELS LIST_MODELS LIST_PROVIDERS CHAT_MODE QUIET SHOW_CONFIG DIAGNOSTICS; do
  if is_truthy "${!flag:-0}"; then printf -v "$flag" 1; else printf -v "$flag" 0; fi
done

# Guard: prevent accidental real API calls (ALLOW_API_CALLS defaults to 1)
: "${ALLOW_API_CALLS:=1}"
if [ -n "${GROQ_API_KEY:-}" ] && ! is_truthy "${ALLOW_API_CALLS:-0}" && ! is_truthy "${DRY_RUN:-0}"; then
  log_error "APIKEY" "GROQ_API_KEY is set but ALLOW_API_CALLS!=1 and DRY_RUN!=1."
  exit "$GROQBASHERRTMP"
fi

# ---------------------------------------------------------------------------
# Immediate actions: refresh, list providers/models, set-default, install-extras
# ---------------------------------------------------------------------------
if [ "$REFRESH_MODELS" -eq 1 ]; then
  if ! ensure_api_key_for_provider "$PROVIDER"; then
    log_error "APIKEY" "API key required to refresh models for provider $PROVIDER."
    exit "$GROQBASHERRNOAPIKEY"
  fi
  refresh_models_dispatch "$MODELS_FILE" || exit "$GROQBASHERRAPI"
  exit 0
fi

if [ "$LIST_PROVIDERS" -eq 1 ]; then
  PROVIDER_FILE="${PROVIDER_FILE:-$GROQBASH_CONFIG_DIR/provider}"
  printf 'Available providers:\n' >&2
  printf '  - groq (embedded)\n' >&2
  extras_prov_dir="$GROQBASH_EXTRAS_DIR/providers"
  if [ -d "$extras_prov_dir" ]; then
    found=0
    for f in "$extras_prov_dir"/*.sh; do
      [ -e "$f" ] || continue
      base="$(basename "$f" .sh)"
      [ "$base" = "groq" ] && continue
      printf '  - %s\n' "$base" >&2
      found=1
    done
  fi
  if [ -f "$PROVIDER_FILE" ]; then
    active="$(sed -n '1p' "$PROVIDER_FILE" 2>/dev/null || true)"
    if [ -n "$active" ]; then
      printf '\nActive provider: %s\n' "$active" >&2
    else
      printf '\nActive provider: groq (default)\n' >&2
    fi
  else
    printf '\nActive provider: groq (default)\n' >&2
  fi
  exit 0
fi

if [ "$LIST_MODELS" -eq 1 ]; then
  if [ -s "$MODELS_FILE" ]; then cat "$MODELS_FILE" >&2; exit 0
  else printf 'No models available locally. Consider --refresh-models.\n' >&2; exit "$GROQBASHERRTMP"; fi
fi

if [ -n "$SET_DEFAULT_MODEL" ]; then
  mkdir -p "$GROQBASH_CONFIG_DIR" 2>/dev/null || true
  if [ -L "$GROQBASH_CONFIG_DIR" ]; then log_error "SEC" "config dir is a symlink."; exit "$GROQBASHERRTMP"; fi
  printf '%s\n' "$SET_DEFAULT_MODEL" | atomic_write "$GROQBASH_CONFIG_DIR/model.$PROVIDER" 10 \
    || { log_error "SEC" "cannot write default model."; exit "$GROQBASHERRTMP"; }
  printf 'groqbash: INFO: Default model for provider %s set to: %s\n' "$PROVIDER" "$SET_DEFAULT_MODEL" >&2
  exit 0
fi

if [ "$STREAM_MODE" -eq 1 ] && { [ "$OUTPUT_MODE" = "json" ] || [ "$OUTPUT_MODE" = "pretty" ]; }; then
  log_error "ARGS" "--stream incompatible with --json/--pretty."
  exit "$GROQBASHERRTMP"
fi

if [ "$INSTALL_EXTRAS" -eq 1 ]; then
  dest_base="$GROQBASH_EXTRAS_DIR"
  dest_docs="$dest_base/docs"
  dest_lib="$dest_base/lib"
  dest_prov="$dest_base/providers"
  dest_security="$dest_base/security"
  dest_test="$dest_base/test"
  src_base="$SCRIPTDIR/extras"
  src_docs="$src_base/docs"
  src_lib="$src_base/lib"
  src_prov="$src_base/providers"
  src_security="$src_base/security"
  src_test="$src_base/test"

  mkdir -p "$dest_docs" "$dest_lib" "$dest_prov" "$dest_security" "$dest_test" 2>/dev/null \
    || { log_error "EXTRAS" "cannot create extras dirs."; exit "$GROQBASHERRTMP"; }
  chmod 700 "$dest_base" "$dest_docs" "$dest_lib" "$dest_prov" "$dest_security" "$dest_test" 2>/dev/null || true

  current_user="$(id -un 2>/dev/null || printf '')"
  [ -d "$src_base" ] || { log_error "EXTRAS" "missing extras source directory: $src_base"; exit "$GROQBASHERRTMP"; }

  files_to_copy=()
  while IFS= read -r -d '' f; do files_to_copy+=("$f"); done < <(find "$src_base" -type f -print0 2>/dev/null || true)

  if [ "${#files_to_copy[@]}" -eq 0 ]; then
    printf 'No extras files found under %s; nothing to install.\n' "$src_base" >&2
    exit 0
  fi

  for src in "${files_to_copy[@]}"; do
    [ -f "$src" ] || { log_error "EXTRAS" "extras entry not a regular file: $src"; exit "$GROQBASHERRTMP"; }
    [ -L "$src" ] && { log_error "EXTRAS" "extras file is symlink: $src"; exit "$GROQBASHERRTMP"; }
    src_owner="$(_get_owner "$src")"
    [ -n "$src_owner" ] && [ "$src_owner" != "$current_user" ] && { log_error "EXTRAS" "wrong owner: $src"; exit "$GROQBASHERRTMP"; }
  done

  installed_providers=()
  installed_libs=()
  installed_docs=()
  installed_security=()
  installed_tests=()

  for src in "${files_to_copy[@]}"; do
    rel="${src#"$src_base"/}"
    dest="$dest_base/$rel"
    destdir="$(dirname "$dest")"
    mkdir -p "$destdir" 2>/dev/null || { log_error "EXTRAS" "cannot create dest dir: $destdir"; exit "$GROQBASHERRTMP"; }
    cat "$src" | atomic_write "$dest" 10 || { log_error "EXTRAS" "Error copying $src"; exit "$GROQBASHERRTMP"; }
    chmod 600 "$dest" 2>/dev/null || true

    case "$rel" in
      providers/*.sh) installed_providers+=("$(basename "$rel" .sh)") ;;
      lib/*.sh) installed_libs+=("$(basename "$rel")") ;;
      docs/*) installed_docs+=("$(basename "$rel")") ;;
      security/*) installed_security+=("$(basename "$rel")") ;;
      test/*) installed_tests+=("$(basename "$rel")") ;;
    esac
  done

  printf 'groqbash: INFO: Extras installed under %s/extras/\n' "$GROQBASH_DIR" >&2

  if [ "${#installed_providers[@]}" -gt 0 ]; then
    printf 'Installed providers: %s\n' "$(printf '%s ' "${installed_providers[@]}")" >&2
  fi
  if [ "${#installed_libs[@]}" -gt 0 ]; then
    printf 'Installed libs: %s\n' "$(printf '%s ' "${installed_libs[@]}")" >&2
  fi
  if [ "${#installed_docs[@]}" -gt 0 ]; then
    printf 'Installed docs: %s\n' "$(printf '%s ' "${installed_docs[@]}")" >&2
  fi
  if [ "${#installed_security[@]}" -gt 0 ]; then
    printf 'Installed security scripts: %s\n' "$(printf '%s ' "${installed_security[@]}")" >&2
  fi
  if [ "${#installed_tests[@]}" -gt 0 ]; then
    printf 'Installed test scripts: %s\n' "$(printf '%s ' "${installed_tests[@]}")" >&2
  fi

  for p in "${installed_providers[@]}"; do
    PROVIDER_MODULE_PATH="$dest_prov/${p}.sh"
    if ! bash -n "$PROVIDER_MODULE_PATH" 2>/dev/null; then
      printf 'groqbash: WARN: provider %s has syntax errors; check %s\n' "$p" "$PROVIDER_MODULE_PATH" >&2
    fi
  done

  exit 0
fi

# ---------------------------------------------------------------------------
# Load local config and whitelist
# ---------------------------------------------------------------------------
load_local_config() {
  local cfg="$GROQBASH_CONFIG_DIR/config" key val
  [ -f "$cfg" ] || return 0
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in ''|\#*) continue ;; esac
    key="${line%%=*}"
    val="${line#*=}"
    case "$key" in
      MODEL) [ -n "$val" ] && MODEL="$val" ;;
      TEMPERATURE|TURE) [ -n "$val" ] && TURE="$val" ;;
      MAX_TOKENS) [ -n "$val" ] && MAX_TOKENS="$val" ;;
      FORMAT) [ -n "$val" ] && OUTPUT_MODE="$val" ;;
      THRESHOLD) [ -n "$val" ] && THRESHOLD="$val" ;;
    esac
  done < "$cfg"
}

load_whitelist() {
  ALLOWED_MODELS="${ALLOWED_MODELS:-}"
  if [ -f "$MODELS_FILE" ] && [ -s "$MODELS_FILE" ]; then
    ALLOWED_MODELS="$(cat "$MODELS_FILE" 2>/dev/null || true)"
  fi
}

# ---------------------------------------------------------------------------
# Small runtime helpers used by CORE
# - is_tty_out: returns 0 if stdout is a TTY (useful for interactive prompts)
# - provider_api_env_var_name: canonical env var name for provider API key
# - ensure_api_key_for_provider: ensure API key present (supports PROVIDER_API_ENV_<prov>)
# ---------------------------------------------------------------------------
is_tty_out() {
  # Return success if stdout is a TTY
  [ -t 1 ]
}

provider_api_env_var_name() {
  local prov="$1"
  local prov_upper
  prov_upper="$(printf '%s' "$prov" | tr '[:lower:]' '[:upper:]' | tr -c 'A-Z0-9_' '_')"
  printf '%s' "${prov_upper}_API_KEY"
}

ensure_api_key_for_provider() {
  local prov="$1"
  local envvar current_key input_key custom_var custom_env
  [ -n "$prov" ] || return 1
  envvar="$(provider_api_env_var_name "$prov")"
  custom_var="PROVIDER_API_ENV_${prov}"
  custom_env="${!custom_var:-}"
  if [ -n "$custom_env" ]; then
    envvar="$custom_env"
  fi
  current_key="${!envvar:-}"
  if [ -n "$current_key" ]; then
    # If provider is groq and envvar differs, sync GROQ_API_KEY for backward compatibility
    if [ "$prov" = "groq" ] && [ "$envvar" != "GROQ_API_KEY" ]; then
      export GROQ_API_KEY="$current_key"
    fi
    return 0
  fi

  # If not interactive, fail with error code
  if [ ! -t 0 ]; then
    printf 'groqbash: ERROR: API key for provider %s not set (env %s). Run interactively or export the variable.\n' "$prov" "$envvar" >&2
    return "$GROQBASHERRNOAPIKEY"
  fi

  # Prompt user for key
  printf 'Enter API key for provider %s (env %s): ' "$prov" "$envvar" >&2
  if ! IFS= read -r input_key; then
    printf '\ngroqbash: ERROR: no input received. Aborting.\n' >&2
    return "$GROQBASHERRNOAPIKEY"
  fi
  input_key="$(printf '%s' "$input_key" | tr -d '\r\n')"
  if [ -z "$input_key" ]; then
    printf 'groqbash: ERROR: API key required. Aborting.\n' >&2
    return "$GROQBASHERRNOAPIKEY"
  fi

  export "$envvar"="$input_key"
  if [ "$prov" = "groq" ] && [ "$envvar" != "GROQ_API_KEY" ]; then
    export GROQ_API_KEY="$input_key"
  fi

  printf '\nTo avoid re-entering the key for subsequent invocations, run this in your shell:\n' >&2
  printf '\n export %s="%s"\n' "$envvar" "$input_key" >&2
  printf '\nYou can add that line to your shell profile (e.g., ~/.bashrc or ~/.profile) to persist it across sessions.\n' >&2

  return 0
}

# ---------------------------------------------------------------------------
# Provider discovery and loading (keeps behavior compatible)
# ---------------------------------------------------------------------------
PROVIDER_FILE="${PROVIDER_FILE:-$GROQBASH_CONFIG_DIR/provider}"

_supported_providers_arr=()
_supported_providers_arr+=("groq")
extras_prov_dir="$GROQBASH_EXTRAS_DIR/providers"
if [ -d "$extras_prov_dir" ]; then
  for pf in "$extras_prov_dir"/*.sh; do
    [ -e "$pf" ] || continue
    base="$(basename "$pf" .sh)"
    [ "$base" = "groq" ] && continue
    _supported_providers_arr+=("$base")
  done
fi
SUPPORTED_PROVIDERS="$(printf '%s ' "${_supported_providers_arr[@]}" | sed 's/ $//')"

# Respect persisted provider selection unless overridden via CLI
if [ -f "$PROVIDER_FILE" ] && [ -z "${PROVIDER_CLI:-}" ] && [ "$PROVIDER_INTERACTIVE" -eq 0 ]; then
  prov="$(sed -n '1p' "$PROVIDER_FILE" 2>/dev/null || true)"
  [ -n "$prov" ] && PROVIDER="$prov"
fi

# CLI provider selection handling
if [ -n "${PROVIDER_CLI:-}" ] && [ "$PROVIDER_CLI" != "list" ]; then
  case " $SUPPORTED_PROVIDERS " in
    *" $PROVIDER_CLI "*) 
      prev_provider="$PROVIDER"
      PROVIDER="$PROVIDER_CLI"
      ;;
    *) log_error "PROVIDER" "unknown provider: $PROVIDER_CLI"; exit "$GROQBASHERRTMP" ;;
  esac

  mkdir -p "$(dirname "$PROVIDER_FILE")" 2>/dev/null || true

  if [ -n "${prev_provider:-}" ] && [ "$prev_provider" != "$PROVIDER" ]; then
    if [ -n "${MODELS_FILE:-}" ] && [ -f "$MODELS_FILE" ]; then
      rm -f "$MODELS_FILE" 2>/dev/null || true
    fi
  fi

  printf '%s\n' "$PROVIDER" | atomic_write "$PROVIDER_FILE" 10 \
    || { log_error "PROVIDER" "cannot persist provider selection."; exit "$GROQBASHERRTMP"; }
  chmod 600 "$PROVIDER_FILE" 2>/dev/null || true

  if ! ensure_api_key_for_provider "$PROVIDER"; then
    log_error "APIKEY" "API key required to refresh models for provider $PROVIDER."
    exit "$GROQBASHERRNOAPIKEY"
  fi
  refresh_models_dispatch "$MODELS_FILE" || true
fi

# Interactive provider selection
if [ "$PROVIDER_INTERACTIVE" -eq 1 ] || [ "${PROVIDER_CLI:-}" = "list" ]; then
  IFS=' ' read -r -a _prov_arr <<EOF
$SUPPORTED_PROVIDERS
EOF
  current_default="$PROVIDER"
  [ -f "$PROVIDER_FILE" ] && pf="$(sed -n '1p' "$PROVIDER_FILE" 2>/dev/null || true)" && [ -n "$pf" ] && current_default="$pf"

  printf 'Select provider:\n' >&2
  i=1
  for p in "${_prov_arr[@]}"; do
    if [ "$p" = "$current_default" ]; then printf '%d) %s (default)\n' "$i" "$p" >&2
    else printf '%d) %s\n' "$i" "$p" >&2; fi
    i=$((i+1))
  done

  printf '> ' >&2
  if ! IFS= read -r sel; then printf 'No selection made.\n' >&2; exit "$GROQBASHERRTMP"; fi
  sel="$(trim "$sel")"
  printf '%s\n' "$sel" | grep -qE '^[0-9]+$' || { log_error "PROVIDER" "Invalid selection."; exit "$GROQBASHERRTMP"; }

  idx="$sel"
  chosen="${_prov_arr[$((idx-1))]}"
  [ -z "$chosen" ] && { log_error "PROVIDER" "Selection out of range."; exit "$GROQBASHERRTMP"; }

  prev_provider="$PROVIDER"
  if ! printf '%s\n' "$chosen" | atomic_write "$PROVIDER_FILE" 10; then
    log_error "PROVIDER" "cannot persist provider selection."
    exit "$GROQBASHERRTMP"
  fi
  chmod 600 "$PROVIDER_FILE" 2>/dev/null || true
  PROVIDER="$chosen"

  if [ -n "${prev_provider:-}" ] && [ "$prev_provider" != "$PROVIDER" ]; then
    if [ -n "${MODELS_FILE:-}" ] && [ -f "$MODELS_FILE" ]; then
      rm -f "$MODELS_FILE" 2>/dev/null || true
    fi
  fi

  if ! ensure_api_key_for_provider "$PROVIDER"; then
    log_error "APIKEY" "API key required to refresh models for provider $PROVIDER."
    exit "$GROQBASHERRNOAPIKEY"
  fi
  refresh_models_dispatch "$MODELS_FILE" || true
  exit 0
fi

# Load provider module if present (embedded groq is always available)
PROVIDER_MODULE_LOADED=0
PROVIDER_MODULE_PATH="$GROQBASH_EXTRAS_DIR/providers/${PROVIDER}.sh"
PROVIDER_DIR="$(dirname "$PROVIDER_MODULE_PATH")"

if [ ! -d "$PROVIDER_DIR" ]; then
  mkdir -p "$PROVIDER_DIR" 2>/dev/null || { log_error "PROVIDER" "cannot create provider directory."; exit "$GROQBASHERRTMP"; }
fi

if _is_world_writable "$PROVIDER_DIR"; then
  log_error "SEC" "provider directory is world-writable."
  exit "$GROQBASHERRTMP"
fi

current_user="$(id -un 2>/dev/null || printf '')"
owner="$(_get_owner "$PROVIDER_DIR")"
[ -n "$owner" ] && [ "$owner" != "$current_user" ] && log_warn "SEC" "provider directory owned by $owner"

if [ ! -f "$PROVIDER_MODULE_PATH" ]; then
  if [ "$PROVIDER" != "groq" ]; then
    printf 'Provider %s is not installed.\n' "$PROVIDER" >&2
    PROVIDER_MODULE_LOADED=0
  else
    PROVIDER_MODULE_LOADED=1
  fi
else
  if [ -L "$PROVIDER_MODULE_PATH" ]; then log_error "SEC" "provider file is symlink."; exit "$GROQBASHERRTMP"; fi

  file_owner="$(_get_owner "$PROVIDER_MODULE_PATH")"
  [ -n "$file_owner" ] && [ "$file_owner" != "$current_user" ] && { log_error "SEC" "wrong owner for provider file."; exit "$GROQBASHERRTMP"; }

  perms="$(_get_perm_string "$PROVIDER_MODULE_PATH")"
  group_write="$(printf '%s' "$perms" | awk '{print substr($0,6,1)}')"
  others_write="$(printf '%s' "$perms" | awk '{print substr($0,9,1)}')"
  if [ "$group_write" = "w" ] || [ "$others_write" = "w" ]; then
    log_error "SEC" "provider file writable by group/world."
    exit "$GROQBASHERRTMP"
  fi

  beforesig="$(getfile_signature "$PROVIDER_MODULE_PATH" 2>/dev/null || true)"

  # Quick syntax check and presence of required functions
  if bash -c ". \"$PROVIDER_MODULE_PATH\" >/dev/null 2>&1 || true; declare -F | grep -q \"buildpayload_${PROVIDER}\" && declare -F | grep -q \"call_api_${PROVIDER}\""; then
    aftersig="$(getfile_signature "$PROVIDER_MODULE_PATH" 2>/dev/null || true)"
    [ "$beforesig" != "$aftersig" ] && { log_error "SEC" "provider file changed."; exit "$GROQBASHERRTMP"; }

    . "$PROVIDER_MODULE_PATH"
    PROVIDER_MODULE_LOADED=1

    invalid_provider=0
    for _req in "buildpayload_${PROVIDER}" "call_api_${PROVIDER}"; do
      type "$_req" >/dev/null 2>&1 || invalid_provider=1
    done

    if [ "$invalid_provider" -eq 1 ]; then
      log_warn "PROVIDER" "provider module incomplete; falling back to embedded provider."
      PROVIDER_MODULE_LOADED=0
    fi
  else
    log_warn "PROVIDER" "provider module invalid; falling back to embedded provider."
    PROVIDER_MODULE_LOADED=0
  fi
fi

# Validate provider interface
validate_provider_interface() {
  local p="$1" missing=0
  local required=( "buildpayload_${p}" "call_api_${p}" )
  local optional=( "call_api_streaming_${p}" "refresh_models_${p}" "validate_model_${p}" "auto_select_model_${p}" )
  local f
  for f in "${required[@]}"; do
    if ! type "$f" >/dev/null 2>&1; then
      printf 'Provider '\''%s'\'' module does not define required function %s().\n' "$p" "$f" >&2
      missing=1
    fi
  done
  for f in "${optional[@]}"; do
    if ! type "$f" >/dev/null 2>&1; then
      log_info "PROVIDER" "Provider '$p' missing optional function $f()"
    fi
  done
  return $missing
}

if [ "${PROVIDER_MODULE_LOADED:-0}" -eq 1 ]; then
  validate_provider_interface "$PROVIDER" || exit "$GROQBASHERRAPI"
else
  log_error "PROVIDER" "no valid provider loaded for '$PROVIDER'. Install or configure a provider plugin."
  exit "$GROQBASHERRAPI"
fi

# ---------------------------------------------------------------------------
# Show config / diagnostics
# ---------------------------------------------------------------------------
if [ "${SHOW_CONFIG:-0}" -eq 1 ]; then
  printf 'GroqBash configuration:\n'
  printf '  Version: %s (%s)\n' "$SCRIPT_VERSION" "$SCRIPT_DATE"
  printf '  Provider: %s\n' "$PROVIDER"
  printf '  Model (active): %s\n' "$MODEL"
  MODEL_PROVIDER_CFG="$GROQBASH_CONFIG_DIR/model.$PROVIDER"
  if [ -s "$MODEL_PROVIDER_CFG" ]; then
    printf '  Model (default): %s\n' "$(sed -n '1p' "$MODEL_PROVIDER_CFG")"
  else
    printf '  Model (default): <none>\n'
  fi
  printf '  Config dir: %s\n' "$GROQBASH_CONFIG_DIR"
  printf '  Models dir: %s\n' "$GROQBASH_MODELS_DIR"
  printf '  Tmp dir: %s\n' "$GROQBASH_TMPDIR"
  printf '  History dir: %s\n' "$GROQBASH_HISTORY_DIR"
  printf '  Quiet: %s\n' "$QUIET"
  printf '  Debug: %s\n' "$DEBUG"
  printf '  Dry-run: %s\n' "$DRY_RUN"
  printf '  Whitelist models: %s\n' "$(printf '%s\n' "$ALLOWED_MODELS" | wc -l)"
  exit 0
fi

if [ "${DIAGNOSTICS:-0}" -eq 1 ]; then
  printf 'GroqBash diagnostics:\n'

  printf '\n[Directories]\n'
  for d in "$GROQBASH_CONFIG_DIR" "$GROQBASH_MODELS_DIR" "$GROQBASH_TMPDIR" "$GROQBASH_EXTRAS_DIR" "$GROQBASH_HISTORY_DIR"; do
    if [ -d "$d" ]; then
      printf '  OK: %s\n' "$d"
    else
      printf '  ERROR: missing directory %s\n' "$d"
    fi
  done

  printf '\n[Provider]\n'
  printf '  Active provider: %s\n' "$PROVIDER"
  if type "buildpayload_${PROVIDER}" >/dev/null 2>&1; then
    printf '  Provider functions: OK\n'
  else
    printf '  ERROR: provider functions missing\n'
  fi

  printf '\n[Model]\n'
  printf '  Active model: %s\n' "$MODEL"
  if printf '%s\n' "$ALLOWED_MODELS" | grep -x -F -q "$MODEL"; then
    printf '  Model in whitelist: OK\n'
  else
    printf '  WARNING: model not in whitelist\n'
  fi

  printf '\n[API Key]\n'
  prov_upper="$(printf '%s' "$PROVIDER" | tr '[:lower:]' '[:upper:]' | tr -c 'A-Z0-9_' '_')"
  check_var="${prov_upper}_API_KEY"
  custom_env_var_var="PROVIDER_API_ENV_${PROVIDER}"
  custom_env_var="${!custom_env_var_var:-}"
  if [ -n "$custom_env_var" ]; then check_var="$custom_env_var"; fi

  if [ -n "${!check_var:-}" ]; then
    printf '  API key: present (env %s)\n' "$check_var"
  else
    printf '  WARNING: API key missing (expected env %s)\n' "$check_var"
  fi

  printf '\n[Tmpdir]\n'
  if [ -d "$GROQBASH_TMPDIR" ]; then
    printf '  Tmpdir exists: OK\n'
  else
    printf '  ERROR: tmpdir missing\n'
  fi

  printf '\nDiagnostics complete.\n'
  exit 0
fi

# ---------------------------------------------------------------------------
# Main flow: assemble content, select model, and execute request(s)
# ---------------------------------------------------------------------------
load_local_config
load_whitelist

final_model=""

if [ -n "$MODEL" ]; then
  final_model="$MODEL"
else
  MODEL_PROVIDER_CFG="$GROQBASH_CONFIG_DIR/model.$PROVIDER"
  if [ -s "$MODEL_PROVIDER_CFG" ]; then
    final_model="$(sed -n '1p' "$MODEL_PROVIDER_CFG" 2>/dev/null || true)"
  fi
  if [ -z "$final_model" ]; then
    final_model="$(auto_select_model_dispatch 2>/dev/null || true)"
  fi
  if [ -z "$final_model" ] && [ -f "$GROQBASH_CONFIG_DIR/config" ]; then
    final_model="$(awk -F= '/^MODEL=/ {sub(/^MODEL=/,""); print; exit}' "$GROQBASH_CONFIG_DIR/config" 2>/dev/null || true)"
  fi
  if [ -z "$final_model" ] && [ -n "$ALLOWED_MODELS" ]; then
    final_model="$(printf '%s\n' "$ALLOWED_MODELS" | awk 'NF{print; exit}')"
  fi
fi

if [ -z "$final_model" ]; then
  log_error "MODEL" "no model could be selected."
  exit "$GROQBASHERRBAD_MODEL"
fi

if ! validate_model_dispatch "$final_model"; then
  log_error "MODEL" "invalid model: $final_model"
  exit "$GROQBASHERRBAD_MODEL"
fi

MODEL="$final_model"

STDIN_CONTENT=""; [ ! -t 0 ] && STDIN_CONTENT="$(cat - 2>/dev/null || true)"

assemble_content() {
  CONTENT="${CONTENT:-}"
  local tmpl tmp_tmpl tmp_final extra file_content

  if [ -n "$JSON_INPUT" ]; then CONTENT=""; return 0; fi

  if [ "${#FILE_INPUTS[@]}" -gt 0 ]; then
    CONTENT="$(collect_input_from_files "${FILE_INPUTS[@]}")"
    if [ "${#ARGS[@]}" -gt 0 ]; then
      extra="$(expand_args_to_content)"
      [ -n "$extra" ] && CONTENT="${CONTENT}"$'\n\n'"$extra"
    fi
    return 0
  fi

  if [ -n "$TEMPLATE" ]; then
    if [ "${#FILE_INPUTS[@]}" -gt 0 ]; then
      CONTENT="$(collect_input_from_files "${FILE_INPUTS[@]}")"
    elif [ -n "$STDIN_CONTENT" ]; then
      CONTENT="$STDIN_CONTENT"
    else
      if [ "${#ARGS[@]}" -gt 0 ]; then CONTENT="$(expand_args_to_content)"; else CONTENT=""; fi
    fi

    tmpl="$(cat "$GROQBASH_TEMPLATES_DIR/$TEMPLATE" 2>/dev/null || true)"
    ensure_run_tmpdir
    tmp_tmpl="$(_mktemp_in_dir "$RUN_TMPDIR" 2>/dev/null || true)"

    if [ -n "$tmp_tmpl" ]; then
      printf '%s' "$tmpl" | awk -v repl="$CONTENT" 'BEGIN{RS=""; ORS="";} {gsub(/\{\{CONTENT\}\}/, repl); print}' > "$tmp_tmpl"
      tmp_final="${tmp_tmpl}.final"
      mv "$tmp_tmpl" "$tmp_final" 2>/dev/null || true
      file_content="$(cat "$tmp_final" 2>/dev/null || printf '%s' "$tmpl")"
      CONTENT="$file_content"
      rm -f "$tmp_final" 2>/dev/null || true
    else
      CONTENT="$(printf '%s' "$tmpl" | awk -v repl="$CONTENT" 'BEGIN{RS=""; ORS="";} {gsub(/\{\{CONTENT\}\}/, repl); print}')"
    fi
    return 0
  fi

  if [ -n "$STDIN_CONTENT" ]; then
    CONTENT="$STDIN_CONTENT"
    if [ "${#ARGS[@]}" -gt 0 ]; then
      extra="$(expand_args_to_content)"
      [ -n "$extra" ] && CONTENT="${CONTENT}"$'\n\n'"$extra"
    fi
    return 0
  fi

  if [ "${#ARGS[@]}" -gt 0 ]; then CONTENT="$(expand_args_to_content)"; else CONTENT=""; fi
  return 0
}

assemble_content

if [ -z "$CONTENT" ] && [ -z "$JSON_INPUT" ] && [ "$CHAT_MODE" -eq 0 ] && [ -z "$BATCH_FILE" ]; then
  log_error "INPUT" "no prompt provided."
  exit "$GROQBASHERRNO_PROMPT"
fi

is_number "$TURE" || { log_error "ARGS" "--ture must be numeric"; exit "$GROQBASHERRTMP"; }
is_number "$MAX_TOKENS" || { log_error "ARGS" "--max must be numeric"; exit "$GROQBASHERRTMP"; }

if [ -n "$ALLOWED_MODELS" ] && [ -n "$MODEL" ]; then
  if ! printf '%s\n' "$ALLOWED_MODELS" | grep -x -F -q "$MODEL"; then
    log_error "MODEL" "model '$MODEL' not supported or deprecated."
    printf '%s\n' "$ALLOWED_MODELS" >&2
    exit "$GROQBASHERRBAD_MODEL"
  fi
fi

ensure_run_tmpdir

# Batch processing
if [ -n "$BATCH_FILE" ]; then
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in ''|\#*) continue ;; esac
    CONTENT="$line"
    build_payload_from_vars
    if ! ensure_api_key_for_provider "$PROVIDER"; then log_error "APIKEY" "missing API key; aborting batch item."; continue; fi
    if [ "$STREAM_MODE" -eq 1 ]; then call_api_streaming || log_error "CALL" "Error during streaming call."
    else perform_request_once || true; fi
    printf '\n----\n'
  done < "$BATCH_FILE"
  exit 0
fi

# Interactive chat mode
if [ "$CHAT_MODE" -eq 1 ]; then
  if [ ! -t 0 ]; then log_error "CHAT" "interactive chat requires a TTY."; exit "$GROQBASHERRTMP"; fi
  [ -t 1 ] && [ "$QUIET" -ne 1 ] && printf 'Entering interactive chat. Press Ctrl+D to exit.\n' >&2
  CONVERSATION=""
  while true; do
    if is_tty_out && [ "$QUIET" -ne 1 ] && { [ "$OUTPUT_MODE" = "text" ] || [ "$OUTPUT_MODE" = "raw" ]; }; then printf '\nYou: ' >&2; fi
    if ! IFS= read -r userline; then printf '\n' >&2; break; fi
    [ -z "$userline" ] && continue
    [ -z "$CONVERSATION" ] && CONVERSATION="$userline" || CONVERSATION="${CONVERSATION}"$'\n\n'"User: ${userline}"
    CONTENT="$userline"
    build_payload_from_vars
    if ! ensure_api_key_for_provider "$PROVIDER"; then log_error "APIKEY" "missing API key; aborting chat turn."; continue; fi
    if [ "$STREAM_MODE" -eq 1 ]; then call_api_streaming || log_error "CALL" "Streaming call failed."
    else perform_request_once || log_error "CALL" "Call failed."; fi
  done
  exit 0
fi

# Single request (streaming or non-streaming)
if [ "$STREAM_MODE" -eq 1 ]; then
  build_payload_from_vars
  if ! ensure_api_key_for_provider "$PROVIDER"; then log_error "APIKEY" "missing API key; aborting."; exit "$GROQBASHERRTMP"; fi
  if call_api_streaming; then log_info "STREAM" "Streaming completed; captured response in $RESP"; printf '\n'; exit 0
  else log_error "STREAM" "streaming request failed."; exit "$GROQBASHERRCURL_FAILED"; fi
else
  if is_tty_out && [ "$QUIET" -ne 1 ] && { [ "$OUTPUT_MODE" = "text" ] || [ "$OUTPUT_MODE" = "raw" ]; }; then
    printf '%b\n' "\033[1;36mYou:\033[0m" >&2
    if [ "${#ARGS[@]}" -gt 0 ]; then
      anyfile=0
      for a in "${ARGS[@]}"; do [ -r "$a" ] && [ -f "$a" ] && { anyfile=1; break; }; done
      [ "$anyfile" -eq 1 ] && printf '%s\n' "(using file contents)" >&2 || printf '%s\n' "$CONTENT" >&2
    else printf '%s\n' "$CONTENT" >&2; fi
    printf '%b\n' "\033[1;32mProvider ($PROVIDER, model: $MODEL):\033[0m" >&2
  fi
  build_payload_from_vars
  if ! ensure_api_key_for_provider "$PROVIDER"; then log_error "APIKEY" "missing API key; aborting."; exit "$GROQBASHERRTMP"; fi
  perform_request_once || exit "$GROQBASHERRAPI"
  exit 0
fi
# ==== CORE END ====
