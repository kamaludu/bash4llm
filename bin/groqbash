#!/usr/bin/env bash
# =============================================================================
# GroqBash — Bash-first wrapper for the Groq API
# File: groqbash
# Copyright (C) 2026 Cristian Evangelisti
# License: GPL-3.0-or-later
# Source: https://github.com/kamaludu/groqbash
# =============================================================================
# Bash-only. Requires: bash, jq, curl, mktemp, stat or find.
# Designed for POSIX-like environments (Linux, macOS, BSD, WSL, Termux) with required tools installed.
# ==== PRECORE BEGIN ====
set -euo pipefail

SCRIPT_NAME="groqbash"
SCRIPT_VERSION="2.0.0"
SCRIPT_DATE="2026-02-02"

# Canonical error codes (define here and expose short aliases used across the codebase)
GROQBASH_ERR_NO_API_KEY=10
GROQBASH_ERR_BAD_MODEL=11
GROQBASH_ERR_CURL_FAILED=12
GROQBASH_ERR_INVALID_JSON=13
GROQBASH_ERR_NO_PROMPT=14
GROQBASH_ERR_TMP=15
GROQBASH_ERR_API=16

GROQBASHERRNOAPIKEY=$GROQBASH_ERR_NO_API_KEY
GROQBASHERRBAD_MODEL=$GROQBASH_ERR_BAD_MODEL
GROQBASHERRCURL_FAILED=$GROQBASH_ERR_CURL_FAILED
GROQBASHERRINVALID_JSON=$GROQBASH_ERR_INVALID_JSON
GROQBASHERRNO_PROMPT=$GROQBASH_ERR_NO_PROMPT
GROQBASHERRTMP=$GROQBASH_ERR_TMP
GROQBASHERRAPI=$GROQBASH_ERR_API

# jq is required
if ! command -v jq >/dev/null 2>&1; then
  printf 'Error: jq is required. Please install jq and retry.\n' >&2
  exit "$GROQBASHERRINVALID_JSON"
fi

# NOTE: The dispatcher functions (refresh_models_dispatch, validate_model_dispatch, auto_select_model_dispatch)
# are implemented centrally in CORE3. This placeholder avoids "function not found" errors if referenced early.
# Keep as a no-op placeholder; CORE3 will replace with the real implementations when sourced.
# shellcheck disable=SC2329
refresh_models_dispatch() { :; }
# shellcheck disable=SC2329
validate_model_dispatch() { :; }
# shellcheck disable=SC2329
auto_select_model_dispatch() { :; }

resolve_script_dir() {
  local src="$0" rl dir
  if command -v readlink >/dev/null 2>&1 && [ -L "$src" ]; then
    rl="$(readlink "$src" 2>/dev/null || true)"
    [ -n "$rl" ] && case "$rl" in /*) src="$rl" ;; *) src="$(dirname "$src")/$rl" ;; esac
  fi
  dir="$(cd "$(dirname "$src")" >/dev/null 2>&1 && pwd || printf '%s' "$(dirname "$src")")"
  printf '%s' "$dir"
}

SCRIPTDIR="$(resolve_script_dir)"
GROQBASH_DIR="${GROQBASH_DIR:-$SCRIPTDIR/groqbash.d}"
GROQBASH_CONFIG_DIR="${GROQBASH_CONFIG_DIR:-$GROQBASH_DIR/config}"
GROQBASH_MODELS_DIR="${GROQBASH_MODELS_DIR:-$GROQBASH_DIR/models}"
GROQBASH_TEMPLATES_DIR="${GROQBASH_TEMPLATES_DIR:-$GROQBASH_DIR/templates}"
GROQBASH_HISTORY_DIR="${GROQBASH_HISTORY_DIR:-$GROQBASH_DIR/history}"
GROQBASH_TMPDIR="${GROQBASH_TMPDIR:-$GROQBASH_DIR/tmp}"
GROQBASH_EXTRAS_DIR="${GROQBASH_EXTRAS_DIR:-$GROQBASH_DIR/extras}"
MODELS_FILE="${MODELS_FILE:-$GROQBASH_MODELS_DIR/models.txt}"

umask 077

# Create project-local directories with strict perms
umask 077
mkdir -p "$GROQBASH_CONFIG_DIR" "$GROQBASH_MODELS_DIR" "$GROQBASH_TEMPLATES_DIR" "$GROQBASH_HISTORY_DIR" "$GROQBASH_TMPDIR" "$GROQBASH_EXTRAS_DIR" "$GROQBASH_EXTRAS_DIR/providers" 2>/dev/null || true

# Ensure directories are not symlinks and have strict permissions
for d in "$GROQBASH_DIR" "$GROQBASH_CONFIG_DIR" "$GROQBASH_MODELS_DIR" "$GROQBASH_TEMPLATES_DIR" "$GROQBASH_HISTORY_DIR" "$GROQBASH_TMPDIR" "$GROQBASH_EXTRAS_DIR" "$GROQBASH_EXTRAS_DIR/providers"; do
  if [ -L "$d" ]; then
    printf 'Security error: directory is a symlink: %s\n' "$d" >&2
    exit "$GROQBASHERRTMP"
  fi
  mkdir -p "$d" 2>/dev/null || { printf 'Error: cannot create directory: %s\n' "$d" >&2; exit "$GROQBASHERRTMP"; }
  chmod 700 "$d" 2>/dev/null || true
done

# Enforce project-local tmpdir only; refuse symlinks or world/group writable dirs
GROQBASH_TMPDIR="${GROQBASH_TMPDIR:-$GROQBASH_DIR/tmp}"
mkdir -p "$GROQBASH_TMPDIR" 2>/dev/null || { printf 'Error: cannot create tmpdir: %s\n' "$GROQBASH_TMPDIR" >&2; exit "$GROQBASHERRTMP"; }
if [ -L "$GROQBASH_TMPDIR" ]; then
  printf 'Security error: GROQBASH_TMPDIR is a symlink: %s\n' "$GROQBASH_TMPDIR" >&2
  exit "$GROQBASHERRTMP"
fi

# Use internal helper to get permission string; defined below
perms="$(_get_perm_string "$GROQBASH_TMPDIR" 2>/dev/null || true)"
group_write="$(printf '%s' "$perms" | awk '{print substr($0,6,1)}')"
others_write="$(printf '%s' "$perms" | awk '{print substr($0,9,1)}')"
if [ "$group_write" = "w" ] || [ "$others_write" = "w" ]; then
  printf 'Security error: GROQBASH_TMPDIR is writable by group or others: %s\n' "$GROQBASH_TMPDIR" >&2
  exit "$GROQBASHERRTMP"
fi
chmod 700 "$GROQBASH_TMPDIR" 2>/dev/null || true
export TMPDIR="$GROQBASH_TMPDIR"

# Runtime globals (respect environment if set)
CONTENT="${CONTENT:-}"
RUN_TMPDIR="${RUN_TMPDIR:-}"
PAYLOAD="${PAYLOAD:-}"
RESP="${RESP:-}"
ERRF="${ERRF:-}"
JSON_INPUT="${JSON_INPUT:-}"
# Arrays: preserve if exported as strings (best-effort); otherwise initialize empty
IFS_SAVE="$IFS"
IFS=$'\n'
ARGS=()
if [ -n "${ARGS:-}" ]; then
  # if ARGS exported as a single string, split on newline
  read -r -d '' -a _tmp_args <<<"${ARGS:-}" 2>/dev/null || true
  [ "${#_tmp_args[@]}" -gt 0 ] && ARGS=("${_tmp_args[@]}")
fi
FILE_INPUTS=()
if [ -n "${FILE_INPUTS:-}" ]; then
  read -r -d '' -a _tmp_files <<<"${FILE_INPUTS:-}" 2>/dev/null || true
  [ "${#_tmp_files[@]}" -gt 0 ] && FILE_INPUTS=("${_tmp_files[@]}")
fi
IFS="$IFS_SAVE"
TEMPLATE="${TEMPLATE:-}"
BATCH_FILE="${BATCH_FILE:-}"
CHAT_MODE="${CHAT_MODE:-0}"
SET_DEFAULT_MODEL="${SET_DEFAULT_MODEL:-}"
REFRESH_MODELS="${REFRESH_MODELS:-0}"
LIST_MODELS="${LIST_MODELS:-0}"
FORCE_SAVE_MODE="${FORCE_SAVE_MODE:-}"
OUT_PATH="${OUT_PATH:-}"
SYSTEM_PROMPT="${SYSTEM_PROMPT:-}"
# Temperature handling: prefer explicit TURE, then TEMPERATURE, then default
TURE="${TURE:-${TEMPERATURE:-1.0}}"
TEMPERATURE="${TEMPERATURE:-${TURE:-1.0}}"
TURE="${TURE:-$TEMPERATURE}"
MAX_TOKENS="${MAX_TOKENS:-4096}"
MODEL="${MODEL:-}"
AUTO_POLICY="${AUTO_POLICY:-preferred}"
DEBUG="${DEBUG:-0}"
QUIET="${QUIET:-0}"
DRY_RUN="${DRY_RUN:-0}"
STREAM_MODE="${STREAM_MODE:-0}"
OUTPUT_MODE="${OUTPUT_MODE:-text}"
THRESHOLD="${THRESHOLD:-1000}"
MAX_RETRIES="${MAX_RETRIES:-3}"
SUPPORTED_PROVIDERS="${SUPPORTED_PROVIDERS:-groq gemini huggingface}"
PROVIDER="${PROVIDER:-groq}"
PROVIDER_CLI="${PROVIDER_CLI:-}"
PROVIDER_INTERACTIVE="${PROVIDER_INTERACTIVE:-0}"
INSTALL_EXTRAS="${INSTALL_EXTRAS:-0}"
ALLOWED_MODELS="${ALLOWED_MODELS:-}"

CURL_BASE_OPTS=( --silent --show-error --no-buffer --max-time 120 )

# Ensure curl is available
if ! command -v curl >/dev/null 2>&1; then
  printf 'Error: curl is required. Please install curl and retry.\n' >&2
  exit "$GROQBASHERRCURL_FAILED"
fi

# Central truthy helper (used by core and providers)
is_truthy() {
  case "${1:-}" in
    1|true|TRUE|True|yes|YES|Yes) return 0 ;;
    *) return 1 ;;
  esac
}

# Atomic write helper: read stdin and atomically write to destination path.
# Ensures file is created in same directory and moved into place with secure perms.
atomic_write() {
  local dest="$1" tmpdir tmpf rc
  [ -n "$dest" ] || return "$GROQBASHERRTMP"
  tmpdir="$(dirname "$dest")"
  [ -d "$tmpdir" ] || mkdir -p "$tmpdir" 2>/dev/null || return "$GROQBASHERRTMP"
  tmpf="$(mktemp -p "$tmpdir" groq-atomic.XXXX 2>/dev/null || true)"
  [ -n "$tmpf" ] || return "$GROQBASHERRTMP"
  # Read stdin to tmpf
  cat - > "$tmpf"
  rc=$?
  if [ "$rc" -ne 0 ]; then
    rm -f "$tmpf" 2>/dev/null || true
    return "$GROQBASHERRTMP"
  fi
  chmod 600 "$tmpf" 2>/dev/null || true
  if mv "$tmpf" "$dest" 2>/dev/null; then
    chmod 600 "$dest" 2>/dev/null || true
    return 0
  else
    rm -f "$tmpf" 2>/dev/null || true
    return "$GROQBASHERRTMP"
  fi
}

# Debug helper (masks sensitive values)
dbg() {
  [ "${DEBUG:-0}" -eq 1 ] || return 0
  local msg="$*"
  # Mask known sensitive environment variables if present
  if [ -n "${GROQ_API_KEY:-}" ]; then
    # Escape for use in sed: replace literal occurrences of the key
    local key_escaped
    key_escaped="$(printf '%s' "${GROQ_API_KEY}" | sed -e 's/[\/&]/\\&/g')"
    msg="$(printf '%s' "$msg" | sed -e "s/${key_escaped}/***REDACTED***/g")"
  fi
  # Generic mask for common-looking API keys (heuristic): long alnum strings >20 chars
  msg="$(printf '%s' "$msg" | sed -E 's/[A-Za-z0-9_\-]{20,}/***REDACTED***/g')"
  printf '%s\n' "$msg" >&2
}

is_tty_out() { [ -t 1 ]; }

# Permission and ownership helpers (single canonical implementations)
_get_perm_string() {
  local path="$1" perm=""
  case "$(uname 2>/dev/null || echo Linux)" in
    Darwin)
      perm="$(stat -f %Sp "$path" 2>/dev/null || true)"
      ;;
    *)
      if command -v stat >/dev/null 2>&1; then
        perm="$(stat -c %A "$path" 2>/dev/null || true)"
      elif command -v find >/dev/null 2>&1; then
        perm="$(find "$path" -maxdepth 0 -printf '%M' 2>/dev/null || true)"
      fi
      ;;
  esac
  printf '%s' "$perm"
}

_get_owner() {
  local path="$1" owner=""
  case "$(uname 2>/dev/null || echo Linux)" in
    Darwin)
      owner="$(stat -f %Su "$path" 2>/dev/null || true)"
      ;;
    *)
      if command -v stat >/dev/null 2>&1; then
        owner="$(stat -c %U "$path" 2>/dev/null || true)"
      elif command -v find >/dev/null 2>&1; then
        owner="$(find "$path" -maxdepth 0 -printf '%u' 2>/dev/null || true)"
      fi
      ;;
  esac
  printf '%s' "$owner"
}

# File signature helper: implementation + public wrapper
_get_file_signature() {
  local path="$1" sig=""
  case "$(uname 2>/dev/null || echo Linux)" in
    Darwin)
      sig="$(stat -f '%Sp|%Su|%Sg|%z|%m' "$path" 2>/dev/null || true)"
      ;;
    *)
      if command -v stat >/dev/null 2>&1; then
        sig="$(stat -c '%A|%U|%G|%s|%Y' "$path" 2>/dev/null || true)"
      elif command -v find >/dev/null 2>&1; then
        sig="$(find "$path" -maxdepth 0 -printf '%M|%u|%g|%s|%T@' 2>/dev/null || true)"
      fi
      ;;
  esac
  printf '%s' "$sig"
}
getfile_signature() { _get_file_signature "$1"; }

_is_world_writable() {
  local d="$1" perms others_write
  [ -d "$d" ] || return "$GROQBASHERRTMP"
  perms="$(_get_perm_string "$d")"
  [ -z "$perms" ] && return "$GROQBASHERRTMP"
  others_write="$(printf '%s' "$perms" | awk '{print substr($0,9,1)}')"
  [ "$others_write" = "w" ]
}

# Lightweight helpers for tmpdir creation and management (canonical)
make_tmpdir() {
  umask 077
  local tmpd
  if [ -n "${GROQBASH_TMPDIR:-}" ] && [ -d "$GROQBASH_TMPDIR" ]; then
    tmpd="$(mktemp -d -p "$GROQBASH_TMPDIR" groq.XXXX 2>/dev/null || true)"
    if [ -n "$tmpd" ] && [ -d "$tmpd" ]; then
      chmod 700 "$tmpd" 2>/dev/null || true
      printf '%s' "$tmpd"
      return 0
    fi
  fi
  # Fallback: explicitly create under GROQBASH_TMPDIR
  if [ -n "${GROQBASH_TMPDIR:-}" ]; then
    tmpd="$(mktemp -d -p "$GROQBASH_TMPDIR" groq.XXXX 2>/dev/null || true)"
  else
    tmpd="$(mktemp -d -p "$(pwd)" groq.XXXX 2>/dev/null || true)"
  fi
  if [ -n "$tmpd" ] && [ -d "$tmpd" ]; then
    chmod 700 "$tmpd" 2>/dev/null || true
    printf '%s' "$tmpd"
    return 0
  fi
  return "$GROQBASHERRTMP"
}

# Create a run-specific tmpdir and set PAYLOAD/RESP/ERRF
ensure_run_tmpdir() {
  if [ -n "${RUN_TMPDIR:-}" ] && [ -d "${RUN_TMPDIR:-}" ]; then return 0; fi
  RUN_TMPDIR="$(make_tmpdir)" || { printf 'Error: cannot create RUN_TMPDIR in %s\n' "$GROQBASH_TMPDIR" >&2; exit "$GROQBASHERRTMP"; }
  PAYLOAD="$RUN_TMPDIR/payload.json"
  RESP="$RUN_TMPDIR/resp.json"
  ERRF="$RUN_TMPDIR/err.log"
  trap 'if [ -n "${RUN_TMPDIR:-}" ] && [ "${DEBUG:-0}" -eq 0 ]; then rm -rf -- "$RUN_TMPDIR"; else dbg "DEBUG mode: preserving RUN_TMPDIR=$RUN_TMPDIR"; fi' EXIT INT TERM
  dbg "Created RUN_TMPDIR: $RUN_TMPDIR"
}

# Small utility helpers
file_readable() { [ -r "$1" ] && [ -f "$1" ]; }
trim() { printf '%s' "$1" | awk '{$1=$1; print}'; }
is_number() { printf '%s\n' "$1" | awk 'BEGIN{exit 0} {exit !( $0+0 == $0+0 )}'; }

# Configuration loaders
load_local_config() {
  local cfg="$GROQBASH_CONFIG_DIR/config" key val
  [ -f "$cfg" ] || return 0
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in ''|\#*) continue ;; esac
    key="${line%%=*}"
    val="${line#*=}"
    case "$key" in
      MODEL) [ -n "$val" ] && MODEL="$val" ;;
      TEMPERATURE|TURE) [ -n "$val" ] && TURE="$val" ;;
      MAX_TOKENS) [ -n "$val" ] && MAX_TOKENS="$val" ;;
      FORMAT) [ -n "$val" ] && OUTPUT_MODE="$val" ;;
      THRESHOLD) [ -n "$val" ] && THRESHOLD="$val" ;;
    esac
  done < "$cfg"
}

load_whitelist() {
  ALLOWED_MODELS="${ALLOWED_MODELS:-}"
  if [ -f "$MODELS_FILE" ] && [ -s "$MODELS_FILE" ]; then
    ALLOWED_MODELS="$(cat "$MODELS_FILE" 2>/dev/null || true)"
  fi
}
# ==== PRECORE END ====
# ==== PROVIDER BEGIN ====
###############################################################################
##### BEGIN PROVIDER DEFAULT (embedded) #######################################
###############################################################################
# Provider: groq (embedded)
GROQ_API_KEY="${GROQ_API_KEY:-}"

# NOTE: This provider implementation uses canonical helpers from PRECORE:
# - is_truthy
# - atomic_write
# - make_tmpdir
# - ensure_run_tmpdir
# - _get_file_signature / getfile_signature
# - _get_perm_string, _get_owner
# If any of those are missing at runtime, the provider will fail early.

# Helper: create a temporary file in a directory (small local wrapper using mktemp)
_mktemp_in_dir() {
  local dir="$1" tmpf
  [ -n "$dir" ] || return "$GROQBASHERRTMP"
  [ -d "$dir" ] || return "$GROQBASHERRTMP"
  tmpf="$(mktemp -p "$dir" groq-XXXX 2>/dev/null || true)"
  [ -z "$tmpf" ] && return "$GROQBASHERRTMP"
  printf '%s' "$tmpf"
  return 0
}

# Build payload for groq provider (canonical name)
buildpayload_groq() {
  local workdir tmp_payload model_in_file model_to_use user_prompt stream_json
  # Prefer existing RUN_TMPDIR or create via make_tmpdir
  workdir="${RUN_TMPDIR:-}"
  if [ -z "$workdir" ] || [ ! -d "$workdir" ]; then
    workdir="$(make_tmpdir 2>/dev/null || true)"
  fi
  [ -n "$workdir" ] || return "$GROQBASHERRTMP"
  tmp_payload="$(_mktemp_in_dir "$workdir")" || return "$GROQBASHERRTMP"
  umask 077

  # Normalize stream flag to JSON boolean using PRECORE is_truthy
  if is_truthy "${STREAM_MODE:-0}"; then stream_json=true; else stream_json=false; fi

  if [ -n "${JSON_INPUT:-}" ]; then
    # If JSON_INPUT already contains messages, pass through
    if jq -e 'has("messages")' "$JSON_INPUT" >/dev/null 2>&1; then
      cp "$JSON_INPUT" "$tmp_payload" 2>/dev/null || { rm -f "$tmp_payload" 2>/dev/null || true; return "$GROQBASHERRTMP"; }
      atomic_write "$PAYLOAD" < "$tmp_payload" || { rm -f "$tmp_payload" 2>/dev/null || true; return "$GROQBASHERRTMP"; }
      return 0
    fi

    # If JSON_INPUT contains prompt/model fields, construct canonical payload
    if jq -e 'has("prompt")' "$JSON_INPUT" >/dev/null 2>&1; then
      user_prompt="$(jq -r '.prompt' "$JSON_INPUT" 2>/dev/null || true)"
      model_in_file="$(jq -r '.model // empty' "$JSON_INPUT" 2>/dev/null || true)"
      model_to_use="${model_in_file:-$MODEL}"
      jq -n --arg model "$model_to_use" \
            --argjson stream "$stream_json" \
            --arg ture "$TURE" \
            --arg max_tokens "$MAX_TOKENS" \
            --arg user "$user_prompt" \
            '{model:$model, stream:$stream, temperature:($ture|tonumber), max_tokens:($max_tokens|tonumber), messages:[{role:"user",content:$user}] }' >"$tmp_payload"
      atomic_write "$PAYLOAD" < "$tmp_payload" || { rm -f "$tmp_payload" 2>/dev/null || true; return "$GROQBASHERRTMP"; }
      return 0
    fi

    # Otherwise pass through the JSON_INPUT file
    cp "$JSON_INPUT" "$tmp_payload" 2>/dev/null || { rm -f "$tmp_payload" 2>/dev/null || true; return "$GROQBASHERRTMP"; }
    atomic_write "$PAYLOAD" < "$tmp_payload" || { rm -f "$tmp_payload" 2>/dev/null || true; return "$GROQBASHERRTMP"; }
    return 0
  fi

  # Build payload from CONTENT and optional SYSTEM_PROMPT
  if [ -n "${SYSTEM_PROMPT:-}" ]; then
    jq -n --arg model "$MODEL" \
          --argjson stream "$stream_json" \
          --arg ture "$TURE" \
          --arg max_tokens "$MAX_TOKENS" \
          --arg system "$SYSTEM_PROMPT" \
          --arg user "$CONTENT" \
          '{model:$model, stream:$stream, temperature:($ture|tonumber), max_tokens:($max_tokens|tonumber), messages:[{role:"system",content:$system},{role:"user",content:$user}] }' >"$tmp_payload"
  else
    jq -n --arg model "$MODEL" \
          --argjson stream "$stream_json" \
          --arg ture "$TURE" \
          --arg max_tokens "$MAX_TOKENS" \
          --arg user "$CONTENT" \
          '{model:$model, stream:$stream, temperature:($ture|tonumber), max_tokens:($max_tokens|tonumber), messages:[{role:"user",content:$user}] }' >"$tmp_payload"
  fi

  atomic_write "$PAYLOAD" < "$tmp_payload" || { rm -f "$tmp_payload" 2>/dev/null || true; return "$GROQBASHERRTMP"; }
  return 0
}

# Backwards-compatible wrapper (legacy name)
buildpayloadgroq() { buildpayload_groq "$@"; }

# Call groq API (non-streaming) - canonical name
call_api_groq() {
  # Basic preconditions
  if [ -z "${GROQ_API_KEY:-}" ]; then printf 'Error: GROQ_API_KEY is not set.\n' >&2; return "$GROQBASHERRNOAPIKEY"; fi
  if [ -z "${PAYLOAD:-}" ] || [ ! -s "${PAYLOAD:-}" ]; then printf 'Error: payload file missing or empty: %s\n' "${PAYLOAD:-<unset>}" >&2; return "$GROQBASHERRTMP"; fi

  # Respect DRY_RUN using PRECORE is_truthy
  if is_truthy "${DRY_RUN:-0}"; then printf 'DRY-RUN: skipping HTTP call (exit 0)\n' >&2; return 0; fi

  ensure_run_tmpdir || return "$GROQBASHERRTMP"
  ERRF="${ERRF:-$RUN_TMPDIR/curl.err}"
  RESP="${RESP:-$RUN_TMPDIR/resp.json}"

  local workdir tmpout http_code _time_total api_url rc
  workdir="${RUN_TMPDIR:-}"
  if [ -z "$workdir" ] || [ ! -d "$workdir" ]; then
    workdir="$(make_tmpdir 2>/dev/null || true)"
  fi
  [ -n "$workdir" ] || return "$GROQBASHERRTMP"
  tmpout="$(_mktemp_in_dir "$workdir")" || return "$GROQBASHERRTMP"
  api_url="https://api.groq.com/openai/v1/chat/completions"

  # Use curl; capture http code and time in tmpout, response in RESP, stderr in ERRF
  if ! curl "${CURL_BASE_OPTS[@]}" -H "Authorization: Bearer ${GROQ_API_KEY}" -H "Content-Type: application/json" --data-binary @"$PAYLOAD" -o "$RESP" -w '%{http_code} %{time_total}' "$api_url" 2>"$ERRF" >"$tmpout"; then
    rc=$?
  else
    rc=0
  fi

  read -r http_code _time_total < "$tmpout" 2>/dev/null || http_code="$(cat "$tmpout" 2>/dev/null || echo "000")"
  rm -f "$tmpout" 2>/dev/null || true

  case "$http_code" in
    2*) return 0 ;;
    *) dbg "HTTP error code: $http_code"; dbg "Response (head):"; head -n 200 "$RESP" >&2 || true; dbg "Curl stderr (head):"; head -n 200 "$ERRF" >&2 || true; return "$GROQBASHERRAPI" ;;
  esac
}

# Backwards-compatible wrapper (legacy name)
call_api_groq_legacy() { call_api_groq "$@"; }

# Call groq API (streaming) - canonical name
call_api_streaming_groq() {
  if [ -z "${GROQ_API_KEY:-}" ]; then printf 'Error: GROQ_API_KEY is not set.\n' >&2; return "$GROQBASHERRNOAPIKEY"; fi
  if is_truthy "${DRY_RUN:-0}"; then printf 'DRY-RUN: skipping streaming HTTP call (exit 0)\n' >&2; return 0; fi

  ensure_run_tmpdir || return "$GROQBASHERRTMP"
  ERRF="${ERRF:-$RUN_TMPDIR/curl.err}"
  RESP="${RESP:-$RUN_TMPDIR/resp.json}"
  RESP_RAW="$RUN_TMPDIR/resp.raw"
  : > "$RESP_RAW" 2>/dev/null || true
  chmod 600 "$RESP_RAW" 2>/dev/null || true

  local api_url rc
  api_url="https://api.groq.com/openai/v1/chat/completions"

  local CURL_CMD
  if command -v stdbuf >/dev/null 2>&1; then
    CURL_CMD=(stdbuf -oL curl --http1.1 "${CURL_BASE_OPTS[@]}")
  else
    CURL_CMD=(curl --http1.1 "${CURL_BASE_OPTS[@]}")
  fi

  # Stream and parse incremental data lines
  "${CURL_CMD[@]}" -H "Authorization: Bearer ${GROQ_API_KEY}" -H "Content-Type: application/json" --data-binary @"$PAYLOAD" "$api_url" 2>"$ERRF" | tee -a "$RESP_RAW" | \
  while IFS= read -r line; do
    case "$line" in
      'data: [DONE]'|'data:[DONE]') break ;;
      data:\ * )
        json="${line#data: }"
        content="$(printf '%s' "$json" | jq -r 'fromjson? | (.choices[]?.delta?.content // .choices[]?.message?.content // "")' 2>>"$ERRF" || true)"
        if [ -n "$content" ]; then
          printf '%s' "$content"
        fi
        ;;
      *) ;;
    esac
  done

  rc=${PIPESTATUS[0]:-0}
  if [ "$rc" -ne 0 ]; then
    dbg "curl stderr (head):"; head -n 50 "$ERRF" >&2 || true
    return "$GROQBASHERRCURL_FAILED"
  fi

  # If RESP_RAW is valid JSON, copy to RESP for downstream processing
  if jq -e . "$RESP_RAW" >/dev/null 2>&1; then
    cp -f "$RESP_RAW" "$RESP" 2>/dev/null || true
  fi

  return 0
}

# Backwards-compatible wrapper (legacy name)
call_api_streaming_groq_legacy() { call_api_streaming_groq "$@"; }

# Refresh models list from groq API (canonical name)
refresh_models_groq() {
  if [ -z "${GROQ_API_KEY:-}" ]; then printf 'Error: GROQ_API_KEY is required to refresh models.\n' >&2; return "$GROQBASHERRNOAPIKEY"; fi

  ensure_run_tmpdir || return "$GROQBASHERRTMP"
  local workdir tmpd out errf parsed tmpout api_url jq_ok
  workdir="${RUN_TMPDIR:-}"
  if [ -z "$workdir" ] || [ ! -d "$workdir" ]; then
    workdir="$(make_tmpdir 2>/dev/null || true)"
  fi
  [ -n "$workdir" ] || return "$GROQBASHERRTMP"
  tmpd="$(mktemp -d -p "$workdir" groq-models.XXXX 2>/dev/null || true)"
  [ -z "$tmpd" ] && return "$GROQBASHERRTMP"
  out="$tmpd/models.json"; errf="$tmpd/curl.err"
  api_url="https://api.groq.com/openai/v1/models"

  if ! curl "${CURL_BASE_OPTS[@]}" -H "Authorization: Bearer ${GROQ_API_KEY}" -H "Content-Type: application/json" "$api_url" -o "$out" 2>"$errf"; then
    dbg "curl stderr:"; head -n 50 "$errf" >&2 || true
    rm -rf "$tmpd"
    return "$GROQBASHERRCURL_FAILED"
  fi

  parsed="$tmpd/parsed_models.txt"
  if jq -e . "$out" >/dev/null 2>&1; then
    jq_ok=1
    jq -r '.data[]?.id // empty' "$out" 2>/dev/null | sort -u > "$parsed" || true
  else
    jq_ok=0
    printf 'Warning: models response not valid JSON; using heuristic parse\n' >&2
    grep -oE '"id"[[:space:]]*:[[:space:]]*"[^"]+"' "$out" 2>/dev/null | sed -E 's/.*"([^"]+)".*/\1/' | sort -u > "$parsed" || true
  fi

  if [ -s "$parsed" ]; then
    if [ "$jq_ok" -eq 0 ]; then
      if ! awk 'NF{exit 0} END{exit 1}' "$parsed"; then
        dbg "Heuristic parse produced no models; aborting refresh."
        rm -rf "$tmpd"
        return "$GROQBASHERRAPI"
      fi
      if ! awk '/^[[:alnum:]._:-]+$/{print; ok=1} END{exit !ok}' "$parsed"; then
        printf 'Heuristic parse produced invalid model ids; aborting refresh\n' >&2
        rm -rf "$tmpd"
        return "$GROQBASHERRAPI"
      fi
    fi

    mkdir -p "$(dirname "$MODELS_FILE")" 2>/dev/null || true
    tmpout="$(_mktemp_in_dir "$(dirname "$MODELS_FILE")" )" || tmpout="$MODELS_FILE.tmp"
    cat "$parsed" > "$tmpout"
    atomic_write "$MODELS_FILE" < "$tmpout" || { rm -f "$tmpout" 2>/dev/null || true; rm -rf "$tmpd"; return "$GROQBASHERRTMP"; }
    chmod 600 "$MODELS_FILE" 2>/dev/null || true
    printf 'Models refreshed and saved to: %s\n' "$MODELS_FILE" >&2
    rm -rf "$tmpd"
    return 0
  else
    dbg "Raw response (head):"; head -n 50 "$out" >&2 || true
    rm -rf "$tmpd"
    return "$GROQBASHERRAPI"
  fi
}

# Backwards-compatible wrapper (legacy name)
refreshmodelsgroq() { refresh_models_groq "$@"; }

# Validate model against local MODELS_FILE (canonical name)
validate_model_groq() {
  local model="$1"
  if [ -f "$MODELS_FILE" ] && [ -s "$MODELS_FILE" ]; then
    grep -x -F -q "$model" "$MODELS_FILE" 2>/dev/null
    return $?
  fi
  return 0
}

# Backwards-compatible wrapper (legacy name)
validatemodelgroq() { validate_model_groq "$@"; }

# Auto-select a model from MODELS_FILE (canonical name)
auto_select_model_groq() {
  local file="$MODELS_FILE" result=""
  if [ -f "$file" ] && [ -s "$file" ]; then
    if jq -e . "$file" >/dev/null 2>&1; then
      result="$(jq -r '.data[]?.id // empty' "$file" 2>/dev/null | awk 'NF{print; exit}')"
    else
      result="$(awk 'NF{print; exit}' "$file" 2>/dev/null || true)"
    fi
  fi
  result="$(printf '%s' "$result" | awk '{$1=$1;print}')"
  printf '%s' "$result"
  return 0
}

# Backwards-compatible wrapper (legacy name)
autoselectmodelgroq() { auto_select_model_groq "$@"; }

###############################################################################
##### END PROVIDER DEFAULT (embedded) #########################################
###############################################################################
# ==== PROVIDER END ====
# ==== CORE1 BEGIN ====
call_provider() {
  local fn="$1" shift_args=("${@:2}")
  if type "$fn" >/dev/null 2>&1; then "$fn" "${shift_args[@]}"; return $?; fi
  return 127
}

build_payload_from_vars() {
  ensure_run_tmpdir
  local fn="buildpayload${PROVIDER}"
  if call_provider "$fn"; then return 0; fi
  printf 'Provider '\''%s'\'' does not provide %s().\n' "$PROVIDER" "$fn" >&2
  exit "$GROQBASHERRAPI"
}

call_api_once() {
  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    show_payload_head "$PAYLOAD" 200 || true
    printf 'DRY-RUN: skipping provider HTTP call (exit 0)\n' >&2
    return 0
  fi
  local fn="call_api_${PROVIDER}"
  if call_provider "$fn"; then return 0; fi
  printf 'Provider '\''%s'\'' does not provide %s().\n' "$PROVIDER" "$fn" >&2
  exit "$GROQBASHERRAPI"
}

call_api_streaming() {
  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    show_payload_head "$PAYLOAD" 200 || true
    printf 'DRY-RUN: skipping provider streaming HTTP call (exit 0)\n' >&2
    return 0
  fi
  local fn="call_api_streaming_${PROVIDER}"
  if call_provider "$fn"; then return 0; fi
  printf 'Provider '\''%s'\'' does not provide %s().\n' "$PROVIDER" "$fn" >&2
  exit "$GROQBASHERRAPI"
}

show_payload_head() {
  local path="${1:-$PAYLOAD}" lines="${2:-200}"
  if [ -z "${path:-}" ]; then
    printf 'DRY-RUN: payload file missing: %s\n' "<unset>" >&2
    exit "$GROQBASHERRTMP"
  fi
  if [ ! -e "$path" ]; then
    printf 'DRY-RUN: payload file missing: %s\n' "$path" >&2
    exit "$GROQBASHERRTMP"
  fi
  if [ ! -s "$path" ]; then
    printf 'DRY-RUN: payload exists but is empty: %s\n' "$path" >&2
    return 0
  fi
  printf 'DRY-RUN: payload path: %s\n' "$path" >&2
  printf 'DRY-RUN: payload (head %d lines):\n' "$lines" >&2
  head -n "$lines" "$path" 2>/dev/null >&2 || true
  return 0
}

extract_text_from_resp() {
  [ ! -s "${RESP:-}" ] && return 0
  if jq -e . "$RESP" >/dev/null 2>&1; then
    jq -r '
      [ .choices[]? | (.message?.content // .delta?.content // "") ] | join("\n")
    ' "$RESP" 2>/dev/null | sed 's/\\"/"/g' || true
  else
    # Fallback: return raw file (useful for streaming partial captures)
    cat "$RESP" 2>/dev/null || true
  fi
  return 0
}

extract_api_error() {
  [ ! -s "${RESP:-}" ] && return 0
  if jq -e . "$RESP" >/dev/null 2>&1; then
    jq -r '.error?.message // .choices[]?.message?.content // empty' "$RESP" 2>/dev/null | head -n1 || true
  else
    # If not JSON, return first non-empty line from raw response
    awk 'NF{print; exit}' "$RESP" 2>/dev/null || true
  fi
}

finalize_and_output() {
  local mode="$1" text="$2"
  # Ensure RESP exists for json/pretty modes
  if { [ "$mode" = "json" ] || [ "$mode" = "pretty" ]; } && [ ! -s "${RESP:-}" ]; then
    printf 'Error: response file missing or empty: %s\n' "${RESP:-<unset>}" >&2
    return "$GROQBASHERRTMP"
  fi

  case "$mode" in
    json) cat "$RESP" ;;
    pretty) if jq -e . "$RESP" >/dev/null 2>&1; then jq . "$RESP"; else cat "$RESP"; fi ;;
    raw) printf '%s' "$text" ;;
    text) printf '%s\n' "$text" ;;
    *) printf '%s\n' "$text" ;;
  esac

  if [ "$mode" = "text" ] || [ "$mode" = "raw" ]; then
    [ "${FORCE_SAVE_MODE:-}" = "nosave" ] && return 0
    local len do_save=0 tmpf dest_dir dest_path
    len="$(printf '%s' "$text" | wc -c | tr -d ' ')"
    if [ "${FORCE_SAVE_MODE:-}" = "save" ]; then
      do_save=1
    else
      if [ "$len" -gt "$THRESHOLD" ]; then
        do_save=1
      fi
    fi
    if [ "$do_save" -eq 1 ]; then
      if [ -n "$OUT_PATH" ]; then
        if [ -d "$OUT_PATH" ]; then dest_dir="$OUT_PATH"; dest_path="$dest_dir/$(date +%Y%m%d-%H%M%S)-groq-output-$$.txt"; else dest_path="$OUT_PATH"; dest_dir="$(dirname "$dest_path")"; fi
      else dest_dir="$GROQBASH_HISTORY_DIR"; dest_path="$dest_dir/$(date +%Y%m%d-%H%M%S)-groq-output-$$.txt"; fi
      mkdir -p "$dest_dir" 2>/dev/null || true

      # Ensure RUN_TMPDIR exists before mktemp
      if [ -z "${RUN_TMPDIR:-}" ] || [ ! -d "$RUN_TMPDIR" ]; then
        printf 'Error: RUN_TMPDIR not available for saving output.\n' >&2
        return "$GROQBASHERRTMP"
      fi

      tmpf="$(mktemp -p "$RUN_TMPDIR" groq-out.XXXX 2>/dev/null || true)"
      [ -z "$tmpf" ] && { printf 'Error: cannot create temporary file for saving. Skipping save.\n' >&2; return "$GROQBASHERRTMP"; }
      printf '%s\n' "$text" > "$tmpf"
      if mv "$tmpf" "$dest_path" 2>/dev/null; then
        chmod 600 "$dest_path" 2>/dev/null || true
        printf 'Output saved to: %s\n' "$dest_path" >&2
      else
        printf 'Output saved to (tmp): %s\n' "$tmpf" >&2
      fi
    fi
  fi
}

perform_request_once() {
  local attempt=1 rc
  while [ "$attempt" -le "$MAX_RETRIES" ]; do
    if call_api_once; then
      if [ "${DRY_RUN:-0}" -eq 1 ]; then
        printf 'DRY-RUN: request simulated successfully. Payload: %s\n' "$PAYLOAD" >&2
        return 0
      fi
      local text api_err
      text="$(extract_text_from_resp || true)"
      if [ -z "$text" ] && [ "$OUTPUT_MODE" != "json" ] && [ "$OUTPUT_MODE" != "pretty" ]; then
        api_err="$(extract_api_error || true)"
        if [ -n "$api_err" ]; then
          printf 'API error: %s\n' "$api_err" >&2
          return "$GROQBASHERRAPI"
        else
          printf 'Error: no textual content extracted from response.\n' >&2
          dbg "RESP (head):"; head -n 50 "${RESP:-/dev/null}" >&2 || true
          return "$GROQBASHERRAPI"
        fi
      fi
      finalize_and_output "$OUTPUT_MODE" "$text"
      return 0
    else
      rc=$?
      if [ "$rc" -eq "$GROQBASHERRCURL_FAILED" ]; then printf 'Network error (curl). Retrying...\n' >&2
      elif [ "$rc" -eq "$GROQBASHERRAPI" ]; then printf 'HTTP/API error. Not retrying.\n' >&2; dbg "RESP (head):"; head -n 50 "${RESP:-/dev/null}" >&2 || true; return "$GROQBASHERRAPI"
      else printf 'Unknown error (code %s). Retrying...\n' "$rc" >&2
      fi
    fi
    attempt=$((attempt + 1)); sleep $((attempt * 1))
  done
  printf 'Error: request failed after %s attempts.\n' "$MAX_RETRIES" >&2
  return "$GROQBASHERRAPI"
}

collect_input_from_files() {
  local out="" first=1 f
  for f in "$@"; do
    if file_readable "$f"; then
      [ "$first" -eq 0 ] && out="${out}"$'\n\n'"--- FILE: ${f} ---"$'\n\n'
      out="${out}$(cat "$f")"; first=0
    else printf 'Error: file not readable: %s\n' "$f" >&2; exit "$GROQBASHERRTMP"; fi
  done
  printf '%s' "$out"
}
expand_args_to_content() {
  local out="" first=1 a
  for a in "${ARGS[@]}"; do
    if file_readable "$a"; then
      [ "$first" -eq 0 ] && out="${out}"$'\n\n'"--- FILE: ${a} ---"$'\n\n'
      out="${out}$(cat "$a")"; first=0
    else
      [ "$first" -eq 0 ] && out="${out}"$'\n\n'
      out="${out}${a}"; first=0
    fi
  done
  printf '%s' "$out"
}
# ==== CORE1 END ====
# ==== CORE2 BEGIN ====
# CLI parsing
JSON_INPUT="${JSON_INPUT:-}" TEMPLATE="${TEMPLATE:-}" BATCH_FILE="${BATCH_FILE:-}" CHAT_MODE="${CHAT_MODE:-0}" SET_DEFAULT_MODEL="${SET_DEFAULT_MODEL:-}"
REFRESH_MODELS="${REFRESH_MODELS:-0}" LIST_MODELS="${LIST_MODELS:-0}" FORCE_SAVE_MODE="${FORCE_SAVE_MODE:-}" OUT_PATH="${OUT_PATH:-}"
DRY_RUN="${DRY_RUN:-0}" STREAM_MODE="${STREAM_MODE:-0}" QUIET="${QUIET:-0}" INSTALL_EXTRAS="${INSTALL_EXTRAS:-0}" DEBUG="${DEBUG:-0}"
PROVIDER_CLI="${PROVIDER_CLI:-}" PROVIDER_INTERACTIVE="${PROVIDER_INTERACTIVE:-0}"
FILE_INPUTS=() ARGS=() OUTPUT_MODE="${OUTPUT_MODE:-text}"

while [ $# -gt 0 ]; do
  case "$1" in
    --refresh-models|--refresh-model) REFRESH_MODELS=1; shift ;;
    --list-models) LIST_MODELS=1; shift ;;
    --set-default) SET_DEFAULT_MODEL="${2:-}"; shift 2 ;;
    -m|--model) MODEL="${2:-}"; shift 2 ;;
    -f) FILE_INPUTS+=("${2:-}"); shift 2 ;;
    --json-input) JSON_INPUT="${2:-}"; shift 2 ;;
    --template) TEMPLATE="${2:-}"; shift 2 ;;
    --batch) BATCH_FILE="${2:-}"; shift 2 ;;
    --system) SYSTEM_PROMPT="${2:-}"; shift 2 ;;
    --ture) TURE="${2:-}"; shift 2 ;;
    --temperature) TURE="${2:-}"; shift 2 ;;  # alias for --ture
    --max) MAX_TOKENS="${2:-}"; shift 2 ;;
    --debug) DEBUG=1; shift ;;
    --save) FORCE_SAVE_MODE="save"; shift ;;
    --nosave) FORCE_SAVE_MODE="nosave"; shift ;;
    --out) OUT_PATH="${2:-}"; shift 2 ;;
    --threshold) THRESHOLD="${2:-}"; shift 2 ;;
    --dry-run) DRY_RUN=1; shift ;;
    --quiet) QUIET=1; shift ;;
    --stream) STREAM_MODE=1; shift ;;
    --no-stream) STREAM_MODE=0; shift ;;
    --json) OUTPUT_MODE="json"; shift ;;
    --pretty) OUTPUT_MODE="pretty"; shift ;;
    --text) OUTPUT_MODE="text"; shift ;;
    --raw) OUTPUT_MODE="raw"; shift ;;
    --chat) CHAT_MODE=1; shift ;;
    --provider)
      if [ "${2:-}" ] && [ "${2:0:1}" != "-" ]; then PROVIDER_CLI="${2:-}"; shift 2; else PROVIDER_INTERACTIVE=1; shift; fi
      ;;
    --install-extras)
      INSTALL_EXTRAS=1; shift ;;
    --version) printf '%s %s (%s)\n' "$SCRIPT_NAME" "$SCRIPT_VERSION" "$SCRIPT_DATE"; exit 0 ;;
    -h|--help)
      help_file="$GROQBASH_EXTRAS_DIR/docs/help.txt"
      if [ -f "$help_file" ]; then
        cat "$help_file"
      else
        printf 'Help file not found: %s\n' "$help_file" >&2
      fi
      exit 0
      ;;
    --) shift; break ;;
    -*)
      printf 'Unknown option: %s\n' "$1" >&2
      exit "$GROQBASHERRTMP"
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

# Normalize boolean-like flags to 1/0 using PRECORE is_truthy
if is_truthy "${DRY_RUN:-0}"; then DRY_RUN=1; else DRY_RUN=0; fi
if is_truthy "${STREAM_MODE:-0}"; then STREAM_MODE=1; else STREAM_MODE=0; fi
if is_truthy "${INSTALL_EXTRAS:-0}"; then INSTALL_EXTRAS=1; else INSTALL_EXTRAS=0; fi
if is_truthy "${PROVIDER_INTERACTIVE:-0}"; then PROVIDER_INTERACTIVE=1; else PROVIDER_INTERACTIVE=0; fi
if is_truthy "${REFRESH_MODELS:-0}"; then REFRESH_MODELS=1; else REFRESH_MODELS=0; fi
if is_truthy "${LIST_MODELS:-0}"; then LIST_MODELS=1; else LIST_MODELS=0; fi
if is_truthy "${CHAT_MODE:-0}"; then CHAT_MODE=1; else CHAT_MODE=0; fi
if is_truthy "${QUIET:-0}"; then QUIET=1; else QUIET=0; fi

# Guard: prevent accidental real API calls unless explicitly allowed or in dry-run
# This check must run after CLI/env parsing so DRY_RUN and ALLOW_API_CALLS are respected.
: "${ALLOW_API_CALLS:=0}"
if [ -n "${GROQ_API_KEY:-}" ] && ! is_truthy "${ALLOW_API_CALLS:-0}" && ! is_truthy "${DRY_RUN:-0}"; then
  printf 'Error: GROQ_API_KEY is set but ALLOW_API_CALLS!=1 and DRY_RUN!=1. Set ALLOW_API_CALLS=1 to permit real API calls, or use DRY_RUN=1 for testing.\n' >&2
  exit "$GROQBASHERRTMP"
fi

# Handle immediate CLI actions that don't require a prompt
if [ "${REFRESH_MODELS:-0}" -eq 1 ]; then
  refresh_models_dispatch "$MODELS_FILE" || exit "$GROQBASHERRAPI"
  exit 0
fi

if [ "${LIST_MODELS:-0}" -eq 1 ]; then
  if [ -f "$MODELS_FILE" ] && [ -s "$MODELS_FILE" ]; then
    cat "$MODELS_FILE" >&2
    exit 0
  else
    printf 'No models available locally. Consider --refresh-models.\n' >&2
    exit "$GROQBASHERRTMP"
  fi
fi

if [ -n "${SET_DEFAULT_MODEL:-}" ]; then
  mkdir -p "$GROQBASH_CONFIG_DIR" 2>/dev/null || true
  # Security checks for config dir
  if [ -L "$GROQBASH_CONFIG_DIR" ]; then
    printf 'Security error: config dir is a symlink: %s\n' "$GROQBASH_CONFIG_DIR" >&2
    exit "$GROQBASHERRTMP"
  fi
  perms="$(_get_perm_string "$GROQBASH_CONFIG_DIR" 2>/dev/null || true)"
  group_write="$(printf '%s' "$perms" | awk '{print substr($0,6,1)}')"
  others_write="$(printf '%s' "$perms" | awk '{print substr($0,9,1)}')"
  if [ "$group_write" = "w" ] || [ "$others_write" = "w" ]; then
    printf 'Security error: config dir is writable by group or others: %s\n' "$GROQBASH_CONFIG_DIR" >&2
    exit "$GROQBASHERRTMP"
  fi
  # Use atomic_write helper from PRECORE
  printf '%s\n' "$SET_DEFAULT_MODEL" | atomic_write "$GROQBASH_CONFIG_DIR/model.$PROVIDER" || { printf 'Error: cannot write default model.\n' >&2; exit "$GROQBASHERRTMP"; }
  printf 'Default model for provider %s set to: %s\n' "$PROVIDER" "$SET_DEFAULT_MODEL" >&2
  exit 0
fi

if [ "${STREAM_MODE:-0}" -eq 1 ] && { [ "$OUTPUT_MODE" = "json" ] || [ "$OUTPUT_MODE" = "pretty" ]; }; then
  printf 'Error: --stream is not compatible with --json/--pretty (streaming produces partial JSON). Use --text or --raw for streaming.\n' >&2
  exit "$GROQBASHERRTMP"
fi

if [ "${INSTALL_EXTRAS:-0}" -eq 1 ]; then
  dest_base="$GROQBASH_EXTRAS_DIR"
  dest_docs="$dest_base/docs"
  dest_lib="$dest_base/lib"
  dest_prov="$dest_base/providers"
  src_base="$SCRIPTDIR/extras"
  src_docs="$src_base/docs/core-notes.sh"
  src_utils="$src_base/lib/utils.sh"
  src_debug="$src_base/lib/debug.sh"
  src_groq="$src_base/providers/groq.sh"

  # Ensure destination directories exist and are secure
  if ! mkdir -p "$dest_docs" "$dest_lib" "$dest_prov" 2>/dev/null; then
    printf 'Error: cannot create extras directories under %s\n' "$dest_base" >&2
    exit "$GROQBASHERRTMP"
  fi
  chmod 700 "$dest_base" "$dest_docs" "$dest_lib" "$dest_prov" 2>/dev/null || true

  # Verify source files exist and are not symlinks and are owned by current user
  current_user="$(id -un 2>/dev/null || printf '')"
  for src in "$src_docs" "$src_utils" "$src_debug" "$src_groq"; do
    if [ ! -f "$src" ]; then
      printf 'Error: bundled extras file not found: %s\n' "$src" >&2
      exit "$GROQBASHERRTMP"
    fi
    if [ -L "$src" ]; then
      printf 'Security error: bundled extras file is a symlink: %s\n' "$src" >&2
      exit "$GROQBASHERRTMP"
    fi
    src_owner="$(_get_owner "$src")"
    if [ -n "$src_owner" ] && [ -n "$current_user" ] && [ "$src_owner" != "$current_user" ]; then
      printf 'Security error: bundled extras file not owned by current user: %s\n' "$src" >&2
      exit "$GROQBASHERRTMP"
    fi
  done

  # Copy with atomic writes and secure perms using atomic_write
  for pair in "$src_docs:$dest_docs/core-notes.sh" "$src_utils:$dest_lib/utils.sh" "$src_debug:$dest_lib/debug.sh" "$src_groq:$dest_prov/groq.sh"; do
    srcf="${pair%%:*}"; destf="${pair##*:}"
    if ! cat "$srcf" | atomic_write "$destf"; then
      printf 'Error copying %s to %s\n' "$srcf" "$destf" >&2
      exit "$GROQBASHERRTMP"
    fi
    # Ensure secure perms on installed files
    chmod 600 "$destf" 2>/dev/null || true
  done

  printf 'Extras installed under %s/extras/\n' "$GROQBASH_DIR" >&2
  exit 0
fi

# Provider selection and validation is handled centrally in CORE3.
# CORE2 performs CLI parsing and immediate actions only; provider persistence and interactive selection
# are implemented in CORE3 to avoid duplication.

load_local_config
load_whitelist
# ==== CORE2 END ====
# ==== CORE3 BEGIN ====
# Provider selection, model discovery, and provider module loading (secure)

# Ensure PROVIDER_FILE is defined (path to persisted provider selection)
PROVIDER_FILE="${PROVIDER_FILE:-$GROQBASH_CONFIG_DIR/provider}"

# Load provider from config file if present and not overridden by CLI/interactive
if [ -f "$PROVIDER_FILE" ] && [ -z "${PROVIDER_CLI:-}" ] && [ "${PROVIDER_INTERACTIVE:-0}" -eq 0 ]; then
  prov="$(sed -n '1p' "$PROVIDER_FILE" 2>/dev/null || true)"
  [ -n "$prov" ] && PROVIDER="$prov"
fi

# If CLI provided a provider, validate and persist atomically using atomic_write from PRECORE
if [ -n "${PROVIDER_CLI:-}" ] && [ "${PROVIDER_CLI}" != "list" ]; then
  case " $SUPPORTED_PROVIDERS " in *" $PROVIDER_CLI "*) PROVIDER="$PROVIDER_CLI" ;; *) printf 'Error: unknown provider: %s\n' "$PROVIDER_CLI" >&2; exit "$GROQBASHERRTMP" ;; esac
  mkdir -p "$(dirname "$PROVIDER_FILE")" 2>/dev/null || true
  if ! printf '%s\n' "$PROVIDER" | atomic_write "$PROVIDER_FILE"; then
    printf 'Error: cannot persist provider selection.\n' >&2
    exit "$GROQBASHERRTMP"
  fi
  chmod 600 "$PROVIDER_FILE" 2>/dev/null || true
  refresh_models_dispatch "$MODELS_FILE" || true
fi

# Interactive provider selection (validated, numeric input)
if [ "${PROVIDER_INTERACTIVE:-0}" -eq 1 ] || [ "${PROVIDER_CLI:-}" = "list" ]; then
  IFS=' ' read -r -a _prov_arr <<EOF
$SUPPORTED_PROVIDERS
EOF
  current_default="$PROVIDER"
  [ -f "$PROVIDER_FILE" ] && pf="$(sed -n '1p' "$PROVIDER_FILE" 2>/dev/null || true)" && [ -n "$pf" ] && current_default="$pf"
  printf 'Select provider:\n' >&2
  i=1
  for p in "${_prov_arr[@]}"; do
    if [ "$p" = "$current_default" ]; then printf '%d) %s (default)\n' "$i" "$p" >&2; else printf '%d) %s\n' "$i" "$p" >&2; fi
    i=$((i+1))
  done
  printf '> ' >&2
  if ! IFS= read -r sel; then printf 'No selection made. Exiting.\n' >&2; exit "$GROQBASHERRTMP"; fi
  sel="$(trim "$sel")"
  if ! printf '%s\n' "$sel" | grep -qE '^[0-9]+$'; then printf 'Invalid selection. Exiting.\n' >&2; exit "$GROQBASHERRTMP"; fi
  idx="$sel"; chosen="${_prov_arr[$((idx-1))]}"
  [ -z "$chosen" ] && { printf 'Selection out of range. Exiting.\n' >&2; exit "$GROQBASHERRTMP"; }
  if ! printf '%s\n' "$chosen" | atomic_write "$PROVIDER_FILE"; then
    printf 'Error: cannot persist provider selection.\n' >&2
    exit "$GROQBASHERRTMP"
  fi
  chmod 600 "$PROVIDER_FILE" 2>/dev/null || true
  PROVIDER="$chosen"
  refresh_models_dispatch "$MODELS_FILE" || true
  exit 0
fi

# Dispatcher: refresh models (calls provider-specific refresh_models_<provider> if present)
refresh_models_dispatch() {
  local outpath="${1:-$MODELS_FILE}"
  local fn="refresh_models_${PROVIDER}"
  if type "$fn" >/dev/null 2>&1; then
    "$fn" "$outpath"
    return $?
  fi
  printf 'Provider '\''%s'\'' does not support model refresh.\n' "$PROVIDER" >&2
  return "$GROQBASHERRAPI"
}

# Dispatcher: validate model (calls provider-specific validate_model_<provider> if present)
validate_model_dispatch() {
  local model="$1"
  local fn="validate_model_${PROVIDER}"
  if type "$fn" >/dev/null 2>&1; then
    "$fn" "$model"
    return $?
  fi
  if [ -n "$ALLOWED_MODELS" ]; then
    printf '%s\n' "$ALLOWED_MODELS" | grep -x -F -q "$model"
    return $?
  fi
  return 0
}

# Dispatcher: auto-select model (calls provider-specific auto_select_model_<provider> if present)
auto_select_model_dispatch() {
  local fn="auto_select_model_${PROVIDER}"
  if type "$fn" >/dev/null 2>&1; then
    # provider function should print the selected model to stdout
    "$fn"
    return 0
  fi
  if [ -f "$MODELS_FILE" ] && [ -s "$MODELS_FILE" ]; then
    if jq -e . "$MODELS_FILE" >/dev/null 2>&1; then
      jq -r '.data[]?.id // empty' "$MODELS_FILE" 2>/dev/null | awk 'NF{print; exit}'
    else
      awk 'NF{print; exit}' "$MODELS_FILE" 2>/dev/null || printf ''
    fi
    return 0
  fi
  printf ''
  return 0
}

# Model selection: check provider-specific config, auto-select, fallback to global config or whitelist
MODEL_PROVIDER_CFG="$GROQBASH_CONFIG_DIR/model.$PROVIDER"
if [ -z "${MODEL:-}" ] && [ -f "$MODEL_PROVIDER_CFG" ] && [ -s "$MODEL_PROVIDER_CFG" ]; then
  cand="$(sed -n '1p' "$MODEL_PROVIDER_CFG" 2>/dev/null || true)"; [ -n "$cand" ] && MODEL="$cand"
fi

if [ -z "${MODEL:-}" ]; then
  cand="$(auto_select_model_dispatch 2>/dev/null || true)"
  [ -n "$cand" ] && MODEL="$cand"
fi

if [ -z "$MODEL" ] && [ -f "$GROQBASH_CONFIG_DIR/config" ]; then
  cand="$(awk -F= '/^MODEL=/ {sub(/^MODEL=/,""); print $0; exit}' "$GROQBASH_CONFIG_DIR/config" 2>/dev/null || true)"
  [ -n "$cand" ] && MODEL="$cand"
fi

[ -z "$MODEL" ] && [ -n "$ALLOWED_MODELS" ] && MODEL="$(awk 'NF{print; exit}' <<<"$ALLOWED_MODELS" 2>/dev/null || printf '')"

if [ -n "$MODEL" ]; then
  if ! validate_model_dispatch "$MODEL"; then
    printf 'Error: model '\''%s'\'' not supported or deprecated.\n' "$MODEL" >&2
    if [ -n "$ALLOWED_MODELS" ]; then
      printf 'Available models (local whitelist):\n' >&2
      printf '%s\n' "$ALLOWED_MODELS" >&2
    fi
    exit "$GROQBASHERRBAD_MODEL"
  fi
fi

# Provider module loading: secure checks before sourcing
PROVIDER_MODULE_LOADED=0
PROVIDER_MODULE_PATH="$GROQBASH_EXTRAS_DIR/providers/${PROVIDER}.sh"
PROVIDER_DIR="$(dirname "$PROVIDER_MODULE_PATH")"

# Ensure provider directory exists and is secure
if [ ! -d "$PROVIDER_DIR" ]; then
  if ! mkdir -p "$PROVIDER_DIR" 2>/dev/null; then
    printf 'Error: cannot create provider directory: %s\n' "$PROVIDER_DIR" >&2
    exit "$GROQBASHERRTMP"
  fi
fi
if _is_world_writable "$PROVIDER_DIR"; then
  printf 'Security error: extras/providers directory is world-writable; refusing to load provider modules.\n' >&2
  exit "$GROQBASHERRTMP"
fi

# Warn if owner differs
current_user="$(id -un 2>/dev/null || printf '')"
owner="$(_get_owner "$PROVIDER_DIR")"
if [ -n "$owner" ] && [ -n "$current_user" ] && [ "$owner" != "$current_user" ]; then
  dbg "Warning: provider directory $PROVIDER_DIR is owned by $owner, not $current_user."
fi

# If provider module file does not exist, allow default built-in provider 'groq' to proceed
if [ ! -f "$PROVIDER_MODULE_PATH" ]; then
  if [ "$PROVIDER" != "groq" ]; then
    printf 'Provider '\''%s'\'' is not installed. Run --install-extras or provide a valid provider plugin.\n' "$PROVIDER" >&2
    PROVIDER_MODULE_LOADED=0
  else
    PROVIDER_MODULE_LOADED=1
  fi
else
  # Security checks on provider file before sourcing
  if [ -L "$PROVIDER_MODULE_PATH" ]; then
    printf 'Security error: provider file is a symlink: %s\n' "$PROVIDER_MODULE_PATH" >&2
    exit "$GROQBASHERRTMP"
  fi
  file_owner="$(_get_owner "$PROVIDER_MODULE_PATH")"
  current_user="${USER:-$(id -un 2>/dev/null || printf '')}"
  if [ -n "$file_owner" ] && [ -n "$current_user" ] && [ "$file_owner" != "$current_user" ]; then
    printf 'Security error: provider file not owned by current user: %s\n' "$PROVIDER_MODULE_PATH" >&2
    exit "$GROQBASHERRTMP"
  fi
  perms="$(_get_perm_string "$PROVIDER_MODULE_PATH")"
  group_write="$(printf '%s' "$perms" | awk '{print substr($0,6,1)}')"
  others_write="$(printf '%s' "$perms" | awk '{print substr($0,9,1)}')"
  if [ "$group_write" = "w" ] || [ "$others_write" = "w" ]; then
    printf 'Security error: provider file is writable by group or world: %s\n' "$PROVIDER_MODULE_PATH" >&2
    exit "$GROQBASHERRTMP"
  fi

  # Compute signature before sourcing using PRECORE wrapper
  beforesig="$(getfile_signature "$PROVIDER_MODULE_PATH" 2>/dev/null || true)"

  # Source provider module (after security checks)
  # shellcheck source=/dev/null
  . "$PROVIDER_MODULE_PATH"
  PROVIDER_MODULE_LOADED=1

  # Compute signature after sourcing and compare
  aftersig="$(getfile_signature "$PROVIDER_MODULE_PATH" 2>/dev/null || true)"
  if [ -n "$beforesig" ] && [ -n "$aftersig" ] && [ "$beforesig" != "$aftersig" ]; then
    printf 'Security error: provider file changed during validation: %s\n' "$PROVIDER_MODULE_PATH" >&2
    exit "$GROQBASHERRTMP"
  fi
fi
# ==== CORE3 END ====
# ==== CORE4 BEGIN ====
# Provider interface validation, input validation, content assembly, and runtime modes

validate_provider_interface() {
  local p="$1" missing=0
  local required=( "buildpayload_${p}" "call_api_${p}" )
  local optional=( "call_api_streaming_${p}" "refresh_models_${p}" "validate_model_${p}" "auto_select_model_${p}" )
  local f
  for f in "${required[@]}"; do
    if ! type "$f" >/dev/null 2>&1; then
      printf 'Provider '\''%s'\'' module does not define required function %s().\n' "$p" "$f" >&2
      missing=1
    fi
  done
  for f in "${optional[@]}"; do
    if ! type "$f" >/dev/null 2>&1; then
      dbg "Provider '%s' missing optional function %s()" "$p" "$f" || true
    fi
  done
  return $missing
}

# Ensure a provider module was loaded and that it implements required functions
if [ "${PROVIDER_MODULE_LOADED:-0}" -eq 1 ]; then
  validate_provider_interface "$PROVIDER" || exit "$GROQBASHERRAPI"
else
  printf 'Error: no valid provider loaded for '\''%s'\''. Install or configure a provider plugin.\n' "$PROVIDER" >&2
  exit "$GROQBASHERRAPI"
fi

# Validate batch/json/template inputs and read STDIN if present
[ -n "$BATCH_FILE" ] && [ ! -r "$BATCH_FILE" ] && { printf 'Error: batch file not readable: %s\n' "$BATCH_FILE" >&2; exit "$GROQBASHERRTMP"; }
if [ -n "$JSON_INPUT" ]; then
  [ ! -r "$JSON_INPUT" ] && { printf 'Error: JSON input file not readable: %s\n' "$JSON_INPUT" >&2; exit "$GROQBASHERRINVALID_JSON"; }
  if ! jq -e . "$JSON_INPUT" >/dev/null 2>&1; then
    printf 'Error: JSON input is not valid JSON.\n' >&2
    exit "$GROQBASHERRINVALID_JSON"
  fi
fi
[ -n "$TEMPLATE" ] && [ ! -f "$GROQBASH_TEMPLATES_DIR/$TEMPLATE" ] && { printf 'Error: template not found: %s\n' "$TEMPLATE" >&2; exit "$GROQBASHERRTMP"; }

STDIN_CONTENT=""; [ ! -t 0 ] && STDIN_CONTENT="$(cat - 2>/dev/null || true)"
CONTENT="${CONTENT:-}"

# Assemble CONTENT helper: centralize logic for building CONTENT from files, args, template, stdin
assemble_content() {
  # Produces/updates global CONTENT variable
  local tmpl tmp_tmpl tmp_final extra file_content
  CONTENT="${CONTENT:-}"

  if [ -n "$JSON_INPUT" ]; then
    # JSON input is handled later by provider-specific payload builder
    CONTENT=""
    return 0
  fi

  if [ "${#FILE_INPUTS[@]}" -gt 0 ]; then
    CONTENT="$(collect_input_from_files "${FILE_INPUTS[@]}")"
    if [ "${#ARGS[@]}" -gt 0 ]; then
      extra="$(expand_args_to_content)"
      [ -n "$extra" ] && CONTENT="${CONTENT}"$'\n\n'"$extra"
    fi
    return 0
  fi

  if [ -n "$TEMPLATE" ]; then
    # If template specified, prefer file inputs, then stdin, then args
    if [ "${#FILE_INPUTS[@]}" -gt 0 ]; then
      CONTENT="$(collect_input_from_files "${FILE_INPUTS[@]}")"
    elif [ -n "$STDIN_CONTENT" ]; then
      CONTENT="$STDIN_CONTENT"
    else
      if [ "${#ARGS[@]}" -gt 0 ]; then
        CONTENT="$(expand_args_to_content)"
      else
        CONTENT=""
      fi
    fi

    tmpl="$(cat "$GROQBASH_TEMPLATES_DIR/$TEMPLATE" 2>/dev/null || true)"

    # Use run tmpdir for safe temporary processing
    ensure_run_tmpdir
    tmp_tmpl="$(_mktemp_in_dir "$RUN_TMPDIR" 2>/dev/null || true)"
    if [ -n "$tmp_tmpl" ]; then
      # Replace placeholder {{CONTENT}} with CONTENT (preserve newlines)
      printf '%s' "$tmpl" | awk -v repl="$CONTENT" 'BEGIN{RS=""; ORS="";} {gsub(/\{\{CONTENT\}\}/, repl); print}' > "$tmp_tmpl"
      tmp_final="${tmp_tmpl}.final"
      mv "$tmp_tmpl" "$tmp_final" 2>/dev/null || true
      file_content="$(cat "$tmp_final" 2>/dev/null || printf '%s' "$tmpl")"
      CONTENT="$file_content"
      rm -f "$tmp_final" 2>/dev/null || true
    else
      # Fallback: do replacement in-memory
      CONTENT="$(printf '%s' "$tmpl" | awk -v repl="$CONTENT" 'BEGIN{RS=""; ORS="";} {gsub(/\{\{CONTENT\}\}/, repl); print}' )"
    fi
    return 0
  fi

  if [ -n "$STDIN_CONTENT" ]; then
    CONTENT="$STDIN_CONTENT"
    if [ "${#ARGS[@]}" -gt 0 ]; then
      extra="$(expand_args_to_content)"
      [ -n "$extra" ] && CONTENT="${CONTENT}"$'\n\n'"$extra"
    fi
    return 0
  fi

  if [ "${#ARGS[@]}" -gt 0 ]; then
    CONTENT="$(expand_args_to_content)"
  else
    CONTENT=""
  fi

  return 0
}

# Build CONTENT once using the helper
assemble_content

# Ensure we have a prompt unless JSON_INPUT or chat or batch
if [ -z "$CONTENT" ] && [ -z "$JSON_INPUT" ] && [ "${CHAT_MODE:-0}" -eq 0 ] && [ -z "$BATCH_FILE" ]; then
  printf 'Error: no prompt provided.\n' >&2
  exit "$GROQBASHERRNO_PROMPT"
fi

# Validate numeric options
is_number "$TURE" || { printf 'Error: --ture must be numeric\n' >&2; exit "$GROQBASHERRTMP"; }
is_number "$MAX_TOKENS" || { printf 'Error: --max must be numeric\n' >&2; exit "$GROQBASHERRTMP"; }

# Enforce model whitelist if present
if [ -n "$ALLOWED_MODELS" ] && [ -n "$MODEL" ]; then
  if ! printf '%s\n' "$ALLOWED_MODELS" | grep -x -F -q "$MODEL"; then
    printf 'Error: model '\''%s'\'' not supported or deprecated.\n' "$MODEL" >&2
    printf 'Available models (local whitelist):\n' >&2
    printf '%s\n' "$ALLOWED_MODELS" >&2
    exit "$GROQBASHERRBAD_MODEL"
  fi
fi

# Ensure RUN_TMPDIR exists for temporary files
ensure_run_tmpdir

# Batch mode: iterate lines as prompts
if [ -n "$BATCH_FILE" ]; then
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in ''|\#*) continue ;; esac
    CONTENT="$line"
    build_payload_from_vars
    if [ "${STREAM_MODE:-0}" -eq 1 ]; then
      call_api_streaming || { printf 'Error during streaming call.\n' >&2; continue; }
    else
      perform_request_once || true
    fi
    printf '\n----\n'
  done < "$BATCH_FILE"
  exit 0
fi

# Interactive chat mode
if [ "${CHAT_MODE:-0}" -eq 1 ]; then
  if [ ! -t 0 ]; then printf 'Error: interactive chat requires a TTY.\n' >&2; exit "$GROQBASHERRTMP"; fi
  [ -t 1 ] && [ "${QUIET:-0}" -ne 1 ] && { printf 'Entering interactive chat. Press Ctrl+D to exit.\n' >&2; } || printf 'Entering interactive chat. Press Ctrl+D to exit.\n' >&2
  CONVERSATION=""
  while true; do
    if is_tty_out && [ "${QUIET:-0}" -ne 1 ] && { [ "$OUTPUT_MODE" = "text" ] || [ "$OUTPUT_MODE" = "raw" ]; }; then printf '\nYou: ' >&2; fi
    if ! IFS= read -r userline; then printf '\n' >&2; break; fi
    [ -z "$userline" ] && continue
    [ -z "$CONVERSATION" ] && CONVERSATION="$userline" || CONVERSATION="${CONVERSATION}"$'\n\n'"User: ${userline}"
    CONTENT="$userline"
    build_payload_from_vars
    if [ "${STREAM_MODE:-0}" -eq 1 ]; then
      call_api_streaming || printf 'Streaming call failed.\n' >&2
    else
      perform_request_once || printf 'Call failed.\n' >&2
    fi
  done
  exit 0
fi

# Single request (streaming or non-streaming)
if [ "${STREAM_MODE:-0}" -eq 1 ]; then
  build_payload_from_vars
  if call_api_streaming; then dbg "Streaming completed; captured response in $RESP"; printf '\n'; exit 0; else printf 'Error: streaming request failed.\n' >&2; exit "$GROQBASHERRCURL_FAILED"; fi
else
  if is_tty_out && [ "${QUIET:-0}" -ne 1 ] && { [ "$OUTPUT_MODE" = "text" ] || [ "$OUTPUT_MODE" = "raw" ]; }; then
    printf '%b\n' "\033[1;36mYou:\033[0m" >&2
    if [ "${#ARGS[@]}" -gt 0 ]; then
      anyfile=0
      for a in "${ARGS[@]}"; do [ -r "$a" ] && [ -f "$a" ] && { anyfile=1; break; }; done
      [ "$anyfile" -eq 1 ] && printf '%s\n' "(using file contents)" >&2 || printf '%s\n' "$CONTENT" >&2
    else printf '%s\n' "$CONTENT" >&2; fi
    printf '%b\n' "\033[1;32mProvider ($PROVIDER, model: $MODEL):\033[0m" >&2
  fi
  build_payload_from_vars
  perform_request_once || exit "$GROQBASHERRAPI"
  exit 0
fi
# ==== CORE4 END ====
# End of file
