# ---------------------------------------------------------------------------
# buildpayload_groq
# - Produces a base64-staged payload at $PAYLOAD (uses stage_b64)
# - Supports: JSON_INPUT (messages or prompt), SYSTEM_PROMPT + CONTENT,
#   or CONTENT alone.
# - Honors STREAM_MODE via stream boolean in payload.
# - Uses local helpers stage_b64 and _cleanup_local_tmp for atomicity and cleanup.
# ---------------------------------------------------------------------------

# stage_b64: read stdin, write atomic base64 staging file under RUN_TMPDIR or destdir
# Usage: stage_b64 <dest_b64_path> <max_bytes>
stage_b64() {
  local dest_b64="$1"
  local max_bytes="${2:-10485760}" # default 10MB safeguard
  local workdir tmp_local tmp_b64 lockfile size
  [ -n "$dest_b64" ] || return 1
  workdir="$(dirname "$dest_b64")"
  mkdir -p "$workdir" 2>/dev/null || return 1

  tmp_local="$(_mktemp_in_dir "${RUN_TMPDIR:-$GROQBASH_TMPDIR}" "payload" 2>/dev/null || true)"
  [ -n "$tmp_local" ] || tmp_local="${RUN_TMPDIR%/}/payload.tmp.$$"

  # Write stdin to tmp_local
  if ! cat - > "$tmp_local" 2>/dev/null; then
    rm -f -- "$tmp_local" 2>/dev/null || true
    log_error "PAYLOAD" "failed to write staging payload"
    return 1
  fi

  # Optional size check
  size="$(file_size "$tmp_local" 2>/dev/null || echo 0)"
  if [ "$size" -gt "$max_bytes" ]; then
    log_error "PAYLOAD" "staged payload exceeds max allowed size ($size > $max_bytes)"
    rm -f -- "$tmp_local" 2>/dev/null || true
    return 1
  fi

  # Create base64 staging in same dest dir atomically
  tmp_b64="${workdir%/}/.groq-b64.$$.$RANDOM"
  if [ -n "${B64_WRAP_OPT:-}" ]; then
    base64 ${B64_WRAP_OPT} "$tmp_local" > "$tmp_b64" 2>/dev/null || { rm -f -- "$tmp_local" "$tmp_b64" 2>/dev/null || true; return 1; }
  else
    base64 "$tmp_local" | tr -d '\n' > "$tmp_b64" 2>/dev/null || { rm -f -- "$tmp_local" "$tmp_b64" 2>/dev/null || true; return 1; }
  fi
  chmod 600 "$tmp_b64" 2>/dev/null || true

  # Atomic move into place under lock to avoid races
  lockfile="${workdir%/}/.groqbash.lock"
  lock_exec "$lockfile" 10 -- sh -c '
    set -e
    mv -f -- "$1" "$2"
    chmod 600 "$2" 2>/dev/null || true
  ' _ "$tmp_b64" "$dest_b64" || { rm -f -- "$tmp_local" "$tmp_b64" 2>/dev/null || true; return 1; }

  rm -f -- "$tmp_local" 2>/dev/null || true
  return 0
}

# _cleanup_local_tmp: helper to remove local temporary artifacts
_cleanup_local_tmp() {
  local tmp_payload="$1" tmp_b64_local="$2" json_input_file="$3"
  [ -n "$tmp_payload" ] && rm -f -- "$tmp_payload" 2>/dev/null || true
  [ -n "$tmp_b64_local" ] && rm -f -- "$tmp_b64_local" 2>/dev/null || true
  [ -n "$json_input_file" ] && rm -f -- "$json_input_file" 2>/dev/null || true
}

buildpayload_groq() {
  local workdir tmp_payload tmp_b64 dest_b64 model_in_file model_to_use user_prompt stream_json MESSAGES_JSON json_input_file tmp_b64_local

  # Ensure json_input_file is always defined to avoid nounset errors
  json_input_file="${JSON_INPUT:-}"

  ensure_run_tmpdir || return "$GROQBASHERRTMP"
  workdir="${RUN_TMPDIR:-}"
  [ -n "$workdir" ] || return "$GROQBASHERRTMP"

  : "${TURE:=1.0}"
  : "${MAX_TOKENS:=4096}"

  if is_truthy "${STREAM_MODE:-0}"; then stream_json=true; else stream_json=false; fi

  # Require jq for JSON processing
  if ! command -v jq >/dev/null 2>&1; then
    log_error "DEPENDENCY" "jq is required but not found in PATH"
    return "$GROQBASHERRTMP"
  fi

  # Helper: resolve messages JSON (use BUILD_MESSAGES_FILE if non-empty, otherwise fallback to current content)
  resolve_messages_json() {
    local fallback_content="$1" file="${2:-}"
    if [ -n "${file:-}" ] && [ -f "$file" ]; then
      local len
      len="$(jq '.messages | length' "$file" 2>/dev/null || echo 0)"
      if [ "${len:-0}" -gt 0 ]; then
        jq -c '.messages' "$file" 2>/dev/null || printf '[]'
        return 0
      fi
    fi
    jq -c -n --arg role "user" --arg content "$fallback_content" '[{role:$role,content:$content}]'
    return 0
  }

  # Deduplicate messages array by role+content preserving order
  dedupe_messages_json() {
    jq -c 'reduce .[] as $m ( []; if any(.[]; (.role == $m.role) and ((.content // "") == ($m.content // ""))) then . else . + [$m] end )'
  }

  # If JSON_INPUT provided, support '-' (stdin) and files and objects
  if [ -n "${JSON_INPUT:-}" ]; then
    if [ "${JSON_INPUT:-}" = "-" ]; then
      json_input_file="${workdir%/}/json_input.$$"
      : > "$json_input_file"
      if ! cat - > "$json_input_file" 2>/dev/null; then
        _cleanup_local_tmp "" "" "$json_input_file"
        log_error "PAYLOAD" "failed to read JSON input from stdin"
        return "$GROQBASHERRTMP"
      fi
      JSON_INPUT="$json_input_file"
    fi

    # If JSON_INPUT contains messages[], stage it as-is (but dedupe messages)
    if jq -e 'has("messages")' "$JSON_INPUT" >/dev/null 2>&1; then
      MESSAGES_JSON="$(jq -c '.messages' "$JSON_INPUT" 2>/dev/null || printf '[]')"
      MESSAGES_JSON="$(printf '%s' "$MESSAGES_JSON" | dedupe_messages_json || printf '%s' "$MESSAGES_JSON")"

      tmp_payload="$(_mktemp_in_dir "$workdir" 2>/dev/null || true)"
      if [ -z "${tmp_payload:-}" ] || [ ! -e "$tmp_payload" ]; then
        _cleanup_local_tmp "" "" "$json_input_file"
        log_error "TMP" "failed to create temporary payload file"
        return "$GROQBASHERRTMP"
      fi

      jq -n --arg model "${MODEL:-}" --argjson stream "$stream_json" --arg ture "$TURE" --arg max_tokens "$MAX_TOKENS" --argjson messages "$MESSAGES_JSON" \
         '{model:$model, stream:$stream, temperature:($ture|tonumber), max_tokens:($max_tokens|tonumber), messages:$messages }' >"$tmp_payload"

      dest_b64="${PAYLOAD:-$workdir/payload}.b64"
      if [ -z "${dest_b64:-}" ]; then
        _cleanup_local_tmp "$tmp_payload" "" "$json_input_file"
        log_error "PAYLOAD" "destination b64 path is empty"
        return "$GROQBASHERRTMP"
      fi

      if ! stage_b64 "$dest_b64" < "$tmp_payload"; then
        _cleanup_local_tmp "$tmp_payload" "" "$json_input_file"
        return "$GROQBASHERRTMP"
      fi

      if [ ! -f "$dest_b64" ]; then
        _cleanup_local_tmp "$tmp_payload" "" "$json_input_file"
        log_error "PAYLOAD" "staged payload missing: $dest_b64"
        return "$GROQBASHERRTMP"
      fi
      chmod 600 "$dest_b64" 2>/dev/null || true

      PAYLOAD="$dest_b64"
      _cleanup_local_tmp "$tmp_payload" "" "$json_input_file"
      return 0
    fi

    # If JSON_INPUT is a single message object {role,content}
    if jq -e 'type=="object" and has("role") and has("content")' "$JSON_INPUT" >/dev/null 2>&1; then
      model_in_file="$(jq -r '.model // empty' "$JSON_INPUT" 2>/dev/null || true)"
      model_to_use="${model_in_file:-$MODEL}"
      MESSAGES_JSON="$(jq -c -n --arg role "$(jq -r '.role' "$JSON_INPUT" 2>/dev/null || echo user)" --arg content "$(jq -r '.content' "$JSON_INPUT" 2>/dev/null || echo '')" '[{role:$role,content:$content}]')"
      MESSAGES_JSON="$(printf '%s' "$MESSAGES_JSON" | dedupe_messages_json || printf '%s' "$MESSAGES_JSON")"

      tmp_payload="$(_mktemp_in_dir "$workdir" 2>/dev/null || true)"
      if [ -z "${tmp_payload:-}" ] || [ ! -e "$tmp_payload" ]; then
        _cleanup_local_tmp "" "" "$json_input_file"
        log_error "TMP" "failed to create temporary payload file"
        return "$GROQBASHERRTMP"
      fi

      jq -n --arg model "$model_to_use" --argjson stream "$stream_json" --arg ture "$TURE" --arg max_tokens "$MAX_TOKENS" --argjson messages "$MESSAGES_JSON" \
         '{model:$model, stream:$stream, temperature:($ture|tonumber), max_tokens:($max_tokens|tonumber), messages:$messages }' >"$tmp_payload"

      dest_b64="${PAYLOAD:-$workdir/payload}.b64"
      if [ -z "${dest_b64:-}" ]; then
        _cleanup_local_tmp "$tmp_payload" "" "$json_input_file"
        log_error "PAYLOAD" "destination b64 path is empty"
        return "$GROQBASHERRTMP"
      fi

      if ! stage_b64 "$dest_b64" < "$tmp_payload"; then
        _cleanup_local_tmp "$tmp_payload" "" "$json_input_file"
        return "$GROQBASHERRTMP"
      fi

      if [ ! -f "$dest_b64" ]; then
        _cleanup_local_tmp "$tmp_payload" "" "$json_input_file"
        log_error "PAYLOAD" "staged payload missing: $dest_b64"
        return "$GROQBASHERRTMP"
      fi
      chmod 600 "$dest_b64" 2>/dev/null || true

      PAYLOAD="$dest_b64"
      _cleanup_local_tmp "$tmp_payload" "" "$json_input_file"
      return 0
    fi

    # Otherwise stage the raw JSON_INPUT file as-is
    tmp_payload="$(_mktemp_in_dir "$workdir" 2>/dev/null || true)"
    if [ -z "${tmp_payload:-}" ] || [ ! -e "$tmp_payload" ]; then
      _cleanup_local_tmp "" "" "$json_input_file"
      log_error "TMP" "failed to create temporary payload file"
      return "$GROQBASHERRTMP"
    fi

    if ! cat "$JSON_INPUT" > "$tmp_payload" 2>/dev/null; then
      _cleanup_local_tmp "$tmp_payload" "" "$json_input_file"
      return "$GROQBASHERRTMP"
    fi

    dest_b64="${PAYLOAD:-$workdir/payload}.b64"
    if [ -z "${dest_b64:-}" ]; then
      _cleanup_local_tmp "$tmp_payload" "" "$json_input_file"
      log_error "PAYLOAD" "destination b64 path is empty"
      return "$GROQBASHERRTMP"
    fi

    if ! stage_b64 "$dest_b64" < "$tmp_payload"; then
      _cleanup_local_tmp "$tmp_payload" "" "$json_input_file"
      return "$GROQBASHERRTMP"
    fi

    if [ ! -f "$dest_b64" ]; then
      _cleanup_local_tmp "$tmp_payload" "" "$json_input_file"
      log_error "PAYLOAD" "staged payload missing: $dest_b64"
      return "$GROQBASHERRTMP"
    fi
    chmod 600 "$dest_b64" 2>/dev/null || true

    PAYLOAD="$dest_b64"
    _cleanup_local_tmp "$tmp_payload" "" "$json_input_file"
    return 0
  fi

  # Build payload from CONTENT / SYSTEM_PROMPT
  model_to_use="${MODEL}"
  MESSAGES_JSON="$(resolve_messages_json "${CONTENT:-}" "${BUILD_MESSAGES_FILE:-}")"
  MESSAGES_JSON="$(printf '%s' "$MESSAGES_JSON" | dedupe_messages_json || printf '%s' "$MESSAGES_JSON")"

  tmp_payload="$(_mktemp_in_dir "$workdir" 2>/dev/null || true)"
  if [ -z "${tmp_payload:-}" ] || [ ! -e "$tmp_payload" ]; then
    _cleanup_local_tmp "" "" "$json_input_file"
    log_error "TMP" "failed to create temporary payload file"
    return "$GROQBASHERRTMP"
  fi

  jq -n --arg model "$model_to_use" --argjson stream "$stream_json" --arg ture "$TURE" --arg max_tokens "$MAX_TOKENS" --argjson messages "$MESSAGES_JSON" \
     '{model:$model, stream:$stream, temperature:($ture|tonumber), max_tokens:($max_tokens|tonumber), messages:$messages }' >"$tmp_payload"

  dest_b64="${PAYLOAD:-$workdir/payload}.b64"
  if [ -z "${dest_b64:-}" ]; then
    _cleanup_local_tmp "$tmp_payload" "" "$json_input_file"
    log_error "PAYLOAD" "destination b64 path is empty"
    return "$GROQBASHERRTMP"
  fi

  if ! stage_b64 "$dest_b64" < "$tmp_payload"; then
    _cleanup_local_tmp "$tmp_payload" "" "$json_input_file"
    return "$GROQBASHERRTMP"
  fi

  if [ ! -f "$dest_b64" ]; then
    _cleanup_local_tmp "$tmp_payload" "" "$json_input_file"
    log_error "PAYLOAD" "staged payload missing: $dest_b64"
    return "$GROQBASHERRTMP"
  fi
  chmod 600 "$dest_b64" 2>/dev/null || true

  PAYLOAD="$dest_b64"
  _cleanup_local_tmp "$tmp_payload" "" "$json_input_file"
  return 0
}

buildpayloadgroq() { buildpayload_groq "$@"; }

# ---------------------------------------------------------------------------
# call_api_groq (non-streaming) - with enforcement network policy
# ---------------------------------------------------------------------------
call_api_groq() {
  # Enforce network policy first (no HTTP if DRY_RUN or GROQBASH_SKIP_NETWORK)
  if ! enforce_network_policy; then
    # In dry-run mode we still want to show payload head for debugging
    if is_truthy "${DRY_RUN:-0}"; then
      show_payload_head "${PAYLOAD:-}" 200 || true
      log_info "DRYRUN" "DRY-RUN: skipping HTTP call"
      return 0
    fi
    log_error "NETWORK" "Network calls disabled; aborting HTTP request."
    return "$GROQBASHERRCURL_FAILED"
  fi

  if [ -z "${GROQ_API_KEY:-}" ]; then log_error "APIKEY" "GROQ_API_KEY is not set."; return "$GROQBASHERRNOAPIKEY"; fi
  if [ -z "${PAYLOAD:-}" ] || [ ! -s "${PAYLOAD:-}" ]; then log_error "PAYLOAD" "payload file missing or empty: ${PAYLOAD:-<unset>}"; return "$GROQBASHERRTMP"; fi

  ensure_run_tmpdir || return "$GROQBASHERRTMP"
  ERRF="${ERRF:-$RUN_TMPDIR/curl.err}"
  RESP="${RESP:-$RUN_TMPDIR/resp.json}"

  local workdir tmpout http_code _time_total api_url rc decoded_payload try_decoded send_payload
  workdir="${RUN_TMPDIR:-}"
  [ -n "$workdir" ] || return "$GROQBASHERRTMP"
  tmpout="$(_mktemp_in_dir "$workdir")" || return "$GROQBASHERRTMP"
  api_url="https://api.groq.com/openai/v1/chat/completions"

  decoded_payload="$workdir/payload.dec.$$"
  try_decoded=0

  # (decoding/validation logic unchanged — preserve original behavior)
  if printf '%s' "$PAYLOAD" | grep -qE '\.b64$'; then
    if b64decode < "$PAYLOAD" > "$decoded_payload" 2>"$ERRF"; then
      if jq -e . "$decoded_payload" >/dev/null 2>&1; then
        try_decoded=1
      else
        log_error "PAYLOAD" "decoded payload is not valid JSON; aborting HTTP call"
        printf 'groqbash: INFO: decoded payload (head 200 bytes):\n' >&2
        head -c 200 "$decoded_payload" >&2 || true
        printf '\ngroqbash: INFO: curl stderr (head):\n' >&2
        head -n 200 "$ERRF" >&2 || true
        rm -f "$decoded_payload" 2>/dev/null || true
        rm -f "$tmpout" 2>/dev/null || true
        return "$GROQBASHERRTMP"
      fi
    else
      log_error "B64DECODE" "base64 decode failed; see $ERRF"
      head -n 200 "$ERRF" >&2 || true
      rm -f "$decoded_payload" 2>/dev/null || true
      rm -f "$tmpout" 2>/dev/null || true
      return "$GROQBASHERRTMP"
    fi
  else
    if b64decode < "$PAYLOAD" > "$decoded_payload" 2>/dev/null; then
      if jq -e . "$decoded_payload" >/dev/null 2>&1; then
        try_decoded=1
      else
        rm -f "$decoded_payload" 2>/dev/null || true
        try_decoded=0
      fi
    else
      try_decoded=0
    fi
  fi

  if [ "$try_decoded" -eq 1 ]; then
    send_payload="$decoded_payload"
  else
    send_payload="$PAYLOAD"
  fi

  if [ ! -f "$send_payload" ] || [ ! -s "$send_payload" ]; then
    log_error "PAYLOAD" "payload file missing or empty: $send_payload"
    rm -f "$decoded_payload" 2>/dev/null || true
    rm -f "$tmpout" 2>/dev/null || true
    return "$GROQBASHERRTMP"
  fi

  if ! jq -e . "$send_payload" >/dev/null 2>&1; then
    log_error "PAYLOAD" "payload is not valid JSON and not decodable as base64; aborting HTTP call"
    printf 'groqbash: INFO: payload (head 200 bytes):\n' >&2
    head -c 200 "$send_payload" >&2 || true
    printf '\ngroqbash: INFO: curl stderr (head):\n' >&2
    head -n 200 "$ERRF" >&2 || true
    rm -f "$decoded_payload" 2>/dev/null || true
    rm -f "$tmpout" 2>/dev/null || true
    return "$GROQBASHERRTMP"
  fi

  local resp_tmp="${workdir%/}/resp.tmp.$$"
  rm -f "$resp_tmp" 2>/dev/null || true

  if ! curl "${CURL_BASE_OPTS[@]}" -H "Authorization: Bearer ${GROQ_API_KEY}" -H "Content-Type: application/json" --data-binary @"$send_payload" -o "$resp_tmp" -w '%{http_code} %{time_total}' "$api_url" 2>"$ERRF" >"$tmpout"; then
    rc=$?
  else
    rc=0
  fi

  if [ "$rc" -eq 0 ] && [ -s "$resp_tmp" ]; then
    if type atomic_write >/dev/null 2>&1; then
      cat "$resp_tmp" | atomic_write "$RESP" "$GROQBASH_LOCK_TIMEOUT_TMP" || cp -f "$resp_tmp" "$RESP" 2>/dev/null || true
    else
      mv -f "$resp_tmp" "$RESP" 2>/dev/null || cp -f "$resp_tmp" "$RESP" 2>/dev/null || true
    fi
    chmod 600 "$RESP" 2>/dev/null || true
  else
    rm -f "$resp_tmp" 2>/dev/null || true
  fi

  rm -f "$decoded_payload" 2>/dev/null || true

  read -r http_code _time_total < "$tmpout" 2>/dev/null || http_code="$(cat "$tmpout" 2>/dev/null || echo "000")"
  rm -f "$tmpout" 2>/dev/null || true

  case "$http_code" in
    2*) return 0 ;;
    *) log_error "HTTP" "HTTP error code: $http_code"; log_info "RESPHEAD" "Response (head):"; head -n 200 "$RESP" >&2 || true; log_info "CURLERR" "Curl stderr (head):"; head -n 200 "$ERRF" >&2 || true; return "$GROQBASHERRAPI" ;;
  esac
}

# ---------------------------------------------------------------------------
# call_api_streaming_groq (streaming) - with enforcement network policy
# ---------------------------------------------------------------------------
call_api_streaming_groq() {
  # Enforce network policy first
  if ! enforce_network_policy; then
    if is_truthy "${DRY_RUN:-0}"; then
      show_payload_head "${PAYLOAD:-}" 200 || true
      log_info "DRYRUN" "DRY-RUN: skipping streaming HTTP call"
      return 0
    fi
    log_error "NETWORK" "Network calls disabled; aborting streaming request."
    return "$GROQBASHERRCURL_FAILED"
  fi

  if [ -z "${GROQ_API_KEY:-}" ]; then log_error "APIKEY" "GROQ_API_KEY is not set."; return "$GROQBASHERRNOAPIKEY"; fi
  ensure_run_tmpdir || return "$GROQBASHERRTMP"
  ERRF="${ERRF:-$RUN_TMPDIR/curl.err}"
  RESP="${RESP:-$RUN_TMPDIR/resp.json}"
  RESP_RAW="$RUN_TMPDIR/resp.raw"
  : > "$RESP_RAW" 2>/dev/null || true
  chmod 600 "$RESP_RAW" 2>/dev/null || true

  local api_url rc decoded_payload
  api_url="https://api.groq.com/openai/v1/chat/completions"

  decoded_payload="$RUN_TMPDIR/payload.dec.$$"
  if printf '%s' "$PAYLOAD" | grep -qE '\.b64$'; then
    if ! b64decode < "$PAYLOAD" > "$decoded_payload" 2>"$ERRF"; then
      log_error "B64DECODE" "base64 decode failed for payload; see $ERRF"
      rm -f "$decoded_payload" 2>/dev/null || true
      return "$GROQBASHERRTMP"
    fi
  else
    cp -f "$PAYLOAD" "$decoded_payload" 2>/dev/null || true
  fi

  if ! jq -e . "$decoded_payload" >/dev/null 2>&1; then
    log_error "PAYLOAD" "decoded payload is not valid JSON; aborting streaming call"
    printf 'groqbash: INFO: decoded payload (head 200 bytes):\n' >&2
    head -c 200 "$decoded_payload" >&2 || true
    rm -f "$decoded_payload" 2>/dev/null || true
    return "$GROQBASHERRTMP"
  fi

  local CURL_CMD
  if command -v stdbuf >/dev/null 2>&1; then
    CURL_CMD=(stdbuf -oL curl --http1.1 "${CURL_BASE_OPTS[@]}")
  else
    CURL_CMD=(curl --http1.1 "${CURL_BASE_OPTS[@]}")
  fi

  log_info "STREAM" "Streaming active; chunks will be saved under $RUN_TMPDIR"

  "${CURL_CMD[@]}" -H "Authorization: Bearer ${GROQ_API_KEY}" -H "Content-Type: application/json" --data-binary @"$decoded_payload" "$api_url" 2>"$ERRF" | tee -a "$RESP_RAW" | \
  while IFS= read -r line; do
    case "$line" in
      'data: [DONE]'|'data:[DONE]') break ;;
      data:\ * )
        json="${line#data: }"
        content="$(printf '%s' "$json" | jq -r 'try (fromjson | (.choices[]?.delta?.content // .choices[]?.message?.content // "")) catch ""' 2>>"$ERRF" || true)"
        if [ -n "$content" ]; then
          printf '%s' "$content"
        fi
        ;;
      *) ;;
    esac
  done

  rc=${PIPESTATUS[0]:-0}
  rm -f "$decoded_payload" 2>/dev/null || true
  if [ "$rc" -ne 0 ]; then
    log_error "CURLSTREAM" "curl streaming failed (rc $rc)"; head -n 50 "$ERRF" >&2 || true
    return "$GROQBASHERRCURL_FAILED"
  fi

  log_info "STREAM" "Streaming completed; building outputs in $RUN_TMPDIR (final JSON: $RESP)"

  : > "$RUN_TMPDIR/resp.lines" 2>/dev/null || true
  grep -E '^data:' "$RESP_RAW" 2>/dev/null | sed -E 's/^data:[[:space:]]*//' > "$RUN_TMPDIR/resp.lines" 2>/dev/null || true

  : > "$RUN_TMPDIR/resp.valid.jsons" 2>/dev/null || true
  while IFS= read -r _line; do
    if printf '%s' "$_line" | jq -e . >/dev/null 2>&1; then
      printf '%s\n' "$_line" >> "$RUN_TMPDIR/resp.valid.jsons"
    fi
  done < "$RUN_TMPDIR/resp.lines"

  if [ -s "$RUN_TMPDIR/resp.valid.jsons" ]; then
    jq -s '.' "$RUN_TMPDIR/resp.valid.jsons" > "$RUN_TMPDIR/resp.chunks.json" 2>/dev/null || true
    jq -r 'map(.choices[]?.delta?.content // .choices[]?.message?.content // "") | join("")' "$RUN_TMPDIR/resp.chunks.json" > "$RUN_TMPDIR/resp.text.txt" 2>/dev/null || true
    if type atomic_write >/dev/null 2>&1; then
      cat "$RUN_TMPDIR/resp.chunks.json" | atomic_write "$RESP" "$GROQBASH_LOCK_TIMEOUT_TMP" || cp -f "$RUN_TMPDIR/resp.chunks.json" "$RESP" 2>/dev/null || true
    else
      cp -f "$RUN_TMPDIR/resp.chunks.json" "$RESP" 2>/dev/null || true
    fi

    # Remove intermediate files only when RUN_TMPDIR is under GROQBASH_TMPDIR
    case "$RUN_TMPDIR" in
      "$GROQBASH_TMPDIR"/*|"$GROQBASH_TMPDIR")
        rm -f "$RUN_TMPDIR/resp.lines" "$RUN_TMPDIR/resp.valid.jsons" 2>/dev/null || true
        log_info "STREAM" "Removed intermediate files resp.lines and resp.valid.jsons from $RUN_TMPDIR"
        ;;
      *)
        log_info "STREAM" "Preserving intermediate streaming files in $RUN_TMPDIR (outside GROQBASH_TMPDIR)"
        ;;
    esac
  else
    if jq -e . "$RESP_RAW" >/dev/null 2>&1; then
      cp -f "$RESP_RAW" "$RESP" 2>/dev/null || true
    fi
  fi

  return 0
}

call_api_streaming_groq_legacy() { call_api_streaming_groq "$@"; }

# ---------------------------------------------------------------------------
# refresh_models_groq
# - Fetches /openai/v1/models and writes a newline-separated list to MODELS_FILE
# - Uses jq when possible; if response is not valid JSON, attempts a heuristic parse.
# - Writes via b64_atomic_write + lock_exec to ensure atomic update.
# ---------------------------------------------------------------------------
refresh_models_groq() {
  # Fetch Groq models and write normalized model names to MODELS_FILE.
  # Prefer .data[].name then .data[].id then top-level array .[].name/.id.
  if [ -n "${PROVIDER_API_ENV_groq:-}" ] && [ -n "${!PROVIDER_API_ENV_groq:-}" ]; then
    GROQ_API_KEY="${!PROVIDER_API_ENV_groq}"
  fi
  if [ -z "${GROQ_API_KEY:-}" ]; then
    log_error "APIKEY" "GROQ_API_KEY is required to refresh models."
    return "$GROQBASHERRNOAPIKEY"
  fi

  ensure_run_tmpdir || return "$GROQBASHERRTMP"
  local workdir tmpd out errf api_url tmp_parsed tmp_trim tmpout rc
  workdir="${RUN_TMPDIR:-}"
  [ -n "$workdir" ] || return "$GROQBASHERRTMP"
  tmpd="$(mktemp -d -p "$workdir" groq-models.XXXX)" || return "$GROQBASHERRTMP"
  out="$tmpd/models.json"
  errf="$tmpd/curl.err"
  api_url="https://api.groq.com/openai/v1/models"

  rm -f "$out" "$errf" 2>/dev/null || true
  if ! curl "${CURL_BASE_OPTS[@]}" -H "Authorization: Bearer ${GROQ_API_KEY}" -H "Content-Type: application/json" "${api_url}?limit=${MAX_MODELS}" -o "$out" 2>"$errf"; then
    log_error "MODELREFRESH" "Failed to fetch models from $api_url"
    head -n 200 "$errf" >&2 || true
    rm -rf "$tmpd"
    return "$GROQBASHERRAPI"
  fi

  if ! jq -e . "$out" >/dev/null 2>&1; then
    log_error "MODELREFRESH" "Invalid JSON received from $api_url"
    head -n 200 "$errf" >&2 || true
    rm -rf "$tmpd"
    return "$GROQBASHERRAPI"
  fi

  tmp_parsed="$tmpd/parsed_models.txt"
  : > "$tmp_parsed"

  # Extract candidate names: prefer .data[].name, then .data[].id, then top-level array .[].name/.id
  jq -r '
    if (has("data") and (.data|type) == "array") then
      .data[]? | (.name // .id // empty)
    elif (type == "array") then
      .[]? | (.name // .id // empty)
    else
      empty
    end
  ' "$out" | awk 'NF{print}' | sed -E 's/^[[:space:]]+//;s/[[:space:]]+$//' | sort -u > "$tmp_parsed" 2>/dev/null || true

  if [ ! -s "$tmp_parsed" ]; then
    log_error "MODELREFRESH" "models refresh: parsed list empty"
    head -n 200 "$errf" >&2 || true
    rm -rf "$tmpd"
    return "$GROQBASHERRAPI"
  fi

  # Normalize entries: strip common prefixes like "models/" and "groq:"; validate allowed chars
  tmp_trim="$tmpd/parsed_trimmed.txt"
  awk '{
    g=$0
    sub(/^models\//,"",g)
    sub(/^groq[:\/-]*/,"",g)
    # keep only plausible model names (alnum and common separators)
    if (g ~ /^[[:alnum:]._\/:-]+$/) print g
  }' "$tmp_parsed" | awk -v M="$MAX_MODELS" 'NR<=M{print}' > "$tmp_trim" || true

  if [ ! -s "$tmp_trim" ]; then
    log_error "MODELREFRESH" "no valid model names after normalization"
    rm -rf "$tmpd"
    return "$GROQBASHERRAPI"
  fi

  # Ensure destination dir exists and write atomically via base64 staging
  mkdir -p "$(dirname "$MODELS_FILE")" 2>/dev/null || true
  tmpout="$(_mktemp_in_dir "$(dirname "$MODELS_FILE")" 2>/dev/null || true)"
  [ -n "$tmpout" ] || tmpout="$MODELS_FILE.tmp"
  cat "$tmp_trim" > "$tmpout"

  if ! b64_atomic_write "${MODELS_FILE}.b64" 10 < "$tmpout"; then
    log_error "MODELREFRESH" "failed to stage models file"
    rm -f "$tmpout" 2>/dev/null || true
    rm -rf "$tmpd"
    return "$GROQBASHERRTMP"
  fi

  lockfile="$MODELS_LOCK"
  lock_exec "$lockfile" 10 -- sh -c '
    set -e
    manifest_b64="$1"
    dest="$2"
    base64 ${B64_DECODE_OPT} < "$manifest_b64" > "$dest"
    chmod 600 "$dest" 2>/dev/null || true
  ' _ "${MODELS_FILE}.b64" "$MODELS_FILE" || { log_error "MODELREFRESH" "failed to write models file under lock"; rm -rf "$tmpd"; return "$GROQBASHERRTMP"; }

  chmod 600 "$MODELS_FILE" 2>/dev/null || true
  log_info "MODELREFRESH" "Models refreshed and saved to: $MODELS_FILE (max ${MAX_MODELS})"

  rm -rf "$tmpd"
  return 0
}

refreshmodelsgroq() { refresh_models_groq "$@"; }

# ---------------------------------------------------------------------------
# validate_model_groq
# - If MODELS_FILE exists and is non-empty, require the model to be present.
# - If MODELS_FILE does not exist or is empty, allow (backwards compatible).
# ---------------------------------------------------------------------------
validate_model_groq() {
  # Provider-specific validation for Groq models.
  # Accepts either exact matches as stored in MODELS_FILE or normalized names
  # (stripping common prefixes like "models/" or "groq:"), and enforces textual support.
  local model="$1" norm_model file_match
  [ -n "$model" ] || { printf 'groqbash: ERROR: validate_model_groq: model required\n' >&2; return 1; }

  # Normalize incoming model for comparison: strip leading "models/" and "groq:" and trim
  norm_model="$(printf '%s' "$model" | sed -e 's#^models/##' -e 's#^groq[:/ -]*##' -e 's/^[[:space:]]*//;s/[[:space:]]*$//')"

  # If MODELS_FILE exists and non-empty, require presence (allow either raw or normalized forms)
  if [ -f "${MODELS_FILE:-}" ] && [ -s "${MODELS_FILE:-}" ]; then
    # Exact match first (file may contain provider-specific forms)
    if grep -x -F -q "$model" "$MODELS_FILE" 2>/dev/null; then
      file_match=1
    else
      # Compare against normalized entries (strip common prefixes in file)
      if awk '{g=$0; sub(/^models\//,"",g); sub(/^groq[:\/ -]*/,"",g); print g}' "$MODELS_FILE" | grep -x -F -q "$norm_model" 2>/dev/null; then
        file_match=1
      else
        file_match=0
      fi
    fi

    if [ "$file_match" -ne 1 ]; then
      printf 'groqbash: ERROR: The model "%s" is not present in %s\n' "$model" "$MODELS_FILE" >&2
      return 1
    fi
  fi

  # Ensure the (normalized) model is text-capable
  if ! is_supported_model "$norm_model"; then
    printf 'groqbash: ERROR: The "%s" model is not supported by GroqBash (requires non-text input).\n' "$model" >&2
    return 1
  fi

  return 0
}

validatemodelgroq() { validate_model_groq "$@"; }

# ---------------------------------------------------------------------------
# auto_select_model_groq
# ---------------------------------------------------------------------------
auto_select_model_groq() {
  # Return the first supported model candidate from MODELS_FILE for Groq provider.
  # Normalizes entries by stripping common prefixes like "models/" and "groq:".
  # Prints the selected model (normalized) to stdout and returns 0 on success,
  # returns 1 if no suitable model found.
  local file="$MODELS_FILE" line norm cnt=0
  if [ -f "$file" ] && [ -s "$file" ]; then
    while IFS= read -r line || [ -n "$line" ]; do
      [ -z "$line" ] && continue
      cnt=$((cnt+1))
      norm="$(printf '%s' "$line" | sed -e 's#^models/##' -e 's#^groq[:/ -]*##' -e 's/^[[:space:]]*//;s/[[:space:]]*$//')"
      if is_supported_model "$norm"; then
        printf '%s' "$norm"
        return 0
      fi
      [ "$cnt" -ge "$MAX_MODELS" ] && break
    done < "$file"
  fi
  return 1
}

autoselectmodelgroq() { auto_select_model_groq "$@"; }
########################################
# SECTION: PROVIDER - END
########################################
########################################
# SECTION: CORE - BEGIN
########################################
# ---------------------------------------------------------------------------
# Core helpers and CLI wiring (public interfaces preserved)
# ---------------------------------------------------------------------------

# Dispatch helper: call provider-specific function by name if available
call_provider() {
  local fn="$1" shift_args=("${@:2}")
  if type "$fn" >/dev/null 2>&1; then
    "$fn" "${shift_args[@]}"
    return $?
  fi
  return 127
}

# Provider dispatch wrappers (call provider-specific implementations if present)
refresh_models_dispatch() {
  local destfile="${1:-${MODELS_FILE:-$GROQBASH_MODELS_DIR/models.txt}}"
  local fn="refresh_models_${PROVIDER}"
  local rc=0

  if ! type "$fn" >/dev/null 2>&1; then
    log_error "MODELREFRESH" "Provider '$PROVIDER' does not implement $fn()."
    return 127
  fi

  # Try provider-specific refresh; prefer passing destfile but tolerate providers that ignore args
  if "$fn" "$destfile" 2>/dev/null; then
    log_info "MODELREFRESH" "Models refreshed for provider $PROVIDER -> $destfile"
    return 0
  fi

  rc=$?
  if "$fn" 2>/dev/null; then
    log_info "MODELREFRESH" "Models refreshed for provider $PROVIDER (no explicit dest)"
    return 0
  fi

  rc=$?
  log_error "MODELREFRESH" "refresh_models for provider $PROVIDER failed (rc $rc)."
  return "$rc"
}

validate_model_dispatch() {
  local model="$1"
  local fn="validate_model_${PROVIDER}"
  if type "$fn" >/dev/null 2>&1; then
    "$fn" "$model"
    return $?
  fi
  # Default permissive behavior if provider does not implement validation
  return 0
}

auto_select_model_dispatch() {
  local fn="auto_select_model_${PROVIDER}"
  if call_provider "$fn"; then
    return 0
  fi
  return 1
}

# resolve_model: determina MODEL finale seguendo ordine di priorità e validando
# Risultato: imposta la variabile globale FINAL_MODEL (stringa) o vuota se non risolta.
resolve_model() {
  FINAL_MODEL=""

  # 1) CLI-specified model (highest priority)
  if [ "${MODEL_CLI_SET:-0}" -eq 1 ] && [ -n "${MODEL:-}" ]; then
    FINAL_MODEL="$MODEL"
    return 0
  fi

  # Determine active provider robustly for provider-specific default lookup:
  # Precedence: PROVIDER_CLI -> persisted provider file under canonical config dir -> $PROVIDER -> fallback groq
  if [ -n "${PROVIDER_CLI:-}" ]; then
    active_provider="${PROVIDER_CLI}"
  elif [ -f "$(canonical_provider_file)" ] && [ -s "$(canonical_provider_file)" ]; then
    active_provider="$(sed -n '1p' "$(canonical_provider_file)" 2>/dev/null || true)"
    active_provider="$(printf '%s' "$active_provider" | awk '{$1=$1;print}')"
    [ -z "$active_provider" ] && active_provider="${PROVIDER:-groq}"
  else
    active_provider="${PROVIDER:-groq}"
  fi

  # 2) provider-specific persisted default (model.<active_provider>)
  # Determine active provider robustly: precedence PROVIDER_CLI -> persisted provider file -> $PROVIDER -> fallback groq
  if [ -n "${PROVIDER_CLI:-}" ]; then
    active_provider="${PROVIDER_CLI}"
  elif [ -f "$(canonical_provider_file)" ] && [ -s "$(canonical_provider_file)" ]; then
    active_provider="$(sed -n '1p' "$(canonical_provider_file)" 2>/dev/null || true)"
    active_provider="$(printf '%s' "$active_provider" | awk '{$1=$1;print}')"
    [ -z "$active_provider" ] && active_provider="${PROVIDER:-groq}"
  else
    active_provider="${PROVIDER:-groq}"
  fi

  MODEL_PROVIDER_CFG="$(canonical_model_file "${active_provider}")"
  # Defensive check: refuse to read model files if canonical config dir is invalid
  if [ -z "$(canonical_config_dir)" ] || [ "$(canonical_config_dir)" = "/" ]; then
    log_error "SEC" "refusing to read provider-specific model file: invalid canonical config dir: $(canonical_config_dir)"
  else
    if [ -s "$MODEL_PROVIDER_CFG" ]; then
      candidate="$(sed -n '1p' "$MODEL_PROVIDER_CFG" 2>/dev/null || true)"
      candidate="$(printf '%s' "$candidate" | awk '{$1=$1;print}')"
      if [ -n "$candidate" ] && is_supported_model "$candidate"; then
        if validate_model_core "$candidate" >/dev/null 2>&1 && validate_model_dispatch "$candidate" >/dev/null 2>&1; then
          FINAL_MODEL="$candidate"
          return 0
        fi
      fi
    fi
  fi

  # 3) provider auto-select (only if provider module can provide it)
  candidate="$(auto_select_model_dispatch 2>/dev/null || true)"
  if [ -n "$candidate" ] && is_supported_model "$candidate"; then
    if validate_model_dispatch "$candidate" >/dev/null 2>&1 && validate_model_core "$candidate" >/dev/null 2>&1; then
      FINAL_MODEL="$candidate"
      return 0
    fi
  fi

  # 4) first supported entry in MODELS_FILE (if present)
  if [ -f "${MODELS_FILE:-}" ] && [ -s "${MODELS_FILE:-}" ]; then
    cnt=0
    while IFS= read -r m || [ -n "$m" ]; do
      [ -z "$m" ] && continue
      cnt=$((cnt+1))
      if is_supported_model "$m"; then
        if validate_model_core "$m" >/dev/null 2>&1 && validate_model_dispatch "$m" >/dev/null 2>&1; then
          FINAL_MODEL="$m"
          return 0
        fi
      fi
      [ "$cnt" -ge "$MAX_MODELS" ] && break
    done < "$MODELS_FILE"
  fi

  # 5) config MODEL= in config file (legacy)
  if [ -f "${GROQBASH_CONFIG_DIR%/}/config" ]; then
    cfg_model="$(awk -F= '/^MODEL=/ {sub(/^MODEL=/,""); print; exit}' "${GROQBASH_CONFIG_DIR%/}/config" 2>/dev/null || true)"
    cfg_model="$(printf '%s' "$cfg_model" | awk '{$1=$1;print}')"
    if [ -n "$cfg_model" ] && is_supported_model "$cfg_model"; then
      if validate_model_core "$cfg_model" >/dev/null 2>&1 && validate_model_dispatch "$cfg_model" >/dev/null 2>&1; then
        FINAL_MODEL="$cfg_model"
        return 0
      fi
    fi
  fi

  # 6) ALLOWED_MODELS fallback (first supported)
  if [ -n "${ALLOWED_MODELS:-}" ]; then
    cnt=0
    while IFS= read -r m || [ -n "$m" ]; do
      [ -z "$m" ] && continue
      cnt=$((cnt+1))
      if is_supported_model "$m"; then
        if validate_model_core "$m" >/dev/null 2>&1 && validate_model_dispatch "$m" >/dev/null 2>&1; then
          FINAL_MODEL="$m"
          return 0
        fi
      fi
      [ "$cnt" -ge "$MAX_MODELS" ] && break
    done <<EOF
$(printf '%s\n' "$ALLOWED_MODELS")
EOF
  fi

  # Nothing found
  FINAL_MODEL=""
  return 1
}

# ---------------------------------------------------------------------------
# Build payload from current vars (delegates to provider)
# ---------------------------------------------------------------------------
build_payload_from_vars() {
  ensure_run_tmpdir
  local fn="buildpayload_${PROVIDER}"
  if call_provider "$fn"; then
    return 0
  else
    rc=$?
    if [ "$rc" -eq 127 ]; then
      log_error "PROVIDER" "Provider '$PROVIDER' does not provide $fn()."
      exit "$GROQBASHERRAPI"
    else
      return "$rc"
    fi
  fi
}

# ---------------------------------------------------------------------------
# API call wrappers (non-streaming and streaming)
# ---------------------------------------------------------------------------
call_api_once() {
  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    show_payload_head "$PAYLOAD" 200 || true
    log_info "DRYRUN" "DRY-RUN: skipping provider HTTP call"
    return 0
  fi
  local fn="call_api_${PROVIDER}"
  if call_provider "$fn"; then
    return 0
  else
    rc=$?
    if [ "$rc" -eq 127 ]; then
      log_error "PROVIDER" "Provider '$PROVIDER' does not provide $fn()."
      exit "$GROQBASHERRAPI"
    else
      return "$rc"
    fi
  fi
}

call_api_streaming() {
  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    show_payload_head "$PAYLOAD" 200 || true
    log_info "DRYRUN" "DRY-RUN: skipping provider streaming HTTP call"
    return 0
  fi
  local fn="call_api_streaming_${PROVIDER}"
  if call_provider "$fn"; then
    return 0
  else
    rc=$?
    if [ "$rc" -eq 127 ]; then
      log_error "PROVIDER" "Provider '$PROVIDER' does not provide $fn()."
      exit "$GROQBASHERRAPI"
    else
      return "$rc"
    fi
  fi
}

# ---------------------------------------------------------------------------
# Response extraction helpers (improved)
# ---------------------------------------------------------------------------
extract_text_from_resp() {
  [ ! -s "${RESP:-}" ] && return 0

  # estrazione normale (message.content o delta.content)
  local out
  out="$(
    jq -r '
      [ .choices[]? | (.message?.content // .delta?.content // "") | select(length > 0) ]
      | join("\n")
    ' "$RESP" 2>/dev/null | sed 's/\\"/"/g' || true
  )"

  if [ -z "$out" ]; then
    # fallback: se JSON, prova a estrarre il primo frammento non vuoto; altrimenti cat
    if jq -e . "$RESP" >/dev/null 2>&1; then
      jq -r '
        ( [ .choices[]? | (.message?.content // .delta?.content // "") ] | map(select(length > 0)) )[0] // empty
      ' "$RESP" 2>/dev/null | sed 's/\\"/"/g' || true
    else
      cat "$RESP" 2>/dev/null || true
    fi
    return 0
  fi

  printf '%s\n' "$out"
  return 0
}

extract_api_error() {
  [ ! -s "${RESP:-}" ] && return 0

  if jq -e . "$RESP" >/dev/null 2>&1; then
    # Prefer explicit error.message, then any non-empty choice content (first), else empty.
    jq -r '
      ( [ .error?.message // empty ] 
        + [ .choices[]? | (.message?.content // .delta?.content // empty) ] )
      | map(select(length > 0))
      | .[0] // empty
    ' "$RESP" 2>/dev/null | head -n1 || true
  else
    awk 'NF{print; exit}' "$RESP" 2>/dev/null || true
  fi
}

# detect_empty_edge_case: rileva l'edge case "completion vuota"
# NON stampa nulla. Se rilevato, imposta variabili globali diagnostiche:
#   GROQBASH_EDGE_EMPTY=1
#   GROQBASH_EDGE_REQ_ID, GROQBASH_EDGE_FINISH_REASON, GROQBASH_EDGE_COMPLETION_TOKENS
# Ritorna 0 se edge case rilevato, 1 altrimenti.
detect_empty_edge_case() {
  local resp="${RESP:-}"

  # reset diagnostica
  GROQBASH_EDGE_EMPTY=0
  GROQBASH_EDGE_REQ_ID=""
  GROQBASH_EDGE_FINISH_REASON=""
  GROQBASH_EDGE_COMPLETION_TOKENS=0

  [ ! -s "$resp" ] && return 1

  local content finish_reason completion_tokens req_id
  content="$(jq -r '.choices[0]?.message?.content // .choices[0]?.delta?.content // ""' "$resp" 2>/dev/null || echo "")"
  finish_reason="$(jq -r '.choices[0]?.finish_reason // ""' "$resp" 2>/dev/null || echo "")"
  completion_tokens="$(jq -r '.usage?.completion_tokens // 0' "$resp" 2>/dev/null || echo 0)"
  req_id="$(jq -r '.x_groq?.id // .id // empty' "$resp" 2>/dev/null || echo "")"

  if [ -z "$content" ] && [ "$finish_reason" = "stop" ] && [ "$completion_tokens" -eq 1 ]; then
    GROQBASH_EDGE_EMPTY=1
    GROQBASH_EDGE_REQ_ID="${req_id:-<none>}"
    GROQBASH_EDGE_FINISH_REASON="$finish_reason"
    GROQBASH_EDGE_COMPLETION_TOKENS="$completion_tokens"
    return 0
  fi

  return 1
}

# ---------------------------------------------------------------------------
# Finalize and output (fixed tmp usage and save logic)
# ---------------------------------------------------------------------------
finalize_and_output() {
  local mode="$1" text="$2"
  if { [ "$mode" = "json" ] || [ "$mode" = "pretty" ]; } && [ ! -s "${RESP:-}" ]; then
    log_error "RESP" "response file missing or empty: ${RESP:-<unset>}"
    return "$GROQBASHERRTMP"
  fi

  case "$mode" in
    json) cat "$RESP" ;;
    pretty) if jq -e . "$RESP" >/dev/null 2>&1; then jq . "$RESP"; else cat "$RESP"; fi ;;
    raw) printf '%s' "$text" ;;
    text) printf '%s\n' "$text" ;;
    *) printf '%s\n' "$text" ;;
  esac

  if [ "$mode" = "text" ] || [ "$mode" = "raw" ]; then
    [ "${FORCE_SAVE_MODE:-}" = "nosave" ] && return 0
    local len do_save=0 dest_dir dest_path
    len="$(printf '%s' "$text" | wc -c | tr -d ' ')"
    if [ "${FORCE_SAVE_MODE:-}" = "save" ]; then
      do_save=1
    else
      if [ "$len" -gt "$THRESHOLD" ]; then
        do_save=1
      fi
    fi
    if [ "$do_save" -eq 1 ]; then
      if [ -n "$OUT_PATH" ]; then
        if [ -d "$OUT_PATH" ]; then dest_dir="$OUT_PATH"; dest_path="$dest_dir/$(date +%Y%m%d-%H%M%S)-groq-output-$$.txt"; else dest_path="$OUT_PATH"; dest_dir="$(dirname "$dest_path")"; fi
      else dest_dir="$GROQBASH_HISTORY_DIR"; dest_path="$dest_dir/$(date +%Y%m%d-%H%M%S)-groq-output-$$.txt"; fi
      mkdir -p "$dest_dir" 2>/dev/null || true

      if [ -z "${RUN_TMPDIR:-}" ] || [ ! -d "$RUN_TMPDIR" ]; then
        log_error "TMPFAIL" "RUN_TMPDIR not available for saving output."
        return "$GROQBASHERRTMP"
      fi

      # Save via save_to_history which handles atomic tmp creation and rotation
      save_to_history "$text" || log_warn "HISTORY" "Failed to save output to history."
    fi
  fi
}

# ---------------------------------------------------------------------------
# Perform request with retries
# ---------------------------------------------------------------------------
perform_request_once() {
  local attempt=1 rc
  while [ "$attempt" -le "$MAX_RETRIES" ]; do
    if call_api_once; then
      if [ "${DRY_RUN:-0}" -eq 1 ]; then
        log_info "DRYRUN" "DRY-RUN: request simulated successfully. Payload: $PAYLOAD"
        return 0
      fi

      # reset diagnostica all'inizio della gestione della risposta
      GROQBASH_EDGE_EMPTY=0
      GROQBASH_EDGE_REQ_ID=""
      GROQBASH_EDGE_FINISH_REASON=""
      GROQBASH_EDGE_COMPLETION_TOKENS=0

      local text api_err
      text="$(extract_text_from_resp || true)"

      # Esegui il rilevamento dell'edge case qui, sempre, subito dopo l'estrazione
      detect_empty_edge_case || true

      if [ -z "$text" ] && [ "$OUTPUT_MODE" != "json" ] && [ "$OUTPUT_MODE" != "pretty" ]; then
        api_err="$(extract_api_error || true)"
        if [ -n "$api_err" ]; then
          log_error "API" "API error: $api_err"
          return "$GROQBASHERRAPI"
        else
          # Se l'edge case è stato rilevato, emetti il log strutturato una sola volta
          if [ "${GROQBASH_EDGE_EMPTY:-0}" -eq 1 ]; then
            printf '%s\n' \
              "API edge case detected: empty completion" \
              "  req_id: ${GROQBASH_EDGE_REQ_ID:-<none>}" \
              "  finish_reason: ${GROQBASH_EDGE_FINISH_REASON:-<none>}" \
              "  completion_tokens: ${GROQBASH_EDGE_COMPLETION_TOKENS:-0}" >&2

            log_error "API" "empty completion returned by provider (see previous diagnostic lines)."
            return "$GROQBASHERRAPI"
          fi

          # fallback generico: nessun testo e nessun errore esplicito
          log_error "API" "no textual content extracted from response."
          head -n 50 "${RESP:-/dev/null}" >&2 || true
          return "$GROQBASHERRAPI"
        fi
      fi

      finalize_and_output "$OUTPUT_MODE" "$text"
      return 0
    else
      rc=$?
      if [ "$rc" -eq "$GROQBASHERRCURL_FAILED" ]; then
        printf 'groqbash: WARN: Network error (curl). Retrying...\n' >&2
      elif [ "$rc" -eq "$GROQBASHERRAPI" ]; then
        printf 'groqbash: ERROR: HTTP/API error. Not retrying.\n' >&2
        head -n 50 "${RESP:-/dev/null}" >&2 || true
        return "$GROQBASHERRAPI"
      else
        printf 'groqbash: WARN: Unknown error (code %s). Retrying...\n' "$rc" >&2
      fi
    fi

    attempt=$((attempt + 1)); sleep $((attempt * 1))
  done

  log_error "REQUEST" "request failed after $MAX_RETRIES attempts."
  return "$GROQBASHERRAPI"
}

# ---------------------------------------------------------------------------
# Input helpers
# ---------------------------------------------------------------------------
collect_input_from_files() {
  local out="" first=1 f
  for f in "$@"; do
    if file_readable "$f"; then
      [ "$first" -eq 0 ] && out="${out}"$'\n\n'"--- FILE: ${f} ---"$'\n\n'
      out="${out}$(cat "$f")"; first=0
    else log_error "FILE" "file not readable: $f"; exit "$GROQBASHERRTMP"; fi
  done
  printf '%s' "$out"
}
expand_args_to_content() {
  local out="" first=1 a
  for a in "${ARGS[@]}"; do
    if file_readable "$a"; then
      [ "$first" -eq 0 ] && out="${out}"$'\n\n'"--- FILE: ${a} ---"$'\n\n'
      out="${out}$(cat "$a")"; first=0
    else
      [ "$first" -eq 0 ] && out="${out}"$'\n\n'
      out="${out}${a}"; first=0
    fi
  done
  printf '%s' "$out"
}
file_readable() { [ -r "$1" ] && [ -f "$1" ]; }
trim() { printf '%s' "$1" | awk '{$1=$1; print}'; }
is_number() { printf '%s\n' "$1" | awk 'BEGIN{exit 0} {exit !( $0+0 == $0+0 )}'; }

is_supported_model() {
  # Return 0 if model name appears to support text-only usage.
  # Reject models that clearly indicate image/audio/embedding/multimodal capabilities.
  local m="${1:-}" l
  [ -n "$m" ] || return 1
  l="$(printf '%s' "$m" | tr '[:upper:]' '[:lower:]')"

  # Patterns that indicate non-text capabilities
  case "$l" in
    *image*|*imagen*|*img*|*vision*|*vqa*|*vit*|*clip*|*render*|*generate-image*|*generate_image* ) return 1 ;;
    *audio*|*speech*|*tts*|*wav2vec*|*whisper*|*native-audio* ) return 1 ;;
    *embed*|*embedding*|*vector* ) return 1 ;;
    *multimodal*|*vision_audio*|*vision-audio* ) return 1 ;;
    *) return 0 ;;
  esac
}

list_models_cli() {
  # Print MODELS_FILE entries in a provider-agnostic way.
  # Normalize entries (strip leading "models/") and mark non-text models.
  if [ ! -s "${MODELS_FILE:-}" ]; then
    printf 'No models available locally. Consider --refresh-models.\n' >&2
    return 1
  fi

  local count=0 model norm
  while IFS= read -r model || [ -n "$model" ]; do
    [ -z "$model" ] && continue
    count=$((count+1))
    norm="$(printf '%s' "$model" | sed -e 's/^models\///' -e 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    if is_supported_model "$norm"; then
      printf '%s\n' "$norm"
    else
      printf '%s\t[NOT SUPPORTED: Requires non-text input]\n' "$norm"
    fi
    if [ "$count" -ge "$MAX_MODELS" ]; then break; fi
  done < "$MODELS_FILE"
  return 0
}

validate_model_core() {
  # Validate a model name against local MODELS_FILE (if present) and textual support.
  # Accepts exact matches or matches after stripping common provider prefixes like "models/".
  local model="$1" norm_model file_match
  [ -n "$model" ] || { printf 'groqbash: ERROR: validate_model_core: model required\n' >&2; return 1; }

  # Normalize incoming model for comparison: strip leading "models/" and surrounding whitespace
  norm_model="$(printf '%s' "$model" | sed -e 's#^models/##' -e 's/^[[:space:]]*//;s/[[:space:]]*$//')"

  # If MODELS_FILE exists and non-empty, require presence (allow either raw or prefixed forms)
  if [ -f "${MODELS_FILE:-}" ] && [ -s "${MODELS_FILE:-}" ]; then
    # Check exact match first (file may contain provider-specific forms)
    if grep -x -F -q "$model" "$MODELS_FILE" 2>/dev/null; then
      file_match=1
    else
      # Check normalized match (strip leading models/ in file entries and compare)
      if awk '{gsub(/^models\//,""); print}' "$MODELS_FILE" | grep -x -F -q "$norm_model" 2>/dev/null; then
        file_match=1
      else
        file_match=0
      fi
    fi

    if [ "$file_match" -ne 1 ]; then
      printf 'groqbash: ERROR: The model "%s" is not present in %s\n' "$model" "$MODELS_FILE" >&2
      return 1
    fi
  fi

  # Check textual support (reject obvious multimodal/audio/image models by name patterns)
  if ! is_supported_model "$norm_model"; then
    printf 'groqbash: ERROR: The "%s" model is not supported by GroqBash (requires non-text input).\n' "$model" >&2
    return 1
  fi

  return 0
}

# ---------------------------------------------------------------------------
# CLI parsing (flags, normalization, immediate actions)
# ---------------------------------------------------------------------------
JSON_INPUT="${JSON_INPUT:-}" TEMPLATE="${TEMPLATE:-}" BATCH_FILE="${BATCH_FILE:-}" CHAT_MODE="${CHAT_MODE:-0}" SET_DEFAULT_MODEL="${SET_DEFAULT_MODEL:-}"
LIST_MODELS="${LIST_MODELS:-0}" LIST_PROVIDERS="${LIST_PROVIDERS:-0}" FORCE_SAVE_MODE="${FORCE_SAVE_MODE:-}" OUT_PATH="${OUT_PATH:-}"
DRY_RUN="${DRY_RUN:-0}" STREAM_MODE="${STREAM_MODE:-0}" QUIET="${QUIET:-0}" INSTALL_EXTRAS="${INSTALL_EXTRAS:-0}" DEBUG="${DEBUG:-0}"
PROVIDER_CLI="${PROVIDER_CLI:-}" PROVIDER_INTERACTIVE="${PROVIDER_INTERACTIVE:-0}"
SHOW_CONFIG="${SHOW_CONFIG:-0}" DIAGNOSTICS="${DIAGNOSTICS:-0}"
FILE_INPUTS=() ARGS=() OUTPUT_MODE="${OUTPUT_MODE:-text}"
MODEL_CLI_SET="${MODEL_CLI_SET:-0}"
INSTALL_EXTRAS_SRC=""

while [ $# -gt 0 ]; do
  case "$1" in
    --refresh-models|--refresh-model) REFRESH_MODELS=1; shift ;;
    --list-models) LIST_MODELS=1; shift ;;
    --list-providers) LIST_PROVIDERS=1; shift ;;
    --list-providers-raw) LIST_PROVIDERS_RAW=1; shift ;;
    --list-models-raw) LIST_MODELS_RAW=1; shift ;;
    --set-default) SET_DEFAULT_MODEL="${2:-}"; shift 2 ;;
    -m|--model) MODEL="${2:-}"; MODEL_CLI_SET=1; shift 2 ;;
    -f) FILE_INPUTS+=("${2:-}"); shift 2 ;;
    --json-input) JSON_INPUT="${2:-}"; shift 2 ;;
    --template) TEMPLATE="${2:-}"; shift 2 ;;
    --batch) BATCH_FILE="${2:-}"; shift 2 ;;
    --session)
      # opt-in session id
      SESSION_ID="${2:-}"
      if [ -n "$SESSION_ID" ] && [ "${SESSION_ID:0:1}" != "-" ]; then
        shift 2
      else
        log_error "ARGS" "--session requires an argument"
        exit "$GROQBASHERRTMP"
      fi
      ;;
    --session-window)
      SESSION_WINDOW="${2:-}"
      if [ -n "$SESSION_WINDOW" ] && [ "${SESSION_WINDOW:0:1}" != "-" ]; then
        shift 2
      else
        # allow --session-window without value -> default 10
        SESSION_WINDOW="10"
        shift
      fi
      ;;
    --system) SYSTEM_PROMPT="${2:-}"; shift 2 ;;
    --ture) TURE="${2:-}"; shift 2 ;;
    --temperature) TURE="${2:-}"; shift 2 ;;
    --max) MAX_TOKENS="${2:-}"; shift 2 ;;
    --debug) DEBUG=1; shift ;;
    --save) FORCE_SAVE_MODE="save"; shift ;;
    --nosave) FORCE_SAVE_MODE="nosave"; shift ;;
    --out) OUT_PATH="${2:-}"; shift 2 ;;
    --threshold) THRESHOLD="${2:-}"; shift 2 ;;
    --dry-run) DRY_RUN=1; shift ;;
    --quiet) QUIET=1; shift ;;
    --stream) STREAM_MODE=1; shift ;;
    --no-stream) STREAM_MODE=0; shift ;;
    --json) OUTPUT_MODE="json"; shift ;;
    --pretty) OUTPUT_MODE="pretty"; shift ;;
    --text) OUTPUT_MODE="text"; shift ;;
    --raw) OUTPUT_MODE="raw"; shift ;;
    --chat) CHAT_MODE=1; shift ;;
    --show-config) SHOW_CONFIG=1; shift ;;
    --diagnostics) DIAGNOSTICS=1; shift ;;
    --provider)
      if [ "${2:-}" ] && [ "${2:0:1}" != "-" ]; then PROVIDER_CLI="${2:-}"; shift 2; else PROVIDER_INTERACTIVE=1; shift; fi
      ;;
    --install-extras)
      INSTALL_EXTRAS=1
      # optional explicit source: accept either "--install-extras <dir>" or "--install-extras=<dir>"
      if [ $# -gt 1 ] && [ "${2:0:1}" != "-" ]; then
        INSTALL_EXTRAS_SRC="${2:-}"
        shift
      fi
      shift
      ;;
    --install-extras=*)
      INSTALL_EXTRAS=1
      INSTALL_EXTRAS_SRC="${1#--install-extras=}"
      shift
      ;;
    --version) printf '%s %s (%s)\n' "$SCRIPT_NAME" "$SCRIPT_VERSION" "$SCRIPT_DATE"; exit 0 ;;
    -h|--help)
      help_file="$GROQBASH_EXTRAS_DIR/docs/help.txt"
      if [ -f "$help_file" ]; then cat "$help_file"; else printf 'Help file not found: %s\n' "$help_file" >&2; fi
      exit 0 ;;
    --) shift; break ;;
    -*) printf 'Unknown option: %s\n' "$1" >&2; exit "$GROQBASHERRTMP" ;;
    *) ARGS+=("$1"); shift ;;
  esac
done

# ---------------------------------------------------------------------------
# Session Engine: safe sourcing and robust fallback
# - If the module extras/session/session_engine.sh exists, we source it.
# - We never execute the file as a script; we verify the presence of the required functions.
# - SE_AVAILABLE indicates whether to use the engine; in case of errors, the legacy fallback is used.
# ---------------------------------------------------------------------------
SE_ENGINE_PATH="${GROQBASH_EXTRAS_DIR%/}/session/session-engine.sh"
SE_AVAILABLE=0
if [ -f "$SE_ENGINE_PATH" ] && [ "${GROQBASH_SESSION_ENGINE:-on}" != "off" ]; then
  # Source safely (no subshell) so functions become visible in current shell
  # If sourcing fails (syntax error), abort loading and keep SE_AVAILABLE=0
  if bash -n "$SE_ENGINE_PATH" 2>/dev/null; then
    . "$SE_ENGINE_PATH"
    # Validate minimal interface
    if type session_engine_build_window >/dev/null 2>&1 && type session_engine_append >/dev/null 2>&1 && type session_engine_enabled >/dev/null 2>&1; then
      if session_engine_enabled 2>/dev/null; then
        SE_AVAILABLE=1
        log_info "SESSION" "Session Engine loaded and available"
      else
        SE_AVAILABLE=0
        log_info "SESSION" "Session Engine loaded but disabled by module"
      fi
    else
      SE_AVAILABLE=0
      log_warn "SESSION" "Session Engine module missing required functions; falling back to legacy"
    fi
  else
    SE_AVAILABLE=0
    log_warn "SESSION" "Session Engine module has syntax errors; falling back to legacy"
  fi
else
  # No engine file present or explicitly disabled
  SE_AVAILABLE=0
  if [ -n "${SESSION_ID:-}" ]; then
    log_info "SESSION" "Session Engine not available; using legacy session helpers"
  fi
fi

# Usage note: callers should attempt session_engine_* only when SE_AVAILABLE=1,
# and otherwise call legacy session_read_window/session_append as fallback.

# ---------------------------------------------------------------------------
# Normalize boolean-like flags
# ---------------------------------------------------------------------------
for flag in DRY_RUN STREAM_MODE INSTALL_EXTRAS PROVIDER_INTERACTIVE LIST_MODELS LIST_PROVIDERS CHAT_MODE QUIET SHOW_CONFIG DIAGNOSTICS; do
  if is_truthy "${!flag:-0}"; then printf -v "$flag" 1; else printf -v "$flag" 0; fi
done

# Guard: prevent accidental real API calls (ALLOW_API_CALLS defaults to 1)
: "${ALLOW_API_CALLS:=1}"
if [ -n "${GROQ_API_KEY:-}" ] && ! is_truthy "${ALLOW_API_CALLS:-0}" && ! is_truthy "${DRY_RUN:-0}"; then
  log_error "APIKEY" "GROQ_API_KEY is set but ALLOW_API_CALLS!=1 and DRY_RUN!=1."
  exit "$GROQBASHERRTMP"
fi

# Rebuild supported providers array (machine-readable source of truth)
_supported_providers_arr=()
_supported_providers_arr+=("groq")
# Resolve extras providers dir: prefer explicit PROVIDERS_DIR, then extras dir, then canonical config providers
extras_prov_dir="${PROVIDERS_DIR:-${GROQBASH_EXTRAS_DIR%/}/providers}"
if [ -z "${extras_prov_dir:-}" ]; then
  extras_prov_dir="$(canonical_config_dir)/providers"
fi
if [ -d "$extras_prov_dir" ]; then
  for pf in "$extras_prov_dir"/*.sh; do
    [ -e "$pf" ] || continue
    base="$(basename "$pf" .sh)"
    # skip duplicate embedded name
    [ "$base" = "groq" ] && continue
    _supported_providers_arr+=("$base")
  done
fi
SUPPORTED_PROVIDERS="$(printf '%s ' "${_supported_providers_arr[@]}" | sed 's/ $//')"

# Non-interactive machine-readable provider listing
if [ "${LIST_PROVIDERS_RAW:-0}" -eq 1 ]; then
  # If no providers found or providers dir missing -> exit 1
  if [ "${#_supported_providers_arr[@]}" -eq 0 ]; then
    exit 1
  fi
  # Print one provider name per line, no decoration, no sourcing
  for p in "${_supported_providers_arr[@]}"; do
    printf '%s\n' "$p"
  done
  exit 0
fi

# Non-interactive machine-readable models listing (one normalized model name per line)
if [ "${LIST_MODELS_RAW:-0}" -eq 1 ]; then
  # If CLI provided a provider override, honor it as context but do NOT source provider modules
  if [ -n "${PROVIDER_CLI:-}" ]; then
    PROVIDER="${PROVIDER_CLI}"
  fi

  # MODELS_FILE is the canonical source of truth
  if [ -f "${MODELS_FILE:-}" ] && [ -s "${MODELS_FILE:-}" ]; then
    # Normalize entries: strip leading "models/" and common provider prefixes, trim whitespace
    # Keep only non-empty lines; print one model per line, no annotations
    awk '{
      g=$0
      sub(/^models\//,"",g)
      sub(/^groq[:\/ -]*/,"",g)
      sub(/^[[:space:]]+/,"",g)
      sub(/[[:space:]]+$/,"",g)
      if (g != "") print g
    }' "$MODELS_FILE"
    exit 0
  else
    # File missing or empty
    exit 2
  fi
fi

# ---------------------------------------------------------------------------
# Immediate actions: list providers/models, set-default, install-extras
# Note: explicit --refresh-models handling has been moved to after provider load.
# ---------------------------------------------------------------------------
if [ "$LIST_PROVIDERS" -eq 1 ]; then
  printf 'Available providers:\n' >&2
  printf '  - groq (embedded)\n' >&2
  extras_prov_dir="$PROVIDERS_DIR"
  if [ -d "$extras_prov_dir" ]; then
    found=0
    for f in "$extras_prov_dir"/*.sh; do
      [ -e "$f" ] || continue
      base="$(basename "$f" .sh)"
      [ "$base" = "groq" ] && continue
      printf '  - %s\n' "$base" >&2
      found=1
    done
  fi

  # Determine active provider robustly for provider-specific default lookup:
  # Precedence: PROVIDER_CLI -> persisted provider file under canonical config dir -> $PROVIDER -> fallback groq
  if [ -n "${PROVIDER_CLI:-}" ]; then
    active_provider="${PROVIDER_CLI}"
  elif [ -f "$(canonical_provider_file)" ] && [ -s "$(canonical_provider_file)" ]; then
    active_provider="$(sed -n '1p' "$(canonical_provider_file)" 2>/dev/null || true)"
    active_provider="$(printf '%s' "$active_provider" | awk '{$1=$1;print}')"
    [ -z "$active_provider" ] && active_provider="${PROVIDER:-groq}"
  else
    active_provider="${PROVIDER:-groq}"
  fi

  # 2) provider-specific persisted default (model.<active_provider>)
  # Determine active provider robustly: precedence PROVIDER_CLI -> persisted provider file -> $PROVIDER -> fallback groq
  if [ -n "${PROVIDER_CLI:-}" ]; then
    active_provider="${PROVIDER_CLI}"
  elif [ -f "$(canonical_provider_file)" ] && [ -s "$(canonical_provider_file)" ]; then
    active_provider="$(sed -n '1p' "$(canonical_provider_file)" 2>/dev/null || true)"
    active_provider="$(printf '%s' "$active_provider" | awk '{$1=$1;print}')"
    [ -z "$active_provider" ] && active_provider="${PROVIDER:-groq}"
  else
    active_provider="${PROVIDER:-groq}"
  fi

  MODEL_PROVIDER_CFG="$(canonical_model_file "${active_provider}")"
  if [ -s "$MODEL_PROVIDER_CFG" ]; then
    candidate="$(sed -n '1p' "$MODEL_PROVIDER_CFG" 2>/dev/null || true)"
    candidate="$(printf '%s' "$candidate" | awk '{$1=$1;print}')"
    if [ -n "$candidate" ] && is_supported_model "$candidate"; then
      if validate_model_core "$candidate" >/dev/null 2>&1 && validate_model_dispatch "$candidate" >/dev/null 2>&1; then
        FINAL_MODEL="$candidate"
        return 0
      fi
    fi
  fi
fi

if [ "$LIST_MODELS" -eq 1 ]; then
  if list_models_cli; then exit 0; else exit "$GROQBASHERRTMP"; fi
fi

if [ -n "$SET_DEFAULT_MODEL" ]; then
  # Ensure canonical config dir exists and is safe
  if ! mkdir -p "$(canonical_config_dir)" 2>/dev/null; then
    log_error "SEC" "cannot create config dir: $(canonical_config_dir)"; exit "$GROQBASHERRTMP"
  fi
  if [ -L "$(canonical_config_dir)" ]; then log_error "SEC" "config dir is a symlink."; exit "$GROQBASHERRTMP"; fi

  # Determine the active provider robustly:
  # 1) explicit CLI override PROVIDER_CLI
  # 2) persisted provider file under canonical provider file (if present)
  # 3) current $PROVIDER variable
  if [ -n "${PROVIDER_CLI:-}" ]; then
    target_provider="${PROVIDER_CLI}"
  elif [ -f "$(canonical_provider_file)" ] && [ -s "$(canonical_provider_file)" ]; then
    target_provider="$(sed -n '1p' "$(canonical_provider_file)" 2>/dev/null || true)"
    target_provider="$(printf '%s' "$target_provider" | awk '{$1=$1;print}')"
    [ -z "$target_provider" ] && target_provider="${PROVIDER:-groq}"
  else
    target_provider="${PROVIDER:-groq}"
  fi

  # Persist default model for the explicit/active provider under canonical config dir
  target_model_file="$(canonical_model_file "${target_provider}")"
  printf '%s\n' "$SET_DEFAULT_MODEL" | atomic_write "$target_model_file" 10 \
    || { log_error "SEC" "cannot write default model for provider ${target_provider} to ${target_model_file}."; exit "$GROQBASHERRTMP"; }
  chmod 600 "$target_model_file" 2>/dev/null || true

  # Log must reflect the actual provider used (target_provider)
  printf 'groqbash: INFO: Default model for provider %s set to: %s\n' "$target_provider" "$SET_DEFAULT_MODEL" >&2
  exit 0
fi

if [ "$STREAM_MODE" -eq 1 ] && { [ "$OUTPUT_MODE" = "json" ] || [ "$OUTPUT_MODE" = "pretty" ]; }; then
  log_error "ARGS" "--stream incompatible with --json/--pretty."
  exit "$GROQBASHERRTMP"
fi

if [ "${INSTALL_EXTRAS:-0}" -eq 1 ]; then
  # Determine chosen source: explicit override wins, otherwise default to SCRIPTDIR/extras
  if [ -n "${INSTALL_EXTRAS_SRC:-}" ]; then
    SRC_BASE="${INSTALL_EXTRAS_SRC%/}"
  else
    SRC_BASE="${SCRIPTDIR%/}/extras"
  fi

  # Canonicalize chosen source and destination (use cd && pwd for portability)
  if [ -d "${SRC_BASE}" ]; then
    SRC_BASE="$(cd "${SRC_BASE}" >/dev/null 2>&1 && pwd || printf '%s' "${SRC_BASE}")"
  else
    SRC_BASE="${SRC_BASE%/}"
  fi
  DEST_BASE="$(cd "${GROQBASH_EXTRAS_DIR%/}" >/dev/null 2>&1 && pwd || printf '%s' "${GROQBASH_EXTRAS_DIR%/}")"
  # Destination for provider assets: prefer explicit PROVIDERS_DIR, otherwise use DEST_BASE/providers.
  # Do not implicitly fall back to an empty GROQBASH_CONFIG_DIR; use canonical_config_dir only if DEST_BASE is unset.
  DEST_PROV="${PROVIDERS_DIR:-${DEST_BASE:-$(canonical_config_dir)}/providers}"

  # Legacy detection: only fatal if a legacy dir exists and is neither the canonical destination
  # nor the chosen source. Do not treat SCRIPTDIR/extras as fatal when it is the chosen source.
  if [ -d "${LEGACY_EXTRAS_DIR}" ]; then
    LEGACY_REAL="$(cd "${LEGACY_EXTRAS_DIR}" >/dev/null 2>&1 && pwd || printf '%s' "${LEGACY_EXTRAS_DIR}")"
    if [ "${LEGACY_REAL}" != "${DEST_BASE}" ] && [ "${LEGACY_REAL}" != "${SRC_BASE}" ]; then
      printf 'groqbash: ERROR: legacy extras directory found at %s\n' "${LEGACY_REAL}" >&2
      printf 'groqbash: ERROR: only %s is supported as runtime destination. Move or remove the legacy directory and retry.\n' "${DEST_BASE}" >&2
      exit "$GROQBASHERRTMP"
    fi
  fi

  # Validate source existence and type
  if [ ! -d "${SRC_BASE}" ]; then
    log_error "EXTRAS" "missing extras source directory: ${SRC_BASE}"
    exit "$GROQBASHERRTMP"
  fi
  if [ -L "${SRC_BASE}" ]; then
    log_error "EXTRAS" "extras source is a symlink: ${SRC_BASE}"
    exit "$GROQBASHERRTMP"
  fi

  # Prevent copying when source equals destination or source is inside destination (avoid nested copies)
  if [ "${SRC_BASE}" = "${DEST_BASE}" ]; then
    log_error "EXTRAS" "extras source and destination are identical (${SRC_BASE}); nothing to do."
    exit "$GROQBASHERRTMP"
  fi
  case "${SRC_BASE}/" in
    "${DEST_BASE}/"*) log_error "EXTRAS" "extras source ${SRC_BASE} is inside destination ${DEST_BASE}; aborting to avoid nested copy."; exit "$GROQBASHERRTMP" ;;
  esac

  # Prepare destination directories with strict perms
  mkdir -p "${DEST_BASE}" "${DEST_PROV}" 2>/dev/null || { log_error "EXTRAS" "cannot create extras dest: ${DEST_BASE}"; exit "$GROQBASHERRTMP"; }
  chmod 700 "${DEST_BASE}" 2>/dev/null || true

  # Gather regular files from source
  files_to_copy=()
  while IFS= read -r -d '' f; do files_to_copy+=("$f"); done < <(find "${SRC_BASE}" -type f -print0 2>/dev/null || true)

  if [ "${#files_to_copy[@]}" -eq 0 ]; then
    printf 'No extras files found under %s; nothing to install.\n' "${SRC_BASE}" >&2
    exit 0
  fi

  # Validate ownership and file types before any writes
  current_user="$(id -un 2>/dev/null || printf '')"
  for src in "${files_to_copy[@]}"; do
    [ -f "$src" ] || { log_error "EXTRAS" "extras entry not a regular file: $src"; exit "$GROQBASHERRTMP"; }
    [ -L "$src" ] && { log_error "EXTRAS" "extras file is symlink: $src"; exit "$GROQBASHERRTMP"; }
    src_owner="$(_get_owner "$src")"
    [ -n "$src_owner" ] && [ "$src_owner" != "$current_user" ] && { log_error "EXTRAS" "wrong owner: $src"; exit "$GROQBASHERRTMP"; }
  done

  # Copy files atomically preserving relative layout under DEST_BASE
  installed_providers=()
  installed_libs=()
  installed_docs=()
  installed_security=()
  installed_tests=()

  for src in "${files_to_copy[@]}"; do
    rel="${src#${SRC_BASE}/}"
    dest="${DEST_BASE}/${rel}"
    destdir="$(dirname "$dest")"
    mkdir -p "$destdir" 2>/dev/null || { log_error "EXTRAS" "cannot create dest dir: $destdir"; exit "$GROQBASHERRTMP"; }

    if type atomic_write >/dev/null 2>&1; then
      cat "$src" | atomic_write "$dest" 10 || { log_error "EXTRAS" "Error copying $src"; exit "$GROQBASHERRTMP"; }
    else
      cp -f "$src" "$dest" 2>/dev/null || { log_error "EXTRAS" "Error copying $src"; exit "$GROQBASHERRTMP"; }
      chmod 600 "$dest" 2>/dev/null || true
    fi

    chmod 600 "$dest" 2>/dev/null || true

    case "$rel" in
      providers/*.sh) installed_providers+=("$(basename "$rel" .sh)") ;;
      lib/*) installed_libs+=("$(basename "$rel")") ;;
      docs/*) installed_docs+=("$(basename "$rel")") ;;
      security/*) installed_security+=("$(basename "$rel")") ;;
      test/*) installed_tests+=("$(basename "$rel")") ;;
    esac
  done

  printf 'groqbash: INFO: Extras installed under %s\n' "${DEST_BASE}" >&2

  if [ "${#installed_providers[@]}" -gt 0 ]; then
    printf 'Installed providers: %s\n' "$(printf '%s ' "${installed_providers[@]}")" >&2
  fi
  if [ "${#installed_libs[@]}" -gt 0 ]; then
    printf 'Installed libs: %s\n' "$(printf '%s ' "${installed_libs[@]}")" >&2
  fi
  if [ "${#installed_docs[@]}" -gt 0 ]; then
    printf 'Installed docs: %s\n' "$(printf '%s ' "${installed_docs[@]}")" >&2
  fi
  if [ "${#installed_security[@]}" -gt 0 ]; then
    printf 'Installed security scripts: %s\n' "$(printf '%s ' "${installed_security[@]}")" >&2
  fi
  if [ "${#installed_tests[@]}" -gt 0 ]; then
    printf 'Installed test scripts: %s\n' "$(printf '%s ' "${installed_tests[@]}")" >&2
  fi

  # Syntax check for installed providers
  for p in "${installed_providers[@]}"; do
    PROVIDER_MODULE_PATH="${DEST_PROV}/${p}.sh"
    if ! bash -n "$PROVIDER_MODULE_PATH" 2>/dev/null; then
      printf 'groqbash: WARN: provider %s has syntax errors; check %s\n' "$p" "$PROVIDER_MODULE_PATH" >&2
    fi
  done

  exit 0
fi

# ---------------------------------------------------------------------------
# Load local config and whitelist
# ---------------------------------------------------------------------------
load_local_config() {
  local cfg="${GROQBASH_CONFIG_DIR%/}/config" key val
  [ -f "$cfg" ] || return 0
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in ''|\#*) continue ;; esac
    key="${line%%=*}"
    val="${line#*=}"
    case "$key" in
      MODEL) [ -n "$val" ] && MODEL="$val" ;;
      TEMPERATURE|TURE) [ -n "$val" ] && TURE="$val" ;;
      MAX_TOKENS) [ -n "$val" ] && MAX_TOKENS="$val" ;;
      FORMAT) [ -n "$val" ] && OUTPUT_MODE="$val" ;;
      THRESHOLD) [ -n "$val" ] && THRESHOLD="$val" ;;
    esac
  done < "$cfg"
}

load_whitelist() {
  ALLOWED_MODELS="${ALLOWED_MODELS:-}"
  if [ -f "$MODELS_FILE" ] && [ -s "$MODELS_FILE" ]; then
    # Normalize entries: strip leading "models/" and trim whitespace
    # Keep one model per line in ALLOWED_MODELS
    ALLOWED_MODELS="$(awk '{ gsub(/^models\//,""); sub(/^[[:space:]]+/,""); sub(/[[:space:]]+$/,""); if (NF) print }' "$MODELS_FILE" 2>/dev/null || true)"
  fi
}

# ---------------------------------------------------------------------------
# Small runtime helpers used by CORE
# - is_tty_out: returns 0 if stdout is a TTY (useful for interactive prompts)
# - provider_api_env_var_name: canonical env var name for provider API key
# - ensure_api_key_for_provider: ensure API key present (supports PROVIDER_API_ENV_<prov>)
# ---------------------------------------------------------------------------
is_tty_out() {
  # Return success if stdout is a TTY
  [ -t 1 ]
}

# ---------------------------------------------------------------------------
# Provider discovery and loading (keeps behavior compatible)
# ---------------------------------------------------------------------------

_supported_providers_arr=()
_supported_providers_arr+=("groq")
extras_prov_dir="$PROVIDERS_DIR"
if [ -d "$extras_prov_dir" ]; then
  for pf in "$extras_prov_dir"/*.sh; do
    [ -e "$pf" ] || continue
    base="$(basename "$pf" .sh)"
    [ "$base" = "groq" ] && continue
    _supported_providers_arr+=("$base")
  done
fi
SUPPORTED_PROVIDERS="$(printf '%s ' "${_supported_providers_arr[@]}" | sed 's/ $//')"

# Respect persisted provider selection unless overridden via CLI
if [ -f "$(canonical_provider_file)" ] && [ -z "${PROVIDER_CLI:-}" ] && [ "${PROVIDER_INTERACTIVE:-0}" -eq 0 ]; then
  prov="$(sed -n '1p' "$(canonical_provider_file)" 2>/dev/null || true)"
  prov="$(printf '%s' "$prov" | awk '{$1=$1;print}')"
  [ -n "$prov" ] && PROVIDER="$prov"
fi

# CLI provider selection handling
if [ -n "${PROVIDER_CLI:-}" ] && [ "$PROVIDER_CLI" != "list" ]; then
  case " $SUPPORTED_PROVIDERS " in
    *" $PROVIDER_CLI "*) 
      prev_provider="$PROVIDER"
      PROVIDER="$PROVIDER_CLI"
      ;;
    *) log_error "PROVIDER" "unknown provider: $PROVIDER_CLI"; exit "$GROQBASHERRTMP" ;;
  esac

  # Ensure config dir is available and writable
  if ! ensure_config_dir; then
    log_error "PROVIDER" "cannot persist provider selection: config dir unavailable."
    exit "$GROQBASHERRTMP"
  fi

  if [ -n "${prev_provider:-}" ] && [ "$prev_provider" != "$PROVIDER" ]; then
    if [ -n "${MODELS_FILE:-}" ] && [ -f "$MODELS_FILE" ]; then
      rm -f "$MODELS_FILE" 2>/dev/null || true
    fi
  fi

  # Persist the explicit CLI-chosen provider (use PROVIDER_CLI to avoid race with other logic)
  target_provider="${PROVIDER_CLI}"
  target_provider_file="$(canonical_provider_file)"
  printf '%s\n' "$target_provider" | atomic_write "$target_provider_file" 10 \
    || { log_error "PROVIDER" "cannot persist provider selection to ${target_provider_file}."; exit "$GROQBASHERRTMP"; }
  chmod 600 "$target_provider_file" 2>/dev/null || true

fi

# Interactive provider selection
if [ "$PROVIDER_INTERACTIVE" -eq 1 ] || [ "${PROVIDER_CLI:-}" = "list" ]; then
  IFS=' ' read -r -a _prov_arr <<EOF
$SUPPORTED_PROVIDERS
EOF
  current_default="$PROVIDER"
  if [ -f "$(canonical_provider_file)" ]; then
    pf="$(sed -n '1p' "$(canonical_provider_file)" 2>/dev/null || true)"
    pf="$(printf '%s' "$pf" | awk '{$1=$1;print}')"
    [ -n "$pf" ] && current_default="$pf"
  fi

  printf 'Select provider:\n' >&2
  i=1
  for p in "${_prov_arr[@]}"; do
    if [ "$p" = "$current_default" ]; then printf '%d) %s (default)\n' "$i" "$p" >&2
    else printf '%d) %s\n' "$i" "$p" >&2; fi
    i=$((i+1))
  done

  printf '> ' >&2
  if ! IFS= read -r sel; then printf 'No selection made.\n' >&2; exit "$GROQBASHERRTMP"; fi
  sel="$(trim "$sel")"
  printf '%s\n' "$sel" | grep -qE '^[0-9]+$' || { log_error "PROVIDER" "Invalid selection."; exit "$GROQBASHERRTMP"; }

  idx="$sel"
  chosen="${_prov_arr[$((idx-1))]}"
  [ -z "$chosen" ] && { log_error "PROVIDER" "Selection out of range."; exit "$GROQBASHERRTMP"; }

  prev_provider="$PROVIDER"

  # Ensure config dir available
  if ! ensure_config_dir; then
    log_error "PROVIDER" "cannot persist provider selection: config dir unavailable."
    exit "$GROQBASHERRTMP"
  fi

  target_provider_file="$(canonical_provider_file)"
  if ! printf '%s\n' "$chosen" | atomic_write "$target_provider_file" 10; then
    log_error "PROVIDER" "cannot persist provider selection to $target_provider_file."
    exit "$GROQBASHERRTMP"
  fi
  chmod 600 "$target_provider_file" 2>/dev/null || true
  PROVIDER="$chosen"

  if [ -n "${prev_provider:-}" ] && [ "$prev_provider" != "$PROVIDER" ]; then
    if [ -n "${MODELS_FILE:-}" ] && [ -f "$MODELS_FILE" ]; then
      rm -f "$MODELS_FILE" 2>/dev/null || true
    fi
  fi

  # NOTE: do not call refresh_models_dispatch here — provider module must be loaded first.
  # Continue execution instead of exiting so the chosen provider is applied to the rest of the run.
fi

# Load provider module if present (embedded groq is always available)
PROVIDER_MODULE_LOADED=0
PROVIDER_MODULE_PATH="$PROVIDERS_DIR/${PROVIDER}.sh"
PROVIDER_DIR="$PROVIDERS_DIR"

if [ ! -d "$PROVIDER_DIR" ]; then
  mkdir -p "$PROVIDER_DIR" 2>/dev/null || { log_error "PROVIDER" "cannot create provider directory."; exit "$GROQBASHERRTMP"; }
fi

if _is_world_writable "$PROVIDER_DIR"; then
  log_error "SEC" "provider directory is world-writable."
  exit "$GROQBASHERRTMP"
fi

current_user="$(id -un 2>/dev/null || printf '')"
owner="$(_get_owner "$PROVIDER_DIR")"
[ -n "$owner" ] && [ "$owner" != "$current_user" ] && log_warn "SEC" "provider directory owned by $owner"

if [ ! -f "$PROVIDER_MODULE_PATH" ]; then
  if [ "$PROVIDER" != "groq" ]; then
    printf 'Provider %s is not installed.\n' "$PROVIDER" >&2
    PROVIDER_MODULE_LOADED=0
  else
    PROVIDER_MODULE_LOADED=1
  fi
else
  if [ -L "$PROVIDER_MODULE_PATH" ]; then log_error "SEC" "provider file is symlink."; exit "$GROQBASHERRTMP"; fi

  file_owner="$(_get_owner "$PROVIDER_MODULE_PATH")"
  [ -n "$file_owner" ] && [ "$file_owner" != "$current_user" ] && { log_error "SEC" "wrong owner for provider file."; exit "$GROQBASHERRTMP"; }

  perms="$(_get_perm_string "$PROVIDER_MODULE_PATH")"
  group_write="$(printf '%s' "$perms" | awk '{print substr($0,6,1)}')"
  others_write="$(printf '%s' "$perms" | awk '{print substr($0,9,1)}')"
  if [ "$group_write" = "w" ] || [ "$others_write" = "w" ]; then
    log_error "SEC" "provider file writable by group/world."
    exit "$GROQBASHERRTMP"
  fi

  beforesig="$(getfile_signature "$PROVIDER_MODULE_PATH" 2>/dev/null || true)"

  # Robust syntax check and load in current shell (avoid subshell tests)
  if bash -n "$PROVIDER_MODULE_PATH" 2>/dev/null; then
    # Source the provider into the current shell so functions are visible
    . "$PROVIDER_MODULE_PATH"
    PROVIDER_MODULE_LOADED=1

    # Validate presence of required functions in current shell
    invalid_provider=0
    for _req in "buildpayload_${PROVIDER}" "call_api_${PROVIDER}"; do
      type "$_req" >/dev/null 2>&1 || invalid_provider=1
    done

    aftersig="$(getfile_signature "$PROVIDER_MODULE_PATH" 2>/dev/null || true)"
    [ "$beforesig" != "$aftersig" ] && { log_error "SEC" "provider file changed."; exit "$GROQBASHERRTMP"; }

    if [ "$invalid_provider" -eq 1 ]; then
      log_warn "PROVIDER" "provider module incomplete; falling back to embedded provider."
      PROVIDER_MODULE_LOADED=0
    fi
  else
    log_warn "PROVIDER" "provider module invalid; falling back to embedded provider."
    PROVIDER_MODULE_LOADED=0
  fi
fi

# Validate provider interface
validate_provider_interface() {
  local p="$1" missing=0
  local required=( "buildpayload_${p}" "call_api_${p}" )
  local optional=( "call_api_streaming_${p}" "refresh_models_${p}" "validate_model_${p}" "auto_select_model_${p}" )
  local f
  for f in "${required[@]}"; do
    if ! type "$f" >/dev/null 2>&1; then
      printf 'Provider '\''%s'\'' module does not define required function %s().\n' "$p" "$f" >&2
      missing=1
    fi
  done
  for f in "${optional[@]}"; do
    if ! type "$f" >/dev/null 2>&1; then
      log_info "PROVIDER" "Provider '$p' missing optional function $f()"
    fi
  done
  return $missing
}

if [ "${PROVIDER_MODULE_LOADED:-0}" -eq 1 ]; then
  validate_provider_interface "$PROVIDER" || exit "$GROQBASHERRAPI"
else
  log_error "PROVIDER" "no valid provider loaded for '$PROVIDER'. Install or configure a provider plugin."
  exit "$GROQBASHERRAPI"
fi

# Handle explicit --refresh-models only after provider module is loaded and validated
if [ "${REFRESH_MODELS:-0}" -eq 1 ]; then
  if ! ensure_api_key_for_provider "$PROVIDER"; then
    log_error "APIKEY" "API key required to refresh models for provider $PROVIDER."
    exit "$GROQBASHERRNOAPIKEY"
  fi
  refresh_models_dispatch "$MODELS_FILE" || exit "$GROQBASHERRAPI"
  exit 0
fi

# After provider module is loaded and validated, refresh models if local whitelist is missing
# This ensures refresh_models_dispatch invokes the provider-specific refresh implementation.
if [ ! -s "${MODELS_FILE:-}" ]; then
  if ! ensure_api_key_for_provider "$PROVIDER"; then
    log_error "APIKEY" "API key required to refresh models for provider $PROVIDER."
    # do not exit hard here; allow operation without refreshed models where possible
  else
    refresh_models_dispatch "$MODELS_FILE" || true
  fi
fi

# ---------------------------------------------------------------------------
# Show config / diagnostics
# ---------------------------------------------------------------------------
if [ "${PRINT_CONFIG_DIR:-0}" -eq 1 ]; then
  printf '%s\n' "$(canonical_config_dir)"
  exit 0
fi

if [ "${PRINT_PROVIDER_FILE:-0}" -eq 1 ]; then
  printf '%s\n' "$(canonical_provider_file)"
  exit 0
fi

if [ -n "${PRINT_MODEL_FILE:-}" ]; then
  # PRINT_MODEL_FILE expected to contain provider name
  printf '%s\n' "$(canonical_model_file "${PRINT_MODEL_FILE}")"
  exit 0
fi

# Show full configuration (existing behavior), but use canonical helpers for model file lookup
if [ "${SHOW_CONFIG:-0}" -eq 1 ]; then
  printf 'GroqBash configuration:\n'
  printf '  Version: %s (%s)\n' "$SCRIPT_VERSION" "$SCRIPT_DATE"
  printf '  Provider: %s\n' "$PROVIDER"
  printf '  Model (active): %s\n' "$MODEL"
  printf '  Model set via CLI: %s\n' "${MODEL_CLI_SET:-0}"

  # Determine model default file using persisted provider file if present
  if [ -f "$(canonical_provider_file)" ] && [ -s "$(canonical_provider_file)" ]; then
    cfg_prov="$(sed -n '1p' "$(canonical_provider_file)" 2>/dev/null || true)"
    cfg_prov="$(printf '%s' "$cfg_prov" | awk '{$1=$1;print}')"
    model_provider="${cfg_prov:-${PROVIDER:-groq}}"
  else
    model_provider="${PROVIDER:-groq}"
  fi

  MODEL_PROVIDER_CFG="$(canonical_model_file "${model_provider}")"
  if [ -s "$MODEL_PROVIDER_CFG" ]; then
    printf '  Model (default): %s\n' "$(sed -n '1p' "$MODEL_PROVIDER_CFG")"
  else
    printf '  Model (default): <none>\n'
  fi

  printf '  Config dir: %s\n' "$(canonical_config_dir)"
  printf '  Models dir: %s\n' "$GROQBASH_MODELS_DIR"
  printf '  Tmp dir: %s\n' "$GROQBASH_TMPDIR"
  printf '  History dir: %s\n' "$GROQBASH_HISTORY_DIR"
  printf '  Quiet: %s\n' "$QUIET"
  printf '  Debug: %s\n' "$DEBUG"
  printf '  Dry-run: %s\n' "$DRY_RUN"
  printf '  Whitelist models: %s\n' "$(printf '%s\n' "$ALLOWED_MODELS" | wc -l)"
  exit 0
fi

if [ "${DIAGNOSTICS:-0}" -eq 1 ]; then
  printf 'GroqBash diagnostics:\n'

  printf '\n[Directories]\n'
  for d in "$GROQBASH_CONFIG_DIR" "$GROQBASH_MODELS_DIR" "$GROQBASH_TMPDIR" "$GROQBASH_EXTRAS_DIR" "$GROQBASH_HISTORY_DIR"; do
    if [ -d "$d" ]; then
      printf '  OK: %s\n' "$d"
    else
      printf '  ERROR: missing directory %s\n' "$d"
    fi
  done

  printf '\n[Provider]\n'
  printf '  Active provider: %s\n' "$PROVIDER"
  if type "buildpayload_${PROVIDER}" >/dev/null 2>&1; then
    printf '  Provider functions: OK\n'
  else
    printf '  ERROR: provider functions missing\n'
  fi

  printf '\n[Model]\n'
  printf '  Active model: %s\n' "$MODEL"
  if printf '%s\n' "$ALLOWED_MODELS" | grep -x -F -q "$MODEL"; then
    printf '  Model in whitelist: OK\n'
  else
    printf '  WARNING: model not in whitelist\n'
  fi

  printf '\n[API Key]\n'
  prov_upper="$(printf '%s' "$PROVIDER" | tr '[:lower:]' '[:upper:]' | tr -c 'A-Z0-9_' '_')"
  check_var="${prov_upper}_API_KEY"
  custom_env_var_var="PROVIDER_API_ENV_${PROVIDER}"
  custom_env_var="${!custom_env_var_var:-}"
  if [ -n "$custom_env_var" ]; then check_var="$custom_env_var"; fi

  if [ -n "${!check_var:-}" ]; then
    printf '  API key: present (env %s)\n' "$check_var"
  else
    printf '  WARNING: API key missing (expected env %s)\n' "$check_var"
  fi

  printf '\n[Tmpdir]\n'
  if [ -d "$GROQBASH_TMPDIR" ]; then
    printf '  Tmpdir exists: OK\n'
  else
    printf '  ERROR: tmpdir missing\n'
  fi

  printf '\nDiagnostics complete.\n'
  exit 0
fi

# ---------------------------------------------------------------------------
# Main flow: assemble content, select model, and execute request(s)
# ---------------------------------------------------------------------------
load_local_config
load_whitelist

# Ensure run tmpdir is available before proceeding with model selection and payload assembly
if ! ensure_run_tmpdir; then
  log_error "TMP" "cannot create or access RUN_TMPDIR ($GROQBASH_TMPDIR). Aborting."
  exit "$GROQBASHERRTMP"
fi

# Determine final model using centralized resolver
if ! resolve_model; then
  log_error "MODEL" "no model could be selected."
  exit "$GROQBASHERRBAD_MODEL"
fi

# FINAL_MODEL set by resolve_model()
# Validate core and provider-specific constraints
if ! validate_model_core "$FINAL_MODEL"; then
  log_error "MODEL" "model failed core validation: $FINAL_MODEL"
  exit "$GROQBASHERRBAD_MODEL"
fi

if ! validate_model_dispatch "$FINAL_MODEL"; then
  log_error "MODEL" "invalid model for provider $PROVIDER: $FINAL_MODEL"
  exit "$GROQBASHERRBAD_MODEL"
fi

MODEL="$FINAL_MODEL"

# Read stdin only when JSON_INPUT is not explicitly requested.
STDIN_CONTENT=""
if [ -z "${JSON_INPUT:-}" ] && [ ! -t 0 ]; then
  STDIN_CONTENT="$(cat - 2>/dev/null || true)"
fi

assemble_content() {
  CONTENT="${CONTENT:-}"
  local tmpl tmp_tmpl tmp_final extra file_content

  if [ -n "$JSON_INPUT" ]; then CONTENT=""; return 0; fi

  if [ "${#FILE_INPUTS[@]}" -gt 0 ]; then
    CONTENT="$(collect_input_from_files "${FILE_INPUTS[@]}")"
    if [ "${#ARGS[@]}" -gt 0 ]; then
      extra="$(expand_args_to_content)"
      [ -n "$extra" ] && CONTENT="${CONTENT}"$'\n\n'"$extra"
    fi
    return 0
  fi

  if [ -n "$TEMPLATE" ]; then
    if [ "${#FILE_INPUTS[@]}" -gt 0 ]; then
      CONTENT="$(collect_input_from_files "${FILE_INPUTS[@]}")"
    elif [ -n "$STDIN_CONTENT" ]; then
      CONTENT="$STDIN_CONTENT"
    else
      if [ "${#ARGS[@]}" -gt 0 ]; then CONTENT="$(expand_args_to_content)"; else CONTENT=""; fi
    fi

    tmpl="$(cat "$GROQBASH_TEMPLATES_DIR/$TEMPLATE" 2>/dev/null || true)"
    ensure_run_tmpdir
    tmp_tmpl="$(_mktemp_in_dir "$RUN_TMPDIR" 2>/dev/null || true)"

    if [ -n "$tmp_tmpl" ]; then
      # Preserve original newlines while replacing the placeholder
      printf '%s' "$tmpl" | awk -v repl="$CONTENT" '{ gsub(/\{\{CONTENT\}\}/, repl); print }' > "$tmp_tmpl"
      tmp_final="${tmp_tmpl}.final"
      mv "$tmp_tmpl" "$tmp_final" 2>/dev/null || true
      file_content="$(cat "$tmp_final" 2>/dev/null || printf '%s' "$tmpl")"
      CONTENT="$file_content"
      rm -f "$tmp_final" 2>/dev/null || true
    else
      # Fallback: perform replacement while preserving newlines
      CONTENT="$(printf '%s' "$tmpl" | awk -v repl="$CONTENT" '{ gsub(/\{\{CONTENT\}\}/, repl); print }')"
    fi
    return 0
  fi

  if [ -n "$STDIN_CONTENT" ]; then
    CONTENT="$STDIN_CONTENT"
    if [ "${#ARGS[@]}" -gt 0 ]; then
      extra="$(expand_args_to_content)"
      [ -n "$extra" ] && CONTENT="${CONTENT}"$'\n\n'"$extra"
    fi
    return 0
  fi

  if [ "${#ARGS[@]}" -gt 0 ]; then CONTENT="$(expand_args_to_content)"; else CONTENT=""; fi
  return 0
}

assemble_content

if [ -z "$CONTENT" ] && [ -z "$JSON_INPUT" ] && [ "$CHAT_MODE" -eq 0 ] && [ -z "$BATCH_FILE" ]; then
  log_error "INPUT" "no prompt provided."
  exit "$GROQBASHERRNO_PROMPT"
fi

is_number "$TURE" || { log_error "ARGS" "--ture must be numeric"; exit "$GROQBASHERRTMP"; }
is_number "$MAX_TOKENS" || { log_error "ARGS" "--max must be numeric"; exit "$GROQBASHERRTMP"; }

# Final guard: if ALLOWED_MODELS is present, compare normalized model names
if [ -n "$ALLOWED_MODELS" ] && [ -n "$MODEL" ]; then
  norm_model="$(printf '%s' "$MODEL" | sed -e 's#^models/##' -e 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  if ! printf '%s\n' "$ALLOWED_MODELS" | grep -x -F -q "$norm_model"; then
    log_error "MODEL" "model '$MODEL' not supported or deprecated."
    printf '%s\n' "$ALLOWED_MODELS" >&2
    exit "$GROQBASHERRBAD_MODEL"
  fi
fi

ensure_run_tmpdir

# Batch processing
if [ -n "$BATCH_FILE" ]; then
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in ''|\#*) continue ;; esac
    CONTENT="$line"

    # If sessioning is requested, validate and prepare messages file for buildpayload
    if [ -n "${SESSION_ID:-}" ]; then
      if ! session_validate_id "$SESSION_ID"; then
        log_error "SESSION" "invalid session id: $SESSION_ID"
        exit "$GROQBASHERRTMP"
      fi
      # Ensure sessions dir exists with strict perms
      mkdir -p "$GROQBASH_HISTORY_DIR/sessions" 2>/dev/null || true
      chmod 700 "$GROQBASH_HISTORY_DIR/sessions" 2>/dev/null || true

      # Enforce recommended window limit and warn if exceeded
      if [ -n "${SESSION_WINDOW:-}" ]; then
        if ! printf '%s' "$SESSION_WINDOW" | grep -qE '^[0-9]+$'; then
          SESSION_WINDOW=10
        fi
      else
        SESSION_WINDOW=10
      fi
      if [ "$SESSION_WINDOW" -gt 20 ]; then
        log_warn "SESSION" "session-window > 20 requested ($SESSION_WINDOW); recommended <= 20"
      fi

      # Prepare messages JSON file under RUN_TMPDIR and populate it (atomic)
      ensure_run_tmpdir || { log_error "SESSION" "cannot create run tmpdir"; exit "$GROQBASHERRTMP"; }
      BUILD_MESSAGES_FILE="${RUN_TMPDIR%/}/session-${SESSION_ID}-messages.json"
      export BUILD_MESSAGES_FILE

      # Try Session Engine first (Option A semantics: engine will honor --session-window override)
      if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
        if ! session_engine_build_window "$SESSION_ID" "$SESSION_WINDOW" "${GROQBASH_SESSION_TARGET_BYTES:-}" "$BUILD_MESSAGES_FILE" 2>/dev/null; then
          # Engine failed: fallback to legacy session_read_window
          log_warn "SESSION" "session_engine_build_window failed; falling back to legacy session_read_window"
          session_read_window "$SESSION_ID" "$SESSION_WINDOW" "$BUILD_MESSAGES_FILE" 2>/dev/null || log_warn "SESSION" "legacy session_read_window also failed"
        fi
      else
        # Engine not available: use legacy behavior
        session_read_window "$SESSION_ID" "$SESSION_WINDOW" "$BUILD_MESSAGES_FILE" 2>/dev/null || log_warn "SESSION" "legacy session_read_window failed"
      fi

      # If BUILD_MESSAGES_FILE is still missing or invalid, ensure at least current user message is present
      if [ ! -f "${BUILD_MESSAGES_FILE:-}" ] || [ "$(jq -r '.messages | length' "$BUILD_MESSAGES_FILE" 2>/dev/null || echo 0)" -eq 0 ]; then
        jq -n --arg role "user" --arg content "${CONTENT:-}" '{messages:[{role:$role,content:$content}] }' > "${BUILD_MESSAGES_FILE}"
      fi

      # Final fallback: ensure at least the current user message is present so API never receives messages:[]
      if [ ! -f "${BUILD_MESSAGES_FILE:-}" ] || [ "$(jq -r '.messages | length' "$BUILD_MESSAGES_FILE" 2>/dev/null || echo 0)" -eq 0 ]; then
        jq -n --arg role "user" --arg content "${CONTENT:-}" '{messages:[{role:$role,content:$content}] }' > "${BUILD_MESSAGES_FILE}"
      fi
    fi

    # Now build payload (provider will honor BUILD_MESSAGES_FILE if present)
    build_payload_from_vars

    if ! ensure_api_key_for_provider "$PROVIDER"; then
      log_error "APIKEY" "missing API key; aborting batch item."
      continue
    fi

    if [ "$STREAM_MODE" -eq 1 ]; then
      call_api_streaming || log_error "CALL" "Error during streaming call."
    else
      perform_request_once || true
    fi

    printf '\n----\n'
  done < "$BATCH_FILE"
  exit 0
fi

# Interactive chat mode
if [ "$CHAT_MODE" -eq 1 ]; then
  if [ ! -t 0 ]; then log_error "CHAT" "interactive chat requires a TTY."; exit "$GROQBASHERRTMP"; fi
  [ -t 1 ] && [ "$QUIET" -ne 1 ] && printf 'Entering interactive chat. Press Ctrl+D to exit.\n' >&2
  CONVERSATION=""
  while true; do
    if is_tty_out && [ "$QUIET" -ne 1 ] && { [ "$OUTPUT_MODE" = "text" ] || [ "$OUTPUT_MODE" = "raw" ]; }; then printf '\nYou: ' >&2; fi
    if ! IFS= read -r userline; then printf '\n' >&2; break; fi
    [ -z "$userline" ] && continue
    [ -z "$CONVERSATION" ] && CONVERSATION="$userline" || CONVERSATION="${CONVERSATION}"$'\n\n'"User: ${userline}"
    CONTENT="$userline"

    # Pre-JSON session hook: prepare BUILD_MESSAGES_FILE if sessioning requested
    if [ -n "${SESSION_ID:-}" ]; then
      if ! session_validate_id "$SESSION_ID"; then
        log_error "SESSION" "invalid session id: $SESSION_ID"
        exit "$GROQBASHERRTMP"
      fi
      mkdir -p "$GROQBASH_HISTORY_DIR/sessions" 2>/dev/null || true
      chmod 700 "$GROQBASH_HISTORY_DIR/sessions" 2>/dev/null || true

      if [ -n "${SESSION_WINDOW:-}" ]; then
        if ! printf '%s' "$SESSION_WINDOW" | grep -qE '^[0-9]+$'; then
          SESSION_WINDOW=10
        fi
      else
        SESSION_WINDOW=10
      fi
      if [ "$SESSION_WINDOW" -gt 20 ]; then
        log_warn "SESSION" "session-window > 20 requested ($SESSION_WINDOW); recommended <= 20"
      fi

      ensure_run_tmpdir || { log_error "SESSION" "cannot create run tmpdir"; exit "$GROQBASHERRTMP"; }
      BUILD_MESSAGES_FILE="$RUN_TMPDIR/session-${SESSION_ID}-messages.json"

      # Try Session Engine first; fallback to legacy on any failure
      if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
        if ! session_engine_build_window "$SESSION_ID" "$SESSION_WINDOW" "${GROQBASH_SESSION_TARGET_BYTES:-}" "$BUILD_MESSAGES_FILE" 2>/dev/null; then
          log_warn "SESSION" "session_engine_build_window failed; falling back to legacy session_read_window"
          session_read_window "$SESSION_ID" "$SESSION_WINDOW" "$BUILD_MESSAGES_FILE" || log_warn "SESSION" "legacy session_read_window failed"
        fi
      else
        session_read_window "$SESSION_ID" "$SESSION_WINDOW" "$BUILD_MESSAGES_FILE" || log_warn "SESSION" "legacy session_read_window failed"
      fi

      export BUILD_MESSAGES_FILE
    fi

    build_payload_from_vars
    if ! ensure_api_key_for_provider "$PROVIDER"; then log_error "APIKEY" "missing API key; aborting chat turn."; continue; fi
    if [ "$STREAM_MODE" -eq 1 ]; then call_api_streaming || log_error "CALL" "Streaming call failed."
    else perform_request_once || log_error "CALL" "Call failed."; fi
  done
  exit 0
fi

# Single request (streaming or non-streaming)
if [ "$STREAM_MODE" -eq 1 ]; then

  # Pre-JSON session hook: prepare BUILD_MESSAGES_FILE if sessioning requested
  if [ -n "${SESSION_ID:-}" ]; then
    if ! session_validate_id "$SESSION_ID"; then
      log_error "SESSION" "invalid session id: $SESSION_ID"
      exit "$GROQBASHERRTMP"
    fi
    mkdir -p "$GROQBASH_HISTORY_DIR/sessions" 2>/dev/null || true
    chmod 700 "$GROQBASH_HISTORY_DIR/sessions" 2>/dev/null || true

    if [ -n "${SESSION_WINDOW:-}" ]; then
      if ! printf '%s' "$SESSION_WINDOW" | grep -qE '^[0-9]+$'; then
        SESSION_WINDOW=10
      fi
    else
      SESSION_WINDOW=10
    fi
    if [ "$SESSION_WINDOW" -gt 20 ]; then
      log_warn "SESSION" "session-window > 20 requested ($SESSION_WINDOW); recommended <= 20"
    fi

    ensure_run_tmpdir || { log_error "SESSION" "cannot create run tmpdir"; exit "$GROQBASHERRTMP"; }
    BUILD_MESSAGES_FILE="$RUN_TMPDIR/session-${SESSION_ID}-messages.json"

    # Try Session Engine first; fallback to legacy on any failure
    if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
      if ! session_engine_build_window "$SESSION_ID" "$SESSION_WINDOW" "${GROQBASH_SESSION_TARGET_BYTES:-}" "$BUILD_MESSAGES_FILE" 2>/dev/null; then
        log_warn "SESSION" "session_engine_build_window failed; falling back to legacy session_read_window"
        session_read_window "$SESSION_ID" "$SESSION_WINDOW" "$BUILD_MESSAGES_FILE" || { log_warn "SESSION" "failed to read session window for $SESSION_ID"; rm -f "$BUILD_MESSAGES_FILE" 2>/dev/null || true; }
      fi
    else
      session_read_window "$SESSION_ID" "$SESSION_WINDOW" "$BUILD_MESSAGES_FILE" || { log_warn "SESSION" "failed to read session window for $SESSION_ID"; rm -f "$BUILD_MESSAGES_FILE" 2>/dev/null || true; }
    fi

    export BUILD_MESSAGES_FILE
  fi

  build_payload_from_vars

  # Skip API key prompt in dry-run mode
  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    log_info "DRY" "dry-run: skipping API key check for provider $PROVIDER"
  else
    if ! ensure_api_key_for_provider "$PROVIDER"; then
      log_error "APIKEY" "missing API key; aborting."
      exit "$GROQBASHERRTMP"
    fi
  fi

  if call_api_streaming; then
    log_info "STREAM" "Streaming completed; captured response in $RESP"

    # If sessioning requested, append both user and assistant
    if [ -n "${SESSION_ID:-}" ]; then
      # 1) Append user message (preserve existing semantics) only if non-empty
      if [ -n "${CONTENT:-}" ]; then
        meta_source="cli"
        meta_cmd="$(session_sanitize_cmd "$0 ${ARGS[*]:-}")"
        meta_json="$(jq -c -n --arg source "$meta_source" --arg cmd "$meta_cmd" --arg id "" '{source:$source, cmd:$cmd, id:$id}')"

        if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
          if ! session_engine_append "$SESSION_ID" "user" "$CONTENT" "$meta_json"; then
            log_warn "SESSION" "session_engine_append (user) failed; falling back to legacy session_append"
            session_append "$SESSION_ID" "user" "$CONTENT" "$meta_json" || log_warn "SESSION" "failed to append message to session $SESSION_ID (streaming)"
          fi
        else
          session_append "$SESSION_ID" "user" "$CONTENT" "$meta_json" || log_warn "SESSION" "failed to append message to session $SESSION_ID (streaming)"
        fi
      fi

      # 2) Append assistant response reconstructed from RESP (if present)
      # Only append assistant when not in DRY_RUN and when RESP contains data
      if [ "${DRY_RUN:-0}" -ne 1 ] && [ -s "${RESP:-}" ]; then
        # extract_text_from_resp uses the same extraction logic used by finalize_and_output
        assistant_text="$(extract_text_from_resp || true)"
        # Normalize whitespace-only responses away
        assistant_text="$(printf '%s' "$assistant_text" | sed -e 's/\r$//' -e '/^[[:space:]]*$/d' || true)"
        if [ -n "${assistant_text:-}" ]; then
          meta_source="provider"
          meta_json="$(jq -c -n --arg source "$meta_source" --arg model "$MODEL" --arg id "" '{source:$source, model:$model, id:$id}')"

          if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
            if ! session_engine_append "$SESSION_ID" "assistant" "$assistant_text" "$meta_json"; then
              log_warn "SESSION" "session_engine_append (assistant) failed; falling back to legacy session_append"
              session_append "$SESSION_ID" "assistant" "$assistant_text" "$meta_json" || log_warn "SESSION" "failed to append assistant response to session $SESSION_ID (streaming)"
            fi
          else
            session_append "$SESSION_ID" "assistant" "$assistant_text" "$meta_json" || log_warn "SESSION" "failed to append assistant response to session $SESSION_ID (streaming)"
          fi
        fi
      fi
    fi

    printf '\n'
    exit 0
  else
    log_error "STREAM" "streaming request failed."
    exit "$GROQBASHERRCURL_FAILED"
  fi

else
  # Non-streaming single request path

  if is_tty_out && [ "$QUIET" -ne 1 ] && { [ "$OUTPUT_MODE" = "text" ] || [ "$OUTPUT_MODE" = "raw" ]; }; then
    printf '%b\n' "\033[1;36mYou:\033[0m" >&2
    if [ "${#ARGS[@]}" -gt 0 ]; then
      anyfile=0
      for a in "${ARGS[@]}"; do [ -r "$a" ] && [ -f "$a" ] && { anyfile=1; break; }; done
      [ "$anyfile" -eq 1 ] && printf '%s\n' "(using file contents)" >&2 || printf '%s\n' "$CONTENT" >&2
    else
      printf '%s\n' "$CONTENT" >&2
    fi
    printf '%b\n' "\033[1;32mProvider ($PROVIDER, model: $MODEL):\033[0m" >&2
  fi

  # Pre-JSON session hook: prepare BUILD_MESSAGES_FILE if sessioning requested
  if [ -n "${SESSION_ID:-}" ]; then
    if ! session_validate_id "$SESSION_ID"; then
      log_error "SESSION" "invalid session id: $SESSION_ID"
      exit "$GROQBASHERRTMP"
    fi
    mkdir -p "$GROQBASH_HISTORY_DIR/sessions" 2>/dev/null || true
    chmod 700 "$GROQBASH_HISTORY_DIR/sessions" 2>/dev/null || true

    if [ -n "${SESSION_WINDOW:-}" ]; then
      if ! printf '%s' "$SESSION_WINDOW" | grep -qE '^[0-9]+$'; then
        SESSION_WINDOW=10
      fi
    else
      SESSION_WINDOW=10
    fi
    if [ "$SESSION_WINDOW" -gt 20 ]; then
      log_warn "SESSION" "session-window > 20 requested ($SESSION_WINDOW); recommended <= 20"
    fi

    ensure_run_tmpdir || { log_error "SESSION" "cannot create run tmpdir"; exit "$GROQBASHERRTMP"; }
    BUILD_MESSAGES_FILE="$RUN_TMPDIR/session-${SESSION_ID}-messages.json"

    # Try Session Engine first; fallback to legacy on any failure
    if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
      if ! session_engine_build_window "$SESSION_ID" "$SESSION_WINDOW" "${GROQBASH_SESSION_TARGET_BYTES:-}" "$BUILD_MESSAGES_FILE" 2>/dev/null; then
        log_warn "SESSION" "session_engine_build_window failed; falling back to legacy session_read_window"
        session_read_window "$SESSION_ID" "$SESSION_WINDOW" "$BUILD_MESSAGES_FILE" || { log_warn "SESSION" "failed to read session window for $SESSION_ID"; rm -f "$BUILD_MESSAGES_FILE" 2>/dev/null || true; }
      fi
    else
      session_read_window "$SESSION_ID" "$SESSION_WINDOW" "$BUILD_MESSAGES_FILE" || { log_warn "SESSION" "failed to read session window for $SESSION_ID"; rm -f "$BUILD_MESSAGES_FILE" 2>/dev/null || true; }
    fi

    export BUILD_MESSAGES_FILE
  fi

  build_payload_from_vars

  # Skip API key prompt in dry-run mode
  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    log_info "DRY" "dry-run: skipping API key check for provider $PROVIDER"
  else
    if ! ensure_api_key_for_provider "$PROVIDER"; then
      log_error "APIKEY" "missing API key; aborting."
      exit "$GROQBASHERRTMP"
    fi
  fi

  # Perform request (with retries). After final attempt, append to session if requested.
  if perform_request_once; then
    # On success, append to session if SESSION_ID present (MVP)
    if [ -n "${SESSION_ID:-}" ]; then
      # 1) Append the user message (existing behavior) only if non-empty
      if [ -n "${CONTENT:-}" ]; then
        meta_source="cli"
        meta_cmd="$(session_sanitize_cmd "$0 ${ARGS[*]:-}")"
        meta_json="$(jq -c -n --arg source "$meta_source" --arg cmd "$meta_cmd" --arg id "" '{source:$source, cmd:$cmd, id:$id}')"

        if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
          if ! session_engine_append "$SESSION_ID" "user" "$CONTENT" "$meta_json"; then
            log_warn "SESSION" "session_engine_append (user) failed; falling back to legacy session_append"
            session_append "$SESSION_ID" "user" "$CONTENT" "$meta_json" || log_warn "SESSION" "failed to append message to session $SESSION_ID"
          fi
        else
          session_append "$SESSION_ID" "user" "$CONTENT" "$meta_json" || log_warn "SESSION" "failed to append message to session $SESSION_ID"
        fi
      fi

      # 2) Append the assistant response (new)
      # Only append assistant when not in DRY_RUN and when RESP contains data
      if [ "${DRY_RUN:-0}" -ne 1 ] && [ -s "${RESP:-}" ]; then
        assistant_text="$(extract_text_from_resp || true)"
        assistant_text="$(printf '%s' "$assistant_text" | sed -e 's/\r$//' -e '/^[[:space:]]*$/d' || true)"
        if [ -n "${assistant_text:-}" ]; then
          meta_source="provider"
          meta_json="$(jq -c -n --arg source "$meta_source" --arg model "$MODEL" --arg id "" '{source:$source, model:$model, id:$id}')"

          if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
            if ! session_engine_append "$SESSION_ID" "assistant" "$assistant_text" "$meta_json"; then
              log_warn "SESSION" "session_engine_append (assistant) failed; falling back to legacy session_append"
              session_append "$SESSION_ID" "assistant" "$assistant_text" "$meta_json" || log_warn "SESSION" "failed to append assistant response to session $SESSION_ID"
            fi
          else
            session_append "$SESSION_ID" "assistant" "$assistant_text" "$meta_json" || log_warn "SESSION" "failed to append assistant response to session $SESSION_ID"
          fi
        fi
      fi
    fi
    exit 0
  else
    # On failure, still attempt append (record of attempted message) but do not block
    if [ -n "${SESSION_ID:-}" ]; then
      if [ -n "${CONTENT:-}" ]; then
        meta_source="cli"
        meta_cmd="$(session_sanitize_cmd "$0 ${ARGS[*]:-}")"
        meta_json="$(jq -c -n --arg source "$meta_source" --arg cmd "$meta_cmd" --arg id "" '{source:$source, cmd:$cmd, id:$id}')"

        if [ "${SE_AVAILABLE:-0}" -eq 1 ]; then
          if ! session_engine_append "$SESSION_ID" "user" "$CONTENT" "$meta_json"; then
            log_warn "SESSION" "session_engine_append (user) failed after failed request; falling back to legacy session_append"
            session_append "$SESSION_ID" "user" "$CONTENT" "$meta_json" || log_warn "SESSION" "failed to append message to session $SESSION_ID after failed request"
          fi
        else
          session_append "$SESSION_ID" "user" "$CONTENT" "$meta_json" || log_warn "SESSION" "failed to append message to session $SESSION_ID after failed request"
        fi
      fi
    fi
    exit "$GROQBASHERRAPI"
  fi
fi
