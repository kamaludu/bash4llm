#!/usr/bin/env bash
# =============================================================================
# GroqBash — Bash-first wrapper for the Groq API
# Final hardened release (python removed)
# Version: 2.0.0+flock-b64-hardened
# Requirements (no fallbacks): bash, coreutils, curl, jq, mktemp, stat, flock, base64.
# =============================================================================
set -euo pipefail

# === BOOTSTRAP START ===
# Bootstrapping: metadata, error codes, path resolution, directory creation,
# and verification of required external commands (explicit, no implicit deps).
SCRIPT_NAME="groqbash"
SCRIPT_VERSION="2.0.0+flock-b64-hardened"
SCRIPT_DATE="2026-02-27"

# ---------------------------------------------------------------------------
# Error codes
# ---------------------------------------------------------------------------
GROQBASH_ERR_NO_API_KEY=10
GROQBASH_ERR_BAD_MODEL=11
GROQBASH_ERR_CURL_FAILED=12
GROQBASH_ERR_INVALID_JSON=13
GROQBASH_ERR_NO_PROMPT=14
GROQBASH_ERR_TMP=15
GROQBASH_ERR_API=16
GROQBASH_ERR_INSTALL_EXTRAS=20

GROQBASHERRNOAPIKEY=$GROQBASH_ERR_NO_API_KEY
GROQBASHERRBAD_MODEL=$GROQBASH_ERR_BAD_MODEL
GROQBASHERRCURL_FAILED=$GROQBASH_ERR_CURL_FAILED
GROQBASHERRINVALID_JSON=$GROQBASH_ERR_INVALID_JSON
GROQBASHERRNO_PROMPT=$GROQBASH_ERR_NO_PROMPT
GROQBASHERRTMP=$GROQBASH_ERR_TMP
GROQBASHERRAPI=$GROQBASH_ERR_API
GROQBASHERRINSTALL=$GROQBASH_ERR_INSTALL_EXTRAS

# ---------------------------------------------------------------------------
# Verify mandatory commands (no fallback)
# ---------------------------------------------------------------------------
# Extended to include all external commands actually used in the script.
# Builtins (bash internal) are intentionally NOT listed here.
for cmd in bash jq curl mktemp stat flock base64 find awk sed grep xargs sync \
           readlink date mv cp chmod rm cat head sort tee stdbuf wc; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    printf 'groqbash: ERROR: required command not found: %s\n' "$cmd" >&2
    exit 1
  fi
done

# ---------------------------------------------------------------------------
# Paths and directories
# ---------------------------------------------------------------------------
resolve_script_dir() {
  local src="$0" rl dir
  if command -v readlink >/dev/null 2>&1 && [ -L "$src" ]; then
    rl="$(readlink "$src" 2>/dev/null || true)"
    [ -n "$rl" ] && case "$rl" in /*) src="$rl" ;; *) src="$(dirname "$src")/$rl" ;; esac
  fi
  dir="$(cd "$(dirname "$src")" >/dev/null 2>&1 && pwd || printf '%s' "$(dirname "$src")")"
  printf '%s' "$dir"
}

SCRIPTDIR="$(resolve_script_dir)"
GROQBASH_DIR="${GROQBASH_DIR:-$SCRIPTDIR/groqbash.d}"
GROQBASH_CONFIG_DIR="${GROQBASH_CONFIG_DIR:-$GROQBASH_DIR/config}"
GROQBASH_MODELS_DIR="${GROQBASH_MODELS_DIR:-$GROQBASH_DIR/models}"
GROQBASH_TEMPLATES_DIR="${GROQBASH_TEMPLATES_DIR:-$GROQBASH_DIR/templates}"
GROQBASH_HISTORY_DIR="${GROQBASH_HISTORY_DIR:-$GROQBASH_DIR/history}"
GROQBASH_TMPDIR="${GROQBASH_TMPDIR:-$GROQBASH_DIR/tmp}"
GROQBASH_EXTRAS_DIR="${GROQBASH_EXTRAS_DIR:-$GROQBASH_DIR/extras}"
MODELS_FILE="${MODELS_FILE:-$GROQBASH_MODELS_DIR/models.txt}"

umask 077
mkdir -p "$GROQBASH_CONFIG_DIR" "$GROQBASH_MODELS_DIR" "$GROQBASH_TEMPLATES_DIR" "$GROQBASH_HISTORY_DIR" "$GROQBASH_TMPDIR" "$GROQBASH_EXTRAS_DIR" "$GROQBASH_EXTRAS_DIR/providers" 2>/dev/null || true

# Ensure directories are not symlinks and have strict perms
for d in "$GROQBASH_DIR" "$GROQBASH_CONFIG_DIR" "$GROQBASH_MODELS_DIR" "$GROQBASH_TEMPLATES_DIR" "$GROQBASH_HISTORY_DIR" "$GROQBASH_TMPDIR" "$GROQBASH_EXTRAS_DIR" "$GROQBASH_EXTRAS_DIR/providers"; do
  if [ -L "$d" ]; then
    printf 'groqbash: ERROR: directory is a symlink: %s\n' "$d" >&2
    exit "$GROQBASHERRTMP"
  fi
  mkdir -p "$d" 2>/dev/null || { printf 'groqbash: ERROR: cannot create directory: %s\n' "$d" >&2; exit "$GROQBASHERRTMP"; }
  chmod 700 "$d" 2>/dev/null || true
done

mkdir -p "$GROQBASH_TMPDIR" 2>/dev/null || { printf 'groqbash: ERROR: cannot create tmpdir: %s\n' "$GROQBASH_TMPDIR" >&2; exit "$GROQBASHERRTMP"; }
if [ -L "$GROQBASH_TMPDIR" ]; then
  printf 'groqbash: ERROR: GROQBASH_TMPDIR is a symlink: %s\n' "$GROQBASH_TMPDIR" >&2
  exit "$GROQBASHERRTMP"
fi
chmod 700 "$GROQBASH_TMPDIR" 2>/dev/null || true
export TMPDIR="$GROQBASH_TMPDIR"

# ---------------------------------------------------------------------------
# Logging helpers (structured)
# ---------------------------------------------------------------------------
GROQBASH_DEBUG="${GROQBASH_DEBUG:-0}"
GROQBASH_LOG="${GROQBASH_LOG:-}" # optional path to append structured logs

log_prefix() { printf 'groqbash: %s: ' "$SCRIPT_NAME"; }

log_info() {
  local code="${1:-INFO}" msg="${2:-}"
  if [ "${GROQBASH_DEBUG:-0}" -eq 1 ]; then
    printf '%sINFO: %s: %s\n' "$(log_prefix)" "$code" "$msg" >&2
  fi
  if [ -n "$GROQBASH_LOG" ]; then printf '%s INFO %s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$code" "$msg" >>"$GROQBASH_LOG" 2>/dev/null || true; fi
}

log_warn() {
  local code="${1:-WARN}" msg="${2:-}"
  printf '%sWARN: %s: %s\n' "$(log_prefix)" "$code" "$msg" >&2
  if [ -n "$GROQBASH_LOG" ]; then printf '%s WARN %s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$code" "$msg" >>"$GROQBASH_LOG" 2>/dev/null || true; fi
}

log_error() {
  local code="${1:-ERROR}" msg="${2:-}"
  printf '%sERROR: %s: %s\n' "$(log_prefix)" "$code" "$msg" >&2
  if [ -n "$GROQBASH_LOG" ]; then printf '%s ERROR %s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$code" "$msg" >>"$GROQBASH_LOG" 2>/dev/null || true; fi
}

# ---------------------------------------------------------------------------
# Helper: check colocation of lockfile and resource (device id)
# - Only emits a debug warning if devices differ (useful for NFS detection)
# - Note: flock can be unreliable on network filesystems (NFS). This function
#   only emits a diagnostic when GROQBASH_DEBUG=1; it does not change behavior.
#   Operational recommendation: place lockfiles and resources on the same
#   local filesystem when possible to avoid flock/NFS issues.
# ---------------------------------------------------------------------------
_check_colocation() {
  local lockfile="$1" resource="$2"
  [ "${GROQBASH_DEBUG:-0}" -eq 1 ] || return 0
  if [ ! -e "$lockfile" ] || [ ! -e "$resource" ]; then return 0; fi
  local dev_lock dev_res
  case "$(uname 2>/dev/null || echo Linux)" in
    Darwin)
      dev_lock="$(stat -f %d "$lockfile" 2>/dev/null || true)"
      dev_res="$(stat -f %d "$resource" 2>/dev/null || true)"
      ;;
    *)
      dev_lock="$(stat -c %d "$lockfile" 2>/dev/null || true)"
      dev_res="$(stat -c %d "$resource" 2>/dev/null || true)"
      ;;
  esac
  if [ -n "$dev_lock" ] && [ -n "$dev_res" ] && [ "$dev_lock" != "$dev_res" ]; then
    log_warn "NFS" "lockfile $lockfile and resource $resource are on different devices (dev $dev_lock vs $dev_res). flock on network FS may be unreliable."
  fi
}

# ---------------------------------------------------------------------------
# lock_exec: acquire exclusive flock on a lockfile with timeout
# Usage: lock_exec <lockfile> <timeout> -- <command> [args...]
# On timeout prints structured diagnostic with code LOCKTIMEOUT and returns 124.
# ---------------------------------------------------------------------------
lock_exec() {
  local lockfile="$1"
  local timeout="${2:-10}"
  shift 2
  if [ "$1" != "--" ]; then
    log_error "USAGE" "lock_exec <lockfile> <timeout> -- <cmd> [args...]"
    return 2
  fi
  shift
  mkdir -p "$(dirname "$lockfile")" 2>/dev/null || { log_error "LOCKFAIL" "cannot create lockfile dir: $(dirname "$lockfile")"; return 2; }
  # Optional colocation check (debug only)
  _check_colocation "$lockfile" "$(dirname "$lockfile")"
  (
    if ! flock -x -w "$timeout" 200; then
      printf '%sERROR: LOCKTIMEOUT: could not acquire lock on %s within %s seconds\n' "$(log_prefix)" "$lockfile" "$timeout" >&2
      exit 124
    fi
    "$@"
  ) 200>"$lockfile"
  return $?
}

# ---------------------------------------------------------------------------
# Atomic raw write helper
# - atomic_write <dest> <timeout> -- (reads stdin)
# Note: sync is used as a portable best-effort flush (documented).
# ---------------------------------------------------------------------------
atomic_write() {
  local dest="$1"
  local timeout="${2:-10}"
  shift 2 || true
  [ -n "$dest" ] || return "$GROQBASHERRTMP"
  local destdir lockfile tmp
  destdir="$(dirname -- "$dest")"
  mkdir -p "$destdir" 2>/dev/null || { log_error "ATOMICFAIL" "cannot create dir $destdir"; return "$GROQBASHERRTMP"; }
  lockfile="${destdir}/.groqbash.lock"
  tmp="$(mktemp -p "$destdir" .groq-atomic.XXXXXX 2>/dev/null || true)"
  [ -n "$tmp" ] || tmp="$destdir/.groq-atomic.$$.$RANDOM"
  if ! cat - > "$tmp"; then
    rm -f -- "$tmp" 2>/dev/null || true
    log_error "ATOMICFAIL" "writing to temp failed"
    return "$GROQBASHERRTMP"
  fi
  # Best-effort flush using sync (coreutils). No python dependency.
  # Note: sync is a global flush and is not equivalent to fsync(fd) on a single
  # file descriptor. We use sync as a portable, dependency-free best-effort
  # flush. Atomicity of the operation is still provided by the lock + mv
  # (rename) which is atomic on the same filesystem. However, immediate
  # persistence guarantees on crash depend on the filesystem and kernel.
  sync || true
  chmod 600 "$tmp" 2>/dev/null || true
  lock_exec "$lockfile" "$timeout" -- sh -c '
    set -e
    mv -f -- "$1" "$2"
    chmod 600 "$2" 2>/dev/null || true
  ' _ "$tmp" "$dest" || { rc=$?; rm -f -- "$tmp" 2>/dev/null || true; return "$rc"; }
  return 0
}

# Tmpdir creation under TMP_LOCK to avoid races
make_tmpdir() {
  umask 077
  local tmpd lockfile
  lockfile="$TMP_LOCK"
  mkdir -p "$GROQBASH_TMPDIR" 2>/dev/null || return "$GROQBASHERRTMP"
  lock_exec "$lockfile" "$GROQBASH_LOCK_TIMEOUT_TMP" -- sh -c '
    set -e
    base="$1"
    tmpd="$(mktemp -d -p "$base" groq.XXXX 2>/dev/null || true)"
    if [ -z "$tmpd" ]; then
      tmpd="$base/groq.$$.$RANDOM"
      mkdir -p "$tmpd"
    fi
    chmod 700 "$tmpd" 2>/dev/null || true
    printf "%s" "$tmpd"
  ' _ "$GROQBASH_TMPDIR"
  return $?
}

ensure_run_tmpdir() {
  if [ -n "${RUN_TMPDIR:-}" ] && [ -d "${RUN_TMPDIR:-}" ]; then return 0; fi
  RUN_TMPDIR="$(make_tmpdir)" || { log_error "TMPFAIL" "cannot create RUN_TMPDIR in $GROQBASH_TMPDIR"; exit "$GROQBASHERRTMP"; }
  PAYLOAD="$RUN_TMPDIR/payload.json.b64"
  RESP="$RUN_TMPDIR/resp.json"
  ERRF="$RUN_TMPDIR/err.log"
  trap 'if [ "${GROQBASH_DEBUG:-0}" -eq 0 ]; then cleanup_tmp; else log_info "TMPDEBUG" "preserving RUN_TMPDIR=$RUN_TMPDIR"; fi' EXIT INT TERM
  log_info "TMPCREATE" "Created RUN_TMPDIR: $RUN_TMPDIR"
}

cleanup_tmp() {
  if [ -n "${RUN_TMPDIR:-}" ]; then
    case "$RUN_TMPDIR" in
      "$GROQBASH_TMPDIR"/*|"$GROQBASH_TMPDIR")
        rm -rf -- "$RUN_TMPDIR" 2>/dev/null || true
        ;;
      *)
        ;;
    esac
  fi
}
# === BOOTSTRAP END ===

# === HISTORY_MANIFEST START ===
# Portable base64 wrappers (Linux, macOS, BusyBox)
# - b64encode: reads stdin, writes base64 without newlines
# - b64decode: reads base64 stdin, writes decoded bytes
# All code must use these wrappers exclusively.
b64encode() {
  # Prefer option that prevents wrapping; otherwise strip newlines
  if base64 --help >/dev/null 2>&1 && base64 --help 2>&1 | grep -q -- '-w'; then
    base64 -w0
  else
    base64 | tr -d '\n'
  fi
}

b64decode() {
  # Use -d or -D depending on implementation
  if base64 --help >/dev/null 2>&1 && base64 --help 2>&1 | grep -q -- '-d'; then
    base64 -d
  else
    base64 -D
  fi
}

# Atomic base64 write/read helpers (use for payloads, manifests, staging)
# - b64_atomic_write <dest.b64> <timeout> -- (reads stdin)
# - b64_atomic_read <src.b64> (writes decoded to stdout)
b64_atomic_write() {
  local dest="$1"
  local timeout="${2:-10}"
  shift 2 || true
  [ -n "$dest" ] || { log_error "B64FAIL" "b64_atomic_write: dest required"; return "$GROQBASHERRTMP"; }
  local destdir tmp lockfile
  destdir="$(dirname -- "$dest")"
  mkdir -p "$destdir" 2>/dev/null || { log_error "B64FAIL" "cannot create dir $destdir"; return "$GROQBASHERRTMP"; }
  lockfile="$MODELS_LOCK"
  tmp="$(mktemp -p "$destdir" .groq-b64.XXXXXX 2>/dev/null || true)"
  [ -n "$tmp" ] || tmp="$destdir/.groq-b64.$$.$RANDOM"
  if ! b64encode > "$tmp"; then
    rm -f -- "$tmp" 2>/dev/null || true
    log_error "B64FAIL" "base64 encoding failed"
    return "$GROQBASHERRTMP"
  fi
  chmod 600 "$tmp" 2>/dev/null || true
  lock_exec "$lockfile" "$timeout" -- sh -c '
    set -e
    mv -f -- "$1" "$2"
    chmod 600 "$2" 2>/dev/null || true
  ' _ "$tmp" "$dest" || { rc=$?; rm -f -- "$tmp" 2>/dev/null || true; return "$rc"; }
  return 0
}

b64_atomic_read() {
  local src="$1"
  [ -f "$src" ] || return 1
  b64decode < "$src"
  return $?
}

# Portable helpers for rotate_history and save_to_history
file_size() {
  local f="$1"
  if [ -z "$f" ] || [ ! -f "$f" ]; then
    printf '0'
    return 0
  fi
  case "$(uname 2>/dev/null || echo Linux)" in
    Darwin) stat -f %z "$f" 2>/dev/null || printf '0' ;;
    *) stat -c %s "$f" 2>/dev/null || printf '0' ;;
  esac
}

list_files_sorted_by_mtime() {
  local dir="$1"
  find "$dir" -type f -print0 2>/dev/null | while IFS= read -r -d '' f; do
    case "$(uname 2>/dev/null || echo Linux)" in
      Darwin) mtime="$(stat -f %m "$f" 2>/dev/null || echo 0)" ;;
      *) mtime="$(stat -c %Y "$f" 2>/dev/null || echo 0)" ;;
    esac
    printf '%s|%s\n' "$mtime" "$f"
  done | sort -n
}

# History rotation and compaction (portable)
GROQBASH_ROTATE_HISTORY="${GROQBASH_ROTATE_HISTORY:-0}"
GROQBASH_HISTORY_MAX_FILES="${GROQBASH_HISTORY_MAX_FILES:-100}"
GROQBASH_HISTORY_MAX_BYTES="${GROQBASH_HISTORY_MAX_BYTES:-104857600}" # 100MB
GROQBASH_HISTORY_KEEP_DAYS="${GROQBASH_HISTORY_KEEP_DAYS:-90}"

rotate_history() {
  local timeout="${1:-$GROQBASH_LOCK_TIMEOUT_HISTORY}"
  lock_exec "$HISTORY_LOCK" "$timeout" -- sh -c '
    set -e
    dir="$1"
    max_files="$2"
    max_bytes="$3"
    keep_days="$4"
    # Remove files older than keep_days
    find "$dir" -type f -mtime +"$keep_days" -print0 | xargs -0 -r rm -f --
    # Remove oldest files until total bytes <= max_bytes
    while :; do
      total=0
      while IFS= read -r -d "" f; do
        if [ -f "$f" ]; then
          size=$( (case "$(uname 2>/dev/null || echo Linux)" in Darwin) stat -f %z "$f" ;; *) stat -c %s "$f" ;; esac 2>/dev/null || echo 0)
          total=$((total + size))
        fi
      done < <(find "$dir" -type f -print0)
      [ "$total" -le "$max_bytes" ] && break
      oldest="$(list_files_sorted_by_mtime "$dir" | head -n1 | awk -F"|" '{print $2}')"
      [ -z "$oldest" ] && break
      rm -f -- "$oldest"
    done
    # Ensure number of files <= max_files
    while :; do
      count=$(find "$dir" -type f | wc -l)
      [ "$count" -le "$max_files" ] && break
      oldest="$(list_files_sorted_by_mtime "$dir" | head -n1 | awk -F"|" '{print $2}')"
      [ -z "$oldest" ] && break
      rm -f -- "$oldest"
    done
  ' _ "$GROQBASH_HISTORY_DIR" "$GROQBASH_HISTORY_MAX_FILES" "$GROQBASH_HISTORY_MAX_BYTES" "$GROQBASH_HISTORY_KEEP_DAYS"
  return $?
}

save_to_history() {
  local content="$1"
  local filename
  filename="$(date +%Y%m%d-%H%M%S)-groq-output-$$.txt"
  mkdir -p "$GROQBASH_HISTORY_DIR" 2>/dev/null || true
  local tmpf dest lockfile
  tmpf="$(mktemp -p "$GROQBASH_TMPDIR" groq-out.XXXX 2>/dev/null || true)"
  [ -n "$tmpf" ] || { log_error "HISTORYFAIL" "save_to_history: cannot create tmp file"; return "$GROQBASHERRTMP"; }
  printf '%s\n' "$content" > "$tmpf"
  dest="$GROQBASH_HISTORY_DIR/$filename"
  lockfile="$HISTORY_LOCK"
  lock_exec "$lockfile" "$GROQBASH_LOCK_TIMEOUT_HISTORY" -- sh -c '
    set -e
    mv -f -- "$1" "$2"
    chmod 600 "$2" 2>/dev/null || true
  ' _ "$tmpf" "$dest" || { rc=$?; rm -f -- "$tmpf" 2>/dev/null || true; return "$rc"; }
  if [ "${GROQBASH_ROTATE_HISTORY:-0}" -eq 1 ]; then
    rotate_history "$GROQBASH_LOCK_TIMEOUT_HISTORY" || true
  fi
  log_info "HISTORY_SAVE" "$dest"
  return 0
}

# Manifest multimodale helpers (atomic, jq --arg usage)
# All base64 operations use b64encode/b64decode and b64_atomic_write/read.
manifest_create() {
  local manifest="$1"
  local timeout="${2:-$GROQBASH_LOCK_TIMEOUT_MODELS}"
  mkdir -p "$(dirname "$manifest")" 2>/dev/null || { log_error "MANIFESTFAIL" "manifest_create: cannot create dir"; return 1; }
  lock_exec "${manifest}.lock" "$timeout" -- sh -c '
    set -e
    manifest="$1"
    tmp="$(mktemp -p "$(dirname "$manifest")" manifest.tmp.XXXX)"
    printf "%s" "{\"parts\":[]}" > "$tmp"
    # write base64 staging using b64encode
    b64encode < "$tmp" > "${manifest}.b64"
    mv -f "$tmp" "$manifest"
    chmod 600 "$manifest" 2>/dev/null || true
  ' _ "$manifest"
  return $?
}

manifest_add_part() {
  local manifest="$1" name="$2" file_path="$3" mime="$4" timeout="${5:-$GROQBASH_LOCK_TIMEOUT_MODELS}"
  [ -f "$file_path" ] || { log_error "MANIFESTFAIL" "manifest_add_part: file not found: $file_path"; return 1; }
  mkdir -p "$(dirname "$manifest")" 2>/dev/null || true
  # Ensure manifest exists under lock
  lock_exec "${manifest}.lock" "$timeout" -- sh -c '
    set -e
    manifest="$1"
    if [ ! -f "$manifest" ] && [ ! -f "${manifest}.b64" ]; then
      tmpinit="$(mktemp -p "$(dirname "$manifest")" manifest.init.XXXX)"
      printf "%s" "{\"parts\":[]}" > "$tmpinit"
      mv -f "$tmpinit" "$manifest"
      b64encode < "$manifest" > "${manifest}.b64"
      chmod 600 "$manifest" 2>/dev/null || true
    fi
  ' _ "$manifest"
  # Stage the part as base64 (unique name)
  local destdir part_b64 tmpstamp part_tmp
  destdir="$(dirname "$manifest")"
  tmpstamp="$(date +%s)-$$"
  part_b64="$destdir/parts-$(basename "$file_path").${tmpstamp}.b64"
  part_tmp="$GROQBASH_TMPDIR/part.${tmpstamp}.tmp"
  b64encode < "$file_path" > "$part_tmp" || { rm -f "$part_tmp" 2>/dev/null || true; log_error "B64FAIL" "manifest_add_part: b64 encode failed"; return 1; }
  mv -f "$part_tmp" "$part_b64"
  chmod 600 "$part_b64" 2>/dev/null || true
  # Now update manifest atomically under lock using jq --arg
  lock_exec "${manifest}.lock" "$timeout" -- sh -c '
    set -e
    manifest="$1"
    part_b64="$2"
    name="$3"
    mime="$4"
    tmp="$(mktemp -p "$(dirname "$manifest")" manifest.edit.XXXX)"
    # decode manifest.b64 if present, else use manifest file
    if [ -f "${manifest}.b64" ]; then
      b64decode < "${manifest}.b64" > "$tmp" 2>/dev/null || printf "%s" "{\"parts\":[]}" > "$tmp"
    elif [ -f "$manifest" ]; then
      cp -f "$manifest" "$tmp"
    else
      printf "%s" "{\"parts\":[]}" > "$tmp"
    fi
    jq --arg name "$name" --arg path "$part_b64" --arg enc "b64" --arg type "$mime" \
       '.parts += [{name:$name, path:$path, encoding:$enc, type:$type}]' "$tmp" > "${tmp}.new"
    mv -f "${tmp}.new" "$tmp"
    b64encode < "$tmp" > "${manifest}.b64"
    mv -f "$tmp" "$manifest"
    chmod 600 "$manifest" 2>/dev/null || true
    rm -f "$tmp" 2>/dev/null || true
  ' _ "$manifest" "$part_b64" "$name" "$mime" || { log_error "MANIFESTFAIL" "manifest_add_part: update failed"; return 1; }
  log_info "MANIFEST_ADD" "added part $name -> $part_b64"
  return 0
}

manifest_read() {
  local manifest="$1"
  if [ -f "$manifest" ]; then
    cat "$manifest"
    return 0
  fi
  if [ -f "${manifest}.b64" ]; then
    b64decode < "${manifest}.b64"
    return $?
  fi
  return 1
}
# === HISTORY_MANIFEST END ===

# === INSTALL_EXTRAS START ===
# Minimal, portable implementation following the user's reduced plan.
# Provides: --install-extras [components...] --source <path> --force --dry-run
# Uses GROQBASH_EXTRAS_SOURCE as optional env var for source path.

# Configuration for installer
GROQBASH_EXTRAS_SOURCE="${GROQBASH_EXTRAS_SOURCE:-}"
INSTALL_LOCK="$GROQBASH_EXTRAS_DIR/.install.lock"
INSTALL_RECORD="$GROQBASH_EXTRAS_DIR/INSTALLATION-RECORD"

# Helper: compute sha256 if available, else empty
_compute_sha256() {
  local file="$1"
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$file" 2>/dev/null | awk '{print $1}'
    return 0
  fi
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$file" 2>/dev/null | awk '{print $1}'
    return 0
  fi
  # no checksum tool available
  printf ''
  return 0
}

# Helper: normalize path to absolute without using readlink -f
_normalize_path() {
  local path="$1"
  if [ -z "$path" ]; then
    printf '%s' ""
    return 0
  fi
  # If already absolute, use subshell to resolve . and ..
  if [ "${path:0:1}" = "/" ]; then
    ( cd "$(dirname "$path")" >/dev/null 2>&1 && printf '%s/%s' "$(pwd)" "$(basename "$path")" ) || printf '%s' "$path"
    return 0
  fi
  # relative path: resolve relative to current working dir
  ( cd "$(pwd)" >/dev/null 2>&1 && printf '%s/%s' "$(pwd)" "$path" ) || printf '%s' "$path"
  return 0
}

# Helper: safe join path and ensure dest is under GROQBASH_EXTRAS_DIR
_is_under_extras() {
  local dest="$1"
  # Normalize both paths
  local norm_dest norm_base
  norm_dest="$(_normalize_path "$dest")"
  norm_base="$(_normalize_path "$GROQBASH_EXTRAS_DIR")"
  case "$norm_dest" in
    "$norm_base"/*|"$norm_base") return 0 ;;
    *) return 1 ;;
  esac
}

# Helper: resolve symlink target without readlink -f; limit depth to avoid loops
_resolve_symlink_safe() {
  local src="$1"
  local depth=0
  local cur="$src"
  while [ -L "$cur" ] && [ "$depth" -lt 8 ]; do
    local link
    link="$(readlink "$cur" 2>/dev/null || true)"
    if [ -z "$link" ]; then
      break
    fi
    # If relative, make it relative to the symlink's directory
    if [ "${link:0:1}" != "/" ]; then
      local base_dir
      base_dir="$(cd "$(dirname "$cur")" >/dev/null 2>&1 && pwd || true)"
      if [ -n "$base_dir" ]; then
        cur="$base_dir/$link"
      else
        cur="$(dirname "$cur")/$link"
      fi
    else
      cur="$link"
    fi
    depth=$((depth + 1))
  done
  # Normalize final path
  _normalize_path "$cur"
  return 0
}

# Helper: compare identity using sha256 if available, else mtime+size
_is_same_file() {
  local a="$1" b="$2"
  if [ ! -f "$a" ] || [ ! -f "$b" ]; then return 1; fi
  local ha hb
  ha="$(_compute_sha256 "$a")"
  hb="$(_compute_sha256 "$b")"
  if [ -n "$ha" ] && [ -n "$hb" ]; then
    [ "$ha" = "$hb" ] && return 0 || return 1
  fi
  # fallback to size+mtime
  local sa sb ma mb
  sa="$(file_size "$a")" || sa=0
  sb="$(file_size "$b")" || sb=0
  case "$(uname 2>/dev/null || echo Linux)" in
    Darwin) ma="$(stat -f %m "$a" 2>/dev/null || echo 0)"; mb="$(stat -f %m "$b" 2>/dev/null || echo 0)";;
    *) ma="$(stat -c %Y "$a" 2>/dev/null || echo 0)"; mb="$(stat -c %Y "$b" 2>/dev/null || echo 0)";;
  esac
  [ "$sa" -eq "$sb" ] && [ "$ma" -eq "$mb" ] && return 0 || return 1
}

# Helper: atomic copy of a single file from src to dest (dest path must be under extras)
_copy_file_atomic() {
  local src="$1" dest="$2" force="$3" dryrun="$4"
  # Validate dest under extras
  if ! _is_under_extras "$dest"; then
    log_error "INSTALL" "destination outside extras: $dest"
    return 2
  fi
  mkdir -p "$(dirname "$dest")" 2>/dev/null || { log_error "INSTALL" "cannot create dest dir: $(dirname "$dest")"; return 2; }
  if [ -e "$dest" ] && [ "$force" != "1" ]; then
    if _is_same_file "$src" "$dest"; then
      # identical, nothing to do
      return 0
    else
      # conflict
      return 3
    fi
  fi
  if [ "$dryrun" = "1" ]; then
    return 0
  fi
  # create temp file in same dir with mktemp fallback
  local tmp
  tmp="$(mktemp -p "$(dirname "$dest")" .groq-extras.tmp.XXXXXX 2>/dev/null || true)"
  if [ -z "$tmp" ]; then
    tmp="$(dirname "$dest")/.groq-extras.$$.$RANDOM"
  fi
  # Prefer portable copy: use cat to avoid cp option incompatibilities
  if ! cat -- "$src" > "$tmp" 2>/dev/null; then
    rm -f -- "$tmp" 2>/dev/null || true
    log_error "INSTALL" "copy failed (cat): $src -> $tmp"
    return 2
  fi
  # set permissions: base 600, if src executable then 700
  if [ -x "$src" ]; then
    if ! chmod 700 "$tmp" 2>/dev/null; then
      # chmod failure is non-blocking; warn user (common on NTFS/WSL)
      log_warn "INSTALL" "chmod failed on $dest (filesystem may be non-POSIX, e.g. NTFS/WSL)"
    fi
  else
    if ! chmod 600 "$tmp" 2>/dev/null; then
      # chmod failure is non-blocking; warn user (common on NTFS/WSL)
      log_warn "INSTALL" "chmod failed on $dest (filesystem may be non-POSIX, e.g. NTFS/WSL)"
    fi
  fi
  # atomic move
  if ! mv -f -- "$tmp" "$dest" 2>/dev/null; then
    rm -f -- "$tmp" 2>/dev/null || true
    log_error "INSTALL" "mv failed: $tmp -> $dest"
    return 2
  fi
  return 0
}

# Helper: record installation entries (atomic)
_record_installation() {
  local source="$1"
  shift
  local files=("$@")
  local record_tmp
  record_tmp="$(mktemp -p "$GROQBASH_EXTRAS_DIR" .install-record.XXXXXX 2>/dev/null || true)"
  [ -n "$record_tmp" ] || record_tmp="$GROQBASH_EXTRAS_DIR/.install-record.$$.$RANDOM"
  {
    printf 'timestamp=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    printf 'source=%s\n' "$source"
    printf 'files=\n'
    for f in "${files[@]}"; do
      printf '%s\n' "$f"
    done
  } > "$record_tmp"
  chmod 600 "$record_tmp" 2>/dev/null || true
  mv -f -- "$record_tmp" "$INSTALL_RECORD" 2>/dev/null || true
  return 0
}

# Main installer orchestrator
install_extras() {
  # args: components... (empty => all)
  local components=("$@")
  local source_path=""
  local force_flag="${INSTALL_EXTRAS_FORCE:-0}"
  local dryrun_flag="${INSTALL_EXTRAS_DRYRUN:-0}"
  # Determine source: precedence --source (via INSTALL_EXTRAS_SOURCE var), env GROQBASH_EXTRAS_SOURCE, default locations
  if [ -n "${INSTALL_EXTRAS_SOURCE:-}" ]; then
    source_path="${INSTALL_EXTRAS_SOURCE}"
  elif [ -n "${GROQBASH_EXTRAS_SOURCE:-}" ]; then
    source_path="${GROQBASH_EXTRAS_SOURCE}"
  else
    # default search order
    if [ -d "$SCRIPTDIR/extras" ] && [ ! -L "$SCRIPTDIR/extras" ]; then
      source_path="$SCRIPTDIR/extras"
    elif [ -d "$SCRIPTDIR/../extras" ] && [ ! -L "$SCRIPTDIR/../extras" ]; then
      source_path="$SCRIPTDIR/../extras"
    else
      source_path=""
    fi
  fi

  if [ -z "$source_path" ] || [ ! -d "$source_path" ]; then
    log_error "INSTALL" "extras source not found or not a directory"
    return "$GROQBASHERRINSTALL"
  fi

  # Ensure source is not a symlink
  if [ -L "$source_path" ]; then
    log_error "INSTALL" "extras source is a symlink; refusing to use symlinked source: $source_path"
    return "$GROQBASHERRINSTALL"
  fi

  # Normalize source_path for robust comparisons
  source_path="$(_normalize_path "$source_path")"

  # Ensure destination exists
  mkdir -p "$GROQBASH_EXTRAS_DIR" 2>/dev/null || { log_error "INSTALL" "cannot create extras destination: $GROQBASH_EXTRAS_DIR"; return "$GROQBASHERRINSTALL"; }
  chmod 700 "$GROQBASH_EXTRAS_DIR" 2>/dev/null || true

  # Acquire install lock using flock (blocking with timeout loop)
  exec 9>"$INSTALL_LOCK" 2>/dev/null || { log_error "INSTALL" "cannot open install lock: $INSTALL_LOCK"; return "$GROQBASHERRINSTALL"; }
  # Ensure lock FD is always closed on function exit or exit of shell
  trap 'exec 9>&- || true' RETURN EXIT

  local waited=0
  # Timeout (seconds) for acquiring the install lock.
  # Default is 10 seconds; can be overridden by exporting GROQBASH_LOCK_TIMEOUT_MODELS.
  local timeout="${GROQBASH_LOCK_TIMEOUT_MODELS:-10}"
  while ! flock -x -w 1 9 2>/dev/null; do
    waited=$((waited + 1))
    if [ "$waited" -ge "$timeout" ]; then
      log_error "INSTALL" "could not acquire install lock within timeout"
      exec 9>&- || true
      return "$GROQBASHERRINSTALL"
    fi
    sleep 1
  done
  # At this point lock held on fd 9

  log_info "INSTALL" "using source: $source_path"
  log_info "INSTALL" "destination: $GROQBASH_EXTRAS_DIR"
  log_info "INSTALL" "components: ${components[*]:-<all>}"
  log_info "INSTALL" "force: $force_flag dry-run: $dryrun_flag"

  # Build list of files to process
  local -a to_copy
  local -a copied_files
  local -a skipped_files
  local -a conflict_files
  local -a symlink_rejected

  if [ "${#components[@]}" -eq 0 ]; then
    # all files under source
    while IFS= read -r -d '' f; do
      to_copy+=("$f")
    done < <(find "$source_path" -mindepth 1 -print0 2>/dev/null)
  else
    # only specified components: treat each as immediate child under source
    local comp
    for comp in "${components[@]}"; do
      # sanitize comp: no slashes allowed
      case "$comp" in
        */*|*\\*) log_warn "INSTALL" "invalid component name (skipping): $comp"; continue ;;
      esac
      if [ -d "$source_path/$comp" ]; then
        while IFS= read -r -d '' f; do
          to_copy+=("$f")
        done < <(find "$source_path/$comp" -mindepth 1 -print0 2>/dev/null)
      elif [ -f "$source_path/$comp" ]; then
        to_copy+=("$source_path/$comp")
      else
        log_warn "INSTALL" "component not found in source: $comp"
      fi
    done
  fi

  # Iterate and copy
  local src dest rel resolved src_norm
  for src in "${to_copy[@]}"; do
    # normalize src path for robust rel computation
    src_norm="$(_normalize_path "$src")"
    # compute relative path from source_path
    rel="${src_norm#$source_path/}"
    dest="$GROQBASH_EXTRAS_DIR/$rel"

    # If src is symlink, resolve safely
    if [ -L "$src" ]; then
      resolved="$(_resolve_symlink_safe "$src")"
      resolved="$(_normalize_path "$resolved")"
      if [ -z "$resolved" ]; then
        symlink_rejected+=("$rel")
        log_warn "INSTALL" "symlink resolution failed or empty: $src"
        continue
      fi
      # If resolved path is not under source_path, reject
      case "$resolved" in
        "$source_path"/*|"$source_path")
          # treat resolved as the real source
          src="$resolved"
          src_norm="$resolved"
          ;;
        *)
          symlink_rejected+=("$rel")
          log_warn "INSTALL" "symlink points outside source; rejecting: $rel -> $resolved"
          continue
          ;;
      esac
    fi

    # If src is directory, ensure dest dir exists and continue
    if [ -d "$src" ]; then
      if [ "$dryrun_flag" = "1" ]; then
        skipped_files+=("$rel (dir)")
        continue
      fi
      mkdir -p "$dest" 2>/dev/null || { log_warn "INSTALL" "cannot create dir: $dest"; continue; }
      chmod 700 "$dest" 2>/dev/null || true
      skipped_files+=("$rel (dir)")
      continue
    fi

    # Only process regular files
    if [ ! -f "$src" ]; then
      log_warn "INSTALL" "skipping non-regular file: $rel"
      skipped_files+=("$rel (non-regular)")
      continue
    fi

    # Validate destination under extras
    if ! _is_under_extras "$dest"; then
      log_error "INSTALL" "computed destination outside extras: $dest"
      exec 9>&- || true
      return "$GROQBASHERRINSTALL"
    fi

    # Decide copy vs skip vs conflict
    # Conflict handling: by design, conflicts (existing differing files) are treated as warnings.
    # The installer will skip these files and exit with code 0; use --force to overwrite.
    if [ -e "$dest" ] && [ "$force_flag" != "1" ]; then
      if _is_same_file "$src" "$dest"; then
        skipped_files+=("$rel (identical)")
        continue
      else
        conflict_files+=("$rel")
        log_warn "INSTALL" "conflict (not overwriting): $rel"
        continue
      fi
    fi

    # Perform copy (atomic)
    if [ "$dryrun_flag" = "1" ]; then
      copied_files+=("$rel (dry-run)")
      continue
    fi

    if _copy_file_atomic "$src" "$dest" "$force_flag" "$dryrun_flag"; then
      copied_files+=("$rel")
    else
      local rc=$?
      # Conflict code returned by _copy_file_atomic is 3
      # Conflicts are warnings per design (not blocking errors)
      if [ "$rc" -eq 3 ]; then
        # Conflict handling: record and warn; installer continues.
        conflict_files+=("$rel")
        log_warn "INSTALL" "conflict detected for $rel"
      else
        log_error "INSTALL" "failed to copy $rel (rc $rc)"
        exec 9>&- || true
        return "$GROQBASHERRINSTALL"
      fi
    fi
  done

  # Write INSTALLATION-RECORD if any files copied (and not dry-run)
  if [ "${#copied_files[@]}" -gt 0 ] && [ "$dryrun_flag" != "1" ]; then
    _record_installation "$source_path" "${copied_files[@]}"
  fi

  # Release lock (trap RETURN/EXIT will close fd 9)
  exec 9>&- || true

  # Print summary
  log_info "INSTALL_SUMMARY" "source=$source_path"
  log_info "INSTALL_SUMMARY" "copied=${#copied_files[@]} skipped=${#skipped_files[@]} conflicts=${#conflict_files[@]} symlink_rejected=${#symlink_rejected[@]}"

  # Detailed logs if debug
  if [ "${GROQBASH_DEBUG:-0}" -eq 1 ]; then
    [ "${#copied_files[@]}" -gt 0 ] && printf 'Copied files:\n' && printf '%s\n' "${copied_files[@]}" >&2 || true
    [ "${#skipped_files[@]}" -gt 0 ] && printf 'Skipped:\n' && printf '%s\n' "${skipped_files[@]}" >&2 || true
    [ "${#conflict_files[@]}" -gt 0 ] && printf 'Conflicts:\n' && printf '%s\n' "${conflict_files[@]}" >&2 || true
    [ "${#symlink_rejected[@]}" -gt 0 ] && printf 'Symlink rejected:\n' && printf '%s\n' "${symlink_rejected[@]}" >&2 || true
  fi

  # Exit code: 0 if no blocking errors; conflicts are warnings per design
  return 0
}
# === INSTALL_EXTRAS END ===

# === PROVIDER START ===
# Provider embedded: groq (full implementations)
# All base64 usage uses b64encode/b64decode and b64_atomic_write/read.
GROQ_API_KEY="${GROQ_API_KEY:-}"
if [ -n "${PROVIDER_API_ENV_groq:-}" ]; then
  if [ -n "${!PROVIDER_API_ENV_groq:-}" ]; then
    GROQ_API_KEY="${!PROVIDER_API_ENV_groq}"
  fi
fi

_mktemp_in_dir() {
  local dir="$1" tmpf
  [ -n "$dir" ] || return "$GROQBASHERRTMP"
  [ -d "$dir" ] || return "$GROQBASHERRTMP"
  tmpf="$(mktemp -p "$dir" groq-XXXX 2>/dev/null || true)"
  [ -z "$tmpf" ] && return "$GROQBASHERRTMP"
  printf '%s' "$tmpf"
  return 0
}

buildpayload_groq() {
  local workdir tmp_payload model_in_file model_to_use user_prompt stream_json
  workdir="${RUN_TMPDIR:-}"
  if [ -z "$workdir" ] || [ ! -d "$workdir" ]; then
    workdir="$(make_tmpdir 2>/dev/null || true)"
  fi
  [ -n "$workdir" ] || return "$GROQBASHERRTMP"
  tmp_payload="$(_mktemp_in_dir "$workdir")" || return "$GROQBASHERRTMP"
  umask 077
  if is_truthy "${STREAM_MODE:-0}"; then stream_json=true; else stream_json=false; fi

  if [ -n "${JSON_INPUT:-}" ]; then
    if jq -e 'has("messages")' "$JSON_INPUT" >/dev/null 2>&1; then
      b64_atomic_write "$PAYLOAD" 10 < "$JSON_INPUT" || return "$GROQBASHERRTMP"
      return 0
    fi
    if jq -e 'has("prompt")' "$JSON_INPUT" >/dev/null 2>&1; then
      user_prompt="$(jq -r '.prompt' "$JSON_INPUT" 2>/dev/null || true)"
      model_in_file="$(jq -r '.model // empty' "$JSON_INPUT" 2>/dev/null || true)"
      model_to_use="${model_in_file:-$MODEL}"
      jq -n --arg model "$model_to_use" \
            --argjson stream "$stream_json" \
            --arg ture "$TURE" \
            --arg max_tokens "$MAX_TOKENS" \
            --arg user "$user_prompt" \
            '{model:$model, stream:$stream, temperature:($ture|tonumber), max_tokens:($max_tokens|tonumber), messages:[{role:"user",content:$user}] }' >"$tmp_payload"
      b64_atomic_write "$PAYLOAD" 10 < "$tmp_payload" || return "$GROQBASHERRTMP"
      return 0
    fi
    b64_atomic_write "$PAYLOAD" 10 < "$JSON_INPUT" || return "$GROQBASHERRTMP"
    return 0
  fi

  if [ -n "${SYSTEM_PROMPT:-}" ]; then
    jq -n --arg model "$MODEL" \
          --argjson stream "$stream_json" \
          --arg ture "$TURE" \
          --arg max_tokens "$MAX_TOKENS" \
          --arg system "$SYSTEM_PROMPT" \
          --arg user "$CONTENT" \
          '{model:$model, stream:$stream, temperature:($ture|tonumber), max_tokens:($max_tokens|tonumber), messages:[{role:"system",content:$system},{role:"user",content:$user}] }' >"$tmp_payload"
  else
    jq -n --arg model "$MODEL" \
          --argjson stream "$stream_json" \
          --arg ture "$TURE" \
          --arg max_tokens "$MAX_TOKENS" \
          --arg user "$CONTENT" \
          '{model:$model, stream:$stream, temperature:($ture|tonumber), max_tokens:($max_tokens|tonumber), messages:[{role:"user",content:$user}] }' >"$tmp_payload"
  fi

  b64_atomic_write "$PAYLOAD" 10 < "$tmp_payload" || return "$GROQBASHERRTMP"
  return 0
}

buildpayloadgroq() { buildpayload_groq "$@"; }

call_api_groq() {
  if [ -z "${GROQ_API_KEY:-}" ]; then log_error "APIKEY" "GROQ_API_KEY is not set."; return "$GROQBASHERRNOAPIKEY"; fi
  if [ -z "${PAYLOAD:-}" ] || [ ! -s "${PAYLOAD:-}" ]; then log_error "PAYLOAD" "payload file missing or empty: ${PAYLOAD:-<unset>}"; return "$GROQBASHERRTMP"; fi
  if is_truthy "${DRY_RUN:-0}"; then log_info "DRYRUN" "DRY-RUN: skipping HTTP call"; return 0; fi

  ensure_run_tmpdir || return "$GROQBASHERRTMP"
  ERRF="${ERRF:-$RUN_TMPDIR/curl.err}"
  RESP="${RESP:-$RUN_TMPDIR/resp.json}"

  local workdir tmpout http_code _time_total api_url rc decoded_payload
  workdir="${RUN_TMPDIR:-}"
  [ -n "$workdir" ] || return "$GROQBASHERRTMP"
  tmpout="$(_mktemp_in_dir "$workdir")" || return "$GROQBASHERRTMP"
  api_url="https://api.groq.com/openai/v1/chat/completions"

  decoded_payload="$workdir/payload.dec.$$"
  b64_atomic_read "$PAYLOAD" > "$decoded_payload" || { rm -f "$decoded_payload" 2>/dev/null || true; return "$GROQBASHERRTMP"; }

  if ! curl "${CURL_BASE_OPTS[@]}" -H "Authorization: Bearer ${GROQ_API_KEY}" -H "Content-Type: application/json" --data-binary @"$decoded_payload" -o "$RESP" -w '%{http_code} %{time_total}' "$api_url" 2>"$ERRF" >"$tmpout"; then
    rc=$?
  else
    rc=0
  fi

  rm -f "$decoded_payload" 2>/dev/null || true
  read -r http_code _time_total < "$tmpout" 2>/dev/null || http_code="$(cat "$tmpout" 2>/dev/null || echo "000")"
  rm -f "$tmpout" 2>/dev/null || true

  case "$http_code" in
    2*) return 0 ;;
    *) log_error "HTTP" "HTTP error code: $http_code"; log_info "RESPHEAD" "Response (head):"; head -n 200 "$RESP" >&2 || true; log_info "CURLERR" "Curl stderr (head):"; head -n 200 "$ERRF" >&2 || true; return "$GROQBASHERRAPI" ;;
  esac
}

call_api_groq_legacy() { call_api_groq "$@"; }

call_api_streaming_groq() {
  if [ -z "${GROQ_API_KEY:-}" ]; then log_error "APIKEY" "GROQ_API_KEY is not set."; return "$GROQBASHERRNOAPIKEY"; fi
  if is_truthy "${DRY_RUN:-0}"; then log_info "DRYRUN" "DRY-RUN: skipping streaming HTTP call"; return 0; fi

  ensure_run_tmpdir || return "$GROQBASHERRTMP"
  ERRF="${ERRF:-$RUN_TMPDIR/curl.err}"
  RESP="${RESP:-$RUN_TMPDIR/resp.json}"
  RESP_RAW="$RUN_TMPDIR/resp.raw"
  : > "$RESP_RAW" 2>/dev/null || true
  chmod 600 "$RESP_RAW" 2>/dev/null || true

  local api_url rc decoded_payload
  api_url="https://api.groq.com/openai/v1/chat/completions"

  decoded_payload="$RUN_TMPDIR/payload.dec.$$"
  b64_atomic_read "$PAYLOAD" > "$decoded_payload" || { rm -f "$decoded_payload" 2>/dev/null || true; return "$GROQBASHERRTMP"; }

  local CURL_CMD
  # stdbuf is optional: if present we use it to reduce buffering for streaming.
  # If stdbuf is not available the code falls back to plain curl; behavior is
  # correct in both cases, stdbuf only improves streaming latency when present.
  if command -v stdbuf >/dev/null 2>&1; then
    CURL_CMD=(stdbuf -oL curl --http1.1 "${CURL_BASE_OPTS[@]}")
  else
    CURL_CMD=(curl --http1.1 "${CURL_BASE_OPTS[@]}")
  fi

  "${CURL_CMD[@]}" -H "Authorization: Bearer ${GROQ_API_KEY}" -H "Content-Type: application/json" --data-binary @"$decoded_payload" "$api_url" 2>"$ERRF" | tee -a "$RESP_RAW" | \
  while IFS= read -r line; do
    case "$line" in
      'data: [DONE]'|'data:[DONE]') break ;;
      data:\ * )
        json="${line#data: }"
        content="$(printf '%s' "$json" | jq -r 'fromjson? | (.choices[]?.delta?.content // .choices[]?.message?.content // "")' 2>>"$ERRF" || true)"
        if [ -n "$content" ]; then
          printf '%s' "$content"
        fi
        ;;
      *) ;;
    esac
  done

  rc=${PIPESTATUS[0]:-0}
  rm -f "$decoded_payload" 2>/dev/null || true
  if [ "$rc" -ne 0 ]; then
    log_error "CURLSTREAM" "curl streaming failed (rc $rc)"; head -n 50 "$ERRF" >&2 || true
    return "$GROQBASHERRCURL_FAILED"
  fi

  if jq -e . "$RESP_RAW" >/dev/null 2>&1; then
    cp -f "$RESP_RAW" "$RESP" 2>/dev/null || true
  fi

  return 0
}

call_api_streaming_groq_legacy() { call_api_streaming_groq "$@"; }

refresh_models_groq() {
  if [ -n "${PROVIDER_API_ENV_groq:-}" ] && [ -n "${!PROVIDER_API_ENV_groq:-}" ]; then
    GROQ_API_KEY="${!PROVIDER_API_ENV_groq}"
  fi
  if [ -z "${GROQ_API_KEY:-}" ]; then
    log_error "APIKEY" "GROQ_API_KEY is required to refresh models."
    return "$GROQBASHERRNOAPIKEY"
  fi

  ensure_run_tmpdir || return "$GROQBASHERRTMP"
  local workdir tmpd out errf parsed tmpout api_url jq_ok lockfile
  workdir="${RUN_TMPDIR:-}"
  [ -n "$workdir" ] || return "$GROQBASHERRTMP"
  tmpd="$(mktemp -d -p "$workdir" groq-models.XXXX 2>/dev/null || true)"
  [ -z "$tmpd" ] && return "$GROQBASHERRTMP"
  out="$tmpd/models.json"; errf="$tmpd/curl.err"
  api_url="https://api.groq.com/openai/v1/models"

  if ! curl "${CURL_BASE_OPTS[@]}" -H "Authorization: Bearer ${GROQ_API_KEY}" -H "Content-Type: application/json" "$api_url" -o "$out" 2>"$errf"; then
    log_error "CURL" "curl failed while refreshing models"; head -n 50 "$errf" >&2 || true
    rm -rf "$tmpd"
    return "$GROQBASHERRCURL_FAILED"
  fi

  parsed="$tmpd/parsed_models.txt"
  if jq -e . "$out" >/dev/null 2>&1; then
    jq_ok=1
    jq -r '.data[]?.id // empty' "$out" 2>/dev/null | sort -u > "$parsed" || true
  else
    jq_ok=0
    log_warn "MODELREFRESH" "models response not valid JSON; using heuristic parse"
    grep -oE '"id"[[:space:]]*:[[:space:]]*"[^"]+"' "$out" 2>/dev/null | sed -E 's/.*"([^"]+)".*/\1/' | sort -u > "$parsed" || true
  fi

  if [ -s "$parsed" ]; then
    if [ "$jq_ok" -eq 0 ]; then
      if ! awk 'NF{exit 0} END{exit 1}' "$parsed"; then
        log_error "MODELREFRESH" "Heuristic parse produced no models; aborting refresh."
        rm -rf "$tmpd"
        return "$GROQBASHERRAPI"
      fi
      if ! awk '/^[[:alnum:]._:-]+$/{print; ok=1} END{exit !ok}' "$parsed"; then
        log_error "MODELREFRESH" "Heuristic parse produced invalid model ids; aborting refresh"
        rm -rf "$tmpd"
        return "$GROQBASHERRAPI"
      fi
    fi

    mkdir -p "$(dirname "$MODELS_FILE")" 2>/dev/null || true
    tmpout="$(_mktemp_in_dir "$(dirname "$MODELS_FILE")" )" || tmpout="$MODELS_FILE.tmp"
    cat "$parsed" > "$tmpout"
    # write base64 staging and then atomically decode under models lock
    b64_atomic_write "${MODELS_FILE}.b64" 10 < "$tmpout" || { rm -f "$tmpout" 2>/dev/null || true; rm -rf "$tmpd"; return "$GROQBASHERRTMP"; }
    lockfile="$MODELS_LOCK"
    lock_exec "$lockfile" 10 -- sh -c '
      set -e
      src_b64="$1"
      dest="$2"
      b64decode < "$src_b64" > "$dest"
      chmod 600 "$dest" 2>/dev/null || true
    ' _ "${MODELS_FILE}.b64" "$MODELS_FILE" || { rm -f "$tmpout" 2>/dev/null || true; rm -rf "$tmpd"; return "$GROQBASHERRTMP"; }
    chmod 600 "$MODELS_FILE" 2>/dev/null || true
    log_info "MODELREFRESH" "Models refreshed and saved to: $MODELS_FILE"
    rm -rf "$tmpd"
    return 0
  else
    log_error "MODELREFRESH" "models refresh: parsed list empty"
    rm -rf "$tmpd"
    return "$GROQBASHERRAPI"
  fi
}

refreshmodelsgroq() { refresh_models_groq "$@"; }

validate_model_groq() {
  local model="$1"
  if [ -f "$MODELS_FILE" ] && [ -s "$MODELS_FILE" ]; then
    grep -x -F -q "$model" "$MODELS_FILE" 2>/dev/null
    return $?
  fi
  return 0
}

validatemodelgroq() { validate_model_groq "$@"; }

auto_select_model_groq() {
  local file="$MODELS_FILE" result=""
  if [ -f "$file" ] && [ -s "$file" ]; then
    result="$(awk 'NF{print; exit}' "$file" 2>/dev/null || true)"
  fi
  result="$(printf '%s' "$result" | awk '{$1=$1;print}')"
  printf '%s' "$result"
  return 0
}

autoselectmodelgroq() { auto_select_model_groq "$@"; }
